# Application Configuration
# Copy this file to .env and update the values

# Base URL - Change this when deploying to production
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Environment
NODE_ENV=development

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5433/erp_next?schema=public"

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# NEXTAUTH_URL:
#   • Để trống (hoặc comment) khi dev/test trên LAN (192.168.x.x, mDNS, ngrok…)
#     → NextAuth sẽ dùng host của request, cookie auto bind đúng host và
#     redirect callback cũng trả về đúng LAN IP máy đang test.
#   • Chỉ set cứng khi deploy production với domain cố định.
# NEXTAUTH_URL=http://localhost:3000

# ============================================
# WEB PUSH (PWA notifications) — OPTIONAL
# ============================================
# Generate once with: npm run pwa:vapid
# The public key is safe to expose on the client; the private key is NEVER.
# If these are unset, the app simply skips sending push (in-app notifications still work).
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@your-domain.com

# ============================================
# FILE UPLOAD
# ============================================
# Local upload directory (default: ./uploads)
UPLOAD_DIR=./uploads
# Max file size in bytes (default: 10MB = 10485760)
MAX_FILE_SIZE=10485760

# ============================================
# GHTK SHIPPING API
# ============================================
# Get these from your GHTK account dashboard
GHTK_API_TOKEN=your-ghtk-api-token
GHTK_PARTNER_CODE=your-partner-code

# Optional: Webhook security
# GHTK_WEBHOOK_SECRET=your-webhook-secret-for-hmac-verification

# Optional: IP whitelist for webhook (comma-separated)
# GHTK_WHITELIST_IPS=103.x.x.x,118.x.x.x

# ============================================
# MEILISEARCH (Fast Search Engine)
# ============================================
# Meilisearch server URL
MEILISEARCH_HOST=http://localhost:7700
# Master key (generate with: openssl rand -base64 32)
MEILISEARCH_API_KEY=devMasterKey123456
# Environment: development or production
MEILISEARCH_ENV=development

# ============================================
# PKGX Integration (phukiengiaxuong.com.vn)
# ============================================
PKGX_DEFAULT_API_KEY=your-pkgx-api-key

# ============================================
# OPTIONAL: S3/Cloud Storage (for production)
# ============================================
# S3_BUCKET=your-bucket-name
# S3_REGION=ap-southeast-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# ============================================
# SENTRY ERROR TRACKING
# ============================================
# Get these from sentry.io - create a Next.js project
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-project-name
# SENTRY_AUTH_TOKEN=your-auth-token-for-sourcemaps
