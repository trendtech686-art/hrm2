# ============================================
# HRM2 - Production Environment
# ============================================
# Copy file này thành .env.production rồi điền giá trị thật
# KHÔNG commit file .env.production lên git!

# ============================================
# DATABASE
# ============================================
DB_USER=hrm2
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=hrm2
DATABASE_URL=postgresql://hrm2:CHANGE_ME_STRONG_PASSWORD@postgres:5432/hrm2?schema=public

# ============================================
# AUTHENTICATION
# ============================================
# Generate: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
NEXTAUTH_URL=https://your-domain.com

# ============================================
# APP
# ============================================
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NODE_ENV=production

# ============================================
# MEILISEARCH
# ============================================
# Generate: openssl rand -base64 32
MEILISEARCH_MASTER_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# ============================================
# CRON JOBS
# ============================================
# Generate: openssl rand -hex 32
CRON_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ============================================
# SENTRY (optional)
# ============================================
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=your-token

# ============================================
# SHIPPING APIs (optional)
# ============================================
# GHTK_API_TOKEN=your-token
# GHTK_PARTNER_CODE=your-code

# ============================================
# FILE UPLOAD
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
