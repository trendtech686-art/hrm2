# ============================================
# HRM2 - Production Environment
# ============================================
# Copy file này thành .env.production rồi điền giá trị thật
# KHÔNG commit file .env.production lên git!

# ============================================
# DATABASE
# ============================================
DB_USER=erp_user
DB_PASSWORD=THAY_PASSWORD_MANH_O_DAY
DB_NAME=erp_db
DATABASE_URL=postgresql://erp_user:THAY_PASSWORD_MANH_O_DAY@postgres:5432/erp_db?schema=public

# ============================================
# AUTHENTICATION
# ============================================
# Generate: openssl rand -base64 32
AUTH_SECRET=THAY_SECRET_O_DAY
NEXTAUTH_SECRET=THAY_SECRET_O_DAY
NEXTAUTH_URL=https://your-domain.com

# ============================================
# APP
# ============================================
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NODE_ENV=production

# ============================================
# MEILISEARCH
# ============================================
# Generate: openssl rand -base64 32
MEILISEARCH_MASTER_KEY=THAY_MASTER_KEY_O_DAY
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=THAY_MASTER_KEY_O_DAY

# ============================================
# CRON JOBS
# ============================================
# Generate: openssl rand -hex 32
CRON_SECRET=THAY_CRON_SECRET_O_DAY

# ============================================
# SENTRY (optional nhưng khuyến khích)
# ============================================
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=your-token

# ============================================
# SHIPPING APIs (optional)
# ============================================
# GHTK_API_TOKEN=your-token
# GHTK_PARTNER_CODE=your-code

# ============================================
# FILE UPLOAD
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
