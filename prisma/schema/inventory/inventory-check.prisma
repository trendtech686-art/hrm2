model InventoryCheck {
  systemId   String               @id
  id         String               @unique
  branchId   String
  employeeId String?
  checkDate  DateTime             @default(now())
  status     InventoryCheckStatus @default(DRAFT)
  notes      String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  createdBy  String?
  updatedBy  String?

  // === MISSING FIELDS FROM types.ts (Phase 7) ===

  // Branch info (denormalized)
  branchSystemId String?
  branchName     String?

  // Balance tracking
  balancedAt DateTime?
  balancedBy String?

  // Cancellation tracking
  cancelledAt     DateTime?
  cancelledBy     String?
  cancelledReason String?

  // Items (stored as JSON for flexibility)
  checkItems Json? // Array of InventoryCheckItem with reason

  // === CROSS-MODULE REFERENCES ===
  linkedComplaintSystemId String? // Link to Complaint that created this inventory check

  // === RELATIONS ===
  items InventoryCheckItem[]
  linkedComplaint Complaint? @relation(fields: [linkedComplaintSystemId], references: [systemId])

  @@index([branchId])
  @@index([status])
  @@index([linkedComplaintSystemId])
  @@map("inventory_checks")
}
