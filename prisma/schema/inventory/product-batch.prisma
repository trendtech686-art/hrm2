/// Quản lý lô hàng - hạn sử dụng (Batch/Lot tracking with expiry dates)
/// Mỗi lô hàng gắn với 1 sản phẩm tại 1 chi nhánh, có mã lô + ngày sản xuất + HSD
model ProductBatch {
  systemId String @id @default(cuid())

  // Liên kết sản phẩm & chi nhánh
  productId String
  branchId  String

  // Thông tin lô
  batchNumber    String // Mã/số lô
  manufactureDate DateTime? // Ngày sản xuất
  expiryDate     DateTime? // Hạn sử dụng

  // Tồn kho theo lô
  quantity   Int @default(0) // Số lượng hiện tại trong lô
  initialQty Int @default(0) // Số lượng ban đầu khi nhập lô

  // Metadata
  supplierName String? // NCC của lô hàng
  notes        String?
  status       BatchStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, branchId, batchNumber])
  @@index([productId])
  @@index([branchId])
  @@index([expiryDate])
  @@index([status])
  @@index([productId, branchId])
  @@map("product_batches")
}

enum BatchStatus {
  ACTIVE // Đang sử dụng
  EXPIRED // Hết hạn
  DEPLETED // Hết hàng
  DISPOSED // Đã xử lý/tiêu hủy
}
