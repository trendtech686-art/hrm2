model RecurringTask {
  systemId    String   @id
  id          String   @unique
  title       String
  description String?

  // Assignment
  assigneeSystemId String?
  assignees        Json?    // Array of TaskAssignee { systemId, employeeSystemId, employeeName, role, assignedAt, assignedBy }
  assignerId       String?
  assignerName     String?

  // Task defaults
  priority       TaskPriority @default(MEDIUM)
  estimatedHours Decimal?     @db.Decimal(6, 2)
  type           String?

  // Recurrence pattern
  recurrencePattern Json     // RecurrencePattern { frequency, interval, daysOfWeek, dayOfMonth, etc. }
  startDate         DateTime
  durationDays      Int      @default(1)
  createDaysBefore  Int      @default(0)

  // Status
  isActive  Boolean @default(true)
  isPaused  Boolean @default(false)

  // Tracking
  createdTaskIds     Json?     // String[] - IDs of tasks created from this recurring task
  lastCreatedDate    DateTime?
  nextOccurrenceDate DateTime?
  occurrenceCount    Int       @default(0)

  // Audit
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  // Template reference
  templateId String?

  @@index([isActive])
  @@index([isPaused])
  @@index([nextOccurrenceDate])
  @@map("recurring_tasks")
}

model TaskTemplate {
  systemId    String  @id
  id          String  @unique
  name        String
  description String?

  // Template content
  category    String?
  title       String?    // Default task title
  taskDescription String? // Default task description

  // Default values
  priority       TaskPriority @default(MEDIUM)
  estimatedHours Decimal?     @db.Decimal(6, 2)
  type           String?

  // Pre-configured structure
  assigneeRoles  Json?  // Array of { role, description }
  subtasks       Json?  // Array of { title, description, estimatedHours, order }
  checklistItems Json?  // String[]
  customFields   Json?  // Record<string, unknown>

  // Metadata
  usageCount Int     @default(0)
  isActive   Boolean @default(true)

  // Audit
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  @@index([category])
  @@index([isActive])
  @@map("task_templates")
}
