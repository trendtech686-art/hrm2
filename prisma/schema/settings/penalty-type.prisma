// Loại phạt - PenaltyType settings
model PenaltyTypeSetting {
  systemId      String  @id
  id            String  @unique
  name          String
  description   String?
  defaultAmount Decimal @default(0) @db.Decimal(15, 2)
  category      String  @default("other") // 'complaint' | 'attendance' | 'performance' | 'other'
  isActive      Boolean @default(true)
  sortOrder     Int     @default(0)

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@index([isActive])
  @@index([category])
  @@map("penalty_type_settings")
}
