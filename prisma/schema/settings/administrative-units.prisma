// Administrative Units (Provinces, Districts, Wards)
// 2-level: 34 provinces (new), ~3,321 wards (no districts)
// 3-level: 63 provinces (old), ~624 districts, ~10,035 wards

model Province {
  systemId String @id @map("system_id")
  id       String @map("business_id") // e.g. "01", "02"
  name     String
  level    String @default("2-level") // '2-level' | '3-level'

  // Audit fields
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  @@unique([id, level]) // same id can exist in both 2-level and 3-level
  @@index([level])
  @@map("provinces")
}

model District {
  systemId   String @id @map("system_id")
  id         Int    // district number e.g. 1, 100, 101
  name       String
  provinceId String @map("province_id") // stores province id (not systemId)
  level      String @default("3-level") // '2-level' | '3-level' (districts only in 3-level)

  // Audit fields
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  @@unique([id, level]) // same id can exist in both levels
  @@index([provinceId])
  @@index([level])
  @@map("districts")
}

model Ward {
  systemId     String  @id @map("system_id")
  id           String // ward code e.g. "1", "00001"
  name         String
  provinceId   String  @map("province_id") // reference to province systemId
  provinceName String? @map("province_name") // denormalized for query perf
  districtId   Int?    @map("district_id") // null for 2-level wards
  districtName String? @map("district_name") // denormalized for query perf
  level        String  @default("3-level") // '2-level' | '3-level'

  // Audit fields
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  // Note: Relations removed due to composite key complexity
  // provinceId now stores province systemId for direct lookup

  @@unique([id, provinceId, level]) // ward id unique within province and level
  @@index([provinceId])
  @@index([districtId])
  @@index([level])
  @@map("wards")
}
