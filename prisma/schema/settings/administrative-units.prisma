// Administrative Units (Provinces, Districts, Wards)
// Total: 34 provinces, ~624 districts, ~10,000+ wards

model Province {
  systemId String @id @map("system_id")
  id       String @unique @map("business_id") // e.g. "01", "02"
  name     String

  // Audit fields
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  // Relations
  districts District[]
  wards     Ward[]

  @@map("provinces")
}

model District {
  systemId   String @id @map("system_id")
  id         Int    @unique // district number e.g. 1, 100, 101
  name       String
  provinceId String @map("province_id")

  // Audit fields
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  // Relations
  province Province @relation(fields: [provinceId], references: [id])
  wards    Ward[]

  @@index([provinceId])
  @@map("districts")
}

model Ward {
  systemId     String  @id @map("system_id")
  id           String // ward code e.g. "1", "00001"
  name         String
  provinceId   String  @map("province_id")
  provinceName String? @map("province_name") // denormalized for query perf
  districtId   Int?    @map("district_id") // null for 2-level wards
  districtName String? @map("district_name") // denormalized for query perf
  level        String  @default("3-level") // '2-level' | '3-level'

  // Audit fields
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  // Relations
  province Province  @relation(fields: [provinceId], references: [id])
  district District? @relation(fields: [districtId], references: [id])

  @@unique([id, provinceId]) // ward id unique within province
  @@index([provinceId])
  @@index([districtId])
  @@index([level])
  @@map("wards")
}
