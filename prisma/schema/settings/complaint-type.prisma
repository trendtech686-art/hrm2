// Loại khiếu nại - ComplaintType settings
model ComplaintTypeSetting {
  systemId    String  @id
  id          String  @unique
  name        String
  description String?
  color       String? // Tailwind color class
  isActive    Boolean @default(true)
  isDefault   Boolean @default(false)
  sortOrder   Int     @default(0)

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@index([isActive])
  @@map("complaint_type_settings")
}
