     return isNaN(num) || num < 0 ? undefined : num;\r\n    },\r\n    // NOTE: Field nâ”œأ،y chأںâ•—أ« dâ”œâ•£ng khi import tأںâ•‘أ­o mأںâ•—آ¢i\r\n    // Khâ”œâ”¤ng export vâ”œآ¼ tأںâ•—أ´n kho thأںâ•—â–’c tأںâ•‘â”گ nأںâ•‘â–’m trong inventoryByBranch\r\n  },\r\n  {\r\n    key: 'isStockTracked',\r\n    label: 'Theo dâ”œâ•،i tأںâ•—أ´n kho',\r\n    required: false,\r\n    type: 'boolean',\r\n    exportGroup: 'Tأںâ•—أ´n kho',\r\n    example: 'Câ”œâ”‚',\r\n    defaultValue: true,\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return true;\r\n      const str = String(value).toLowerCase();\r\n      return str === 'câ”œâ”‚' || str === 'yes' || str === 'true' || str === '1';\r\n    },\r\n  },\r\n  {\r\n    key: 'reorderLevel',\r\n    label: 'Mأںâ•—âŒگc â”€أ¦أںâ•‘â•–t hâ”œأ،ng lأںâ•‘أ­i',\r\n    required: false,\r\n    type: 'number',\r\n    exportGroup: 'Tأںâ•—أ´n kho',\r\n    example: '10',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const num = Number(String(value).replace(/[,.\\s]/g, ''));\r\n      return isNaN(num) ? undefined : num;\r\n    },\r\n  },\r\n  {\r\n    key: 'safetyStock',\r\n    label: 'Tأںâ•—أ´n kho an toâ”œأ،n',\r\n    required: false,\r\n    type: 'number',\r\n    exportGroup: 'Tأںâ•—أ´n kho',\r\n    example: '5',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const num = Number(String(value).replace(/[,.\\s]/g, ''));\r\n      return isNaN(num) ? undefined : num;\r\n    },\r\n  },\r\n  {\r\n    key: 'maxStock',\r\n    label: 'Tأںâ•—أ´n kho tأںâ•—أ¦i â”€أ¦a',\r\n    required: false,\r\n    type: 'number',\r\n    exportGroup: 'Tأںâ•—أ´n kho',\r\n    example: '100',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const num = Number(String(value).replace(/[,.\\s]/g, ''));\r\n      return isNaN(num) ? undefined : num;\r\n    },\r\n  },\r\n\r\n  // ===== Vأںâ•‘آ¼T Lâ”œآ¥ =====\r\n  {\r\n    key: 'weight',\r\n    label: 'Trأںâ•—أ¬ng lâ•‍â–‘أںâ•—أ؛ng',\r\n    required: false,\r\n    type: 'number',\r\n    exportGroup: 'Vأںâ•‘آ،t lâ”œâ•œ',\r\n    example: '200',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const num = Number(String(value).replace(/[,.\\s]/g, ''));\r\n      return isNaN(num) ? undefined : num;\r\n    },\r\n  },\r\n  {\r\n    key: 'weightUnit',\r\n    label: 'â”€أ‰â•‍أ­n vأںâ•—أ¯ trأںâ•—أ¬ng lâ•‍â–‘أںâ•—أ؛ng',\r\n    required: false,\r\n    type: 'enum',\r\n    enumValues: ['g', 'kg'],\r\n    exportGroup: 'Vأںâ•‘آ،t lâ”œâ•œ',\r\n    example: 'g',\r\n    defaultValue: 'g',\r\n  },\r\n\r\n  // ===== Bأںâ•‘أ³O Hâ”œأ‡NH =====\r\n  {\r\n    key: 'warrantyPeriodMonths',\r\n    label: 'Bأںâ•‘أ؛o hâ”œأ،nh (thâ”œأ­ng)',\r\n    required: false,\r\n    type: 'number',\r\n    exportGroup: 'Bأںâ•‘أ؛o hâ”œأ،nh',\r\n    example: '12',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const num = Number(String(value).replace(/[,.\\s]/g, ''));\r\n      return isNaN(num) ? undefined : num;\r\n    },\r\n  },\r\n\r\n  // ===== Kâ”œأ¬CH THâ•‍آ»أںâ•—أœC =====\r\n  {\r\n    key: 'dimensions',\r\n    label: 'Kâ”œآ،ch thâ•‍â–‘أںâ•—آ¢c (DxRxC cm)',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Vأںâ•‘آ،t lâ”œâ•œ',\r\n    example: '30x20x10',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const str = String(value).trim();\r\n      const match = str.match(/^(\\d+(?:\\.\\d+)?)\\s*[xXâ”œأ¹]\\s*(\\d+(?:\\.\\d+)?)\\s*[xXâ”œأ¹]\\s*(\\d+(?:\\.\\d+)?)$/);\r\n      if (match) {\r\n        return {\r\n          length: parseFloat(match[1]),\r\n          width: parseFloat(match[2]),\r\n          height: parseFloat(match[3]),\r\n        };\r\n      }\r\n      return undefined;\r\n    },\r\n    exportTransform: (value: unknown) => {\r\n      const dims = value as { length?: number; width?: number; height?: number } | undefined;\r\n      if (dims && typeof dims === 'object' && 'length' in dims) {\r\n        return `${dims.length || 0}x${dims.width || 0}x${dims.height || 0}`;\r\n      }\r\n      return '';\r\n    },\r\n  },\r\n\r\n  // ===== THâ”œأ¶NG TIN Mأںâ•—â‚§ Rأںâ•—أ؟NG =====\r\n  {\r\n    key: 'ktitle',\r\n    label: 'Tiâ”œآ¬u â”€أ¦أںâ•—أ¼ SEO',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Mâ”œâ”¤ tأںâ•‘أ؛',\r\n    example: 'â”œأ¼o sâ•‍أ­ mi nam cao cأںâ•‘أ‘p | Thأںâ•—آ¥i trang ABC',\r\n  },\r\n  {\r\n    key: 'seoDescription',\r\n    label: 'Mâ”œâ”¤ tأںâ•‘أ؛ SEO',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Mâ”œâ”¤ tأںâ•‘أ؛',\r\n    example: 'â”œأ¼o sâ•‍أ­ mi nam chأںâ•‘أ‘t liأںâ•—أ§u cotton cao cأںâ•‘أ‘p...',\r\n  },\r\n  {\r\n    key: 'subCategories',\r\n    label: 'Danh mأںâ•—أ‘c phأںâ•—أ‘',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Phâ”œأ³n loأںâ•‘أ­i',\r\n    example: 'Slim fit > Form â”œâ”¤m; Cotton > Cao cأںâ•‘أ‘p', // Nhiأںâ•—أ¼u danh mأںâ•—أ‘c phأںâ•—أ‘ phâ”œأ³n câ”œأ­ch bأںâ•‘â–’ng ;\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const str = String(value).trim();\r\n      if (!str) return undefined;\r\n      // Split by semicolon to get multiple sub-categories\r\n      return str.split(';').map(s => s.trim()).filter(Boolean);\r\n    },\r\n    exportTransform: (value: unknown) => {\r\n      const subCategories = value as string[] | undefined;\r\n      return subCategories?.join('; ') || '';\r\n    },\r\n  },\r\n  // Legacy single subCategory field (backward compatibility)\r\n  {\r\n    key: 'subCategory',\r\n    label: 'Danh mأںâ•—أ‘c phأںâ•—أ‘ (câ”¼âŒگ)',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Phâ”œأ³n loأںâ•‘أ­i',\r\n    hidden: true,\r\n    example: 'â”œأ¼o sâ•‍أ­ mi > Dâ”œأ،i tay > Slim fit',\r\n  },\r\n  {\r\n    key: 'tags',\r\n    label: 'Tags',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Phâ”œأ³n loأںâ•‘أ­i',\r\n    example: 'nam,câ”œâ”¤ng sأںâ•—ئ’,cotton',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const str = String(value).trim();\r\n      return str.split(/[,;]/).map(s => s.trim()).filter(Boolean);\r\n    },\r\n    exportTransform: (value: unknown) => {\r\n      const tags = value as string[] | undefined;\r\n      return tags?.join(', ') || '';\r\n    },\r\n  },\r\n  {\r\n    key: 'pkgxId',\r\n    label: 'ID PKGX',\r\n    required: false,\r\n    type: 'number',\r\n    exportGroup: 'Thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n',\r\n    example: '12345',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const num = Number(String(value).replace(/[,.\\s]/g, ''));\r\n      return isNaN(num) || num <= 0 ? undefined : num;\r\n    },\r\n  },\r\n  {\r\n    key: 'trendtechId',\r\n    label: 'ID Trendtech',\r\n    required: false,\r\n    type: 'number',\r\n    exportGroup: 'Thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n',\r\n    example: '67890',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const num = Number(String(value).replace(/[,.\\s]/g, ''));\r\n      return isNaN(num) || num <= 0 ? undefined : num;\r\n    },\r\n  },\r\n  {\r\n    key: 'warehouseLocation',\r\n    label: 'Vأںâ•—أ¯ trâ”œآ، kho',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Tأںâ•—أ´n kho',\r\n    example: 'A1-01',\r\n  },\r\n\r\n  // ===== GIâ”œأ¼ Bأںâ•—أ¶ SUNG =====\r\n  {\r\n    key: 'lastPurchasePrice',\r\n    label: 'Giâ”œأ­ nhأںâ•‘آ،p gأںâ•‘آ؛n nhأںâ•‘أ‘t',\r\n    required: false,\r\n    type: 'number',\r\n    exportGroup: 'Giâ”œأ­',\r\n    example: '140000',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const num = Number(String(value).replace(/[,.\\s]/g, ''));\r\n      return isNaN(num) ? undefined : num;\r\n    },\r\n  },\r\n\r\n  // ===== THâ”œأ¶NG TIN TEM =====\r\n  {\r\n    key: 'nameVat',\r\n    label: 'T