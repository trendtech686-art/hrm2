 usePageHeader } from '../../contexts/page-header-context';\r\nimport { ActivityHistory, type HistoryEntry } from '../../components/ActivityHistory';\r\nimport { SimplePrintOptionsDialog, SimplePrintOptionsResult, PaperSize } from '../../components/shared/simple-print-options-dialog';\r\nimport { formatDateForDisplay, formatDateTimeForDisplay } from '@/lib/date-utils';\r\n\r\n// =============================================\r\n// CONSTANTS\r\n// =============================================\r\n\r\nconst STATUS_LABEL: Record<PayrollBatch['status'], string> = {\r\n  draft: 'Nhâ”œأ­p',\r\n  reviewed: 'â”€أ‰ang duyأںâ•—أ§t',\r\n  locked: 'â”€أ‰â”œأ؛ khâ”œâ”‚a',\r\n  cancelled: 'â”€أ‰â”œأ؛ hأںâ•—آ؛y',\r\n};\r\n\r\nconst STATUS_HINTS: Record<PayrollBatch['status'], { title: string; description: string; tone: 'info' | 'warning' | 'success' | 'destructive' }> = {\r\n  draft: {\r\n    title: 'Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng â”€أ¦ang أںâ•—ئ’ trأںâ•‘أ­ng thâ”œأ­i Nhâ”œأ­p',\r\n    description: 'Kiأںâ•—أ¢m tra dأںâ•—آ» liأںâ•—أ§u vâ”œأ، bأںâ•‘أ‘m \"â”€أ‰â”œأ­nh dأںâ•‘أ‘u â”€أ¦â”œأ؛ duyأںâ•—أ§t\" â”€أ¦أںâ•—أ¢ chuyأںâ•—أ¢n sang bâ•‍â–‘أںâ•—آ¢c xem xâ”œâŒگt trâ•‍â–‘أںâ•—آ¢c khi khâ”œâ”‚a.',\r\n    tone: 'warning',\r\n  },\r\n  reviewed: {\r\n    title: 'Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c duyأںâ•—أ§t',\r\n    description: 'Bأںâ•‘أ­n câ”œâ”‚ thأںâ•—أ¢ khâ”œâ”‚a bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng â”€أ¦أںâ•—أ¢ cأںâ•—أ¦ â”€أ¦أںâ•—أ¯nh dأںâ•—آ» liأںâ•—أ§u vâ”œأ، khâ”œâ”‚a câ”œأ­c thâ”œأ­ng chأںâ•‘أ‘m câ”œâ”¤ng liâ”œآ¬n quan.',\r\n    tone: 'info',\r\n  },\r\n  locked: {\r\n    title: 'Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c khâ”œâ”‚a',\r\n    description: 'Dأںâ•—آ» liأںâ•—أ§u chi trأںâ•‘أ؛ vâ”œأ، thâ”œأ­ng chأںâ•‘أ‘m câ”œâ”¤ng tham chiأںâ•‘â”گu hiأںâ•—أ§n chأںâ•—أ« â”€أ¦أںâ•—أ¬c. Mأںâ•—أ¬i thay â”€أ¦أںâ•—أ²i cأںâ•‘آ؛n tأںâ•‘أ­o batch mأںâ•—آ¢i.',\r\n    tone: 'success',\r\n  },\r\n  cancelled: {\r\n    title: 'Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng â”€أ¦â”œأ؛ bأںâ•—أ¯ hأںâ•—آ؛y',\r\n    description: 'Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng nâ”œأ،y â”€أ¦â”œأ؛ bأںâ•—أ¯ hأںâ•—آ؛y vâ”œأ، khâ”œâ”¤ng câ”œâ–“n hiأںâ•—أ§u lأںâ•—â–’c. Câ”œأ­c phiأںâ•‘â”گu thanh toâ”œأ­n vâ”œأ، phiأںâ•‘â”گu phأںâ•‘أ­t liâ”œآ¬n quan â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c rollback.',\r\n    tone: 'destructive',\r\n  },\r\n};\r\n\r\nconst AUDIT_ACTION_LABEL: Record<PayrollAuditAction, string> = {\r\n  run: 'Khأںâ•—ئ’i tأںâ•‘أ­o',\r\n  recalculate: 'Tâ”œأ­i tâ”œآ،nh toâ”œأ­n',\r\n  review: 'â”€أ‰â”œأ­nh dأںâ•‘أ‘u duyأںâ•—أ§t',\r\n  lock: 'Khâ”œâ”‚a bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng',\r\n  unlock: 'Mأںâ•—ئ’ khâ”œâ”‚a',\r\n  export: 'Xuأںâ•‘أ‘t dأںâ•—آ» liأںâ•—أ§u',\r\n};\r\n\r\nconst _ALERT_CLASS_BY_TONE: Record<'info' | 'warning' | 'success', string> = {\r\n  info: 'border-blue-200 bg-blue-50 text-blue-900 dark:border-blue-400/40 dark:bg-blue-950/40',\r\n  warning: 'border-amber-200 bg-amber-50 text-amber-900 dark:border-amber-400/40 dark:bg-amber-950/40',\r\n  success: 'border-emerald-200 bg-emerald-50 text-emerald-900 dark:border-emerald-400/40 dark:bg-emerald-950/40',\r\n};\r\n\r\ntype ApprovalAction = 'review' | 'lock';\r\n\r\nconst APPROVAL_DIALOG_CONFIG: Record<ApprovalAction, { title: string; description: string; confirmLabel: string }> = {\r\n  review: {\r\n    title: 'Xâ”œأ­c nhأںâ•‘آ،n â”€أ¦â”œأ­nh dأںâ•‘أ‘u â”€أ¦â”œأ؛ duyأںâ•—أ§t',\r\n    description: 'Sau khi duyأںâ•—أ§t, bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng sأںâ•‘â•œ chuyأںâ•—أ¢n sang bâ•‍â–‘أںâ•—آ¢c chأںâ•—آ¥ khâ”œâ”‚a. Bأںâ•‘أ­n vأںâ•‘آ½n câ”œâ”‚ thأںâ•—أ¢ quay lأںâ•‘أ­i chأںâ•—أ«nh sأںâ•—آ،a trâ•‍â–‘أںâ•—آ¢c khi khâ”œâ”‚a.',\r\n    confirmLabel: 'â”€أ‰â”œأ­nh dأںâ•‘أ‘u â”€أ¦â”œأ؛ duyأںâ•—أ§t',\r\n  },\r\n  lock: {\r\n    title: 'Khâ”œâ”‚a bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng',\r\n    description:\r\n      'Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng sأںâ•‘â•œ khâ”œâ”‚a vâ”€âŒگnh viأںâ•—أ n vâ”œأ، câ”œأ­c thâ”œأ­ng chأںâ•‘أ‘m câ”œâ”¤ng tham chiأںâ•‘â”گu sأںâ•‘â•œ chuyأںâ•—أ¢n sang chأںâ•—أ« â”€أ¦أںâ•—أ¬c. Hâ”œأ؛y chأںâ•‘آ»c chأںâ•‘آ»n rأںâ•‘â–’ng sأںâ•—أ¦ liأںâ•—أ§u â”€أ¦â”œأ؛ châ”œآ،nh xâ”œأ­c.',\r\n    confirmLabel: 'Khâ”œâ”‚a bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng',\r\n  },\r\n};\r\n\r\n// =============================================\r\n// FORMATTERS\r\n// =============================================\r\n\r\nconst currencyFormatter = new Intl.NumberFormat('vi-VN', {\r\n  style: 'currency',\r\n  currency: 'VND',\r\n  maximumFractionDigits: 0,\r\n});\r\n\r\nconst formatCurrency = (value?: number) => (typeof value === 'number' ? currencyFormatter.format(value) : 'خ“أ‡أ¶');\r\nconst formatDate = (value?: string) => (value ? formatDateForDisplay(value) : 'خ“أ‡أ¶');\r\nconst _formatDateTime = (value?: string) => (value ? formatDateTimeForDisplay(value) : 'خ“أ‡أ¶');\r\n\r\nconst formatMonthKey = (monthKey?: string) => {\r\n  if (!monthKey) return 'خ“أ‡أ¶';\r\n  const [year, month] = monthKey.split('-');\r\n  return `Thâ”œأ­ng ${month}/${year}`;\r\n};\r\n\r\nconst formatPeriod = (period?: PayrollPeriod) => {\r\n  if (!period) return 'خ“أ‡أ¶';\r\n  return `${formatDate(period.startDate)} خ“أ‡أ´ ${formatDate(period.endDate)}`;\r\n};\r\n\r\n// =============================================\r\n// TYPES\r\n// =============================================\r\n\r\ntype DepartmentSummaryRow = {\r\n  departmentSystemId?: SystemId | undefined;\r\n  departmentName: string;\r\n  headcount: number;\r\n  totalEarnings: number;\r\n  totalDeductions: number;\r\n  totalContributions: number;\r\n  totalNet: number;\r\n};\r\n\r\ntype PayslipExportRow = {\r\n  employeeId: BusinessId;\r\n  employeeName: string;\r\n  departmentName: string;\r\n  earnings: number;\r\n  deductions: number;\r\n  contributions: number;\r\n  net: number;\r\n};\r\n\r\ntype PayrollExportMetadata = {\r\n  batchId: string;\r\n  title: string;\r\n  payPeriodLabel: string;\r\n  payrollDateLabel: string;\r\n  referenceMonths: string;\r\n};\r\n\r\n// =============================================\r\n// CSV HELPERS\r\n// =============================================\r\n\r\nconst CSV_BOM = '\\uFEFF';\r\n\r\nconst _buildDepartmentReportCsv = (rows: DepartmentSummaryRow[], metadata: PayrollExportMetadata) => {\r\n  const headerRows: Array<Array<string | number>> = [\r\n    ['Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng', metadata.batchId],\r\n    ['Tiâ”œآ¬u â”€أ¦أںâ•—أ¼', metadata.title],\r\n    ['Kأںâ•—â”‚ lâ•‍â–‘â•‍أ­ng', metadata.payPeriodLabel],\r\n    ['Ngâ”œأ،y chi trأںâ•‘أ؛', metadata.payrollDateLabel],\r\n    ['Thâ”œأ­ng chأںâ•‘أ‘m câ”œâ”¤ng', metadata.referenceMonths || 'Khâ”œâ”¤ng xâ”œأ­c â”€أ¦أںâ•—أ¯nh'],\r\n    [],\r\n    ['Phâ”œâ–“ng ban', 'Sأںâ•—أ¦ nhâ”œأ³n viâ”œآ¬n', 'Tأںâ•—أ²ng thu nhأںâ•‘آ،p', 'Tأںâ•—أ²ng khأںâ•‘أ‘u trأںâ•—آ½', 'â”€أ‰â”œâ”‚ng gâ”œâ”‚p doanh nghiأںâ•—أ§p', 'Tأںâ•—أ²ng thأںâ•—â–’c lâ”€âŒگnh'],\r\n  ];\r\n  const bodyRows = rows.map((row) => [\r\n    row.departmentName,\r\n    row.headcount,\r\n    row.totalEarnings,\r\n    row.totalDeductions,\r\n    row.totalContributions,\r\n    row.totalNet,\r\n  ]);\r\n  return buildCsvContent([...headerRows, ...bodyRows]);\r\n};\r\n\r\nconst _buildPayslipReportCsv = (rows: PayslipExportRow[], metadata: PayrollExportMetadata) => {\r\n  const headerRows: Array<Array<string | number>> = [\r\n    ['Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng', metadata.batchId],\r\n    ['Tiâ”œآ¬u â”€أ¦أںâ•—أ¼', metadata.title],\r\n    ['Kأںâ•—â”‚ lâ•‍â–‘â•‍أ­ng', metadata.payPeriodLabel],\r\n    ['Ngâ”œأ،y chi trأںâ•‘أ؛', metadata.payrollDateLabel],\r\n    ['Thâ”œأ­ng chأںâ•‘أ‘m câ”œâ”¤ng', metadata.referenceMonths || 'Khâ”œâ”¤ng xâ”œأ­c â”€أ¦أںâ•—أ¯nh'],\r\n    [],\r\n    ['Mâ”œأ؛ nhâ”œأ³n viâ”œآ¬n', 'Hأںâ•—أ¬ tâ”œآ¬n', 'Phâ”œâ–“ng ban', 'Tأںâ•—أ²ng thu nhأںâ•‘آ،p', 'Tأںâ•—أ²ng khأںâ•‘أ‘u trأںâ•—آ½', 'â”€أ‰â”œâ”‚ng gâ”œâ”‚p doanh nghiأںâ•—أ§p', 'Thأںâ•—â–’c lâ”€âŒگnh'],\r\n  ];\r\n  const bodyRows = rows.map((row) => [\r\n    row.employeeId,\r\n    row.employeeName,\r\n    row.departmentName,\r\n    row.earnings,\r\n    row.deductions,\r\n    row.contributions,\r\n    row.net,\r\n  ]);\r\n  return buildCsvContent([...headerRows, ...bodyRows]);\r\n};\r\n\r\nconst buildCsvContent = (rows: Array<Array<string | number>>) =>\r\n  rows.map((row) => row.map(serializeCsvValue).join(',')).join('\\n');\r\n\r\nconst serializeCsvValue = (value: string | number) => {\r\n  const normalized = value === undefined || value === null ? '' : String(value);\r\n  const escaped = normalized.replace(/\"/g, '\"\"');\r\n  return `\"${escaped}\"`;\r\n};\r\n\r\nconst _downloadCsv = (content: string, filename: string) => {\r\n  const blob = new Blob([CSV_BOM + content], { type: 'text/csv;charset=utf-8;' });\r\n  const link = document.createElement('a');\r\n  const url = URL.createObjectURL(blob);\r\n  link.setAttribute('href', url);\r\n  link.setAttribute('download', filename);\r\n  link.style.visibility = 'hidden';\r\n  document.body.appendChild(link);\r\n  link.click();\r\n  document.body.removeChild(link);\r\n  URL.revokeObjectURL(url);\r\n};\r\n\r\n// =============================================\r\n// STABLE DATA HOOK - Prevents infinite loops\r\n// =============================================\r\n\r\nfunction usePayrollDetailData(systemId: SystemId | undefined) {\r\n  // Get data from React Query hooks\r\n  const { data: batch } = usePayrollById(systemId);\r\n  const { data: payslipsData } = usePayslipsByBatch(systemId);\r\n  const payslips = payslipsData?.data ?? [];\r\n  const templates = useAllPayrollTemplates();\r\n  const { data: employees } = useAllEmployees();\r\n  const { data: departmentsData } = useDepartments({ limit: 1000 });\r\n  const departments = departmentsData?.data ?? [];\r\n\r\n  // Get audit logs from batch data\r\n  const auditLogs = React.useMemo(() => (batch as any)?.auditLogs ?? [], [(batch as any)?.auditLogs]);\r\n\r\n  const template = React.useMemo(() => {\r\n    if (!batch?.templateSystemId) return undefined;\r\n    return templates.find((t) => t.systemId === batch.templateSystemId);\r\n  }, [templates, batch?.templateSystemId]);\r\n\r\n  const batchAuditLogs = React.useMemo(() => {\r\n    return auditLogs\r\n      .filter((entry: any) => entry.batchSystemId === batch?.systemId)\r\n      .sort((a: any, b: any) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());\r\n  }, [auditLogs, batch]);\r\n\r\n  // Lookup maps\r\n  const employeeLookup = React.useMemo(() => {\r\n    return employees.reduce<Record<SystemId, (typeof employees)[number]>>(\r\n      (acc, employee) => {\r\n        acc[employee.systemId] = employee;\r\n        return acc;\r\n      },\r\n      {} as Record<SystemId, (typeof employees)[number]>\r\n    );\r\n  }, [employees]);\r\n\r\n  // Convert audit logs to HistoryEntry format for ActivityHistory component\r\n  // Must be after employeeLookup to use it for name resolution\r\n  const historyEntries: HistoryEntry[] = React.useMemo(() => {\r\n    return batchAuditLogs.map((entry: any): HistoryEntry => {\r\n      // Try to get employee name from lookup\r\n      const employee = employeeLookup[entry.actorSystemId as SystemId];\r\n      const actorName = entry.actorDisplayName || employee?.fullName || entry.actorSystemId;\r\n      \r\n      return {\r\n        id: entry.systemId,\r\n        action: 'custom',\r\n        timestamp: new Date(entry.createdAt),\r\n        user: {\r\n          systemId: entry.actorSystemId,\r\n          name: actorName,\r\n        },\r\n        description: AUDIT_ACTION_LABEL[entry.action] ?? entry.action,\r\n        metadata: (entry.payload as { note?: string })?.note\r\n          ? { note: String((entry.payload as { note?: string }).note) }\r\n          : undefined,\r\n      };\r\n    });\r\n  }, [batchAuditLogs, employeeLookup]);\r\n\r\n  const departmentLookup = React.useMemo(() => {\r\n    return departments.reduce<Record<SystemId, (typeof departments)[number]>>(\r\n      (acc, department) => {\r\n        acc[department.systemId] = department;\r\n        return acc;\r\n      },\r\n      {} as Record<SystemId, (typeof departments)[number]>\r\n    );\r\n  }, [departments]);\r\n\r\n  // Derived data\r\n  const batchPayslips = React.useMemo<PayslipRow[]>(() => {\r\n    if (!batch) return [];\r\n    return payslips.map((payslip) => {\r\n      const employee = employeeLookup[payslip.employeeSystemId];\r\n      const departmentName = payslip.departmentSystemId\r\n        ? departmentLookup[payslip.departmentSystemId]?.name\r\n        : undefined;\r\n      return {\r\n        systemId: payslip.systemId,\r\n        employeeSystemId: payslip.employeeSystemId,\r\n        employeeId: employee?.id ?? payslip.employeeId,\r\n        employeeName: employee?.fullName ?? `Nhâ”œأ³n viâ”œآ¬n ${payslip.employeeId}`,\r\n        departmentName: departmentName ?? employee?.department ?? 'خ“أ‡أ¶',\r\n        positionName: employee?.positionName,\r\n        totals: payslip.totals,\r\n      } satisfies PayslipRow;\r\n    });\r\n  }, [batch, payslips, employeeLookup, departmentLookup]);\r\n\r\n  const departmentSummaries = React.useMemo<DepartmentSummaryRow[]>(() => {\r\n    if (!payslips.length) return [];\r\n    const summaryMap = new Map<string, DepartmentSummaryRow>();\r\n    payslips.forEach((slip) => {\r\n      const departmentKey = slip.departmentSystemId ?? '__unknown__';\r\n      const departmentName = slip.departmentSystemId\r\n        ? departmentLookup[slip.departmentSystemId]?.name\r\n        : employeeLookup[slip.employeeSystemId]?.department;\r\n      const current = summaryMap.get(departmentKey) ?? {\r\n        departmentSystemId: slip.departmentSystemId,\r\n        departmentName: departmentName ?? 'Khâ”œâ”¤ng xâ”œأ­c â”€أ¦أںâ•—أ¯nh',\r\n        headcount: 0,\r\n        totalEarnings: 0,\r\n        totalDeductions: 0,\r\n        totalContributions: 0,\r\n        totalNet: 0,\r\n      };\r\n      current.headcount += 1;\r\n      current.totalEarnings += slip.totals.earnings;\r\n      current.totalDeductions += slip.totals.deductions;\r\n      current.totalContributions += slip.totals.contributions;\r\n      current.totalNet += slip.totals.netPay;\r\n      summaryMap.set(departmentKey, current);\r\n    });\r\n    return Array.from(summaryMap.values()).sort((a, b) => b.totalNet - a.totalNet);\r\n  }, [payslips, departmentLookup, employeeLookup]);\r\n\r\n  const payslipExports = React.useMemo<PayslipExportRow[]>(() => {\r\n    if (!payslips.length) return [];\r\n    return payslips.map((slip) => {\r\n      const employee = employeeLookup[slip.employeeSystemId];\r\n      const departmentName = slip.departmentSystemId\r\n        ? departmentLookup[slip.departmentSystemId]?.name\r\n        : employee?.department;\r\n      return {\r\n        employeeId: employee?.id ?? slip.employeeId,\r\n        employeeName: employee?.fullName ?? `Nhâ”œأ³n viâ”œآ¬n ${slip.employeeId}`,\r\n        departmentName: departmentName ?? 'Khâ”œâ”¤ng xâ”œأ­c â”€أ¦أںâ•—أ¯nh',\r\n        earnings: slip.totals.earnings,\r\n        deductions: slip.totals.deductions,\r\n        contributions: slip.totals.contributions,\r\n        net: slip.totals.netPay,\r\n      } satisfies PayslipExportRow;\r\n    });\r\n  }, [payslips, employeeLookup, departmentLookup]);\r\n\r\n  const totals = React.useMemo(() => {\r\n    return payslips.reduce(\r\n      (acc, slip) => {\r\n        acc.earnings += slip.totals.earnings;\r\n        acc.deductions += slip.totals.deductions;\r\n        acc.contributions += slip.totals.contributions;\r\n        acc.net += slip.totals.netPay;\r\n        return acc;\r\n      },\r\n      { earnings: 0, deductions: 0, contributions: 0, net: 0 }\r\n    );\r\n  }, [payslips]);\r\n\r\n  // Labels\r\n  const referenceMonthsLabel = React.useMemo(() => {\r\n    if (!batch?.referenceAttendanceMonthKeys?.length) return '';\r\n    return batch.referenceAttendanceMonthKeys.map((month) => formatMonthKey(month)).join(', ');\r\n  }, [batch?.referenceAttendanceMonthKeys]);\r\n\r\n  const payPeriodLabel = React.useMemo(() => (batch ? formatPeriod(batch.payPeriod) : ''), [batch]);\r\n\r\n  const exportMetadata = React.useMemo<PayrollExportMetadata | null>(() => {\r\n    if (!batch) return null;\r\n    return {\r\n      batchId: batch.id,\r\n      title: batch.title,\r\n      payPeriodLabel,\r\n      payrollDateLabel: formatDate(batch.payrollDate),\r\n      referenceMonths: referenceMonthsLabel,\r\n    };\r\n  }, [batch, payPeriodLabel, referenceMonthsLabel]);\r\n\r\n  return {\r\n    batch,\r\n    payslips,\r\n    template,\r\n    batchAuditLogs,\r\n    historyEntries,\r\n    batchPayslips,\r\n    departmentSummaries,\r\n    payslipExports,\r\n    totals,\r\n    referenceMonthsLabel,\r\n    payPeriodLabel,\r\n    exportMetadata,\r\n    employeeLookup,\r\n    departmentLookup,\r\n  };\r\n}\r\n\r\n// =============================================\r\n// =============================================\r\n// MAIN COMPONENT\r\n// =============================================\r\n\r\nexport function PayrollDetailPage() {\r\n  const params = useParams<{ systemId?: string }>();\r\n  const router = useRouter();\r\n\r\n  // Parse systemId once\r\n  const resolvedSystemId = React.useMemo(\r\n    () => (params.systemId ? ensureSystemId(params.systemId, 'PayrollDetailPage') : undefined),\r\n    [params.systemId]\r\n  );\r\n\r\n  // Get all data from custom hook\r\n  const {\r\n    batch,\r\n    payslips,\r\n    template: _template,\r\n    batchAuditLogs: _batchAuditLogs,\r\n    historyEntries,\r\n    batchPayslips,\r\n    departmentSummaries: _departmentSummaries,\r\n    payslipExports: _payslipExports,\r\n    totals,\r\n    referenceMonthsLabel,\r\n    payPeriodLabel,\r\n    exportMetadata: _exportMetadata,\r\n    employeeLookup,\r\n    departmentLookup,\r\n  } = usePayrollDetailData(resolvedSystemId);\r\n\r\n  // Mutations\r\n  const { updateStatus } = usePayrollBatchMutations({\r\n    onSuccess: () => {},\r\n    onError: (err) => toast.error('Lأںâ•—أ¹i', { description: err.message }),\r\n  });\r\n  const { updateWithAudit, removeFromBatch } = usePayslipExtendedMutations({\r\n    onSuccess: () => {},\r\n    onError: (err) => toast.error('Lأںâ•—أ¹i', { description: err.message }),\r\n  });\r\n  \r\n  // Payment store - to check linked payments\r\n  const { data: allPaymentsData } = usePayments({ limit: 10000 });\r\n  const allPayments = allPaymentsData?.data ?? [];\r\n  const linkedPayments = React.useMemo(\r\n    () => allPayments.filter((p) => batch && p.linkedPayrollBatchSystemId === batch.systemId),\r\n    [allPayments, batch]\r\n  );\r\n\r\n  // Penalty store - to get penalty details for printing\r\n  const { data: allPenaltiesData } = usePenalties({ limit: 10000 });\r\n  const allPenalties = allPenaltiesData?.data ?? [];\r\n\r\n  // Print integration\r\n  const { info: storeInfo } = useStoreInfoData();\r\n  const { print, printMultiple } = usePrint();\r\n\r\n  // Dialog state\r\n  const [approvalAction, setApprovalAction] = React.useState<ApprovalAction | null>(null);\r\n  const [approvalNote, setApprovalNote] = React.useState('');\r\n  const [isApprovalDialogOpen, setIsApprovalDialogOpen] = React.useState(false);\r\n  \r\n  // Edit payslip dialog state\r\n  const [editingPayslipId, setEditingPayslipId] = React.useState<SystemId | null>(null);\r\n  const editingPayslip = React.useMemo(() => {\r\n    if (!editingPayslipId) return undefined;\r\n    return payslips.find((p) => p.systemId === editingPayslipId);\r\n  }, [editingPayslipId, payslips]);\r\n\r\n  // Create payment dialog state\r\n  const [isCreatePaymentOpen, setIsCreatePaymentOpen] = React.useState(false);\r\n\r\n  // Derived state\r\n  const _canReview = batch?.status === 'draft';\r\n  const _canLock = batch?.status === 'reviewed';\r\n  const isLocked = batch?.status === 'locked';\r\n\r\n  // Handlers\r\n  const handleBack = React.useCallback(() => {\r\n    router.push(ROUTES.PAYROLL.LIST);\r\n  }, [router]);\r\n\r\n  const handlePrint = React.useCallback(() => {\r\n    if (!batch) return;\r\n\r\n    const storeSettings = createStoreSettings(storeInfo);\r\n    const batchForPrint = convertPayrollBatchForPrint(\r\n      batch,\r\n      payslips,\r\n      {\r\n        employeeLookup: employeeLookup as Record<SystemId, { fullName?: string; id?: string; department?: string }>,\r\n        departmentLookup: departmentLookup as Record<SystemId, { name?: string }>,\r\n      }\r\n    );\r\n\r\n    print('payroll', {\r\n      data: mapPayrollBatchToPrintData(batchForPrint, storeSettings),\r\n      lineItems: mapPayrollBatchLineItems(batchForPrint.payslips),\r\n    });\r\n  }, [batch, payslips, employeeLookup, departmentLookup, storeInfo, print]);\r\n\r\n  const handleRunNew = React.useCallback(() => {\r\n    router.push(ROUTES.PAYROLL.RUN);\r\n  }, [router]);\r\n\r\n  // Approval dialog handlers (moved up for headerActions dependency)\r\n  const openApprovalDialog = React.useCallback((action: ApprovalAction) => {\r\n    setApprovalAction(action);\r\n    setApprovalNote('');\r\n    setIsApprovalDialogOpen(true);\r\n  }, []);\r\n\r\n  // Build header actions\r\n  const headerActions = React.useMemo(() => {\r\n    if (!batch) return undefined;\r\n    const actions: React.ReactNode[] = [];\r\n    \r\n    // === TRأںâ•‘أ،NG THâ”œأ¼I NHâ”œأ¼P (draft) ===\r\n    if (batch.status === 'draft') {\r\n      actions.push(\r\n        <Button key=\"review\" size=\"sm\" className=\"h-9\" onClick={() => openApprovalDialog('review')}>\r\n          <CheckCircle2 className=\"h-4 w-4 mr-2\" />\r\n          â”€أ‰â”œأ­nh dأںâ•‘أ‘u â”€أ¦â”œأ؛ duyأںâ•—أ§t\r\n        </Button>\r\n      );\r\n    }\r\n    \r\n    // === TRأںâ•‘أ،NG THâ”œأ¼I â”€أ‰â”œأ¢ DUYأںâ•—أ¥T (reviewed) ===\r\n    if (batch.status === 'reviewed') {\r\n      actions.push(\r\n        <Button key=\"lock\" size=\"sm\" className=\"h-9\" onClick={() => openApprovalDialog('lock')}>\r\n          <Lock className=\"h-4 w-4 mr-2\" />\r\n          Khâ”œâ”‚a bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng\r\n        </Button>\r\n      );\r\n    }\r\n    \r\n    // === TRأںâ•‘أ،NG THâ”œأ¼I â”€أ‰â”œأ¢ KHâ”œأ´A (locked) ===\r\n    // Create payment button (only when locked and no linked payments)\r\n    if (isLocked && linkedPayments.length === 0) {\r\n      actions.push(\r\n        <Button key=\"create-payment\" size=\"sm\" className=\"h-9\" onClick={() => setIsCreatePaymentOpen(true)}>\r\n          <Banknote className=\"h-4 w-4 mr-2\" />\r\n          Tأںâ•‘أ­o phiأںâ•‘â”گu chi\r\n        </Button>\r\n      );\r\n    }\r\n    \r\n    // Unlock button\r\n    if (isLocked) {\r\n      actions.push(\r\n        <Button key=\"unlock\" size=\"sm\" className=\"h-9\" variant=\"outline\" onClick={() => {\r\n          if (!batch) return;\r\n          updateStatus.mutate(\r\n            { systemId: batch.systemId, data: { status: 'reviewed', note: 'Mأںâ•—ئ’ khâ”œâ”‚a bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng' } },\r\n            {\r\n              onSuccess: () => {\r\n                toast.success('Cأںâ•‘آ،p nhأںâ•‘آ،t trأںâ•‘أ­ng thâ”œأ­i thâ”œأ،nh câ”œâ”¤ng', {\r\n                  description: 'Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng â”€أ¦â”œأ؛ chuyأںâ•—أ¢n sang trأںâ•‘أ­ng thâ”œأ­i â”€أ‰ang duyأںâ•—أ§t.',\r\n                });\r\n              },\r\n            }\r\n          );\r\n        }}>\r\n          <Unlock className=\"h-4 w-4 mr-2\" />\r\n          Mأںâ•—ئ’ khâ”œâ”‚a\r\n        </Button>\r\n      );\r\n    }\r\n    \r\n    // Print button\r\n    actions.push(\r\n      <Button key=\"print\" variant=\"outline\" size=\"sm\" className=\"h-9\" onClick={handlePrint}>\r\n        <Printer className=\"h-4 w-4 mr-2\" />\r\n        In\r\n      </Button>\r\n    );\r\n    \r\n    // Run new button\r\n    actions.push(\r\n      <Button key=\"run-new\" variant=\"outline\" size=\"sm\" className=\"h-9\" onClick={handleRunNew}>\r\n        Chأںâ•‘أ­y kأںâ•—â”‚ mأںâ•—آ¢i\r\n      </Button>\r\n    );\r\n    \r\n    return actions;\r\n  }, [batch, isLocked, linkedPayments.length, handlePrint, handleRunNew, updateStatus, openApprovalDialog]);\r\n\r\n  // Header subtitle\r\n  const headerSubtitle = React.useMemo(() => {\r\n    if (!batch) return 'â”€أ‰ang tأںâ•‘أ؛i...';\r\n    const parts: string[] = [];\r\n    if (payPeriodLabel) parts.push(`Kأںâ•—â”‚ ${payPeriodLabel}`);\r\n    if (referenceMonthsLabel) parts.push(`Chأںâ•‘أ‘m câ”œâ”¤ng: ${referenceMonthsLabel}`);\r\n    return parts.join(' خ“أ‡أ³ ') || 'Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng nأںâ•—أ–i bأںâ•—أ–';\r\n  }, [batch, payPeriodLabel, referenceMonthsLabel]);\r\n\r\n  // Page header with breadcrumb - set after batch is loaded\r\n  const { setPageHeader, clearPageHeader } = usePageHeader();\r\n  React.useEffect(() => {\r\n    setPageHeader({ \r\n      title: batch ? `Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng ${batch.id}` : 'Chi tiأںâ•‘â”گt bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng',\r\n      subtitle: headerSubtitle,\r\n      breadcrumb: [\r\n        { label: 'Trang chأںâ•—آ؛', href: ROUTES.DASHBOARD },\r\n        { label: 'Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng', href: ROUTES.PAYROLL.LIST },\r\n        { label: batch?.id ?? 'Chi tiأںâ•‘â”گt', href: '' },\r\n      ],\r\n      actions: headerActions,\r\n      badge: batch ? <PayrollStatusBadge status={batch.status} /> : undefined,\r\n      showBackButton: true,\r\n    });\r\n    return () => clearPageHeader();\r\n  }, [setPageHeader, clearPageHeader, batch, headerSubtitle, headerActions]);\r\n\r\n  const closeApprovalDialog = React.useCallback(() => {\r\n    setIsApprovalDialogOpen(false);\r\n    setApprovalAction(null);\r\n    setApprovalNote('');\r\n  }, []);\r\n\r\n  const handleStatusChange = React.useCallback((status: PayrollBatch['status'], note?: string) => {\r\n    if (!batch) return;\r\n    updateStatus.mutate(\r\n      { systemId: batch.systemId, data: { status, note } },\r\n      {\r\n        onSuccess: () => {\r\n          toast.success('Cأںâ•‘آ،p nhأںâ•‘آ،t trأںâ•‘أ­ng thâ”œأ­i thâ”œأ،nh câ”œâ”¤ng', {\r\n            description: `Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng â”€أ¦â”œأ؛ chuyأںâ•—أ¢n sang trأںâ•‘أ­ng thâ”œأ­i ${STATUS_LABEL[status]}.`,\r\n          });\r\n        },\r\n      }\r\n    );\r\n  }, [batch, updateStatus]);\r\n\r\n  const handleConfirmApproval = React.useCallback(() => {\r\n    if (!approvalAction || !batch) return;\r\n    const status = approvalAction === 'review' ? 'reviewed' : 'locked';\r\n    const note = approvalNote.trim() || undefined;\r\n    handleStatusChange(status, note);\r\n    closeApprovalDialog();\r\n  }, [approvalAction, batch, approvalNote, handleStatusChange, closeApprovalDialog]);\r\n\r\n  const _handleUnlock = React.useCallback(() => {\r\n    if (!batch) return;\r\n    handleStatusChange('reviewed', 'Mأںâ•—ئ’ khâ”œâ”‚a bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng');\r\n  }, [batch, handleStatusChange]);\r\n\r\n  const _handleOpenEmployee = React.useCallback((row: PayslipRow) => {\r\n    if (!row.employeeSystemId) return;\r\n    router.push(ROUTES.HRM.EMPLOYEE_VIEW.replace(':systemId', row.employeeSystemId));\r\n  }, [router]);\r\n\r\n  // Payslip action handlers\r\n  const handleEditPayslip = React.useCallback((row: PayslipRow) => {\r\n    if (isLocked) {\r\n      toast.error('Khâ”œâ”¤ng thأںâ•—أ¢ sأںâ•—آ،a', { description: 'Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng â”€أ¦â”œأ؛ khâ”œâ”‚a.' });\r\n      return;\r\n    }\r\n    setEditingPayslipId(row.systemId);\r\n  }, [isLocked]);\r\n\r\n  const handleSavePayslip = React.useCallback((payload: PayslipUpdatePayload) => {\r\n    if (!editingPayslipId) return;\r\n    updateWithAudit.mutate(\r\n      {\r\n        systemId: editingPayslipId,\r\n        data: payload,\r\n      },\r\n      {\r\n        onSuccess: () => {\r\n          toast.success('â”€أ‰â”œأ؛ cأںâ•‘آ،p nhأںâ•‘آ،t phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng');\r\n          setEditingPayslipId(null);\r\n        },\r\n        onError: (err) => {\r\n          toast.error('Khâ”œâ”¤ng thأںâ•—أ¢ cأںâ•‘آ،p nhأںâ•‘آ،t', { description: err.message });\r\n        },\r\n      }\r\n    );\r\n  }, [editingPayslipId, updateWithAudit]);\r\n\r\n  const handlePrintPayslip = React.useCallback((row: PayslipRow) => {\r\n    const payslip = payslips.find((p) => p.systemId === row.systemId);\r\n    if (!payslip || !batch) return;\r\n\r\n    // Get employee info\r\n    const employee = employeeLookup[payslip.employeeSystemId as SystemId];\r\n    const departmentName = payslip.departmentSystemId\r\n      ? departmentLookup[payslip.departmentSystemId as SystemId]?.name\r\n      : undefined;\r\n\r\n    const storeSettings = createStoreSettings(storeInfo);\r\n    \r\n    // Convert to PayslipForPrint for individual payslip printing\r\n    const payslipForPrint = convertPayslipForPrint(\r\n      payslip,\r\n      batch,\r\n      {\r\n        employee: employee ? {\r\n          id: employee.id,\r\n          fullName: employee.fullName,\r\n          department: departmentName,\r\n          position: employee.positionName,\r\n        } : undefined,\r\n        departmentName,\r\n      }\r\n    );\r\n\r\n    // Debug: log components\r\n\r\n    // Use payslip template (not payroll)\r\n    print('payslip', {\r\n      data: mapPayslipToPrintData(payslipForPrint, storeSettings),\r\n      lineItems: mapPayslipComponentLineItems(payslipForPrint.components),\r\n    });\r\n  }, [batch, payslips, employeeLookup, departmentLookup, storeInfo, print]);\r\n\r\n  const handleRemovePayslip = React.useCallback((row: PayslipRow) => {\r\n    if (isLocked) {\r\n      toast.error('Khâ”œâ”¤ng thأںâ•—أ¢ xâ”œâ”‚a', { description: 'Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng â”€أ¦â”œأ؛ khâ”œâ”‚a.' });\r\n      return;\r\n    }\r\n    removeFromBatch.mutate(row.systemId, {\r\n      onSuccess: () => {\r\n        toast.success('â”€أ‰â”œأ؛ xâ”œâ”‚a phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng khأںâ•—أ…i bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng');\r\n      },\r\n      onError: (err) => {\r\n        toast.error('Khâ”œâ”¤ng thأںâ•—أ¢ xâ”œâ”‚a', { description: err.message });\r\n      },\r\n    });\r\n  }, [isLocked, removeFromBatch]);\r\n\r\n  // Print payment voucher for a payslip (In phiأںâ•‘â”گu chi)\r\n  const handlePrintPayment = React.useCallback((row: PayslipRow) => {\r\n    if (!batch) return;\r\n    \r\n    // Find payment linked to this payslip (by payslipSystemId)\r\n    const payslip = payslips.find((p) => p.systemId === row.systemId);\r\n    if (!payslip) {\r\n      toast.error('Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng');\r\n      return;\r\n    }\r\n    \r\n    // Find payment voucher that matches this payslip\r\n    const payment = linkedPayments.find(\r\n      (p) => p.linkedPayslipSystemId === payslip.systemId\r\n    );\r\n    \r\n    if (!payment) {\r\n      toast.error('Châ•‍â–‘a tأںâ•‘أ­o phiأںâ•‘â”گu chi', {\r\n        description: 'Nhâ”œأ³n viâ”œآ¬n nâ”œأ،y châ•‍â–‘a câ”œâ”‚ phiأںâ•‘â”گu chi. Hâ”œأ؛y tأںâ•‘أ­o phiأںâ•‘â”گu chi trâ•‍â–‘أںâ•—آ¢c.',\r\n      });\r\n      return;\r\n    }\r\n\r\n    // Convert payment to print format\r\n    const storeSettings = createStoreSettings(storeInfo);\r\n    const employee = employeeLookup[payslip.employeeSystemId as SystemId];\r\n\r\n    const paymentForPrint: PaymentForPrint = {\r\n      code: payment.id,\r\n      createdAt: payment.createdAt,\r\n      amount: payment.amount,\r\n      paymentMethod: payment.paymentMethodName,\r\n      recipientName: employee?.fullName ?? payslip.employeeId,\r\n      recipientType: 'Nhâ”œأ³n viâ”œآ¬n',\r\n      description: payment.description,\r\n      groupName: payment.paymentReceiptTypeName,\r\n      location: {\r\n        name: payment.branchName,\r\n      },\r\n    };\r\n\r\n    print('payment', {\r\n      data: mapPaymentToPrintData(paymentForPrint, storeSettings),\r\n      lineItems: [],\r\n    });\r\n    \r\n    toast.success('â”€أ‰â”œأ؛ gأںâ•—آ،i in phiأںâ•‘â”گu chi');\r\n  }, [batch, payslips, linkedPayments, employeeLookup, storeInfo, print]);\r\n\r\n  // Print penalties for a payslip (In phiأںâ•‘â”گu phأںâ•‘أ­t)\r\n  const handlePrintPenalties = React.useCallback((row: PayslipRow) => {\r\n    if (!batch) return;\r\n    \r\n    // Find payslip to get deducted penalty IDs\r\n    const payslip = payslips.find((p) => p.systemId === row.systemId);\r\n    if (!payslip) {\r\n      toast.error('Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng');\r\n      return;\r\n    }\r\n    \r\n    // Get deducted penalties\r\n    const penaltyIds = payslip.deductedPenaltySystemIds || [];\r\n    if (penaltyIds.length === 0) {\r\n      toast.info('Khâ”œâ”¤ng câ”œâ”‚ phiأںâ•‘â”گu phأںâ•‘أ­t', {\r\n        description: 'Nhâ”œأ³n viâ”œآ¬n nâ”œأ،y khâ”œâ”¤ng câ”œâ”‚ phiأںâ•‘â”گu phأںâ•‘أ­t nâ”œأ،o trong kأںâ•—â”‚ lâ•‍â–‘â•‍أ­ng.',\r\n      });\r\n      return;\r\n    }\r\n    \r\n    // Get penalties from store\r\n    const penalties = penaltyIds\r\n      .map((id) => allPenalties.find((p) => p.systemId === id))\r\n      .filter(Boolean);\r\n    \r\n    if (penalties.length === 0) {\r\n      toast.error('Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y phiأںâ•‘â”گu phأںâ•‘أ­t');\r\n      return;\r\n    }\r\n    \r\n    // Build print jobs for all penalties\r\n    const storeSettings = createStoreSettings(storeInfo);\r\n    const employee = employeeLookup[payslip.employeeSystemId as SystemId];\r\n    \r\n    const printJobs = penalties\r\n      .filter((penalty): penalty is NonNullable<typeof penalty> => penalty != null)\r\n      .map((penalty) => {\r\n        const penaltyForPrint = convertPenaltyForPrint(penalty, {\r\n          employee: employee || null,\r\n        });\r\n        \r\n        return {\r\n          data: mapPenaltyToPrintData(penaltyForPrint, storeSettings),\r\n          lineItems: [] as never[],\r\n        };\r\n      });\r\n    \r\n    // Print all penalties at once (single popup)\r\n    printMultiple('penalty', printJobs);\r\n    \r\n    toast.success(`â”€أ‰â”œأ؛ in ${penalties.length} phiأںâ•‘â”گu phأںâ•‘أ­t`);\r\n  }, [batch, payslips, allPenalties, employeeLookup, storeInfo, printMultiple]);\r\n\r\n  // Print dialog state\r\n  const [isPrintDialogOpen, setIsPrintDialogOpen] = React.useState(false);\r\n  const [pendingPrintRows, setPendingPrintRows] = React.useState<PayslipRow[]>([]);\r\n  const [printMode, setPrintMode] = React.useState<'payslips' | 'penalties'>('payslips');\r\n\r\n  // Bulk print penalties - open dialog\r\n  const handleBulkPrintPenalties = React.useCallback((rows: PayslipRow[]) => {\r\n    if (!batch || rows.length === 0) return;\r\n    setPendingPrintRows(rows);\r\n    setPrintMode('penalties');\r\n    setIsPrintDialogOpen(true);\r\n  }, [batch]);\r\n\r\n  // Bulk print payslips - open dialog\r\n  const handleBulkPrintPayslips = React.useCallback((rows: PayslipRow[]) => {\r\n    if (!batch || rows.length === 0) return;\r\n    setPendingPrintRows(rows);\r\n    setPrintMode('payslips');\r\n    setIsPrintDialogOpen(true);\r\n  }, [batch]);\r\n\r\n  // Handle print confirm from dialog\r\n  const handlePrintConfirm = React.useCallback((options: SimplePrintOptionsResult) => {\r\n    if (!batch) return;\r\n    \r\n    const { paperSize } = options;\r\n    const storeSettings = createStoreSettings(storeInfo);\r\n    \r\n    if (printMode === 'penalties') {\r\n      // Print penalties\r\n      const printOptionsList: Array<{\r\n        data: ReturnType<typeof mapPenaltyToPrintData>;\r\n        lineItems: never[];\r\n        paperSize: PaperSize;\r\n      }> = [];\r\n      \r\n      pendingPrintRows.forEach((row) => {\r\n        const payslip = payslips.find((p) => p.systemId === row.systemId);\r\n        if (!payslip) return;\r\n        \r\n        const penaltyIds = payslip.deductedPenaltySystemIds || [];\r\n        if (penaltyIds.length === 0) return;\r\n        \r\n        const penalties = penaltyIds\r\n          .map((id) => allPenalties.find((p) => p.systemId === id))\r\n          .filter(Boolean);\r\n        \r\n        const employee = employeeLookup[payslip.employeeSystemId as SystemId];\r\n        \r\n        penalties.forEach((penalty) => {\r\n          if (!penalty) return;\r\n          \r\n          const penaltyForPrint = convertPenaltyForPrint(penalty, {\r\n            employee: employee || null,\r\n          });\r\n          \r\n          printOptionsList.push({\r\n            data: mapPenaltyToPrintData(penaltyForPrint, storeSettings),\r\n            lineItems: [],\r\n            paperSize,\r\n          });\r\n        });\r\n      });\r\n      \r\n      if (printOptionsList.length > 0) {\r\n        printMultiple('penalty', printOptionsList);\r\n        toast.success(`â”€أ‰â”œأ؛ gأںâ•—آ،i lأںâ•—أ§nh in ${printOptionsList.length} phiأںâ•‘â”گu phأںâ•‘أ­t`);\r\n      } else {\r\n        toast.info('Khâ”œâ”¤ng câ”œâ”‚ phiأںâ•‘â”گu phأںâ•‘أ­t', {\r\n          description: 'Câ”œأ­c nhâ”œأ³n viâ”œآ¬n â”€أ¦â•‍â–‘أںâ•—أ؛c chأںâ•—أ¬n khâ”œâ”¤ng câ”œâ”‚ phiأںâ•‘â”گu phأںâ•‘أ­t nâ”œأ،o.',\r\n        });\r\n      }\r\n    } else {\r\n      // Print payslips\r\n      const printOptionsList: Array<{\r\n        data: ReturnType<typeof mapPayslipToPrintData>;\r\n        lineItems: ReturnType<typeof mapPayslipComponentLineItems>;\r\n        paperSize: PaperSize;\r\n      }> = [];\r\n      \r\n      pendingPrintRows.forEach((row) => {\r\n        const payslip = payslips.find((p) => p.systemId === row.systemId);\r\n        if (!payslip) return;\r\n\r\n        const employee = employeeLookup[payslip.employeeSystemId as SystemId];\r\n        const departmentName = payslip.departmentSystemId\r\n          ? departmentLookup[payslip.departmentSystemId as SystemId]?.name\r\n          : undefined;\r\n\r\n        const payslipForPrint = convertPayslipForPrint(\r\n          payslip,\r\n          batch,\r\n          {\r\n            employee: employee ? {\r\n              id: employee.id,\r\n              fullName: employee.fullName,\r\n              department: departmentName,\r\n              position: employee.positionName,\r\n            } : undefined,\r\n            departmentName,\r\n          }\r\n        );\r\n\r\n        printOptionsList.push({\r\n          data: mapPayslipToPrintData(payslipForPrint, storeSettings),\r\n          lineItems: mapPayslipComponentLineItems(payslipForPrint.components),\r\n          paperSize,\r\n        });\r\n      });\r\n      \r\n      if (printOptionsList.length > 0) {\r\n        printMultiple('payslip', printOptionsList);\r\n        toast.success(`â”€أ‰â”œأ؛ gأںâ•—آ،i lأںâ•—أ§nh in ${printOptionsList.length} phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng`);\r\n      }\r\n    }\r\n    \r\n    setPendingPrintRows([]);\r\n  }, [batch, printMode, pendingPrintRows, payslips, allPenalties, employeeLookup, departmentLookup, storeInfo, printMultiple]);\r\n\r\n  // Bulk delete\r\n  const handleBulkDeletePayslips = React.useCallback((rows: PayslipRow[]) => {\r\n    if (isLocked) {\r\n      toast.error('Khâ”œâ”¤ng thأںâ•—أ¢ xâ”œâ”‚a', { description: 'Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng â”€أ¦â”œأ؛ khâ”œâ”‚a.' });\r\n      return;\r\n    }\r\n    \r\n    let successCount = 0;\r\n    let errorCount = 0;\r\n    \r\n    rows.forEach((row) => {\r\n      try {\r\n        (removeFromBatch as any)(row.systemId);\r\n        successCount++;\r\n      } catch (e) {\r\n        errorCount++;\r\n      }\r\n    });\r\n    \r\n    if (successCount > 0) {\r\n      toast.success(`â”€أ‰â”œأ؛ xâ”œâ”‚a ${successCount} phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng`);\r\n    }\r\n    if (errorCount > 0) {\r\n      toast.error(`Khâ”œâ”¤ng thأںâ•—أ¢ xâ”œâ”‚a ${errorCount} phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng`);\r\n    }\r\n  }, [isLocked, removeFromBatch]);\r\n\r\n  // Payslip table actions\r\n  const payslipActions = React.useMemo<PayslipActions>(() => ({\r\n    onEdit: handleEditPayslip,\r\n    onPrint: handlePrintPayslip,\r\n    onPrintPayment: handlePrintPayment,\r\n    onPrintPenalties: handlePrintPenalties,\r\n    onRemove: handleRemovePayslip,\r\n  }), [handleEditPayslip, handlePrintPayslip, handlePrintPayment, handlePrintPenalties, handleRemovePayslip]);\r\n\r\n  // Not found state\r\n  if (!batch) {\r\n    return (\r\n      <div className=\"flex h-72 flex-col items-center justify-center text-center\">\r\n        <p className=\"text-lg font-semibold\">Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng.</p>\r\n        <p className=\"text-body-sm text-muted-foreground\">Vui lâ”œâ–“ng kiأںâ•—أ¢m tra lأںâ•‘أ­i â”€أ¦â•‍â–‘أںâ•—آ¥ng dأںâ•‘آ½n hoأںâ•‘â•–c quay vأںâ•—أ¼ danh sâ”œأ­ch.</p>\r\n        <Button className=\"mt-4 h-9\" onClick={handleBack}>\r\n          Vأںâ•—أ¼ danh sâ”œأ­ch\r\n        </Button>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  const _statusHint = STATUS_HINTS[batch.status];\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      {/* Info Card - 2 cأںâ•—أ–t */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle>Thâ”œâ”¤ng tin chung</CardTitle>\r\n        </CardHeader>\r\n        <CardContent className=\"grid gap-4 md:grid-cols-2\">\r\n          {/* Cأںâ•—أ–t trâ”œأ­i */}\r\n          <div className=\"space-y-3 text-body-sm\">\r\n            <div className=\"flex items-center justify-between\">\r\n              <span className=\"text-muted-foreground\">Mâ”œأ؛</span>\r\n              <span>{batch.id}</span>\r\n            </div>\r\n            <div className=\"flex items-center justify-between\">\r\n              <span className=\"text-muted-foreground\">Tiâ”œآ¬u â”€أ¦أںâ•—أ¼</span>\r\n              <span className=\"font-medium text-right\">{batch.title}</span>\r\n            </div>\r\n            <div className=\"flex items-center justify-between\">\r\n              <span className=\"text-muted-foreground\">Kأںâ•—â”‚ lâ•‍â–‘â•‍أ­ng</span>\r\n              <span className=\"text-right\">{payPeriodLabel}</span>\r\n            </div>\r\n            <div className=\"flex items-center justify-between\">\r\n              <span className=\"text-muted-foreground\">Thâ”œأ­ng chأںâ•‘أ‘m câ”œâ”¤ng</span>\r\n              <span className=\"text-right\">{referenceMonthsLabel || 'خ“أ‡أ¶'}</span>\r\n            </div>\r\n          </div>\r\n          \r\n          {/* Cأںâ•—أ–t phأںâ•‘أ؛i */}\r\n          <div className=\"space-y-3 text-body-sm\">\r\n            <div className=\"flex items-center justify-between\">\r\n              <span className=\"text-muted-foreground\">Ngâ”œأ،y chi trأںâ•‘أ؛</span>\r\n              <span>{formatDate(batch.payrollDate)}</span>\r\n            </div>\r\n            <div className=\"flex items-center justify-between\">\r\n              <span className=\"text-muted-foreground\">Tأںâ•—أ²ng thأںâ•—â–’c lâ”€âŒگnh</span>\r\n              <span className=\"font-semibold text-primary\">{formatCurrency(batch.totalNet)}</span>\r\n            </div>\r\n            <div className=\"flex items-center justify-between\">\r\n              <span className=\"text-muted-foreground\">Sأںâ•—أ¦ phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng</span>\r\n              <span>{batchPayslips.length} nhâ”œأ³n viâ”œآ¬n</span>\r\n            </div>\r\n            <div className=\"flex items-center justify-between\">\r\n              <span className=\"text-muted-foreground\">Trأںâ•‘أ­ng thâ”œأ­i</span>\r\n              <PayrollStatusBadge status={batch.status} />\r\n            </div>\r\n          </div>\r\n          \r\n          {/* Phiأںâ•‘â”گu chi lâ•‍â–‘â•‍أ­ng - full width */}\r\n          <div className=\"md:col-span-2 pt-3 border-t\">\r\n            <div className=\"flex items-center justify-between text-body-sm\">\r\n              <span className=\"text-muted-foreground\">Phiأںâ•‘â”گu chi lâ•‍â–‘â•‍أ­ng</span>\r\n              <span>{linkedPayments.length > 0 ? `${linkedPayments.length} phiأںâ•‘â”گu chi` : 'Châ•‍â–‘a tأںâ•‘أ­o'}</span>\r\n            </div>\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n\r\n      {/* Totals & Notes */}\r\n      <div className=\"grid gap-4 lg:grid-cols-2\">\r\n        <Card>\r\n          <CardHeader>\r\n            <CardTitle>Tأںâ•—أ²ng quan chi trأںâ•‘أ؛</CardTitle>\r\n          </CardHeader>\r\n          <CardContent className=\"grid gap-4 sm:grid-cols-2\">\r\n            <div className=\"rounded-lg border p-3 text-body-sm\">\r\n              <p className=\"text-muted-foreground\">Tأںâ•—أ²ng thu nhأںâ•‘آ،p</p>\r\n              <p className=\"text-xl font-semibold text-emerald-600\">{formatCurrency(totals.earnings)}</p>\r\n            </div>\r\n            <div className=\"rounded-lg border p-3 text-body-sm\">\r\n              <p className=\"text-muted-foreground\">Tأںâ•—أ²ng khأںâ•‘أ‘u trأںâ•—آ½</p>\r\n              <p className=\"text-xl font-semibold text-red-500\">{formatCurrency(totals.deductions)}</p>\r\n            </div>\r\n            <div className=\"rounded-lg border p-3 text-body-sm\">\r\n              <p className=\"text-muted-foreground\">â”€أ‰â”œâ”‚ng gâ”œâ”‚p DN</p>\r\n              <p className=\"text-xl font-semibold text-blue-500\">{formatCurrency(totals.contributions)}</p>\r\n            </div>\r\n            <div className=\"rounded-lg border p-3 text-body-sm\">\r\n              <p className=\"text-muted-foreground\">Tأںâ•—أ²ng thأںâ•—â–’c lâ”€âŒگnh</p>\r\n              <p className=\"text-xl font-semibold\">{formatCurrency(totals.net)}</p>\r\n            </div>\r\n          </CardContent>\r\n        </Card>\r\n\r\n        <Card>\r\n          <CardHeader>\r\n            <CardTitle>Ghi châ”œâ•‘</CardTitle>\r\n          </CardHeader>\r\n          <CardContent>\r\n            <Textarea\r\n              className=\"min-h-[120px]\"\r\n              placeholder=\"Ghi châ”œâ•‘ nأںâ•—أ–i bأںâ•—أ– sأںâ•‘â•œ â”€أ¦â•‍â–‘أںâ•—أ؛c hأںâ•—أ¹ trأںâ•—أ؛ أںâ•—ئ’ bâ•‍â–‘أںâ•—آ¢c tiأںâ•‘â”گp theo.\"\r\n              readOnly\r\n              value={batch.notes ?? ''}\r\n            />\r\n            {!batch.notes && (\r\n              <p className=\"mt-2 text-body-xs text-muted-foreground\">\r\n                Bأںâ•‘أ­n câ”œâ”‚ thأںâ•—أ¢ cأںâ•‘آ،p nhأںâ•‘آ،t ghi châ”œâ•‘ sau khi hoâ”œأ،n thiأںâ•—أ§n tâ”œآ،nh nâ”€أ¢ng chأںâ•—أ«nh sأںâ•—آ،a batch.\r\n              </p>\r\n            )}\r\n          </CardContent>\r\n        </Card>\r\n      </div>\r\n\r\n      {/* Payslip Table */}\r\n      <PayslipDataTable\r\n        data={batchPayslips}\r\n        isLocked={isLocked}\r\n        actions={payslipActions}\r\n        onBulkPrintBatch={handlePrint}\r\n        onBulkPrint={handleBulkPrintPayslips}\r\n        onBulkPrintPenalties={handleBulkPrintPenalties}\r\n        onBulkDelete={handleBulkDeletePayslips}\r\n      />\r\n\r\n      {/* Edit Payslip Dialog */}\r\n      <PayslipEditDialog\r\n        open={!!editingPayslipId}\r\n        onOpenChange={(open) => { if (!open) setEditingPayslipId(null); }}\r\n        payslip={editingPayslip}\r\n        employeeName={editingPayslip ? (employeeLookup[editingPayslip.employeeSystemId]?.fullName ?? `Nhâ”œأ³n viâ”œآ¬n ${editingPayslip.employeeId}`) : ''}\r\n        isLocked={isLocked}\r\n        onSave={handleSavePayslip}\r\n      />\r\n\r\n      {/* Create Payment Dialog */}\r\n      <CreatePaymentDialog\r\n        open={isCreatePaymentOpen}\r\n        onOpenChange={setIsCreatePaymentOpen}\r\n        batch={batch}\r\n        payslips={payslips}\r\n        employeeLookup={employeeLookup as Record<SystemId, import('../employees/types').Employee | undefined>}\r\n      />\r\n\r\n      {/* Audit Logs - ActivityHistory */}\r\n      <ActivityHistory\r\n        history={historyEntries}\r\n        title=\"Nhأںâ•‘آ،t kâ”œâ•œ thao tâ”œأ­c\"\r\n        emptyMessage=\"Châ•‍â–‘a câ”œâ”‚ nhأںâ•‘آ،t kâ”œâ•œ nâ”œأ،o.\"\r\n        showFilters={false}\r\n        groupByDate={false}\r\n        maxHeight=\"400px\"\r\n      />\r\n\r\n      {/* Approval Dialog */}\r\n      <AlertDialog\r\n        open={isApprovalDialogOpen}\r\n        onOpenChange={(open) => {\r\n          if (!open) closeApprovalDialog();\r\n        }}\r\n      >\r\n        <AlertDialogContent>\r\n          <AlertDialogHeader>\r\n            <AlertDialogTitle>\r\n              {approvalAction ? APPROVAL_DIALOG_CONFIG[approvalAction].title : 'Xâ”œأ­c nhأںâ•‘آ،n'}\r\n            </AlertDialogTitle>\r\n            <AlertDialogDescription>\r\n              {approvalAction\r\n                ? APPROVAL_DIALOG_CONFIG[approvalAction].description\r\n                : 'Thao tâ”œأ­c sأںâ•‘â•œ â”€أ¦â•‍â–‘أںâ•—أ؛c â”œأ­p dأںâ•—أ‘ng cho bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng hiأںâ•—أ§n tأںâ•‘أ­i.'}\r\n            </AlertDialogDescription>\r\n          </AlertDialogHeader>\r\n          <div className=\"space-y-2\">\r\n            <Label htmlFor=\"approval-note\" className=\"text-body-sm font-medium\">\r\n              Ghi châ”œâ•‘ nأںâ•—أ–i bأںâ•—أ– (khâ”œâ”¤ng bأںâ•‘آ»t buأںâ•—أ–c)\r\n            </Label>\r\n            <Textarea\r\n              id=\"approval-note\"\r\n              placeholder=\"Nhأںâ•‘آ،p lâ”œâ•œ do duyأںâ•—أ§t/khâ”œâ”‚a â”€أ¦أںâ•—أ¢ lâ•‍â–‘u vâ”œأ،o nhأںâ•‘آ،t kâ”œâ•œ.\"\r\n              className=\"min-h-[80px]\"\r\n              value={approvalNote}\r\n              onChange={(event) => setApprovalNote(event.target.value)}\r\n            />\r\n          </div>\r\n          <AlertDialogFooter>\r\n            <AlertDialogCancel className=\"h-9\" onClick={closeApprovalDialog}>\r\n              Hأںâ•—آ؛y\r\n            </AlertDialogCancel>\r\n            <AlertDialogAction className=\"h-9\" onClick={handleConfirmApproval} disabled={!approvalAction}>\r\n              {approvalAction ? APPROVAL_DIALOG_CONFIG[approvalAction].confirmLabel : 'Xâ”œأ­c nhأںâ•‘آ،n'}\r\n            </AlertDialogAction>\r\n          </AlertDialogFooter>\r\n        </AlertDialogContent>\r\n      </AlertDialog>\r\n\r\n      {/* Print Options Dialog */}\r\n      <SimplePrintOptionsDialog\r\n        open={isPrintDialogOpen}\r\n        onOpenChange={setIsPrintDialogOpen}\r\n        onConfirm={handlePrintConfirm}\r\n        selectedCount={pendingPrintRows.length}\r\n        title={printMode === 'payslips' ? 'In phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng' : 'In phiأںâ•‘â”گu phأںâ•‘أ­t'}\r\n      />\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\payroll\\hooks\\use-payroll-list-handlers.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'asSystemId' is defined but never used. Allowed unused vars must match /^_/u.","line":16,"column":10,"nodeType":null,"messageId":"unusedVar","endLine":16,"endColumn":20},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"The 'penalties' logical expression could make the dependencies of useCallback Hook (a