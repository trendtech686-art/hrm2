slipsData?.data ?? [];\r\n  const storePayslip = payslipSystemId && !payslipData ? allPayslips.find((p) => p.systemId === payslipSystemId) : undefined;\r\n  \r\n  const { data: storeBatch } = usePayrollById(payslipData?.batchSystemId || storePayslip?.batchSystemId);\r\n  \r\n  // Prefer data passed in\r\n  const payslip = payslipData || storePayslip;\r\n  const batch = batchData || storeBatch;\r\n  \r\n  const { data: employees } = useAllEmployees();\r\n  const { data: departments } = useAllDepartments();\r\n  const { info: storeInfo } = useStoreInfoData();\r\n  \r\n  // Print hook\r\n  const { print } = usePrint();\r\n\r\n  // Lookups\r\n  const employeeLookup = React.useMemo(() => {\r\n    return employees.reduce<Record<SystemId, (typeof employees)[number]>>(\r\n      (acc, emp) => {\r\n        acc[emp.systemId] = emp;\r\n        return acc;\r\n      },\r\n      {} as Record<SystemId, (typeof employees)[number]>\r\n    );\r\n  }, [employees]);\r\n\r\n  const departmentLookup = React.useMemo(() => {\r\n    return departments.reduce<Record<SystemId, (typeof departments)[number]>>(\r\n      (acc, dept) => {\r\n        acc[dept.systemId] = dept;\r\n        return acc;\r\n      },\r\n      {} as Record<SystemId, (typeof departments)[number]>\r\n    );\r\n  }, [departments]);\r\n\r\n  // Handler\r\n  const handlePrint = React.useCallback(() => {\r\n    if (!payslip || !batch) {\r\n      toast.error('Khâ”œâ”¤ng thأںâ•—أ¢ in', { description: 'Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y dأںâ•—آ» liأںâ•—أ§u phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng.' });\r\n      return;\r\n    }\r\n\r\n    // Get employee info\r\n    const employee = employeeLookup[payslip.employeeSystemId];\r\n    const departmentName = payslip.departmentSystemId\r\n      ? departmentLookup[payslip.departmentSystemId as SystemId]?.name\r\n      : employee?.department;\r\n\r\n    const storeSettings = createStoreSettings(storeInfo);\r\n    const payslipForPrint = convertPayslipForPrint(\r\n      payslip,\r\n      batch,\r\n      {\r\n        employee: employee ? {\r\n          fullName: employee.fullName,\r\n          id: employee.id,\r\n          department: employee.department,\r\n          position: employee.positionName,\r\n        } : undefined,\r\n        departmentName,\r\n      }\r\n    );\r\n\r\n    // In phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng câ”œأ­ nhâ”œأ³n (template 'payslip')\r\n    print('payslip', {\r\n      data: mapPayslipToPrintData(payslipForPrint, storeSettings),\r\n      lineItems: mapPayslipComponentLineItems(payslipForPrint.components),\r\n    });\r\n\r\n    toast.success('â”€أ‰ang chuأںâ•‘âŒگn bأںâ•—أ¯ in...', { description: 'Phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng sأںâ•‘â•œ â”€أ¦â•‍â–‘أںâ•—أ؛c in ra.' });\r\n  }, [payslip, batch, storeInfo, employeeLookup, departmentLookup, print]);\r\n\r\n  if (!payslip) {\r\n    return null;\r\n  }\r\n\r\n  return (\r\n    <Button\r\n      variant={variant}\r\n      size={size}\r\n      className={className}\r\n      onClick={handlePrint}\r\n    >\r\n      <Printer className={showText ? 'h-4 w-4 mr-2' : 'h-4 w-4'} />\r\n      {showText && 'In phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng'}\r\n    </Button>\r\n  );\r\n}\r\n\r\n// =============================================\r\n// BATCH PRINT BUTTON\r\n// =============================================\r\n\r\ntype BatchPrintButtonProps = {\r\n  batchSystemId: SystemId;\r\n  variant?: 'default' | 'ghost' | 'outline';\r\n  size?: 'default' | 'sm' | 'icon';\r\n  className?: string;\r\n  showText?: boolean;\r\n};\r\n\r\n/**\r\n * BatchPrintButton - In toâ”œأ،n bأںâ•—أ– bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng\r\n */\r\nexport function BatchPrintButton({\r\n  batchSystemId,\r\n  variant = 'outline',\r\n  size = 'sm',\r\n  className,\r\n  showText = true,\r\n}: BatchPrintButtonProps) {\r\n  // Stores\r\n  const batch = undefined as any;\r\n  const payslips = [] as any[];\r\n  const { data: employees } = useAllEmployees();\r\n  const { data: departments } = useAllDepartments();\r\n  const { info: storeInfo } = useStoreInfoData();\r\n  \r\n  const { print } = usePrint();\r\n\r\n  // Lookups\r\n  const employeeLookup = React.useMemo(() => {\r\n    return employees.reduce<Record<SystemId, (typeof employees)[number]>>(\r\n      (acc, emp) => {\r\n        acc[emp.systemId] = emp;\r\n        return acc;\r\n      },\r\n      {} as Record<SystemId, (typeof employees)[number]>\r\n    );\r\n  }, [employees]);\r\n\r\n  const departmentLookup = React.useMemo(() => {\r\n    return departments.reduce<Record<SystemId, (typeof departments)[number]>>(\r\n      (acc, dept) => {\r\n        acc[dept.systemId] = dept;\r\n        return acc;\r\n      },\r\n      {} as Record<SystemId, (typeof departments)[number]>\r\n    );\r\n  }, [departments]);\r\n\r\n  // Handler\r\n  const handlePrint = React.useCallback(() => {\r\n    if (!batch || payslips.length === 0) {\r\n      toast.error('Khâ”œâ”¤ng thأںâ•—أ¢ in', { description: 'Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y dأںâ•—آ» liأںâ•—أ§u bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng.' });\r\n      return;\r\n    }\r\n\r\n    const storeSettings = createStoreSettings(storeInfo);\r\n    const batchForPrint = convertPayrollBatchForPrint(\r\n      batch,\r\n      payslips,\r\n      {\r\n        employeeLookup: employeeLookup as Record<SystemId, { fullName?: string; id?: string; department?: string }>,\r\n        departmentLookup: departmentLookup as Record<SystemId, { name?: string }>,\r\n      }\r\n    );\r\n\r\n    print('payroll', {\r\n      data: mapPayrollBatchToPrintData(batchForPrint, storeSettings),\r\n      lineItems: mapPayrollBatchLineItems(batchForPrint.payslips),\r\n    });\r\n\r\n    toast.success('â”€أ‰ang chuأںâ•‘âŒگn bأںâ•—أ¯ in...', { description: `In ${payslips.length} phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng.` });\r\n  }, [batch, payslips, storeInfo, employeeLookup, departmentLookup, print]);\r\n\r\n  if (!batch) {\r\n    return null;\r\n  }\r\n\r\n  return (\r\n    <Button\r\n      variant={variant}\r\n      size={size}\r\n      className={className}\r\n      onClick={handlePrint}\r\n      disabled={payslips.length === 0}\r\n    >\r\n      <Printer className={showText ? 'h-4 w-4 mr-2' : 'h-4 w-4'} />\r\n      {showText && `In bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng (${payslips.length})`}\r\n    </Button>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\payroll\\components\\payslip-table.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\payroll\\components\\status-badge.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\payroll\\components\\summary-cards.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\payroll\\detail-page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Payslip' is defined but never used. Allowed unused vars must match /^_/u.","line":31,"column":64,"nodeType":null,"messageId":"unusedVar","endLine":31,"endColumn":71},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"The 'payslips' logical expression could make the dependencies of useMemo Hook (at line 336) change on every render. To fix this, wrap the initialization of 'payslips' in its own useMemo() Hook.","line":253,"column":9,"nodeType":"VariableDeclarator","endLine":253,"endColumn":44},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"The 'payslips' logical expression could make the dependencies of useMemo Hook (at line 363) change on every render. To fix this, wrap the initialization of 'payslips' in its own useMemo() Hook.","line":253,"column":9,"nodeType":"VariableDeclarator","endLine":253,"endColumn":44},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"The 'paysl