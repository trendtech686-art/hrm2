px] truncate\" title={row.customerName}>\r\n        {row.customerName}\r\n      </div>\r\n    ),\r\n    meta: {\r\n      displayName: \"Tâ”œآ¬n khâ”œأ­ch hâ”œأ،ng\",\r\n      group: \"Thâ”œâ”¤ng tin khâ”œأ­ch hâ”œأ،ng\"\r\n    },\r\n  },\r\n\r\n  {\r\n    id: \"customerPhone\",\r\n    accessorKey: \"customerPhone\",\r\n    header: \"Sأںâ•—أ¦ â”€أ¦iأںâ•—أ§n thoأںâ•‘أ­i\",\r\n    cell: ({ row }) => (\r\n      <div className=\"whitespace-nowrap\">{row.customerPhone}</div>\r\n    ),\r\n    meta: {\r\n      displayName: \"Sâ”€أ‰T khâ”œأ­ch hâ”œأ،ng\",\r\n      group: \"Thâ”œâ”¤ng tin khâ”œأ­ch hâ”œأ،ng\"\r\n    },\r\n  },\r\n\r\n  {\r\n    id: \"customerAddress\",\r\n    accessorKey: \"customerAddress\",\r\n    header: \"â”€أ‰أںâ•—أ¯a chأںâ•—أ«\",\r\n    cell: ({ row }) => (\r\n      <div className=\"max-w-[200px] truncate\" title={row.customerAddress}>\r\n        {row.customerAddress || 'خ“أ‡أ¶'}\r\n      </div>\r\n    ),\r\n    meta: {\r\n      displayName: \"â”€أ‰أںâ•—أ¯a chأںâ•—أ« khâ”œأ­ch hâ”œأ،ng\",\r\n      group: \"Thâ”œâ”¤ng tin khâ”œأ­ch hâ”œأ،ng\"\r\n    },\r\n  },\r\n\r\n  // Tracking info\r\n  {\r\n    id: \"trackingCode\",\r\n    accessorKey: \"trackingCode\",\r\n    header: \"Mâ”œأ؛ vأںâ•‘آ،n â”€أ¦â•‍أ­n / Mâ”œأ؛ tra cأںâ•—âŒگu\",\r\n    cell: ({ row }) => (\r\n      <div className=\"space-y-0.5\">\r\n        <div className=\"font-mono text-body-xs whitespace-nowrap\">{row.trackingCode}</div>\r\n        {row.publicTrackingCode && (\r\n          <div className=\"font-mono text-body-xs text-muted-foreground\">\r\n            Tra cأںâ•—âŒگu: {row.publicTrackingCode}\r\n          </div>\r\n        )}\r\n      </div>\r\n    ),\r\n    meta: {\r\n      displayName: \"Mâ”œأ؛ vأںâ•‘آ،n â”€أ¦â•‍أ­n / Tra cأںâ•—âŒگu\",\r\n      group: \"Vأںâ•‘آ،n chuyأںâ•—أ¢n\"\r\n    },\r\n  },\r\n\r\n  {\r\n    id: \"shippingFee\",\r\n    accessorKey: \"shippingFee\",\r\n    header: \"Phâ”œآ، câ•‍â–‘أںâ•—آ¢c\",\r\n    cell: ({ row }) => (\r\n      <div className=\"text-right whitespace-nowrap\">\r\n        {row.shippingFee ? `${formatCurrency(row.shippingFee)} خ“أ©آ½` : 'خ“أ‡أ¶'}\r\n      </div>\r\n    ),\r\n    meta: {\r\n      displayName: \"Phâ”œآ، câ•‍â–‘أںâ•—آ¢c\",\r\n      group: \"Vأںâ•‘آ،n chuyأںâ•—أ¢n\"\r\n    },\r\n  },\r\n\r\n  // Reference fields\r\n  {\r\n    id: \"linkedOrderId\",\r\n    accessorKey: \"linkedOrderSystemId\", // خ“آ£أ  Use systemId\r\n    header: \"â”€أ‰â•‍أ­n hâ”œأ،ng liâ”œآ¬n kأںâ•‘â”گt\",\r\n    cell: ({ row }) => {\r\n      if (!row.linkedOrderSystemId) return <span className=\"text-muted-foreground text-body-xs\">خ“أ‡أ¶</span>;\r\n      const orderBusinessId = orders.find(o => o.systemId === row.linkedOrderSystemId)?.id;\r\n      return (\r\n        <div \r\n          className=\"font-medium text-primary cursor-pointer hover:underline whitespace-nowrap\" \r\n          onClick={() => navigate(`/orders/${row.linkedOrderSystemId}`)}\r\n        >\r\n          {orderBusinessId || row.linkedOrderSystemId}\r\n        </div>\r\n      );\r\n    },\r\n    meta: {\r\n      displayName: \"â”€أ‰â•‍أ­n hâ”œأ،ng liâ”œآ¬n kأںâ•‘â”گt\",\r\n      group: \"Tham chiأںâ•‘â”گu\"\r\n    },\r\n  },\r\n\r\n  {\r\n    id: \"referenceUrl\",\r\n    accessorKey: \"referenceUrl\",\r\n    header: \"Link tham chiأںâ•‘â”گu\",\r\n    cell: ({ row }) => {\r\n      if (!row.referenceUrl) return <span className=\"text-muted-foreground text-body-xs\">خ“أ‡أ¶</span>;\r\n      return (\r\n        <a \r\n          href={row.referenceUrl}\r\n          target=\"_blank\"\r\n          rel=\"noopener noreferrer\"\r\n          className=\"text-primary hover:underline text-body-xs flex items-center gap-1\"\r\n          onClick={(e) => e.stopPropagation()}\r\n        >\r\n          <LinkIcon className=\"h-3 w-3\" />\r\n          Link\r\n        </a>\r\n      );\r\n    },\r\n    meta: {\r\n      displayName: \"â”€أ‰â•‍â–‘أںâ•—آ¥ng dأںâ•‘آ½n tham chiأںâ•‘â”گu\",\r\n      group: \"Tham chiأںâ•‘â”گu\"\r\n    },\r\n  },\r\n\r\n  {\r\n    id: \"externalReference\",\r\n    accessorKey: \"externalReference\",\r\n    header: \"Mâ”œأ؛ tham chiأںâ•‘â”گu\",\r\n    cell: ({ row }) => (\r\n      <div className=\"font-mono text-body-xs whitespace-nowrap\">\r\n        {row.externalReference || 'خ“أ‡أ¶'}\r\n      </div>\r\n    ),\r\n    meta: {\r\n      displayName: \"Mâ”œأ؛ tham chiأںâ•‘â”گu bâ”œآ¬n ngoâ”œأ،i\",\r\n      group: \"Tham chiأںâ•‘â”گu\"\r\n    },\r\n  },\r\n\r\n  // Status\r\n  {\r\n    id: \"status\",\r\n    accessorKey: \"status\",\r\n    header: ({ sorting, setSorting }) => (\r\n      <DataTableColumnHeader \r\n        title=\"Trأںâ•‘أ­ng thâ”œأ­i\"\r\n        sortKey=\"status\"\r\n        isSorted={sorting?.id === 'status'}\r\n        sortDirection={sorting?.desc ? 'desc' : 'asc'}\r\n        onSort={() => setSorting?.((s) => ({ id: 'status', desc: s.id === 'status' ? !s.desc : false }))}\r\n      />\r\n    ),\r\n    cell: ({ row }) => (\r\n      <Badge className={WARRANTY_STATUS_COLORS[row.status]}>\r\n        {WARRANTY_STATUS_LABELS[row.status]}\r\n      </Badge>\r\n    ),\r\n    meta: {\r\n      displayName: \"Trأںâ•‘أ­ng thâ”œأ­i\",\r\n      group: \"Trأںâ•‘أ­ng thâ”œأ­i\"\r\n    },\r\n  },\r\n\r\n  // SLA Status column - NEW\r\n  {\r\n    id: \"slaStatus\",\r\n    header: \"SLA\",\r\n    cell: ({ row }) => {\r\n      const overdueStatus = checkWarrantyOverdue(row);\r\n      \r\n      // Nأںâ•‘â”گu â”€أ¦â”œأ؛ trأںâ•‘أ؛ hâ”œأ،ng\r\n      if (row.status === 'returned') {\r\n        return <span className=\"text-muted-foreground\">Hoâ”œأ،n thâ”œأ،nh</span>;\r\n      }\r\n\r\n      // Check trأںâ•‘أ­ng thâ”œأ­i quâ”œأ­ hأںâ•‘أ­n (kiأںâ•—أ¢m tra tأںâ•—آ½ng loأںâ•‘أ­i)\r\n      const isOverdue = overdueStatus.isOverdueResponse || \r\n                        overdueStatus.isOverdueProcessing || \r\n                        overdueStatus.isOverdueReturn;\r\n\r\n      // Nأںâ•‘â”گu khâ”œâ”¤ng quâ”œأ­ hأںâ•‘أ­n - hiأںâ•—أ¢n thأںâ•—أ¯ thأںâ•—آ¥i gian câ”œâ–“n lأںâ•‘أ­i theo trأںâ•‘أ­ng thâ”œأ­i\r\n      if (!isOverdue) {\r\n        let timeLeft = 0;\r\n        if (row.status === 'incomplete') {\r\n          timeLeft = overdueStatus.responseTimeLeft;\r\n        } else if (row.status === 'pending') {\r\n          timeLeft = overdueStatus.processingTimeLeft;\r\n        } else if (row.status === 'processed') {\r\n          timeLeft = overdueStatus.returnTimeLeft;\r\n        }\r\n        \r\n        const timeLeftStr = formatTimeLeft(timeLeft);\r\n        return (\r\n          <div className=\"flex items-center gap-1\">\r\n            <span className=\"text-green-600\">Câ”œâ–“n {timeLeftStr}</span>\r\n          </div>\r\n        );\r\n      }\r\n\r\n      // Quâ”œأ­ hأںâ•‘أ­n - hiأںâ•—أ¢n thأںâ•—أ¯ tأںâ•—آ½ overdueDuration\r\n      return (\r\n        <div className=\"flex items-center gap-1 text-red-600\">\r\n          <AlertTriangle className=\"h-3 w-3\" />\r\n          <span>Quâ”œأ­ {overdueStatus.overdueDuration}</span>\r\n        </div>\r\n      );\r\n    },\r\n    size: 140,\r\n    meta: {\r\n      displayName: \"SLA\",\r\n      group: \"Trأںâ•‘أ­ng thâ”œأ­i\"\r\n    },\r\n  },\r\n\r\n  // Settlement Status - NEW: Trأںâ•‘أ­ng thâ”œأ­i thanh toâ”œأ­n\r\n  {\r\n    id: \"settlementStatus\",\r\n    header: \"Thanh toâ”œأ­n\",\r\n    cell: ({ row }) => {\r\n      // Chأںâ•—أ« hiأںâ•—أ¢n thأںâ•—أ¯ cho phiأںâ•‘â”گu â”€أ¦â”œأ؛ trأںâ•‘أ؛ vâ”œأ، câ”œâ”‚ totalSettlement > 0\r\n      if (row.status !== 'returned' || !row.summary?.totalSettlement || row.summary.totalSettlement <= 0) {\r\n        return <span className=\"text-muted-foreground text-body-xs\">خ“أ‡أ¶</span>;\r\n      }\r\n\r\n      // Get vouchers and calculate\r\n      // REMOVED: useVoucherStore no longer exists\r\n      // const vouchers = useVoucherStore.getState().data;\r\n      const vouchers: { linkedWarrantySystemId?: string; amount?: number }[] = [];\r\n      const relatedVouchers = vouchers.filter(v => v.linkedWarrantySystemId === row.systemId);\r\n      const totalPaid = relatedVouchers.reduce((sum, v) => sum + (v.amount || 0), 0);\r\n      \r\n      // Calculate status using exported function\r\n      const status = calculateSettlementStatus(\r\n        Math.abs(row.summary.totalSettlement),\r\n        totalPaid,\r\n        row.shippingFee || 0\r\n      );\r\n\r\n      return (\r\n        <Badge className={WARRANTY_SETTLEMENT_STATUS_COLORS[status]}>\r\n          {WARRANTY_SETTLEMENT_STATUS_LABELS[status]}\r\n        </Badge>\r\n      );\r\n    },\r\n    meta: {\r\n      displayName: \"Trأںâ•‘أ­ng thâ”œأ­i thanh toâ”œأ­n\",\r\n      group: \"Trأںâ•‘أ­ng thâ”œأ­i\"\r\n    },\r\n  },\r\n\r\n  // Products summary\r\n  {\r\n    id: \"productsCount\",\r\n    accessorKey: \"products\",\r\n    header: \"Sأںâ•‘أ؛n phأںâ•‘âŒگm\",\r\n    cell: ({ row }) => {\r\n      const totalQty = row.products?.reduce((sum, p) => sum + (p.quantity || 1), 0) || 0;\r\n      return (\r\n        <div className=\"flex items-center gap-2\">\r\n          <Package className=\"h-4 w-4 text-muted-foreground\" />\r\n          <span>{totalQty}</span>\r\n        </div>\r\n      );\r\n    },\r\n    meta: {\r\n      displayName: \"Tأںâ•—أ²ng sأںâ•—أ¦ lâ•‍â–‘أںâ•—أ؛ng sأںâ•‘أ؛n phأںâ•‘âŒگm\",\r\n      group: \"Sأںâ•‘أ؛n phأںâ•‘âŒگm\"\r\n    },\r\n  },\r\n\r\n  {\r\n    id: \"totalProducts\",\r\n    accessorKey: \"summary\",\r\n    header: \"Tأںâ•—أ²ng SP\",\r\n    cell: ({ row }) => (\r\n      <div className=\"text-center font-medium\">{row.summary?.totalProducts || 0}</div>\r\n    ),\r\n    meta: {\r\n      displayName: \"Tأںâ•—أ²ng sأںâ•‘أ؛n phأںâ•‘âŒگm\",\r\n      group: \"Sأںâ•‘أ؛n phأںâ•‘âŒگm\"\r\n    },\r\n  },\r\n\r\n  {\r\n    id: \"totalReplaced\",\r\n    accessorKey: \"summary\",\r\n    header: \"â”€أ‰أںâ•—أ²i mأںâ•—آ¢i\",\r\n    cell: ({ row }) => {\r\n      // Fallback: Calculate from products if summary is missing\r\n      let replaced = row.summary?.totalReplaced;\r\n      if (replaced === undefined || replaced === null) {\r\n        replaced = row.products\r\n          ?.filter((p: { resolution?: string }) => p.resolution === 'replace')\r\n          .reduce((sum: number, p: { quantity?: number }) => sum + (p.quantity || 1), 0) || 0;\r\n      }\r\n      if (replaced === 0) return <span className=\"text-muted-foreground text-body-xs\">خ“أ‡أ¶</span>;\r\n      return <div className=\"text-center text-green-600 font-medium\">{replaced}</div>;\r\n    },\r\n    meta: {\r\n      displayName: \"Sأںâ•—أ¦ lâ•‍â–‘أںâ•—أ؛ng â”€أ¦أںâ•—أ²i mأںâ•—آ¢i\",\r\n      group: \"Sأںâ•‘أ؛n phأںâ•‘âŒگm\"\r\n    },\r\n  },\r\n\r\n  {\r\n    id: \"totalReturned\",\r\n    accessorKey: \"summary\",\r\n    header: \"Trأںâ•‘أ؛ lأںâ•‘أ­i\",\r\n    cell: ({ row }) => {\r\n      // Fallback: Calculate from products if summary is missing\r\n      let returned = row.summary?.totalReturned;\r\n      if (returned === undefined || returned === null) {\r\n        returned = row.products\r\n          ?.filter((p: { resolution?: string }) => p.resolution === 'return')\r\n          .reduce((sum: number, p: { quantity?: number }) => sum + (p.quantity || 1), 0) || 0;\r\n      }\r\n      if (returned === 0) return <span className=\"text-muted-foreground text-body-xs\">خ“أ‡أ¶</span>;\r\n      return <div className=\"text-center text-blue-600 font-medium\">{returned}</div>;\r\n    },\r\n    meta: {\r\n      displayName: \"Sأںâ•—أ¦ lâ•‍â–‘أںâ•—أ؛ng trأںâ•‘أ؛ lأںâ•‘أ­i\",\r\n      group: \"Sأںâ•‘أ؛n phأںâ•‘âŒگm\"\r\n    },\r\n  },\r\n\r\n  {\r\n    id: \"totalOutOfStock\",\r\n    accessorKey: \"summary\",\r\n    header: \"Hأںâ•‘â”گt hâ”œأ،ng\",\r\n    cell: ({ row }) => {\r\n      // Fallback: Calculate from products if summary is missing or incorrect\r\n      // Gأںâ•—أ–p cأںâ•‘أ؛ \"out_of_stock\" vâ”œأ، \"deduct\" vâ”œآ¼ â”€أ¦أںâ•—أ¼u lâ”œأ، hأںâ•‘â”گt hâ”œأ،ng خ“أ¥أ† khأںâ•‘أ‘u trأںâ•—آ½ tiأںâ•—أ¼n\r\n      let outOfStock = row.summary?.totalOutOfStock;\r\n      let deduction = row.summary?.totalDeduction;\r\n      \r\n      if (outOfStock === undefined || outOfStock === null || deduction === undefined || deduction === null) {\r\n        const outOfStockProducts = row.products?.filter((p: { resolution?: string }) => \r\n          p.resolution === 'out_of_stock' || p.resolution === 'deduct'\r\n        ) || [];\r\n        outOfStock = outOfStockProducts.reduce((sum: number, p: { quantity?: number }) => sum + (p.quantity || 1), 0);\r\n        deduction = outOfStockProducts.reduce((sum: number, p: { resolution?: string; deductionAmount?: number; quantity?: number; unitPrice?: number }) => {\r\n          if (p.resolution === 'deduct') return sum + (p.deductionAmount || 0);\r\n          if (p.resolution === 'out_of_stock') return sum + ((p.quantity || 1) * (p.unitPrice || 0));\r\n          return sum;\r\n        }, 0);\r\n      }\r\n      \r\n      if (outOfStock === 0 && deduction === 0) return <span className=\"text-muted-foreground text-body-xs\">خ“أ‡أ¶</span>;\r\n      \r\n      return (\r\n        <div className=\"text-center\">\r\n          <div className=\"text-orange-600 font-medium\">{outOfStock} SP</div>\r\n          {deduction > 0 && (\r\n            <div className=\"text-body-xs text-red-600 whitespace-nowrap\">\r\n              {formatCurrency(deduction)} خ“أ©آ½\r\n            </div>\r\n          )}\r\n        </div>\r\n      );\r\n    },\r\n    meta: {\r\n      displayName: \"Hأںâ•‘â”گt hâ”œأ،ng (Khأںâ•‘أ‘u trأںâ•—آ½ tiأںâ•—أ¼n)\",\r\n      group: \"Sأںâ•‘أ؛n phأںâ•‘âŒگm\"\r\n    },\r\n  },\r\n\r\n  {\r\n    id: \"totalSettlement\",\r\n    accessorKey: \"summary\",\r\n    header: \"Bâ”œâ•£ trأںâ•—آ½\",\r\n    cell: ({ row }) => {\r\n      const settlement = row.summary?.totalSettlement || 0;\r\n      if (settlement === 0) return <span className=\"text-muted-foreground text-body-xs\">خ“أ‡أ¶</span>;\r\n      return (\r\n        <div className=\"text-right text-blue-600 whitespace-nowrap\">\r\n          {formatCurrency(Math.abs(settlement))} خ“أ©آ½\r\n        </div>\r\n      );\r\n    },\r\n    meta: {\r\n      displayName: \"Tأںâ•—أ²ng tiأںâ•—أ¼n bâ”œâ•£ trأںâ•—آ½\",\r\n      group: \"Sأںâ•‘أ؛n phأںâ•‘âŒگm\"\r\n    },\r\n  },\r\n\r\n  // Images\r\n  {\r\n    id: \"receivedImagesCount\",\r\n    accessorKey: \"receivedImages\",\r\n    header: \"Hâ”œآ¼nh nhأںâ•‘آ،n\",\r\n    cell: ({ row }) => (\r\n      <div className=\"text-center\">{row.receivedImages?.length || 0} أںâ•‘أ؛nh</div>\r\n    ),\r\n    meta: {\r\n      displayName: \"Sأںâ•—أ¦ أںâ•‘أ؛nh nhأںâ•‘آ،n hâ”œأ،ng\",\r\n      group: \"Hâ”œآ¼nh أںâ•‘أ؛nh\"\r\n    },\r\n  },\r\n\r\n  {\r\n    id: \"processedImagesCount\",\r\n    accessorKey: \"processedImages\",\r\n    header: \"Hâ”œآ¼nh xأںâ•—آ، lâ”œâ•œ\",\r\n    cell: ({ row }) => (\r\n      <div className=\"text-center\">{row.processedImages?.length || 0} أںâ•‘أ؛nh</div>\r\n    ),\r\n    meta: {\r\n      displayName: \"Sأںâ•—أ¦ أںâ•‘أ؛nh xأںâ•—آ، lâ”œâ•œ xong\",\r\n      group: \"Hâ”œآ¼nh أںâ•‘أ؛nh\"\r\n    },\r\n  },\r\n\r\n  // History & Comments\r\n  {\r\n    id: \"historyCount\",\r\n    accessorKey: \"history\",\r\n    header: \"Lأںâ•—أ¯ch sأںâ•—آ،\",\r\n    cell: ({ row }) => (\r\n      <div className=\"text-center\">{row.history?.length || 0}</div>\r\n    ),\r\n    meta: {\r\n      displayName: \"Sأںâ•—أ¦ bأںâ•‘أ؛n ghi lأںâ•—أ¯ch sأںâ•—آ،\",\r\n      group: \"Lأںâ•—أ¯ch sأںâ•—آ، & Bâ”œآ¼nh luأںâ•‘آ،n\"\r\n    },\r\n  },\r\n\r\n  {\r\n    id: \"commentsCount\",\r\n    accessorKey: \"comments\",\r\n    header: \"Bâ”œآ¼nh luأںâ•‘آ،n\",\r\n    cell: ({ row }) => (\r\n      <div className=\"text-center\">{row.comments?.length || 0}</div>\r\n    ),\r\n    meta: {\r\n      displayName: \"Sأںâ•—أ¦ bâ”œآ¼nh luأںâ•‘آ،n\",\r\n      group: \"Lأںâ•—أ¯ch sأںâ•—آ، & Bâ”œآ¼nh luأںâ•‘آ،n\"\r\n    },\r\n  },\r\n\r\n  {\r\n    id: \"subtasksCount\",\r\n    accessorKey: \"subtasks\",\r\n    header: \"Câ”œâ”¤ng viأںâ•—أ§c\",\r\n    cell: ({ row }) => {\r\n      const count = row.subtasks?.length || 0;\r\n      if (count === 0) return <span className=\"text-muted-foreground text-body-xs\">خ“أ‡أ¶</span>;\r\n      return <div className=\"text-center\">{count}</div>;\r\n    },\r\n    meta: {\r\n      displayName: \"Sأںâ•—أ¦ câ”œâ”¤ng viأںâ•—أ§c\",\r\n      group: \"Lأںâ•—أ¯ch sأںâ•—آ، & Bâ”œآ¼nh luأںâ•‘آ،n\"\r\n    },\r\n  },\r\n\r\n  // Notes\r\n  {\r\n    id: \"notes\",\r\n    accessorKey: \"notes\",\r\n    header: \"Ghi châ”œâ•‘\",\r\n    cell: ({ row }) => {\r\n      if (!row.notes?.trim()) return <span className=\"text-muted-foreground text-body-xs\">خ“أ‡أ¶</span>;\r\n      return (\r\n        <div className=\"max-w-[200px] truncate text-body-xs\" title={row.notes}>\r\n          {row.notes}\r\n        </div>\r\n      );\r\n    },\r\n    meta: {\r\n      displayName: \"Ghi châ”œâ•‘\",\r\n      group: \"Thâ”œâ”¤ng tin bأںâ•—أ² sung\"\r\n    },\r\n  },\r\n\r\n  // Timestamps\r\n  {\r\n    id: \"returnedAt\",\r\n    accessorKey: \"returnedAt\",\r\n    header: \"Ngâ”œأ،y trأںâ•‘أ؛ hâ”œأ،ng\",\r\n    cell: ({ row }) => {\r\n      if (!row.returnedAt) return <span className=\"text-muted-foreground text-body-xs\">خ“أ‡أ¶</span>;\r\n      return <div className=\"whitespace-nowrap text-body-xs\">{formatDateTime(row.returnedAt)}</div>;\r\n    },\r\n    meta: {\r\n      displayName: \"Ngâ”œأ،y trأںâ•‘أ؛ hâ”œأ،ng\",\r\n      group: \"Thأںâ•—آ¥i gian\"\r\n    },\r\n  },\r\n\r\n  {\r\n    id: \"completedAt\",\r\n    accessorKey: \"completedAt\",\r\n    header: \"Ngâ”œأ،y kأںâ•‘â”گt thâ”œâ•‘c\",\r\n    cell: ({ row }) => {\r\n      if (!row.completedAt) return <span className=\"text-muted-foreground text-body-xs\">خ“أ‡أ¶</span>;\r\n      return <div className=\"whitespace-nowrap text-body-xs\">{formatDateTime(row.completedAt)}</div>;\r\n    },\r\n    meta: {\r\n      displayName: \"Ngâ”œأ،y kأںâ•‘â”گt thâ”œâ•‘c\",\r\n      group: \"Thأںâ•—آ¥i gian\"\r\n    },\r\n  },\r\n\r\n  // Audit fields\r\n  {\r\n    id: \"createdBy\",\r\n    accessorKey: \"createdBy\",\r\n    header: \"Ngâ•‍â–‘أںâ•—آ¥i tأںâ•‘أ­o\",\r\n    cell: ({ row }) => (\r\n      <div className=\"whitespace-nowrap\">{row.createdBy}</div>\r\n    ),\r\n    met