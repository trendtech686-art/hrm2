error('Khâ”œâ”¤ng thأںâ•—أ¢ thâ”œآ¬m sأںâ•‘أ؛n phأںâ•‘âŒگm. Vui lâ”œâ–“ng thأںâ•—آ، lأںâ•‘أ­i.');\r\n    }\r\n  });\r\n  const [isSubmitting, setIsSubmitting] = React.useState(false);\r\n\r\n  // Form state\r\n  const [formData, setFormData] = React.useState({\r\n    name: \"\",\r\n    sku: \"\",\r\n    costPrice: \"\",\r\n    basePrice: \"\",\r\n    importQuantity: \"\",\r\n    category: \"\",\r\n    unit: \"Câ”œأ­i\",\r\n    productType: \"regular\" as \"regular\" | \"serial-imei\",\r\n  });\r\n\r\n  // Validation errors\r\n  const [errors, setErrors] = React.useState<Record<string, string>>({});\r\n\r\n  // Auto-focus first input when dialog opens\r\n  const nameInputRef = React.useRef<HTMLInputElement>(null);\r\n  React.useEffect(() => {\r\n    if (open) {\r\n      setTimeout(() => nameInputRef.current?.focus(), 100);\r\n    }\r\n  }, [open]);\r\n\r\n  // Reset form when dialog closes\r\n  React.useEffect(() => {\r\n    if (!open) {\r\n      setFormData({\r\n        name: \"\",\r\n        sku: \"\",\r\n        costPrice: \"\",\r\n        basePrice: \"\",\r\n        importQuantity: \"\",\r\n        category: \"\",\r\n        unit: \"Câ”œأ­i\",\r\n        productType: \"regular\",\r\n      });\r\n      setErrors({});\r\n      setIsSubmitting(false);\r\n    }\r\n  }, [open]);\r\n\r\n  const validateForm = (): boolean => {\r\n    const newErrors: Record<string, string> = {};\r\n\r\n    if (!formData.name.trim()) {\r\n      newErrors.name = \"Tâ”œآ¬n sأںâ•‘أ؛n phأںâ•‘âŒگm lâ”œأ، bأںâ•‘آ»t buأںâ•—أ–c\";\r\n    }\r\n\r\n    if (formData.costPrice && isNaN(Number(formData.costPrice))) {\r\n      newErrors.costPrice = \"Giâ”œأ­ nhأںâ•‘آ،p phأںâ•‘أ؛i lâ”œأ، sأںâ•—أ¦\";\r\n    }\r\n\r\n    if (formData.costPrice && Number(formData.costPrice) < 0) {\r\n      newErrors.costPrice = \"Giâ”œأ­ nhأںâ•‘آ،p khâ”œâ”¤ng thأںâ•—أ¢ â”œأ³m\";\r\n    }\r\n\r\n    if (formData.basePrice && isNaN(Number(formData.basePrice))) {\r\n      newErrors.basePrice = \"Giâ”œأ­ bâ”œأ­n lأںâ•‘â•— phأ