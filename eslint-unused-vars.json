   }\r\n\r\n    updateSection.mutate({ type: 'sla', data: sla }, {\r\n      onSuccess: () => toast.success('â”€أ‰â”œأ؛ lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t SLA'),\r\n    });\r\n  };\r\n\r\n  const _handleResetSLA = () => {\r\n    const defaults = clone(defaultSLA);\r\n    setSLA(defaults);\r\n    updateSection.mutate({ type: 'sla', data: defaults }, {\r\n      onSuccess: () => toast.info('â”€أ‰â”œأ؛ khâ”œâ”¤i phأںâ•—أ‘c câ”œأ،i â”€أ¦أںâ•‘â•–t mأںâ•‘â•–c â”€أ¦أںâ•—أ¯nh'),\r\n    });\r\n  };\r\n\r\n  React.useEffect(() => {\r\n    if (activeTab !== 'sla') {\r\n      return;\r\n    }\r\n\r\n    registerSlaActions([\r\n      <SettingsActionButton key=\"save-sla\" onClick={handleSaveSLA}>\r\n        <Save className=\"h-4 w-4\" /> Lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t\r\n      </SettingsActionButton>,\r\n    ]);\r\n  // eslint-disable-next-line react-hooks/exhaustive-deps\r\n  }, [activeTab, registerSlaActions]);\r\n\r\n  // ============================================\r\n  // EVIDENCE HANDLERS\r\n  // ============================================\r\n\r\n  const handleEvidenceChange = (field: keyof EvidenceSettings, value: number | boolean | string[]) => {\r\n    setEvidence(prev => ({\r\n      ...prev,\r\n      [field]: value,\r\n    }));\r\n  };\r\n\r\n  const handleSaveEvidence = () => {\r\n    const errors: string[] = [];\r\n\r\n    if (evidence.maxImages < 1 || evidence.maxImages > 10) {\r\n      errors.push('Sأںâ•—أ¦ lâ•‍â–‘أںâ•—أ؛ng أںâ•‘أ؛nh tأںâ•—أ¦i â”€أ¦a phأںâ•‘أ؛i tأںâ•—آ½ 1-10');\r\n    }\r\n\r\n    if (evidence.minNoteLength < 0 || evidence.minNoteLength > 500) {\r\n      errors.push('â”€أ‰أںâ•—أ– dâ”œأ،i ghi châ”œâ•‘ tأںâ•—أ¦i thiأںâ•—أ¢u phأںâ•‘أ؛i tأںâ•—آ½ 0-500');\r\n    }\r\n\r\n    if (evidence.imageMaxSizeMB < 1 || evidence.imageMaxSizeMB > 50) {\r\n      errors.push('Kâ”œآ،ch thâ•‍â–‘أںâ•—آ¢c file tأںâ•—أ¦i â”€أ¦a phأںâ•‘أ؛i tأںâ•—آ½ 1-50 MB');\r\n    }\r\n\r\n    if (errors.length > 0) {\r\n      toast.error('Lأںâ•—أ¹i xâ”œأ­c thأںâ•—â–’c', { description: errors.join('\\n') });\r\n      return;\r\n    }\r\n\r\n    updateSection.mutate({ type: 'evidence', data: evidence }, {\r\n      onSuccess: () => toast.success('â”€أ‰â”œأ؛ lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t bأںâ•‘â–’ng chأںâ•—âŒگng'),\r\n    });\r\n  };\r\n\r\n  const _handleResetEvidence = () => {\r\n    const defaults = clone(defaultEvidence);\r\n    setEvidence(defaults);\r\n    updateSection.mutate({ type: 'evidence', data: defaults }, {\r\n      onSuccess: () => toast.info('â”€أ‰â”œأ؛ khâ”œâ”¤i phأںâ•—أ‘c câ”œأ،i â”€أ¦أںâ•‘â•–t mأںâ•‘â•–c â”€أ¦أںâ•—أ¯nh'),\r\n    });\r\n  };\r\n\r\n  React.useEffect(() => {\r\n    if (activeTab !== 'evidence') {\r\n      return;\r\n    }\r\n\r\n    registerEvidenceActions([\r\n      <SettingsActionButton key=\"save-evidence\" onClick={handleSaveEvidence}>\r\n        <Save className=\"h-4 w-4\" /> Lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t\r\n      </SettingsActionButton>,\r\n    ]);\r\n  // eslint-disable-next-line react-hooks/exhaustive-deps\r\n  }, [activeTab, registerEvidenceActions]);\r\n\r\n  // ============================================\r\n  // TASK TYPES HANDLERS\r\n  // ============================================\r\n\r\n  const handleAddType = () => {\r\n    const newType: TaskType = {\r\n      id: Date.now().toString(),\r\n      name: '',\r\n      description: '',\r\n      icon: 'â‰،ئ’أ´أ®',\r\n      order: taskTypes.length + 1,\r\n      isActive: true,\r\n    };\r\n    setEditingType(newType);\r\n    setIsAddingType(true);\r\n  };\r\n\r\n  const handleSaveType = () => {\r\n    if (!editingType) return;\r\n\r\n    if (!editingType.name.trim()) {\r\n      toast.error('Tâ”œآ¬n loأںâ•‘أ­i câ”œâ”¤ng viأںâ•—أ§c khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng');\r\n      return;\r\n    }\r\n\r\n    const updatedTypes = isAddingType\r\n      ? [...taskTypes, editingType]\r\n      : taskTypes.map(t => (t.id === editingType.id ? editingType : t));\r\n\r\n    setTaskTypes(updatedTypes);\r\n    updateSection.mutate({ type: 'taskTypes',