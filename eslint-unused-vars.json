 setApiKey, setEnabled, setConnectionStatus } = useTrendtechConfigMutations({ onSuccess: () => {} });\r\n  const { updateSyncSetting } = useTrendtechSyncSettingsMutations({ onSuccess: () => {} });\r\n  const { addLog } = useTrendtechLogMutations();\r\n  const [showApiKey, setShowApiKey] = React.useState(false);\r\n  const [isTesting, setIsTesting] = React.useState(false);\r\n  const [localApiUrl, setLocalApiUrl] = React.useState(settings?.apiUrl ?? '');\r\n  const [localApiKey, setLocalApiKey] = React.useState(settings?.apiKey ?? '');\r\n  \r\n  // Update local state when settings change\r\n  React.useEffect(() => {\r\n    if (settings) {\r\n      setLocalApiUrl(settings.apiUrl);\r\n      setLocalApiKey(settings.apiKey);\r\n    }\r\n  }, [settings]);\r\n  \r\n  const handleSaveConfig = () => {\r\n    setApiUrl.mutate(localApiUrl);\r\n    setApiKey.mutate(localApiKey);\r\n    addLog.mutate({\r\n      action: 'save_config',\r\n      status: 'success',\r\n      message: 'â”€أ‰â”œأ؛ lâ•‍â–‘u cأںâ•‘أ‘u hâ”œآ¼nh API',\r\n      details: { url: localApiUrl },\r\n    });\r\n    toast.success('â”€أ‰â”œأ؛ lâ•‍â–‘u cأںâ•‘أ‘u hâ”œآ¼nh API');\r\n  };\r\n  \r\n  const handleTestConnection = async () => {\r\n    if (!localApiKey) {\r\n      toast.error('Vui lâ”œâ–“ng nhأںâ•‘آ،p API Key trâ•‍â–‘أںâ•—آ¢c khi test');\r\n      return;\r\n    }\r\n    \r\n    if (!localApiUrl) {\r\n      toast.error('Vui lâ”œâ–“ng nhأںâ•‘آ،p API URL trâ•‍â–‘أںâ•—آ¢c khi test');\r\n      return;\r\n    }\r\n    \r\n    setIsTesting(true);\r\n    const startTime = Date.now();\r\n    \r\n    try {\r\n      // Save config first so API service can use it\r\n      setApiUrl.mutate(localApiUrl);\r\n      setApiKey.mutate(localApiKey);\r\n      \r\n      // Step 1: Ping server\r\n      const pingResult = await (ping as any)();\r\n      \r\n      if (!pingResult.success) {\r\n        addLog.mutate({\r\n          action: 'ping',\r\n          status: 'error',\r\n          message: `Server khâ”œâ”¤ng phأںâ•‘أ؛n hأںâ•—أ´i: ${pingResult.error}`,\r\n          details: { url: localApiUrl, error: pingResult.error },\r\n        });\r\n        throw new Error(pingResult.error || 'Server khâ”œâ”¤ng phأںâ•‘أ؛n hأںâ•—أ´i');\r\n      }\r\n      \r\n      addLog.mutate({\r\n        action: 'ping',\r\n        status: 'success',\r\n        message: 'Server hoأںâ•‘أ­t â”€أ¦أںâ•—أ–ng',\r\n        details: { url: localApiUrl, responseTime: Date.now() - startTime },\r\n      });\r\n      \r\n      // Step 2: Test vأںâ•—آ¢i API key\r\n      const testStartTime = Date.now();\r\n      const testResult = await (testConnection as any)();\r\n      \r\n      if (testResult.success && testResult.data) {\r\n        setConnectionStatus.mutate({ status: 'connected' });\r\n        const stats = testResult.data.stats;\r\n        addLog.mutate({\r\n          action: 'test_connection',\r\n          status: 'success',\r\n          message: `Kأںâ•‘â”گt nأںâ•—أ¦i thâ”œأ،nh câ”œâ”¤ng! SP: ${stats?.totalProducts || 0}, DM: ${stats?.totalCategories || 0}, TH: ${stats?.totalBrands || 0}`,\r\n          details: { \r\n            url: localApiUrl, \r\n            responseTime: Date.now() - testStartTime,\r\n            total: stats?.totalProducts || 0,\r\n          },\r\n        });\r\n        toast.success(`Kأںâ•‘â”گt nأںâ•—أ¦i thâ”œأ،nh câ”œâ”¤ng! Sأںâ•‘أ؛n phأںâ•‘âŒگm: ${stats?.totalProducts || 0}, Danh mأںâ•—أ‘c: ${stats?.totalCategories || 0}`);\r\n      } else {\r\n        setConnectionStatus.mutate({ status: 'error', error: testResult.error });\r\n        addLog.mutate({\r\n          action: 'test_connection',\r\n          status: 'error',\r\n          message: `Lأںâ•—أ¹i xâ”œأ­c thأںâ•—â–’c: ${testResult.error}`,\r\n          details: { url: localApiUrl, error: testResult.error },\r\n        });\r\n        toast.error(`Lأںâ•—أ¹i: ${testResult.error}`);\r\n      }\r\n    } catch (error) {\r\n      const errorMessage = error instanceof Error ? error.message : 'Khâ”œâ”¤ng thأںâ•—أ¢ kأںâ•‘â”گt nأںâ•—أ¦i';\r\n      setConnectionStatus.mutate({ status: 'error', error: errorMessage });\r\n      addLog.mutate({\r\n        action: 'test_connection',\r\n        status: 'error',\r\n        message: `Lأںâ•—أ¹i kأںâ•‘â”گt nأںâ•—أ¦i: ${errorMessage}`,\r\n        details: { error: errorMessage, responseTime: Date.now() - startTime },\r\n      });\r\n      toast.error(`Khâ”œâ”¤ng thأںâ•—أ¢ kأںâ•‘â”گt nأںâ•—أ¦i â”€أ¦أںâ•‘â”گn server Trendtech: ${errorMessage}`);\r\n    } finally {\r\n      setIsTesting(false);\r\n    }\r\n  };\r\n  \r\n  const getStatusBadge = () => {\r\n    switch (settings?.connectionStatus) {\r\n      case 'connected':\r\n        return <Badge variant=\"default\" className=\"bg-green-500\"><CheckCircle2 className=\"h-3 w-3 mr-1\" />â”€أ‰â”œأ؛ kأںâ•‘â”گt nأںâ•—أ¦i</Badge>;\r\n      case 'error':\r\n        return <Badge variant=\"destructive\"><XCircle className=\"h-3 w-3 mr-1\" />Lأںâ•—أ¹i kأںâ•‘â”گt nأںâ•—أ¦i</Badge>;\r\n      default:\r\n        return <Badge variant=\"secondary\">Châ•‍â–‘a kأںâ•‘â”گt nأںâ•—أ¦i</Badge>;\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      {/* API Connection Card */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"text-lg\">Thâ”œâ”¤ng tin kأںâ•‘â”گt nأںâ•—أ¦i API</CardTitle>\r\n          <CardDescription>Cأںâ•‘أ‘u hâ”œآ¼nh kأںâ•‘â”گt nأںâ•—أ¦i vأںâ•—آ¢i website Trendtech (Next.js)</CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          <div className=\"space-y-2\">\r\n            <Label htmlFor=\"apiUrl\">API URL</Label>\r\n            <Input\r\n              id=\"apiUrl\"\r\n              value={localApiUrl}\r\n              onChange={(e) => setLocalApiUrl(e.target.value)}\r\n              placeholder=\"https://trendtech.vn/api/hrm\"\r\n            />\r\n            <p className=\"text-sm text-muted-foreground\">\r\n              URL API endpoint cأںâ•—آ؛a Trendtech (VD: https://trendtech.vn/api/hrm)\r\n            </p>\r\n          </div>\r\n          \r\n          <div className=\"space-y-2\">\r\n            <Label htmlFor=\"apiKey\">API Key</Label>\r\n            <div className=\"flex gap-2\">\r\n              <div className=\"relative flex-1\">\r\n                <Input\r\n                  id=\"apiKey\"\r\n                  type={showApiKey ? 'text' : 'password'}\r\n                  value={localApiKey}\r\n                  onChange={(e) => setLocalApiKey(e.target.value)}\r\n                  placeholder=\"Nhأںâ•‘آ،p API Key...\"\r\n                  className=\"pr-10\"\r\n                />\r\n                <Button\r\n                  type=\"button\"\r\n                  variant=\"ghost\"\r\n                  size=\"icon\"\r\n                  className=\"absolute right-0 top-0 h-full\"\r\n                  onClick={() => setShowApiKey(!showApiKey)}\r\n                >\r\n                  {showApiKey ? <EyeOff className=\"h-4 w-4\" /> : <Eye className=\"h-4 w-4\" />}\r\n                </Button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          \r\n          <div className=\"flex items-center gap-2 pt-2\">\r\n            <Button onClick={handleSaveConfig} variant=\"default\">\r\n              <Save className=\"h-4 w-4 mr-2\" />\r\n              Lâ•‍â–‘u cأںâ•‘أ‘u hâ”œآ¼nh\r\n            </Button>\r\n            <Button onClick={handleTestConnection} variant=\"outline\" disabled={isTesting}>\r\n              {isTesting ? (\r\n                <Loader2 className=\"h-4 w-4 mr-2 animate-spin\" />\r\n              ) : (\r\n                <RefreshCw className=\"h-4 w-4 mr-2\" />\r\n              )}\r\n              Test Connection\r\n            </Button>\r\n          </div>\r\n          \r\n          <div className=\"flex items-center gap-2 pt-2\">\r\n            <span className=\"text-sm text-muted-foreground\">Trأںâ•‘أ­ng thâ”œأ­i:</span>\r\n            {getStatusBadge()}\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n\r\n      {/* Integration Status Card */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"text-lg\">Trأںâ•‘أ­ng thâ”œأ­i tâ”œآ،ch hأںâ•—أ؛p</CardTitle>\r\n          <CardDescription>Bأںâ•‘آ،t/tأںâ•‘آ»t â”€أ¦أںâ•—أ´ng bأںâ•—أ– vأںâ•—آ¢i Trendtech</CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          <div className=\"flex items-center justify-between\">\r\n            <div>\r\n              <Label className=\"text-base\">Bأںâ•‘آ،t tâ”œآ،ch hأںâ•—أ؛p Trendtech</Label>\r\n              <p className=\"text-sm text-muted-foreground\">Cho phâ”œâŒگp â”€أ¦أںâ•—أ´ng bأںâ•—أ– sأںâ•‘أ؛n phأںâ•‘âŒگm vأںâ•—آ¢i website</p>\r\n            </div>\r\n            <Switch\r\n              checked={settings?.enabled ?? false}\r\n              onCheckedChange={(checked) => {\r\n                setEnabled.mutate(checked);\r\n                addLog.mutate({\r\n                  action: 'save_config',\r\n                  status: 'info',\r\n                  message: checked ? 'â”€أ‰â”œأ؛ bأںâ•‘آ،t tâ”œآ،ch hأںâ•—أ؛p Trendtech' : 'â”€أ‰â”œأ؛ tأںâ•‘آ»t tâ”œآ،ch hأںâ•—أ؛p Trendtech',\r\n                  details: {},\r\n                });\r\n                toast.success(checked ? 'â”€أ‰â”œأ؛ bأںâ•‘آ،t tâ”œآ،ch hأںâ•—أ؛p Trendtech' : 'â”€أ‰â”œأ؛ tأںâ•‘آ»t tâ”œآ،ch hأںâ•—أ؛p Trendtech');\r\n              }}\r\n            />\r\n          </div>\r\n          \r\n          <div className=\"flex items-center justify-between\">\r\n            <div>\r\n              <Label className=\"text-base\">Bأںâ•‘آ،t Auto Sync</Label>\r\n              <p className=\"text-sm text-muted-foreground\">Tأںâ•—â–’ â”€أ¦أںâ•—أ–ng â”€أ¦أںâ•—أ´ng bأںâ•—أ– dأںâ•—آ» liأںâ•—أ§u theo lأںâ•—أ¯ch</p>\r\n            </div>\r\n            <Switch\r\n              checked={settings?.syncSettings?.autoSyncEnabled ?? false}\r\n              onCheckedChange={(checked) => {\r\n                updateSyncSetting.mutate({ key: 'autoSyncEnabled', value: checked });\r\n                addLog.mutate({\r\n                  action: 'save_config',\r\n                  status: 'info',\r\n                  message: checked ? 'â”€أ‰â”œأ؛ bأںâ•‘آ،t Auto Sync' : 'â”€أ‰â”œأ؛ tأںâ•‘آ»t Auto Sync',\r\n                  details: {},\r\n                });\r\n              }}\r\n              disabled={!settings?.enabled}\r\n            />\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n      \r\n      {/* Info Card */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"text-lg\">Hâ•‍â–‘أںâ•—آ¢ng dأںâ•‘آ½n câ”œأ،i â”€أ¦أںâ•‘â•–t</CardTitle>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-3 text-sm text-muted-foreground\">\r\n          <p>\r\n            <strong>1.</strong> Trendtech cأںâ•‘آ؛n câ”œâ”‚ câ”œأ­c API endpoints tأںâ•‘أ­i <code>/api/hrm/*</code>\r\n          </p>\r\n          <p>\r\n            <strong>2.</strong> API endpoints cأںâ•‘آ؛n thiأںâ•‘â”گt:\r\n          </p>\r\n          <ul className=\"list-disc list-inside ml-4 space-y-1\">\r\n            <li><code>GET /api/hrm/ping</code> - Kiأںâ•—أ¢m tra server</li>\r\n            <li><code>GET /api/hrm/test</code> - Test vأںâ•—آ¢i API Key</li>\r\n            <li><code>GET /api/hrm/products</code> - Lأںâ•‘أ‘y danh sâ”œأ­ch sأںâ•‘أ؛n phأںâ•‘âŒگm</li>\r\n            <li><code>POST /api/hrm/products</code> - Tأںâ•‘أ­o sأںâ•‘أ؛n phأںâ•‘âŒگm</li>\r\n            <li><code>PUT /api/hrm/products/[id]</code> - Cأںâ•‘آ،p nhأںâ•‘آ،t sأںâ•‘أ؛n phأںâ•‘âŒگm</li>\r\n            <li><code>GET /api/hrm/categories</code> - Lأںâ•‘أ‘y danh mأںâ•—أ‘c</li>\r\n            <li><code>GET /api/hrm/brands</code> - Lأںâ•‘أ‘y thâ•‍â–‘â•‍أ­ng hiأںâ•—أ§u</li>\r\n          </ul>\r\n          <p>\r\n            <strong>3.</strong> Authentication: Header <code>Authorization: Bearer YOUR_API_KEY</code>\r\n          </p>\r\n        </CardContent>\r\n      </Card>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\settings\\