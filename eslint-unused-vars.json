LowerCase();\r\n  \r\n  const byId = branches.find(b => b.id.toLowerCase() === normalized);\r\n  if (byId) return byId;\r\n  \r\n  return branches.find(b => b.name.toLowerCase().includes(normalized));\r\n};\r\n\r\nconst getDefaultBranch = (branches: Branch[]) => {\r\n  if (!branches || branches.length === 0) return undefined;\r\n  return branches.find(b => b.isDefault) || branches[0];\r\n};\r\n\r\nconst findPaymentType = (identifier: string, paymentTypes: PaymentType[]) => {\r\n  if (!identifier || !paymentTypes) return undefined;\r\n  const normalized = identifier.trim().toLowerCase();\r\n  \r\n  return paymentTypes.find(t => \r\n    t.id.toLowerCase() === normalized || \r\n    t.name.toLowerCase().includes(normalized)\r\n  );\r\n};\r\n\r\nconst findPaymentMethod = (identifier: string, paymentMethods: PaymentMethod[]) => {\r\n  if (!identifier || !paymentMethods) return undefined;\r\n  const normalized = identifier.trim().toLowerCase();\r\n  \r\n  return paymentMethods.find(m => \r\n    m.id.toLowerCase() === normalized || \r\n    m.name.toLowerCase().includes(normalized)\r\n  );\r\n};\r\n\r\nconst getDefaultPaymentMethod = (paymentMethods: PaymentMethod[]) => {\r\n  if (!paymentMethods || paymentMethods.length === 0) return undefined;\r\n  return paymentMethods.find(m => m.isDefault) || paymentMethods[0];\r\n};\r\n\r\nconst findTargetGroup = (identifier: string, targetGroups: TargetGroup[]) => {\r\n  if (!identifier || !targetGroups) return undefined;\r\n  const normalized = identifier.trim().toLowerCase();\r\n  \r\n  return targetGroups.find(g => \r\n    g.id.toLowerCase() === normalized || \r\n    g.name.toLowerCase().includes(normalized)\r\n  );\r\n};\r\n\r\nconst findRecipient = (recipientType: string, recipientName: string, customers: Customer[], suppliers: Supplier[], employees: Employee[]) => {\r\n  if (!recipientName) return undefined;\r\n  const normalized = recipientName.trim().toLowerCase();\r\n  \r\n  if ((recipientType.includes('Khâ”œأ­ch hâ”œأ،ng') || recipientType === 'KHACHHANG') && customers) {\r\n    return customers.find(c => \r\n      c.id.toLowerCase() === normalized || \r\n      c.name.toLowerCase().includes(normalized)\r\n    );\r\n  }\r\n  \r\n  if ((recipientType.includes('Nhâ”œأ، cung cأںâ•‘أ‘p') || recipientType === 'NHACUNGCAP') && suppliers) {\r\n    return suppliers.find(s => \r\n      s.id.toLowerCase() === normalized || \r\n      s.name.toLowerCase().includes(normalized)\r\n    );\r\n  }\r\n  \r\n  if ((recipientType.includes('Nhâ”œأ³n viâ”œآ¬n') || recipientType === 'NHANVIEN') && employees) {\r\n    return employees.find(e => \r\n      e.id.toLowerCase() === normalized || \r\n      e.fullName?.toLowerCase().includes(normalized)\r\n    );\r\n  }\r\n  \r\n  return undefined;\r\n};\r\n\r\n// ============================================\r\n// FIELD CONFIGURATION\r\n// ============================================\r\n\r\nexport const paymentFields: FieldConfig<Payment>[] = [\r\n  {\r\n    key: 'id',\r\n    label: 'Mâ”œأ؛ phiأںâ•‘â”گu (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'PC001',\r\n    group: 'Thâ”œâ”¤ng tin phiأںâ•‘â”گu',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'date',\r\n    label: 'Ngâ”œأ،y chi (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: '2024-01-15',\r\n    group: 'Thâ”œâ”¤ng tin phiأںâ•‘â”گu',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'amount',\r\n    label: 'Sأںâ•—أ¦ tiأںâ•—أ¼n (*)',\r\n    type: 'number',\r\n    required: true,\r\n    example: '1000000',\r\n    group: 'Thâ”œâ”¤ng tin phiأںâ•‘â”گu',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'description',\r\n    label: 'Diأںâ•—أ n giأںâ•‘أ؛i (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'Chi tiأںâ•—أ¼n mua hâ”œأ،ng',\r\n    group: 'Thâ”œâ”¤ng tin phiأںâ•‘â”گu',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'recipientTypeName' as keyof Payment,\r\n    label: 'Loأںâ•‘أ­i â”€أ¦أںâ•—أ¦i tâ•‍â–‘أںâ•—أ؛ng (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'Nhâ”œأ، cung cأںâ•‘أ‘p',\r\n    group: 'â”€أ‰أںâ•—أ¦i tâ•‍â–‘أںâ•—أ؛ng',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'recipientName',\r\n    label: 'Ngâ•‍â–‘أںâ•—آ¥i nhأںâ•‘آ،n (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'Câ”œâ”¤ng ty ABC',\r\n    group: 'â”€أ‰أںâ•—أ¦i tâ•‍â–‘أںâ•—أ؛ng',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'paymentReceiptTypeName',\r\n    label: 'Loأںâ•‘أ­i phiأںâ•‘â”گu chi (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'Thanh toâ”œأ­n nhâ”œأ، cung cأںâ•‘أ‘p',\r\n    group: 'Phâ”œأ³n loأںâ•‘أ­i',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'paymentMethodName',\r\n    label: 'Phâ•‍â–‘â•‍أ­ng thأںâ•—âŒگc TT',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Chuyأںâ•—أ¢n khoأںâ•‘أ؛n',\r\n    group: 'Phâ”œأ³n loأںâ•‘أ­i',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'branchName',\r\n    label: 'Chi nhâ”œأ­nh',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Chi nhâ”œأ­nh châ”œآ،nh',\r\n    group: 'Phâ”œأ³n loأںâ•‘أ­i',\r\n  },\r\n  {\r\n    key: 'status',\r\n    label: 'Trأںâ•‘أ­ng thâ”œأ­i',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'completed',\r\n    group: 'Phâ”œأ³n loأںâ•‘أ­i',\r\n  },\r\n];\r\n\r\n// ============================================\r\n// MAIN CONFIG\r\n// ============================================\r\n\r\nexport const paymentImportExportConfig: ImportExportConfig<Payment> = {\r\n  entityType: 'payments',\r\n  entityDisplayName: 'Phiأںâ•‘â”گu chi',\r\n  \r\n  fields: paymentFields,\r\n  \r\n  templateFileName: 'Mau_Phieu_Chi.xlsx',\r\n  sheetName: 'PhieuChi',\r\n  \r\n  // Import settings\r\n  upsertKey: 'id',\r\n  allowUpdate: false,\r\n  allowInsert: true,\r\n  \r\n  requirePreview: true,\r\n  maxRows: 2000,\r\n  maxErrorsAllowed: 0,\r\n  \r\n  // Validate each row\r\n  validateRow: (row, _index, existingData, mode) => {\r\n    const errors: Array<{ field?: string; message: string }> = [];\r\n    const payment = row as Partial<Payment>;\r\n    \r\n    if (!payment.id?.toString().trim()) {\r\n      errors.push({ field: 'id', message: 'Mâ”œأ؛ phiأںâ•‘â”گu khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    if (!payment.date) {\r\n      errors.push({ field: 'date', message: 'Ngâ”œأ،y chi khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    if (!payment.amount || payment.amount <= 0) {\r\n      errors.push({ field: 'amount', message: 'Sأںâ•—أ¦ tiأںâ•—أ¼n phأںâ•‘أ؛i lأںâ•—آ¢n hâ•‍أ­n 0' });\r\n    }\r\n    \r\n    if (!payment.description?.trim()) {\r\n      errors.push({ field: 'description', message: 'Diأںâ•—أ n giأںâ•‘أ؛i khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    if (!payment.recipientTypeName) {\r\n      errors.push({ field: 'recipientTypeName', message: 'Loأںâ•‘أ­i â”€أ¦أںâ•—أ¦i tâ•‍â–‘أںâ•—أ؛ng khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    if (!payment.recipientName?.trim()) {\r\n      errors.push({ field: 'recipientName', message: 'Ngâ•‍â–‘أںâ•—آ¥i nhأںâ•‘آ،n khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    if (!payment.paymentReceiptTypeName) {\r\n      errors.push({ field: 'paymentReceiptTypeName', message: 'Loأںâ•‘أ­i phiأںâ•‘â”گu chi khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    // Check duplicate\r\n    if (mode === 'insert-only' && payment.id) {\r\n      const duplicate = existingData.find(p => \r\n        p.id.toString().toUpperCase() === payment.id!.toString().toUpperCase()\r\n      );\r\n      if (duplicate) {\r\n        errors.push({ field: 'id', message: `Mâ”œأ؛ phiأںâ•‘â”گu \"${payment.id}\" â”€أ¦â”œأ؛ tأںâ•—أ´n tأںâ•‘أ­i` });\r\n      }\r\n    }\r\n    \r\n    return errors;\r\n  },\r\n  \r\n  // Transform row to Payment object\r\n  postTransformRow: (row) => {\r\n    const now = new Date().toISOString();\r\n    const defaultBranch = (getDefaultBranch as any)();\r\n    const defaultPaymentMethod = (getDefaultPaymentMethod as any)();\r\n    \r\n    // Lookup entities\r\n    const branch = (findBranch as any)(row.branchName as string) || defaultBranch;\r\n    const paymentType = (findPaymentType as any)(row.paymentReceiptTypeName as string);\r\n    const paymentMethod = (findPaymentMethod as any)(row.paymentMethodName as string) || defaultPaymentMethod;\r\n    const targetGroup = (findTargetGroup as any)(row.recipientTypeName as string);\r\n    const recipient = (findRecipient as any)(row.recipientTypeName as string || '', row.recipientName as string || '');\r\n    \r\n    return {\r\n      systemId: asSystemId(''), // Will be generated\r\n      id: asBusinessId(String(row.id || '').trim()),\r\n      date: String(row.date || now.split('T')[0]),\r\n      amount: Number(row.amount) || 0,\r\n      \r\n      recipientTypeSystemId: targetGroup?.systemId || asSystemId('KHAC'),\r\n      recipientTypeName: targetGroup?.name || String(row.recipientTypeName || 'Khâ”œأ­c'),\r\n      recipientName: String(row.recipientName || '').trim(),\r\n      recipientSystemId: recipient?.systemId,\r\n      \r\n      description: String(row.description || '').trim(),\r\n      \r\n      paymentMethodSystemId: paymentMethod?.systemId || asSystemId(''),\r\n      paymentMethodName: paymentMethod?.name || String(row.paymentMethodName || 'Tiأںâ•—أ¼n mأںâ•‘â•–t'),\r\n      \r\n      accountSystemId: asSystemId(''), // Cash account to be set later\r\n      paymentReceiptTypeSystemId: paymentType?.systemId || asSystemId(''),\r\n      paymentReceiptTypeName: paymentType?.name || String(row.paymentReceiptTypeName || ''),\r\n      \r\n      branchSystemId: branch?.systemId || asSystemId(''),\r\n      branchName: branch?.name || '',\r\n      \r\n      createdBy: asSystemId(''),\r\n      createdAt: now,\r\n      \r\n      status: (row.status as PaymentStatus) || 'completed',\r\n      category: (row.category as PaymentCategory) || 'other',\r\n    } as Payment;\r\n  },\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\lib\\import-export\\configs\\product.config.ts","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":15,"column":49,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":15,"endColumn":52,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[723,726],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[723,726],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":23,"column":46,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":23,"endColumn":49,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1062,1065],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1062,1065],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'getProductTypeSystemIdByName' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":29,"column":7,"nodeType":null,"messageId":"unusedVar","endLine":29,"endColumn":35},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'getProductTypeNameById' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":44,"column":7,"nodeType":null,"messageId":"unusedVar","endLine":44,"endColumn":29},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'getProductTypeSystemIdByEnumType' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":60,"column":7,"nodeType":null,"messageId":"unusedVar","endLine":60,"endColumn":39}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":5,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import type { Product, ProductType as ProductTypeEnum } from '@/lib/types/prisma-extended';\r\nimport type { ImportExportConfig, FieldConfig } from '@/lib/import-export/types';\r\nimport { asSystemId } from '@/lib/id-types';\r\n// NOTE: Prisma import commented to prevent client-side bundling\r\n// These helpers return empty arrays and will be replaced with API calls\r\n// import { prisma } from '@/lib/prisma';\r\n\r\n/**\r\n * Product Import/Export Configuration\r\n * Theo chuأںâ•‘âŒگn ImportExportConfig â”€أ¦أںâ•—أ¢ dâ”œâ•£ng vأںâ•—آ¢i GenericImportDialogV2 vâ”œأ، GenericExportDialogV2\r\n */\r\n\r\n// Helper: Get all pricing policies\r\n// NOTE: Returns empty array - should be called server-side with actual Prisma query\r\nconst getAllPricingPolicies = async (): Promise<any[]> => {\r\n  // return await prisma.pricingPolicy.findMany({ where: { isDeleted: false } });\r\n  return [];\r\n};\r\n\r\n// ===== PRODUCT TYPE HELPERS =====\r\n// Helper: Get all active product types from settings\r\n// NOTE: Returns empty array - should be called server-side with actual Prisma query\r\nconst getAllProductTypes = async (): Promise<any[]> => {\r\n  // return await prisma.productType.findMany({ where: { isDeleted: false, isActive: true } });\r\n  return [];\r\n};\r\n\r\n// Helper: Get ProductType systemId from name (tâ”œآ¬n loأںâ•‘أ­i sأںâ•‘أ؛n phأںâ•‘âŒگm)\r\nconst getProductTypeSystemIdByName = async (name: string): Promise<string | null> => {\r\n  if (!name) return null;\r\n  const productTypes = await getAllProductTypes();\r\n  const normalizedName = name.toLowerCase().trim();\r\n  \r\n  // Tâ”œآ¼m theo tâ”œآ¬n châ”œآ،nh xâ”œأ­c (case-insensitive)\r\n  const productType = productTypes.find(pt => \r\n    pt.name.toLowerCase() === normalizedName ||\r\n    pt.id.toLowerCase() === normalizedName\r\n  );\r\n  \r\n  return productType?.systemId || null;\r\n};\r\n\r\n// Helper: Get ProductType name from systemId\r\nconst getProductTypeNameById = async (systemId: string): Promise<string> => {\r\n  if (!systemId) return '';\r\n  const productTypes = await getAllProductTypes();\r\n  const productType = productTypes.find(pt => pt.systemId === systemId);\r\n  return productType?.name || '';\r\n};\r\n\r\n// Helper: Get default ProductType systemId\r\nconst getDefaultProductTypeSystemId = async (): Promise<string | null> => {\r\n  const productTypes = await getAllProductTypes();\r\n  const defaultType = productTypes.find(pt => pt.isDefault);\r\n  return defaultType?.systemId || productTypes[0]?.systemId || null;\r\n};\r\n\r\n// Helper: Map enum type ('physical', 'service', 'digital') to ProductType systemId\r\n// Fallback khi user import bأںâ•‘â–’ng type câ”¼âŒگ\r\nconst getProductTypeSystemIdByEnumType = async (enumType: ProductTypeEnum | string): Promise<string | null> => {\r\n  if (!enumType) return await getDefaultProductTypeSystemId();\r\n  \r\n  const productTypes = await getAllProductTypes();\r\n  const normalizedType = String(enumType).toLowerCase().trim();\r\n  \r\n  // Map tأںâ•—آ½ enum type sang tâ”œآ¬n tiأںâ•‘â”گng Viأںâ•—أ§t â”€أ¦أںâ•—أ¢ tâ”œآ¼m ProductType\r\n  const typeNameMapping: Record<string, string[]> = {\r\n    'physical': ['hâ”œأ،ng hâ”œâ”‚a', 'hang hoa', 'physical', 'hâ”œأ،ng hoâ”œأ­'],\r\n    'service': ['dأںâ•—أ¯ch vأںâ•—أ‘', 'dich vu', 'service'],\r\n    'digital': ['digital', 'sأںâ•‘أ؛n phأںâ•‘âŒگm sأںâ•—أ¦', 'san pham so', 'kأںâ•—â•£ thuأںâ•‘آ،t sأںâ•—أ¦', 'ky thuat so'],\r\n    'combo': ['combo', 'bأںâ•—أ– sأںâ•‘أ؛n phأںâ•‘âŒگm', 'bo san pham'],\r\n  };\r\n  \r\n  for (const [_enumKey, names] of Object.entries(typeNameMapping)) {\r\n    if (names.includes(normalizedType)) {\r\n      // Tâ”œآ¼m ProductType câ”œâ”‚ tâ”œآ¬n match vأںâ•—آ¢i mأںâ•—أ–t trong câ”œأ­c aliases\r\n      const productType = productTypes.find(pt => \r\n        names.some(name => pt.name.toLowerCase().includes(name) || name.includes(pt.name.toLowerCase()))\r\n      );\r\n      if (productType) return productType.systemId;\r\n    }\r\n  }\r\n  \r\n  // Fallback: tâ”œآ¼m trأںâ•—â–’c tiأںâ•‘â”گp theo tâ”œآ¬n\r\n  const productType = productTypes.find(pt => \r\n    pt.name.toLowerCase().includes(normalizedType) ||\r\n    normalizedType.includes(pt.name.toLowerCase())\r\n  );\r\n  \r\n  return productType?.systemId || await getDefaultProductTypeSystemId();\r\n};\r\n\r\n// ===== PRICING POLICY HELPERS =====\r\n// Helper: Get pricing policy systemId from code (id) OR name\r\n// Hأںâ•—أ¹ trأںâ•—أ؛ nhiأںâ•—أ¼u format cأںâ•—أ–t giâ”œأ­ trong Excel:\r\n// - \"Giâ”œأ­: Giâ”œأ­ bâ”œأ­n lأںâ•‘â•—\" hoأںâ•‘â•–c \"Giâ”œأ­: BANLE\" (câ”œâ”‚ prefix \"Giâ”œأ­:\")\r\n// - \"Giâ”œأ­ bâ”œأ­n lأںâ•‘â•—\" hoأںâ•‘â•–c \"BANLE\" (khâ”œâ”¤ng câ”œâ”‚ prefix)\r\nconst getPricingPolicySystemId = async (columnName: string): Promise<string | null> => {\r\n  const policies = await getAllPricingPolicies();\r\n  \r\n  // Normalize: bأںâ•—أ… prefix \"Giâ”œأ­:\" hoأںâ•‘â•–c \"Gia:\" nأںâ•‘â”گu câ”œâ”‚\r\n  let normalizedName = columnName.trim();\r\n  const pricePrefix = /^(giâ”œأ­|gia)\\s*:\\s*/i;\r\n  if (pricePrefix.test(normalizedName)) {\r\n    normalizedName = normalizedName.replace(pricePrefix, '').trim();\r\n  }\r\n  \r\n  const upperName = normalizedName.toUpperCase();\r\n  \r\n  // Tâ”œآ¼m theo id (mâ”œأ؛ bأںâ•‘أ؛ng giâ”œأ­) trâ•‍â–‘أںâ•—آ¢c\r\n  const policyById = policies.find(p => p.id.toUpperCase() === upperName);\r\n  if (policyById) return policyById.systemId;\r\n  \r\n  // Tâ”œآ¼m theo name (tâ”œآ¬n bأںâ•‘أ؛ng giâ”œأ­)\r\n  const policyByName = policies.find(p => p.name.toUpperCase() === upperName);\r\n  if (policyByName) return policyByName.systemId;\r\n  \r\n  // Tâ”œآ¼m theo name chأںâ•—âŒگa (partial match)\r\n  const policyByPartialName = policies.find(p => \r\n    p.name.toUpperCase().includes(upperName) || \r\n    upperName.includes(p.name.toUpperCase())\r\n  );\r\n  if (policyByPartialName) return policyByPartialName.systemId;\r\n  \r\n  return null;\r\n};\r\n\r\n// Helper: Get pricing policy code (id) from systemId  \r\nconst _getPricingPolicyCode = async (systemId: string): Promise<string> => {\r\n  const policies = await getAllPricingPolicies();\r\n  const policy = policies.find(p => p.systemId === systemId);\r\n  return policy?.id || systemId;\r\n};\r\n\r\n// Helper: Get pricing policy name from systemId  \r\nconst _getPricingPolicyName = async (systemId: string): Promise<string> => {\r\n  const policies = await getAllPricingPolicies();\r\n  const policy = policies.find(p => p.systemId === systemId);\r\n  return policy?.name || systemId;\r\n};\r\n\r\n// Helper: Check if a column name matches a pricing policy (by id or name)\r\nconst _isPricingPolicyColumn = async (columnName: string): Promise<boolean> => {\r\n  return await getPricingPolicySystemId(columnName) !== null;\r\n};\r\n\r\n// ===== FIELD DEFINITIONS =====\r\nexport const productFields: FieldConfig<Product>[] = [\r\n  // ===== THâ”œأ¶NG TIN Câ•‍أ، Bأںâ•‘أ³N =====\r\n  {\r\n    key: 'id',\r\n    label: 'Mâ”œأ؛ sأںâ•‘أ؛n phأںâ•‘âŒگm',\r\n    required: false, // Tأںâ•—â–’ generate nأںâ•‘â”گu â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng\r\n    type: 'string',\r\n    exportGroup: 'Thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n',\r\n    example: 'SP000001',\r\n  },\r\n  {\r\n    key: 'name',\r\n    label: 'Tâ”œآ¬n sأںâ•‘أ؛n phأںâ•‘âŒگm (*)',\r\n    required: true,\r\n    type: 'string',\r\n    exportGroup: 'Thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n',\r\n    example: 'â”œأ¼o sâ•‍أ­ mi nam',\r\n  },\r\n  {\r\n    key: 'sku',\r\n    label: 'SKU',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n',\r\n    example: 'ASM-001',\r\n  },\r\n  {\r\n    key: 'barcode',\r\n    label: 'Mâ”œأ؛ vأںâ•‘أ­ch',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n',\r\n    example: '8934567890123',\r\n  },\r\n  {\r\n    key: 'type',\r\n    label: 'Loأںâ•‘أ­i SP (Hأںâ•—أ§ thأںâ•—أ¦ng)',\r\n    required: false,\r\n    type: 'enum',\r\n    enumValues: ['physical', 'service', 'digital'], // Khâ”œâ”¤ng cho phâ”œâŒگp import combo\r\n    enumLabels: {\r\n      'physical': 'Hâ”œأ،ng hâ”œâ”‚a',\r\n      'service': 'Dأںâ•—أ¯ch vأںâ•—أ‘',\r\n      'digital': 'Sأںâ•‘أ؛n phأںâ•‘âŒگm sأںâ•—أ¦',\r\n    },\r\n    exportGroup: 'Thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n',\r\n    example: 'Hâ”œأ،ng hâ”œâ”‚a',\r\n    defaultValue: 'physical',\r\n    hidden: true, // أںâ•‘آ؟n field câ”¼âŒگ, khuyأںâ•‘â”گn khâ”œآ،ch dâ”œâ•£ng \"Loأںâ•‘أ­i sأںâ•‘أ؛n phأںâ•‘âŒگm\" mأںâ•—آ¢i (productTypeSystemId)\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return 'physical';\r\n      const str = String(value).toLowerCase().trim();\r\n      // Map tiأںâ•‘â”گng Viأںâ•—أ§t sang English\r\n      if (str === 'hâ”œأ،ng hâ”œâ”‚a' || str === 'hang hoa' || str === 'physical' || str === 'hâ”œأ،ng hoâ”œأ­') return 'physical';\r\n      if (str === 'dأںâ•—أ¯ch vأںâ•—أ‘' || str === 'dich vu' || str === 'service') return 'service';\r\n      if (str === 'sأںâ•‘أ؛n phأںâ•‘âŒگm sأںâ•—أ¦' || str === 'san pham so' || str === 'kأںâ•—â•£ thuأںâ•‘آ،t sأںâ•—أ¦' || str === 'digital' || str === 'ky thuat so') return 'digital';\r\n      if (str === 'combo' || str === 'bأںâ•—أ– sأںâ•‘أ؛n phأںâ•‘âŒگm' || str === 'bo san pham') return 'combo';\r\n      return 'physical';\r\n    },\r\n    validator: (value: unknown) => {\r\n      if (value === 'combo') {\r\n        return 'Khâ”œâ”¤ng hأںâ•—أ¹ trأںâ•—أ؛ import sأںâ•‘أ؛n phأںâ•‘âŒگm Combo. Vui lâ”œâ–“ng tأںâ•‘أ­o Combo trأںâ•—â–’c tiأںâ•‘â”گp trong hأںâ•—أ§ thأںâ•—أ¦ng.';\r\n      }\r\n      return null;\r\n    },\r\n  },\r\n  // NEW: Loأںâ•‘أ­i sأںâ•‘أ؛n phأںâ•‘âŒگm tأںâ•—آ½ Settings (ProductType) - Khuyأںâ•‘â”گn khâ”œآ،ch dâ”œâ•£ng thay cho field \"type\" câ”¼âŒگ\r\n  {\r\n    key: 'productTypeSystemId',\r\n    label: 'Loأںâ•‘أ­i sأںâ•‘أ؛n phأںâ•‘âŒگm',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n',\r\n    example: 'Hâ”œأ،ng hâ”œâ”‚a', // User nhأںâ•‘آ،p tâ”œآ¬n loأںâ•‘أ­i SP, hأںâ•—أ§ thأںâ•—أ¦ng tأںâ•—â–’ map sang systemId\r\n    // TODO: Transforms need async support or preloaded data cache\r\n    // The async helpers getProductTypeSystemIdByName, getProductTypeNameById are available\r\n    // but cannot be called from sync transform functions. Need framework support or\r\n    // handle in beforeImport/afterExport hooks.\r\n    // importTransform: async (value: unknown) => {\r\n    //   if (!value) return undefined;\r\n    //   const str = String(value).trim();\r\n    //   if (!str) return undefined;\r\n    //   \r\n    //   const systemId = await getProductTypeSystemIdByName(str);\r\n    //   if (systemId) return systemId;\r\n    //   \r\n    //   const enumSystemId = await getProductTypeSystemIdByEnumType(str);\r\n    //   return enumSystemId || undefined;\r\n    // },\r\n    // exportTransform: async (value: unknown) => {\r\n    //   return await getProductTypeNameById(value as string);\r\n    // },\r\n    // validator: async (value: unknown) => {\r\n    //   if (!value) return null;\r\n    //   const str = String(value).trim();\r\n    //   if (!str) return null;\r\n    //   \r\n    //   const systemId = await getProductTypeSystemIdByName(str);\r\n    //   if (!systemId) {\r\n    //     const enumSystemId = await getProductTypeSystemIdByEnumType(str);\r\n    //     if (!enumSystemId) {\r\n    //       return `Loأںâ•‘أ­i sأںâ•‘أ؛n phأںâ•‘âŒگm \"${str}\" khâ”œâ”¤ng tأںâ•—أ´n tأںâ•‘أ­i trong hأںâ•—أ§ thأںâ•—أ¦ng. Vui lâ”œâ–“ng kiأںâ•—أ¢m tra danh sâ”œأ­ch loأںâ•‘أ­i SP trong Câ”œأ،i â”€أ¦أںâ•‘â•–t > Kho hâ”œأ،ng.`;\r\n    //     }\r\n    //   }\r\n    //   return null;\r\n    // },\r\n  },\r\n  {\r\n    key: 'status',\r\n    label: 'Trأںâ•‘أ­ng thâ”œأ­i',\r\n    required: false,\r\n    type: 'enum',\r\n    enumValues: ['active', 'inactive', 'discontinued'],\r\n    enumLabels: {\r\n      'active': 'â”€أ‰ang kinh doanh',\r\n      'inactive': 'Ngأںâ•—آ½ng kinh doanh',\r\n      'discontinued': 'Ngأںâ•—آ½ng nhأںâ•‘آ،p',\r\n    },\r\n    exportGroup: 'Thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n',\r\n    example: 'â”€أ‰ang kinh doanh',\r\n    defaultValue: 'active',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return 'active';\r\n      const str = String(value).toLowerCase().trim();\r\n      // Map tiأںâ•‘â”گng Viأںâ•—أ§t sang English\r\n      if (str === 'â”€أ¦ang kinh doanh' || str === 'dang kinh doanh' || str === 'active') return 'active';\r\n      if (str === 'ngأںâ•—آ½ng kinh doanh' || str === 'ngung kinh doanh' || str === 'inactive') return 'inactive';\r\n      if (str === 'ngأںâ•—آ½ng nhأںâ•‘آ،p' || str === 'ngung nhap' || str === 'discontinued') return 'discontinued';\r\n      return 'active';\r\n    },\r\n  },\r\n  {\r\n    key: 'unit',\r\n    label: 'â”€أ‰â•‍أ­n vأںâ•—أ¯ tâ”œآ،nh',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n',\r\n    example: 'Câ”œأ­i',\r\n    defaultValue: 'Câ”œأ­i',\r\n  },\r\n  {\r\n    key: 'categories',\r\n    label: 'Danh mأںâ•—أ‘c',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n',\r\n    example: 'Thأںâ•—آ¥i trang > â”œأ¼o nam; Sale > Hot deal', // Nhiأںâ•—أ¼u danh mأںâ•—أ‘c phâ”œأ³n câ”œأ­ch bأںâ•‘â–’ng ;\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const str = String(value).trim();\r\n      if (!str) return undefined;\r\n      // Split by semicolon to get multiple categories, each category can have multi-level with >\r\n      return str.split(';').map(s => s.trim()).filter(Boolean);\r\n    },\r\n    exportTransform: (value: unknown) => {\r\n      const categories = value as string[] | undefined;\r\n      return categories?.join('; ') || '';\r\n    },\r\n  },\r\n  // Legacy single category field (backward compatibility)\r\n  {\r\n    key: 'category',\r\n    label: 'Danh mأںâ•—أ‘c (câ”¼âŒگ)',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n',\r\n    hidden: true, // أںâ•‘آ؟n trong import, chأںâ•—أ« dâ”œâ•£ng cho backward compatibility\r\n    example: 'Thأںâ•—آ¥i trang > â”œأ¼o nam > â”œأ¼o sâ•‍أ­ mi',\r\n  },\r\n  {\r\n    key: 'description',\r\n    label: 'Mâ”œâ”¤ tأںâ•‘أ؛',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n',\r\n    example: 'â”œأ¼o sâ•‍أ­ mi nam cao cأںâ•‘أ‘p',\r\n  },\r\n  {\r\n    key: 'shortDescription',\r\n    label: 'Mâ”œâ”¤ tأںâ•‘أ؛ ngأںâ•‘آ»n',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n',\r\n    example: 'â”œأ¼o sâ•‍أ­ mi nam',\r\n  },\r\n\r\n  // ===== Hâ”œأ®NH أںâ•‘أ³NH =====\r\n  // NOTE: Hâ”œآ¼nh أںâ•‘أ؛nh â”€أ¦â•‍â–‘أںâ•—أ؛c upload lâ”œآ¬n server trâ•‍â–‘أںâ•—آ¢c, sau â”€أ¦â”œâ”‚ import â”€أ¦â•‍â–‘أںâ•—آ¥ng dأںâ•‘آ½n\r\n  // Format: /products/{ma_sp}/{ten_file}.jpg hoأںâ•‘â•–c URL â”€أ¦أںâ•‘آ؛y â”€أ¦أںâ•—آ؛\r\n  {\r\n    key: 'thumbnailImage',\r\n    label: 'أںâ•‘أ³nh â”€أ¦أںâ•‘أ­i diأںâ•—أ§n',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Hâ”œآ¼nh أںâ•‘أ؛nh',\r\n    example: '/products/SP001/main.jpg',\r\n    validator: (value: unknown) => {\r\n      if (!value) return null; // Optional\r\n      const str = String(value).trim();\r\n      // Cho phâ”œâŒگp: /path/to/file.ext hoأںâ•‘â•–c http(s)://...\r\n      if (!str.startsWith('/') && !str.startsWith('http')) {\r\n        return 'â”€أ‰â•‍â–‘أںâ•—آ¥ng dأںâ•‘آ½n أںâ•‘أ؛nh phأںâ•‘أ؛i bأںâ•‘آ»t â”€أ¦أںâ•‘آ؛u bأںâ•‘â–’ng / hoأںâ•‘â•–c http(s)://';\r\n      }\r\n      // Check extension\r\n      const validExts = ['.jpg', '.jpeg', '.png', '.gif', '.webp', '.svg'];\r\n      const hasValidExt = validExts.some(ext => str.toLowerCase().endsWith(ext));\r\n      if (!hasValidExt && !str.includes('?')) { // Ignore if has query params\r\n        return 'â”€أ‰أںâ•—أ¯nh dأںâ•‘أ­ng أںâ•‘أ؛nh khâ”œâ”¤ng hأںâ•—أ؛p lأںâ•—أ§ (jpg, png, gif, webp, svg)';\r\n      }\r\n      return null;\r\n    },\r\n  },\r\n  {\r\n    key: 'galleryImages',\r\n    label: 'أںâ•‘أ³nh bأںâ•—أ– sâ•‍â–‘u tأںâ•‘آ،p',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Hâ”œآ¼nh أںâ•‘أ؛nh',\r\n    example: '/products/SP001/1.jpg, /products/SP001/2.jpg',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const str = String(value).trim();\r\n      if (!str) return undefined;\r\n      return str.split(/[,;|]/).map(s => s.trim()).filter(Boolean);\r\n    },\r\n    exportTransform: (value: unknown) => {\r\n      const images = value as string[] | undefined;\r\n      return images?.join(', ') || '';\r\n    },\r\n    validator: (value: unknown) => {\r\n      if (!value) return null;\r\n      const str = String(value).trim();\r\n      if (!str) return null;\r\n      const paths = str.split(/[,;|]/).map(s => s.trim()).filter(Boolean);\r\n      const validExts = ['.jpg', '.jpeg', '.png', '.gif', '.webp', '.svg'];\r\n      for (const path of paths) {\r\n        if (!path.startsWith('/') && !path.startsWith('http')) {\r\n          return `â”€أ‰â•‍â–‘أںâ•—آ¥ng dأںâ•‘آ½n \"${path}\" phأںâ•‘أ؛i bأںâ•‘آ»t â”€أ¦أںâ•‘آ؛u bأںâ•‘â–’ng / hoأںâ•‘â•–c http(s)://`;\r\n        }\r\n        const hasValidExt = validExts.some(ext => path.toLowerCase().endsWith(ext));\r\n        if (!hasValidExt && !path.includes('?')) {\r\n          return `â”€أ‰â•‍â–‘أںâ•—آ¥ng dأںâ•‘آ½n \"${path}\" câ”œâ”‚ â”€أ¦أںâ•—أ¯nh dأںâ•‘أ­ng أںâ•‘أ؛nh khâ”œâ”¤ng hأںâ•—أ؛p lأںâ•—أ§`;\r\n        }\r\n      }\r\n      return null;\r\n    },\r\n  },\r\n\r\n  // ===== VIDEO LINKS =====\r\n  {\r\n    key: 'videoLinks',\r\n    label: 'Video link',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Media',\r\n    example: 'https://youtube.com/watch?v=xxx; https://drive.google.com/file/xxx',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const str = String(value).trim();\r\n      if (!str) return undefined;\r\n      return str.split(/[,;|]/).map(s => s.trim()).filter(Boolean);\r\n    },\r\n    exportTransform: (value: unknown) => {\r\n      const links = value as string[] | undefined;\r\n      return links?.join('; ') || '';\r\n    },\r\n    validator: (value: unknown) => {\r\n      if (!value) return null;\r\n      const str = String(value).trim();\r\n      if (!str) return null;\r\n      const links = str.split(/[,;|]/).map(s => s.trim()).filter(Boolean);\r\n      for (const link of links) {\r\n        if (!link.startsWith('http')) {\r\n          return `Link \"${link}\" phأںâ•‘أ؛i bأںâ•‘آ»t â”€أ¦أںâ•‘آ؛u bأںâ•‘â–’ng http:// hoأںâ•‘â•–c https://`;\r\n        }\r\n        // Kiأںâ•—أ¢m tra domain hأںâ•—أ؛p lأںâ•—أ§ (YouTube, TikTok, Drive, Vimeo, etc.)\r\n        const validDomains = ['youtube.com', 'youtu.be', 'tiktok.com', 'drive.google.com', 'vimeo.com', 'facebook.com', 'fb.watch'];\r\n        const isValidDomain = validDomains.some(domain => link.includes(domain));\r\n        if (!isValidDomain) {\r\n          // Cho phâ”œâŒگp câ”œأ­c domain khâ”œأ­c nhâ•‍â–‘ng cأںâ•‘أ؛nh bâ”œأ­o\r\n        }\r\n      }\r\n      return null;\r\n    },\r\n  },\r\n\r\n  // ===== GIâ”œأ¼ =====\r\n  {\r\n    key: 'costPrice',\r\n    label: 'Giâ”œأ­ vأںâ•—أ¦n',\r\n    required: false,\r\n    type: 'number',\r\n    exportGroup: 'Giâ”œأ­',\r\n    example: '150000',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return 0;\r\n      const num = Number(String(value).replace(/[,.\\s]/g, ''));\r\n      return isNaN(num) ? 0 : num;\r\n    },\r\n  },\r\n  {\r\n    key: 'sellingPrice',\r\n    label: 'Giâ”œأ­ bâ”œأ­n',\r\n    required: false,\r\n    type: 'number',\r\n