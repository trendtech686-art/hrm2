أںâ•—أ¹ trأںâ•—أ؛ tأںâ•—أ¦t nhأںâ•‘أ‘t.\\n\\nTrâ”œأ³n trأںâ•—أ¬ng,',\r\n    category: 'processing-error',\r\n    order: 5,\r\n  },\r\n];\r\n\r\nconst WARRANTY_SLA_PRIORITY_CONFIGS: Array<{\r\n  key: keyof SLASettings;\r\n  label: string;\r\n  description: string;\r\n  indicatorClass: string;\r\n}> = [\r\n  {\r\n    key: 'low',\r\n    label: 'â•‍آ»u tiâ”œآ¬n thأںâ•‘أ‘p',\r\n    description: 'Câ”œأ­c yâ”œآ¬u cأںâ•‘آ؛u bأںâ•‘أ؛o hâ”œأ،nh câ•‍أ­ bأںâ•‘أ؛n, khâ”œâ”¤ng أںâ•‘أ؛nh hâ•‍â–‘أںâ•—ئ’ng â”€أ¦أںâ•‘â”گn trأںâ•‘أ؛i nghiأںâ•—أ§m khâ”œأ­ch hâ”œأ،ng.',\r\n    indicatorClass: 'bg-green-500',\r\n  },\r\n  {\r\n    key: 'medium',\r\n    label: 'â•‍آ»u tiâ”œآ¬n trung bâ”œآ¼nh',\r\n    description: 'Cأںâ•‘آ؛n xأںâ•—آ، lâ”œâ•œ trong vâ”œâ–“ng 2-3 ngâ”œأ،y lâ”œأ،m viأںâ•—أ§c.',\r\n    indicatorClass: 'bg-yellow-500',\r\n  },\r\n  {\r\n    key: 'high',\r\n    label: 'â•‍آ»u tiâ”œآ¬n cao',\r\n    description: 'Sأںâ•‘أ؛n phأںâ•‘âŒگm lأںâ•—أ¹i gâ”œأ³y giâ”œأ­n â”€أ¦oأںâ•‘أ­n sأںâ•—آ، dأںâ•—أ‘ng, cأںâ•‘آ؛n phأںâ•‘أ؛n hأںâ•—أ´i trong ngâ”œأ،y.',\r\n    indicatorClass: 'bg-orange-500',\r\n  },\r\n  {\r\n    key: 'urgent',\r\n    label: 'â•‍آ»u tiâ”œآ¬n khأںâ•‘âŒگn cأںâ•‘أ‘p',\r\n    description: 'Sأںâ•—â–’ cأںâ•—أ¦ nghiâ”œآ¬m trأںâ•—أ¬ng, yâ”œآ¬u cأںâ•‘آ؛u phأںâ•‘أ؛n hأںâ•—أ´i trong vâ”œâ–“ng 1 giأںâ•—آ¥.',\r\n    indicatorClass: 'bg-red-500',\r\n  },\r\n];\r\n\r\n// ============================================\r\n// SETTINGS STORE\r\n// ============================================\r\n\r\ntype WarrantySettingsState = {\r\n  sla: SLASettings;\r\n  templates: ResponseTemplate[];\r\n  notifications: NotificationSettings;\r\n  publicTracking: PublicTrackingSettings;\r\n  cardColors: CardColorSettings;\r\n};\r\n\r\nconst clone = <T,>(value: T): T => {\r\n  if (typeof structuredClone === 'function') {\r\n    return structuredClone(value);\r\n  }\r\n  return JSON.parse(JSON.stringify(value));\r\n};\r\n\r\nimport { useWarrantySettings, useWarrantySettingsMutations, loadCardColorSettings } from './hooks/use-warranty-settings';\r\n\r\nexport { loadCardColorSettings };\r\n\r\n// ============================================\r\n// MAIN COMPONENT\r\n// ============================================\r\n\r\nexport function WarrantySettingsPage() {\r\n  const [activeTab, setActiveTab] = React.useState('sla');\r\n  const { headerActions, registerActions } = useTabActionRegistry(activeTab);\r\n\r\n  // Fetch settings from React Query\r\n  const { data: settings, isLoading: isLoadingSettings } = useWarrantySettings();\r\n  const { updateSection } = useWarrantySettingsMutations();\r\n\r\n  const registerSlaActions = React.useMemo(() => registerActions('sla'), [registerActions]);\r\n  const registerTemplateActions = React.useMemo(() => registerActions('templates'), [registerActions]);\r\n  const registerNotificationActions = React.useMemo(() => registerActions('notifications'), [registerActions]);\r\n  const registerPublicTrackingActions = React.useMemo(() => registerActions('public-tracking'), [registerActions]);\r\n  const registerCardColorActions = React.useMemo(() => registerActions('card-colors'), [registerActions]);\r\n\r\n  // Get stored values from React Query\r\n  const storedSla = settings.sla;\r\n  const storedTemplates = settings.templates as ResponseTemplate[];\r\n  const storedNotifications = settings.notifications;\r\n  const storedPublicTracking = settings.publicTracking;\r\n  const storedCardColors = settings.cardColors;\r\n\r\n  // SLA State - cast to proper type\r\n  const [sla, setSLA] = React.useState<SLASettings>(storedSla as any);\r\n\r\n  // Templates State\r\n  const [templates, setTemplates] = React.useState<ResponseTemplate[]>(storedTemplates);\r\n  const [editingTemplate, setEditingTemplate] = React.useState<ResponseTemplate | null>(null);\r\n  const [isAddingTemplate, setIsAddingTemplate] = React.useState(false);\r\n  const [showDeleteDialog, setShowDeleteDialog] = React.useState(false);\r\n  const [templateToDelete, setTemplateToDelete] = React.useState<string | null>(null);\r\n  const [showEditDialog, setShowEditDialog] = React.useState(false);\r\n\r\n  // Notifications State\r\n  const [notifications, setNotifications] = React.useState<NotificationSettings>(storedNotifications as any);\r\n\r\n  // Public Tracking State\r\n  const [publicTracking, setPublicTracking] = React.useState<PublicTrackingSettings>(storedPublicTracking);\r\n\r\n  // Card Colors State\r\n  const [cardColors, setCardColors] = React.useState<CardColorSettings>(storedCardColors as any);\r\n\r\n  React.useEffect(() => {\r\n    setSLA(storedSla as any);\r\n  }, [storedSla]);\r\n\r\n  React.useEffect(() => {\r\n    setTemplates(storedTemplates);\r\n  }, [storedTemplates]);\r\n\r\n  React.useEffect(() => {\r\n    setNotifications(storedNotifications as any);\r\n  }, [storedNotifications]);\r\n\r\n  React.useEffect(() => {\r\n    setPublicTracking(storedPublicTracking);\r\n  }, [storedPublicTracking]);\r\n\r\n  React.useEffect(() => {\r\n    setCardColors(storedCardColors as any);\r\n  }, [storedCardColors]);\r\n\r\n  useSettingsPageHeader({\r\n    title: 'Câ”œأ،i â”€أ¦أںâ•‘â•–t bأںâ•‘أ؛o hâ”œأ،nh',\r\n    actions: headerActions,\r\n  });\r\n\r\n  // ============================================\r\n  // SLA HANDLERS\r\n  // ============================================\r\n\r\n  const handleSLAChange = (priority: keyof SLASettings, field: 'responseTime' | 'resolveTime', value: string) => {\r\n    const numValue = parseInt(value) || 0;\r\n    setSLA(prev => ({\r\n      ...prev,\r\n      [priority]: {\r\n        ...prev[priority],\r\n        [field]: numValue,\r\n      }\r\n    }));\r\n  };\r\n\r\n  const handleSaveSLA = () => {\r\n    // Validation\r\n    const priorities: Array<keyof SLASettings> = ['low', 'medium', 'high', 'urgent'];\r\n    for (const priority of priorities) {\r\n      if (sla[priority].responseTime <= 0) {\r\n        toast.error('Lأںâ•—أ¹i validation', {\r\n          description: `Thأںâ•—آ¥i gian phأںâ•‘أ؛n hأںâ•—أ´i cho mأںâ•—âŒگc ${priority} phأںâ•‘أ؛i lأںâ•—آ¢n hâ•‍أ­n 0`,\r\n        });\r\n        return;\r\n      }\r\n      if (sla[priority].resolveTime <= 0) {\r\n        toast.error('Lأںâ•—أ¹i validation', {\r\n          description: `Thأںâ•—آ¥i gian xأںâ•—آ، lâ”œâ•œ cho mأںâ•—âŒگc ${priority} phأںâ•‘أ؛i lأںâ•—آ¢n hâ•‍أ­n 0`,\r\n        });\r\n        return;\r\n      }\r\n    }\r\n\r\n    updateSection.mutate(\r\n      { type: 'sla-targets', data: sla as any },\r\n      {\r\n        onSuccess: () => {\r\n          toast.success('â”€أ‰â”œأ؛ lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t SLA', {\r\n            description: 'Thأںâ•—آ¥i gian phأںâ•‘أ؛n hأںâ•—أ´i vâ”œأ، giأںâ•‘أ؛i quyأںâ•‘â”گt â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c cأںâ•‘آ،p nhأںâ•‘آ،t.',\r\n          });\r\n        },\r\n      }\r\n    );\r\n  };\r\n\r\n  const _handleResetSLA = () => {\r\n    const defaults = clone(defaultSLA);\r\n    setSLA(defaults);\r\n    updateSection.mutate(\r\n      { type: 'sla-targets', data: defaults as any },\r\n      {\r\n        onSuccess: () => {\r\n          toast.info('â”€أ‰â”œأ؛ â”€أ¦أںâ•‘â•–t lأںâ•‘أ­i mأںâ•‘â•–c â”€أ¦أںâ•—أ¯nh', {\r\n            description: 'Câ”œأ،i â”€أ¦أںâ•‘â•–t SLA â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c khâ”œâ”¤i phأںâ•—أ‘c vأںâ•—أ¼ giâ”œأ­ trأںâ•—أ¯ mأںâ•‘â•–c â”€أ¦أںâ•—أ¯nh.',\r\n          });\r\n        },\r\n      }\r\n    );\r\n  };\r\n\r\n  // ============================================\r\n  // TEMPLATE HANDLERS\r\n  // ============================================\r\n\r\n  const handleAddTemplate = () => {\r\n    setEditingTemplate({\r\n      id: Date.now().toString(),\r\n      name: '',\r\n      content: '',\r\n      category: 'general',\r\n      order: templates.length + 1,\r\n    });\r\n    setIsAddingTemplate(true);\r\n    setShowEditDialog(true);\r\n  };\r\n\r\n  const handleSaveTemplate = () => {\r\n    if (!editingTemplate) return;\r\n\r\n    // Validation\r\n    if (!editingTemplate.name.trim()) {\r\n      toast.error('Lأںâ•—أ¹i validation', {\r\n        description: 'Vui lâ”œâ–“ng nhأںâ•‘آ،p tâ”œآ¬n mأںâ•‘آ½u.',\r\n      });\r\n      return;\r\n    }\r\n\r\n    if (!editingTemplate.content.trim()) {\r\n      toast.error('Lأںâ•—أ¹i validation', {\r\n        description: 'Vui lâ”œâ–“ng nhأںâ•‘آ،p nأںâ•—أ–i dung mأںâ•‘آ½u.',\r\n      });\r\n      return;\r\n    }\r\n\r\n    let updatedTemplates: ResponseTemplate[];\r\n    \r\n    if (isAddingTemplate) {\r\n      updatedTemplates = [...templates, editingTemplate];\r\n    } else {\r\n      updatedTemplates = templates.map(t => \r\n        t.id === editingTemplate.id ? editingTemplate : t\r\n      );\r\n    }\r\n\r\n    setTemplates(updatedTemplates);\r\n    updateSection.mutate(\r\n      { type: 'reminder-templates', data: updatedTemplates },\r\n      {\r\n        onSuccess: () => {\r\n          toast.success(isAddingTemplate ? 'â”€أ‰â”œأ؛ thâ”œآ¬m mأںâ•‘آ½u' : 'â”€أ‰â”œأ؛ cأںâ•‘آ،p nhأںâ•‘آ،t mأںâ•‘آ½u', {\r\n            description: `Mأںâ•‘آ½u \"${editingTemplate.name}\" â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c lâ•‍â–‘u.`,\r\n          });\r\n        },\r\n      }\r\n    );\r\n\r\n    setEditingTemplate(null);\r\n    setIsAddingTemplate(false);\r\n    setShowEditDialog(false);\r\n  };\r\n\r\n  const handleDeleteTemplate = (id: string) => {\r\n    setTemplateToDelete(id);\r\n    setShowDeleteDialog(true);\r\n  };\r\n\r\n  const confirmDeleteTemplate = () => {\r\n    if (!templateToDelete) return;\r\n    \r\n    const template = templates.find(t => t.id === templateToDelete);\r\n    const updatedTemplates = templates.filter(t => t.id !== templateToDelete);\r\n    setTemplates(updatedTemplates);\r\n    updateSection.mutate(\r\n      { type: 'reminder-templates', data: updatedTemplates },\r\n      {\r\n        onSuccess: () => {\r\n          toast.success('â”€أ‰â”œأ؛ xâ”œâ”‚a mأںâ•‘آ½u', {\r\n            description: `Mأںâ•‘آ½u \"${template?.name}\" â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c xâ”œâ”‚a.`,\r\n          });\r\n        },\r\n      }\r\n    );\r\n    \r\n    setShowDeleteDialog(false);\r\n    setTemplateToDelete(null);\r\n  };\r\n\r\n  const handleCancelEdit = () => {\r\n    setEditingTemplate(null);\r\n    setIsAddingTemplate(false);\r\n    setShowEditDialog(false);\r\n  };\r\n\r\n  // ============================================\r\n  // NOTIFICATION HANDLERS\r\n  // ============================================\r\n\r\n  const handleNotificationChange = (key: keyof NotificationSettings) => {\r\n    setNotifications(prev => ({\r\n      ...prev,\r\n      [key]: !prev[key],\r\n    }));\r\n  };\r\n\r\n  const handleSaveNotifications = () => {\r\n    updateSection.mutate(\r\n      { type: 'notifications', data: notifications as any },\r\n      {\r\n        onSuccess: () => {\r\n          toast.success('â”€أ‰â”œأ؛ lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t thâ”œâ”¤ng bâ”œأ­o', {\r\n            description: 'Câ”œأ­c tâ”œâ•£y chأںâ•—أ¬n thâ”œâ”¤ng bâ”œأ­o â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c cأںâ•‘آ،p nhأںâ•‘آ،t.',\r\n          });\r\n        },\r\n      }\r\n    );\r\n  };\r\n\r\n  // ============================================\r\n  // PUBLIC TRACKING HANDLERS\r\n  // ============================================\r\n\r\n  const handlePublicTrackingChange = (key: keyof PublicTrackingSettings) => {\r\n    setPublicTracking(prev => ({\r\n      ...prev,\r\n      [key]: !prev[key],\r\n    }));\r\n  };\r\n\r\n  const handleSavePublicTracking = () => {\r\n    updateSection.mutate(\r\n      { type: 'tracking', data: publicTracking },\r\n      {\r\n        onSuccess: () => {\r\n          // Show different message based on enabled state\r\n          if (publicTracking.enabled) {\r\n            toast.success('â”€أ‰â”œأ؛ bأںâ•‘آ،t tracking câ”œâ”¤ng khai', {\r\n              description: 'Khâ”œأ­ch hâ”œأ،ng giأںâ•—آ¥ câ”œâ”‚ thأںâ•—أ¢ theo dâ”œâ•،i tiأںâ•‘â”گn â”€أ¦أںâ•—أ– bأںâ•‘أ؛o hâ”œأ،nh qua link câ”œâ”¤ng khai.',\r\n            });\r\n          } else {\r\n            toast.success('â”€أ‰â”œأ؛ tأںâ•‘آ»t tracking câ”œâ”¤ng khai', {\r\n              description: 'Tâ”œآ،nh nâ”€أ¢ng tracking câ”œâ”¤ng khai â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c vâ”œâ”¤ hiأںâ•—أ§u hâ”œâ”‚a.',\r\n            });\r\n          }\r\n        },\r\n      }\r\n    );\r\n  };\r\n\r\n  // ============================================\r\n  // CARD COLOR HANDLERS\r\n  // ============================================\r\n\r\n  const handleCardColorChange = (category: 'statusColors' | 'overdueColor', key: string, value: string) => {\r\n    if (category === 'overdueColor') {\r\n      setCardColors(prev => ({ ...prev, overdueColor: value }));\r\n    } else {\r\n      setCardColors(prev => ({\r\n        ...prev,\r\n        statusColors: { ...prev.statusColors, [key]: value }\r\n      }));\r\n    }\r\n  };\r\n\r\n  const handleCardColorToggle = (key: 'enableStatusColors' | 'enableOverdueColor') => {\r\n    setCardColors(prev => ({ ...prev, [key]: !prev[key] }));\r\n  };\r\n\r\n  const handleSaveCardColors = () => {\r\n    updateSection.mutate(\r\n      { type: 'cardColors', data: cardColors },\r\n      {\r\n        onSuccess: () => {\r\n          toast.success('â”€أ‰â”œأ؛ lâ•‍â–‘u mâ”œأ،u card', {\r\n            description: 'Câ”œأ،i â”€أ¦أںâ•‘â•–t mâ”œأ،u sأںâ•‘آ»c card bأںâ•‘أ؛o hâ”œأ،nh â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c cأںâ•‘آ،p nhأںâ•‘آ،t. Refresh trang â”€أ¦أںâ•—أ¢ xem thay â”€أ¦أںâ•—أ²i.',\r\n          });\r\n        },\r\n      }\r\n    );\r\n  };\r\n\r\n  const _handleResetCardColors = () => {\r\n    const defaults = clone(defaultCardColors);\r\n    setCardColors(defaults);\r\n    updateSection.mutate(\r\n      { type: 'cardColors', data: defaults },\r\n      {\r\n        onSuccess: () => {\r\n          toast.info('â”€أ‰â”œأ؛ â”€أ¦أںâ•‘â•–t lأںâ•‘أ­i mأںâ•‘â•–c â”€أ¦أںâ•—أ¯nh', {\r\n            description: 'Mâ”œأ،u card â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c khâ”œâ”¤i phأںâ•—أ‘c vأںâ•—أ¼ giâ”œأ­ trأںâ•—أ¯ mأںâ•‘â•–c â”€أ¦أںâ•—أ¯nh.',\r\n          });\r\n        },\r\n      }\r\n    );\r\n  };\r\n\r\n  // ============================================\r\n  // RENDER\r\n  // ============================================\r\n\r\n    React.useEffect(() => {\r\n      if (activeTab !== 'sla') {\r\n        return;\r\n      }\r\n\r\n      registerSlaActions([\r\n        <SettingsActionButton key=\"save\" onClick={handleSaveSLA}>\r\n          <Save className=\"h-4 w-4\" /> Lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t\r\n        </SettingsActionButton>,\r\n      ]);\r\n    // eslint-disable-next-line react-hooks/exhaustive-deps\r\n    }, [activeTab, registerSlaActions]);\r\n\r\n    React.useEffect(() => {\r\n      if (activeTab !== 'templates') {\r\n        return;\r\n      }\r\n\r\n      registerTemplateActions([\r\n        <SettingsActionButton key=\"add\" onClick={handleAddTemplate}>\r\n          <Plus className=\"h-4 w-4\" /> Thâ”œآ¬m mأںâ•‘آ½u\r\n        </SettingsActionButton>,\r\n      ]);\r\n    // eslint-disable-next-line react-hooks/exhaustive-deps\r\n    }, [activeTab, registerTemplateActions]);\r\n\r\n    React.useEffect(() => {\r\n      if (activeTab !== 'notifications') {\r\n        return;\r\n      }\r\n\r\n      registerNotificationActions([\r\n        <SettingsActionButton key=\"save\" onClick={handleSaveNotifications}>\r\n          <Save className=\"h-4 w-4\" /> Lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t\r\n        </SettingsActionButton>,\r\n      ]);\r\n    // eslint-disable-next-line react-hooks/exhaustive-deps\r\n    }, [activeTab, registerNotificationActions]);\r\n\r\n    React.useEffect(() => {\r\n      if (activeTab !== 'public-tracking') {\r\n        return;\r\n      }\r\n\r\n      registerPublicTrackingActions([\r\n        <SettingsActionButton key=\"save\" onClick={handleSavePublicTracking}>\r\n          <Save className=\"h-4 w-4\" /> Lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t\r\n        </SettingsActionButton>,\r\n      ]);\r\n    // eslint-disable-next-line react-hooks/exhaustive-deps\r\n    }, [activeTab, registerPublicTrackingActions]);\r\n\r\n    React.useEffect(() => {\r\n      if (activeTab !== 'card-colors') {\r\n        return;\r\n      }\r\n\r\n      registerCardColorActions([\r\n        <SettingsActionButton key=\"save\" onClick={handleSaveCardColors}>\r\n          <Save className=\"h-4 w-4\" /> Lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t\r\n        </SettingsActionButton>,\r\n      ]);\r\n    // eslint-disable-next-line react-hooks/exhaustive-deps\r\n    }, [activeTab, registerCardColorActions]);\r\n\r\n  const tabs = React.useMemo(\r\n    () => [\r\n      { value: 'sla', label: 'SLA' },\r\n      { value: 'templates', label: 'Mأںâ•‘آ½u biأںâ•—أ¢u' },\r\n      { value: 'notifications', label: 'Thâ”œâ”¤ng bâ”œأ­o' },\r\n      { value: 'public-tracking', label: 'Tracking' },\r\n      { value: 'card-colors', label: 'Mâ”œأ،u card' },\r\n    ],\r\n    [],\r\n  );\r\n\r\n  return (\r\n      <div className=\"space-y-6\">\r\n        <SettingsVerticalTabs value={activeTab} onValueChange={setActiveTab} tabs={tabs}>\r\n\r\n        {/* ============================================ */}\r\n        {/* TAB 1: SLA SETTINGS */}\r\n        {/* ============================================ */}\r\n        <TabsContent value=\"sla\" className=\"mt-0 space-y-4\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle>Câ”œأ،i â”€أ¦أںâ•‘â•–t SLA (Service Level Agreement)</CardTitle>\r\n              <CardDescription>\r\n                Thiأںâ•‘â”گt lأںâ•‘آ،p thأںâ•—آ¥i gian phأںâ•‘أ؛n hأںâ•—أ´i vâ”œأ، xأںâ•—آ، lâ”œâ•œ bأںâ•‘أ؛o hâ”œأ،nh theo mأںâ•—âŒگc â”€أ¦أںâ•—أ– â•‍â–‘u tiâ”œآ¬n\r\n              </CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-6\">\r\n              {WARRANTY_SLA_PRIORITY_CONFIGS.map(({ key, label, description, indicatorClass }) => (\r\n                <SettingsFormSection\r\n                  key={key}\r\n                  title={label}\r\n                  description={description}\r\n                  badge={(\r\n                    <span className=\"inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium\">\r\n                      <span className={cn('h-2 w-2 rounded-full', indicatorClass)} />\r\n                      SLA\r\n                    </span>\r\n                  )}\r\n                >\r\n                  <SettingsFormGrid>\r\n                    <div className=\"space-y-2\">\r\n                      <Label htmlFor={`${key}-response`}>Thأںâ•—آ¥i gian phأںâ•‘أ؛n hأںâ•—أ´i tأںâ•—أ¦i â”€أ¦a (phâ”œâ•‘t)</Label>\r\n                      <Input\r\n                        id={`${key}-response`}\r\n                        type=\"number\"\r\n                        min=\"0\"\r\n                        value={sla[key].responseTime}\r\n                        onChange={(e) => handleSLAChange(key, 'responseTime', e.target.value)}\r\n                      />\r\n                    </div>\r\n                    <div className=\"space-y-2\">\r\n                      <Label htmlFor={`${key}-resolve`}>Thأںâ•—آ¥i gian xأںâ•—آ، lâ”œâ•œ tأںâ•—أ¦i â”€أ¦a (giأںâ•—آ¥)</Label>\r\n                      <Input\r\n                        id={`${key}-resolve`}\r\n                        type=\"number\"\r\n                        min=\"0\"\r\n                        value={sla[key].resolveTime}\r\n                        onChange={(e) => handleSLAChange(key, 'resolveTime', e.target.value)}\r\n                      />\r\n                    </div>\r\n                  </SettingsFormGrid>\r\n                </SettingsFormSection>\r\n              ))}\r\n            </CardContent>\r\n          </Card>\r\n\r\n          {/* Simple Warranty SLA Targets Card */}\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle>Mأںâ•—أ‘c tiâ”œآ¬u SLA â”€أ¦â•‍أ­n giأںâ•‘أ؛n</CardTitle>\r\n              <CardDescription>\r\n                Cأںâ•‘أ‘u hâ”œآ¼nh thأںâ•—آ¥i gian xأںâ•—آ، lâ”œâ•œ chuأںâ•‘âŒگn cho toâ”œأ،n bأںâ•—أ– phiأںâ•‘â”گu bأںâ•‘أ؛o hâ”œأ،nh\r\n              </CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-4\">\r\n              <div className=\"grid gap-4 md:grid-cols-3\">\r\n                <div className=\"space-y-2\">\r\n                  <Label htmlFor=\"sla-response\">\r\n                    Phأںâ•‘أ؛n hأںâ•—أ´i (phâ”œâ•‘t)\r\n                    <span className=\"text-xs text-muted-foreground block\">\r\n                      Nhأںâ•‘آ،n خ“أ¥أ† Bأںâ•‘آ»t â”€أ¦أںâ•‘آ؛u xأںâ•—آ، lâ”œâ•œ\r\n                    </span>\r\n                  </Label>\r\n                  <Input\r\n                    id=\"sla-response\"\r\n                    type=\"number\"\r\n                    defaultValue=\"120\"\r\n                    placeholder=\"120\"\r\n                  />\r\n                </div>\r\n                <div className=\"space-y-2\">\r\n                  <Label htmlFor=\"sla-processing\">\r\n                    Xأںâ•—آ، lâ”œâ•œ (phâ”œâ•‘t)\r\n                    <span className=\"text-xs text-muted-foreground block\">\r\n                      Hoâ”œأ،n tأںâ•‘أ‘t xأںâ•—آ، lâ”œâ•œ SP\r\n                    </span>\r\n                  </Label>\r\n                  <Input\r\n                    id=\"sla-processing\"\r\n                    type=\"number\"\r\n                    defaultValue=\"1440\"\r\n                    placeholder=\"1440\"\r\n                  />\r\n                </div>\r\n                <div className=\"space-y-2\">\r\n                  <Label htmlFor=\"sla-return\">\r\n                    Trأںâ•‘أ؛ hâ”œأ،ng (phâ”œâ•‘t)\r\n                    <span className=\"text-xs text-muted-foreground block\">\r\n                      Hoâ”œأ،n thâ”œأ،nh خ“أ¥أ† Trأںâ•‘أ؛ khâ”œأ­ch\r\n                    </span>\r\n                  </Label>\r\n                  <Input\r\n                    id=\"sla-return\"\r\n                    type=\"number\"\r\n                    defaultValue=\"2880\"\r\n                    placeholder=\"2880\"\r\n                  />\r\n                </div>\r\n              </div>\r\n              <Button variant=\"outline\" className=\"w-full\">\r\n                <Save className=\"h-4 w-4 mr-2\" />\r\n                Lâ•‍â–‘u SLA â”€أ¦â•‍أ­n giأںâ•‘أ؛n\r\n              </Button>\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n\r\n        {/* ============================================ */}\r\n        {/* TAB 2: RESPONSE TEMPLATES */}\r\n        {/* ============================================ */}\r\n        <TabsContent value=\"templates\" className=\"mt-0 space-y-4\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle>Mأںâ•‘آ½u phأںâ•‘أ؛n hأںâ•—أ´i</CardTitle>\r\n              <CardDescription>\r\n                Tأںâ•‘أ­o vâ”œأ، quأںâ•‘أ؛n lâ”œâ•œ câ”œأ­c mأںâ•‘آ½u phأںâ•‘أ؛n hأںâ•—أ´i nhanh cho bأںâ•‘أ؛o hâ”œأ،nh\r\n              </CardDescription>\r\n            </CardHeader>\r\n            <CardContent>\r\n              {templates.length === 0 ? (\r\n                <div className=\"text-center py-8 text-muted-foreground\">\r\n                  Châ•‍â–‘a câ”œâ”‚ mأںâ•‘آ½u phأںâ•‘أ؛n hأںâ•—أ´i nâ”œأ،o. Nhأںâ•‘أ‘n \"Thâ”œآ¬m mأںâ•‘آ½u\" â”€أ¦أںâ•—أ¢ tأںâ•‘أ­o mأںâ•‘آ½u mأںâ•—آ¢i.\r\n                </div>\r\n              ) : (\r\n                <Table>\r\n                  <TableHeader>\r\n                    <TableRow>\r\n                      <TableHead>Tâ”œآ¬n mأںâ•‘آ½u</TableHead>\r\n                      <TableHead>Danh mأںâ•—أ‘c</TableHead>\r\n                      <TableHead className=\"text-right\">Thao tâ”œأ­c</TableHead>\r\n                    </TableRow>\r\n                  </TableHeader>\r\n                  <TableBody>\r\n                    {templates.map(template => (\r\n                      <TableRow key={template.id}>\r\n                        <TableCell className=\"font-medium\">{template.name}</TableCell>\r\n                        <TableCell>\r\n                          <span className=\"text-xs px-2 py-1 rounded-md bg-muted\">\r\n                            {template.category === 'general' && 'Chung'}\r\n                            {template.category === 'processing-error' && 'Lأںâ•—أ¹i xأںâ•—آ، lâ”œâ•œ'}\r\n                            {template.category === 'customer-damage' && 'Lأںâ•—أ¹i khâ”œأ­ch hâ”œأ،ng'}\r\n                            {template.category === 'inspection-result' && 'Kأںâ•‘â”گt quأںâ•‘أ؛ kiأںâ•—أ¢m tra'}\r\n                            {template.category === 'warranty-approved' && 'Chأںâ•‘أ‘p nhأںâ•‘آ،n BH'}\r\n                            {template.category === 'warranty-rejected' && 'Tأںâ•—آ½ chأںâ•—أ¦i BH'}\r\n                          </span>\r\n                        </TableCell>\r\n                        <TableCell className=\"text-right\">\r\n                          <DropdownMenu>\r\n                            <DropdownMenuTrigger asChild>\r\n                              <Button variant=\"ghost\" size=\"icon\" className=\"h-8 w-8\">\r\n                                <MoreHorizontal className=\"h-4 w-4\" />\r\n                              </Button>\r\n                            </DropdownMenuTrigger>\r\n                            <DropdownMenuContent align=\"end\">\r\n                              <DropdownMenuItem onClick={() => {\r\n                                setEditingTemplate(template);\r\n                                setIsAddingTemplate(false);\r\n                                setShowEditDialog(true);\r\n                              }}>\r\n                                Sأںâ•—آ،a\r\n                              </DropdownMenuItem>\r\n                              <DropdownMenuSeparator />\r\n                              <DropdownMenuItem \r\n                                onClick={() => handleDeleteTemplate(template.id)}\r\n                                className=\"text-destructive focus:text-destructive\"\r\n                              >\r\n                                Xâ”œâ”‚a\r\n                              </DropdownMenuItem>\r\n                            </DropdownMenuContent>\r\n                          </DropdownMenu>\r\n                        </TableCell>\r\n                      </TableRow>\r\n                    ))}\r\n                  </TableBody>\r\n                </Table>\r\n              )}\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n\r\n        {/* ============================================ */}\r\n        {/* TAB 3: NOTIFICATIONS */}\r\n        {/* ============================================ */}\r\n        <TabsContent value=\"notifications\" className=\"mt-0 space-y-4\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle>Câ”œأ،i â”€أ¦أںâ•‘â•–t thâ”œâ”¤ng bâ”œأ­o</CardTitle>\r\n              <CardDescription>\r\n                Quأںâ•‘أ؛n lâ”œâ•œ thâ”œâ”¤ng bâ”œأ­o qua email, SMS vâ”œأ، in-app cho câ”œأ­c sأںâ•—â–’ kiأںâ•—أ§n bأںâ•‘أ؛o hâ”œأ،nh\r\n              </CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-6\">\r\n              <SettingsFormSection\r\n                title=\"Thâ”œâ”¤ng bâ”œأ­o Email\"\r\n                description=\"Gأںâ•—آ،i cأںâ•‘آ،p nhأںâ•‘آ،t â”€أ¦أںâ•‘â”گn khâ”œأ­ch hâ”œأ،ng vâ”œأ، â”€أ¦أںâ•—أ–i bأںâ•‘أ؛o hâ”œأ،nh cho tأںâ•—آ½ng giai â”€أ¦oأںâ•‘أ­n.\"\r\n                badge={<Bell className=\"h-4 w-4 text-muted-foreground\" />}\r\n                contentClassName=\"space-y-3\"\r\n              >\r\n                <div className=\"space-y-3\">\r\n                  <div className=\"flex items-center justify-between\">\r\n                    <Label htmlFor=\"email-create\" className=\"cursor-pointer\">\r\n                      Khi bأںâ•‘أ؛o hâ”œأ،nh mأںâ•—آ¢i â”€أ¦â•‍â–‘أںâ•—أ؛c tأںâ•‘أ­o\r\n                    </Label>\r\n                    <Switch\r\n                      id=\"email-create\"\r\n                      checked={notifications.emailOnCreate}\r\n                      onCheckedChange={() => handleNotificationChange('emailOnCreate')}\r\n                    />\r\n                  </div>\r\n\r\n                  <div className=\"flex items-center justify-between\">\r\n                    <Label htmlFor=\"email-assign\" className=\"cursor-pointer\">\r\n                      Khi â”€أ¦â•‍â–‘أںâ•—أ؛c phâ”œأ³n câ”œâ”¤ng xأںâ•—آ، lâ”œâ•œ\r\n                    </Label>\r\n                    <Switch\r\n                      id=\"email-assign\"\r\n                      checked={notifications.emailOnAssign}\r\n                      onCheckedChange={() => handleNotificationChange('emailOnAssign')}\r\n                    />\r\n                  </div>\r\n\r\n                  <div className=\"flex items-center justify-between\">\r\n                    <Label htmlFor=\"email-inspected\" className=\"cursor-pointer\">\r\n                      Khi hoâ”œأ،n thâ”œأ،nh kiأںâ•—أ¢m tra\r\n                    </Label>\r\n                    <Switch\r\n                      id=\"email-inspected\"\r\n                      checked={notifications.emailOnInspected}\r\n                      onCheckedChange={() => handleNotificationChange('emailOnInspected')}\r\n                    />\r\n                  </div>\r\n\r\n                  <div className=\"flex items-center justify-between\">\r\n                    <Label htmlFor=\"email-approved\" className=\"cursor-pointer\">\r\n                      Khi chأںâ•‘أ‘p nhأںâ•‘آ،n bأںâ•‘أ؛o hâ”œأ،nh\r\n                    </Label>\r\n                    <Switch\r\n                      id=\"email-approved\"\r\n                      checked={notifications.emailOnApproved}\r\n                      onCheckedChange={() => handleNotificationChange('emailOnApproved')}\r\n                    />\r\n                  </div>\r\n\r\n                  <div className=\"flex items-center justify-between\">\r\n                    <Label htmlFor=\"email-rejected\" className=\"cursor-pointer\">\r\n                      Khi tأںâ•—آ½ chأںâ•—أ¦i bأںâ•‘أ؛o hâ”œأ،nh\r\n                    </Label>\r\n                    <Switch\r\n                      id=\"email-rejected\"\r\n                      checked={notifications.emailOnRejected}\r\n                      onCheckedChange={() => handleNotificationChange('emailOnRejected')}\r\n                    />\r\n                  </div>\r\n\r\n                  <div className=\"flex items-center justify-between\">\r\n                    <Label htmlFor=\"email-overdue\" className=\"cursor-pointer\">\r\n                      Khi bأںâ•‘أ؛o hâ”œأ،nh quâ”œأ­ hأںâ•‘أ­n SLA\r\n                    </Label>\r\n                    <Switch\r\n                      id=\"email-overdue\"\r\n                      checked={notifications.emailOnOverdue}\r\n                      onCheckedChange={() => handleNotificationChange('emailOnOverdue')}\r\n                    />\r\n                  </div>\r\n                </div>\r\n              </SettingsFormSection>\r\n\r\n              <SettingsFormSection\r\n                title=\"Thâ”œâ”¤ng bâ”œأ­o SMS\"\r\n                description=\"Chأںâ•—أ« bأںâ•‘آ،t cho câ”œأ­c sأںâ•—â–’ kiأںâ•—أ§n cأںâ•‘آ؛n phأںâ•‘أ؛n hأںâ•—أ´i tأںâ•—âŒگc thâ”œآ¼ â”€أ¦أںâ•—أ¢ trâ”œأ­nh spam.\"\r\n                badge={<AlertCircle className=\"h-4 w-4 text-muted-foreground\" />}\r\n              >\r\n                <div className=\"flex items-center justify-between\">\r\n                  <Label htmlFor=\"sms-overdue\" className=\"cursor-pointer\">\r\n                    Cأںâ•‘أ؛nh bâ”œأ­o quâ”œأ­ hأںâ•‘أ­n SLA\r\n                  </Label>\r\n                  <Switch\r\n                    id=\"sms-overdue\"\r\n                    checked={notifications.smsOnOverdue}\r\n                    onCheckedChange={() => handleNotificationChange('smsOnOverdue')}\r\n                  />\r\n                </div>\r\n              </SettingsFormSection>\r\n\r\n              <SettingsFormSection\r\n                title=\"Thâ”œâ”¤ng bâ”œأ­o trong أںâ•—âŒگng dأںâ•—أ‘ng\"\r\n                description=\"Hiأںâ•—أ¢n thأںâ•—أ¯ trong bell icon cأںâ•—آ؛a hأںâ•—أ§ thأںâ•—أ¦ng HRM.\"\r\n                badge={<Bell className=\"h-4 w-4 text-muted-foreground\" />}\r\n              >\r\n                <div className=\"flex items-center justify-between\">\r\n                  <Label htmlFor=\"inapp\" className=\"cursor-pointer\">\r\n                    Bأںâ•‘آ،t thâ”œâ”¤ng bâ”œأ­o in-app (bell icon)\r\n                  </Label>\r\n                  <Switch\r\n                    id=\"inapp\"\r\n                    checked={notifications.inAppNotifications}\r\n                    onCheckedChange={() => handleNotificationChange('inAppNotifications')}\r\n                  />\r\n                </div>\r\n              </SettingsFormSection>\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n\r\n        {/* ============================================ */}\r\n        {/* TAB 4: PUBLIC TRACKING */}\r\n        {/* ============================================ */}\r\n        <TabsContent value=\"public-tracking\" className=\"mt-0 space-y-4\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle>Liâ”œآ¬n kأںâ•‘â”گt theo dâ”œâ•،i câ”œâ”¤ng khai</CardTitle>\r\n              <CardDescription>\r\n                Cho phâ”œâŒگp khâ”œأ­ch hâ”œأ،ng theo dâ”œâ•،i tiأںâ•‘â”گn â”€أ¦أںâ•—أ– xأںâ•—آ، lâ”œâ•œ bأںâ•‘أ؛o hâ”œأ،nh qua link câ”œâ”¤ng khai\r\n              </CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-6\">\r\n              <SettingsFormSection\r\n                title=\"Cأںâ•‘أ‘u hâ”œآ¼nh truy cأںâ•‘آ،p câ”œâ”¤ng khai\"\r\n                description=\"Kiأںâ•—أ¢m soâ”œأ­t dأںâ•—آ» liأںâ•—أ§u nâ”œأ،o â”€أ¦â•‍â–‘أںâ•—أ؛c chia sأںâ•‘â•— cho khâ”œأ­ch hâ”œأ،ng qua link bأںâ•‘أ؛o hâ”œأ،nh.\"\r\n              >\r\n                <div className=\"space-y-4\">\r\n                  <div className=\"flex items-center justify-between\">\r\n                    <div className=\"space-y-1\">\r\n                      <Label htmlFor=\"tracking-enabled\" className=\"cursor-pointer\">\r\n                        Bأںâ•‘آ،t tâ”œآ،nh nâ”€أ¢ng tracking câ”œâ”¤ng khai\r\n                      </Label>\r\n                      <p className=\"text-sm text-muted-foreground\">\r\n                        Tأںâ•‘أ­o link câ”œâ”¤ng khai â”€أ¦أںâ•—أ¢ khâ”œأ­ch hâ”œأ،ng tأںâ•—â–’ theo dâ”œâ•،i tiأںâ•‘â”گn â”€أ¦أںâ•—أ–\r\n                      </p>\r\n                    </div>\r\n                    <Switch\r\n                      id=\"tracking-enabled\"\r\n                      checked={publicTracking.enabled}\r\n                      onCheckedChange={() => handlePublicTrackingChange('enabled')}\r\n                    />\r\n                  </div>\r\n\r\n                  {publicTracking.enabled && (\r\n                    <div className=\"space-y-4\">\r\n                      <div className=\"flex items-center justify-between\">\r\n                        <div className=\"space-y-1\">\r\n                          <Label htmlFor=\"allow-comments\" className=\"cursor-pointer\">\r\n                            Cho phâ”œâŒگp khâ”œأ­ch hâ”œأ،ng comment\r\n                          </Label>\r\n                          <p className=\"text-sm text-muted-foreground\">\r\n                            Thu thأںâ•‘آ،p thâ”œآ¬m bأںâ•‘â–’ng chأںâ•—âŒگng trأںâ•—â–’c tiأںâ•‘â”گp tأںâ•—آ½ khâ”œأ­ch hâ”œأ،ng\r\n                          </p>\r\n                        </div>\r\n                        <Switch\r\n                          id=\"allow-comments\"\r\n                          checked={publicTracking.allowCustomerComments}\r\n                          onCheckedChange={() => handlePublicTrackingChange('allowCustomerComments')}\r\n                        />\r\n                      </div>\r\n\r\n                      <div className=\"flex items-center justify-between\">\r\n                        <div className=\"space-y-1\">\r\n                          <Label htmlFor=\"show-employee\" className=\"cursor-pointer\">\r\n                            Hiأںâ•—أ¢n thأںâ•—أ¯ tâ”œآ¬n nhâ”œأ³n viâ”œآ¬n xأںâ•—آ، lâ”œâ•œ\r\n                          </Label>\r\n                          <p className=\"text-sm text-muted-foreground\">\r\n                            Tâ”€أ¢ng tâ”œآ،nh minh bأںâ•‘أ­ch vâ”œأ، trâ”œأ­ch nhiأںâ•—أ§m\r\n                          </p>\r\n                        </div>\r\n                        <Switch\r\n                          id=\"show-employee\"\r\n                          checked={publicTracking.showEmployeeName}\r\n                          onCheckedChange={() => handlePublicTrackingChange('showEmployeeName')}\r\n                        />\r\n                      </div>\r\n\r\n                      <div className=\"flex items-center justify-between\">\r\n                        <div className=\"space-y-1\">\r\n                          <Label htmlFor=\"show-timeline\" className=\"cursor-pointer\">\r\n                            Hiأںâ•—أ¢n thأںâ•—أ¯ timeline xأںâ•—آ، lâ”œâ•œ\r\n                          </Label>\r\n                          <p className=\"text-sm text-muted-foreground\">\r\n                            Cho phâ”œâŒگp khâ”œأ­ch hâ”œأ،ng xem toâ”œأ،n bأںâ•—أ– lأںâ•—أ¯ch sأںâ•—آ، thao tâ”œأ­c\r\n                          </p>\r\n                        </div>\r\n                        <Switch\r\n                          id=\"show-timeline\"\r\n                          checked={publicTracking.showTimeline}\r\n                          onCheckedChange={() => handlePublicTrackingChange('showTimeline')}\r\n                        />\r\n                      </div>\r\n                    </div>\r\n                  )}\r\n                </div>\r\n              </SettingsFormSection>\r\n\r\n              {/* Example */}\r\n              {publicTracking.enabled && (\r\n                <div className=\"p-4 bg-muted rounded-lg space-y-2\">\r\n                  <p className=\"text-sm font-medium\">Vâ”œآ، dأںâ•—أ‘ link tracking:</p>\r\n                  <code className=\"text-xs bg-background px-2 py-1 rounded block\">\r\n                    https://yoursite.com/warranty/tracking/abc123xyz\r\n                  </code>\r\n                  <p className=\"text-xs text-muted-foreground\">\r\n                    Link nâ”œأ،y sأںâ•‘â•œ â”€أ¦â•‍â–‘أںâ•—أ؛c tأںâ•‘أ­o tأںâ•—â–’ â”€أ¦أںâ•—أ–ng khi tأںâ•‘أ­o yâ”œآ¬u cأںâ•‘آ؛u bأںâ•‘أ؛o hâ”œأ،nh mأںâ•—آ¢i\r\n                  </p>\r\n                </div>\r\n              )}\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n\r\n        {/* ============================================ */}\r\n        {/* TAB 5: CARD COLORS */}\r\n        {/* ============================================ */}\r\n        <TabsContent value=\"card-colors\" className=\"mt-0 space-y-4\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle>Mâ”œأ،u sأںâ•‘آ»c card bأںâ•‘أ؛o hâ”œأ،nh (Kanban View)</CardTitle>\r\n              <CardDescription>\r\n                Tâ”œâ•£y chأںâ•—أ«nh mâ”œأ،u nأںâ•—أ¼n vâ”œأ، viأںâ•—أ¼n card theo trأںâ•‘أ­ng thâ”œأ­i bأںâ•‘أ؛o hâ”œأ،nh trong chأںâ•‘â”گ â”€أ¦أںâ•—أ– Kanban\r\n              </CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-6\">\r\n              <SettingsFormSection\r\n                title=\"Kiأںâ•—أ¢u mâ”œأ،u hiأںâ•—أ¢n thأںâ•—أ¯\"\r\n                description=\"â•‍آ»u tiâ”œآ¬n: quâ”œأ­ hأںâ•‘أ­n خ“أ¥أ† trأںâ•‘أ­ng thâ”œأ­i خ“أ¥أ† mâ”œأ،u mأںâ•‘â•–c â”€أ¦أںâ•—أ¯nh.\"\r\n              >\r\n                <div className=\"space-y-4\">\r\n                  <div className=\"flex items-center justify-between\">\r\n                    <div className=\"space-y-0.5\">\r\n                      <Label htmlFor=\"enable-overdue\">Mâ”œأ،u quâ”œأ­ hأںâ•‘أ­n SLA</Label>\r\n                      <p className=\"text-sm text-muted-foreground\">\r\n                        Override tأںâ•‘أ‘t cأںâ•‘أ؛ mâ”œأ،u khâ”œأ­c khi phiأںâ•‘â”گu quâ”œأ­ hأںâ•‘أ­n\r\n                      </p>\r\n                    </div>\r\n                    <Switch\r\n                      id=\"enable-overd