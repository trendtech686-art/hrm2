          </p>\r\n              </div>\r\n              \r\n              <div className=\"space-y-2\">\r\n                <Label>Ngâ•‍â–‘أںâ•—آ¥i tأںâ•‘أ­o</Label>\r\n                <Input \r\n                  value={currentEmployee?.fullName || user?.name || 'Khâ”œâ”¤ng xâ”œأ­c â”€أ¦أںâ•—أ¯nh'}\r\n                  disabled\r\n                  className=\"h-9 bg-muted\"\r\n                />\r\n                <p className=\"text-xs text-muted-foreground\">\r\n                  {formatDateTimeForDisplay(new Date())}\r\n                </p>\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"space-y-2\">\r\n              <Label>Lâ”œâ•œ do â”€أ¦iأںâ•—أ¼u chأںâ•—أ«nh</Label>\r\n              <Input \r\n                {...form.register('reason')}\r\n                placeholder=\"Vâ”œآ، dأںâ•—أ‘: Cأںâ•‘آ،p nhأںâ•‘آ،t giâ”œأ­ theo â”€أ¦â•‍أ­n nhأںâ•‘آ،p mأںâ•—آ¢i, â”€أ‰iأںâ•—أ¼u chأںâ•—أ«nh giâ”œأ­ theo thأںâ•—أ¯ trâ•‍â–‘أںâ•—آ¥ng...\"\r\n                className=\"h-9\"\r\n              />\r\n            </div>\r\n\r\n            <div className=\"space-y-2\">\r\n              <Label>Ghi châ”œâ•‘</Label>\r\n              <Textarea\r\n                {...form.register('note')}\r\n                placeholder=\"Ghi châ”œâ•‘ thâ”œآ¬m...\"\r\n                rows={2}\r\n              />\r\n            </div>\r\n          </CardContent>\r\n        </Card>\r\n\r\n        {/* Product List */}\r\n        <Card>\r\n          <CardHeader className=\"flex flex-row items-center justify-between\">\r\n            <CardTitle className=\"text-base\">Danh sâ”œأ­ch sأںâ•‘أ؛n phأںâ•‘âŒگm</CardTitle>\r\n            <Button\r\n              type=\"button\"\r\n              variant=\"outline\"\r\n              size=\"sm\"\r\n              onClick={() => setIsProductDialogOpen(true)}\r\n            >\r\n              <Plus className=\"mr-2 h-4 w-4\" />\r\n              Thâ”œآ¬m sأںâ•‘أ؛n phأںâ•‘âŒگm\r\n            </Button>\r\n          </CardHeader>\r\n     