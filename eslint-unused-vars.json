                id=\"email-approval\"\r\n                    checked={notifications.emailOnApprovalPending}\r\n                    onCheckedChange={() => handleNotificationChange('emailOnApprovalPending')}\r\n                  />\r\n                </div>\r\n              </SettingsFormSection>\r\n\r\n              <SettingsFormSection\r\n                title=\"Thâ”œâ”¤ng bâ”œأ­o trong أںâ•—âŒگng dأںâ•—أ‘ng\"\r\n                description=\"Hiأںâ•—أ¢n thأںâ•—أ¯ trong hأںâ•—أ§ thأںâ•—أ¦ng dâ”œأ،nh cho quأںâ•‘أ؛n lâ”œâ•œ task.\"\r\n              >\r\n                <div className=\"flex items-center justify-between\">\r\n                  <div>\r\n                    <Label htmlFor=\"inapp\" className=\"cursor-pointer\">Bأںâ•‘آ،t thâ”œâ”¤ng bâ”œأ­o in-app</Label>\r\n                    <p className=\"text-xs text-muted-foreground\">â”œأ¼p dأںâ•—أ‘ng cho desktop vâ”œأ، mobile app.</p>\r\n                  </div>\r\n                  <Switch\r\n                    id=\"inapp\"\r\n                    checked={notifications.inAppNotifications}\r\n                    onCheckedChange={() => handleNotificationChange('inAppNotifications')}\r\n                  />\r\n                </div>\r\n              </SettingsFormSection>\r\n\r\n              <SettingsFormSection\r\n                title=\"Cأںâ•‘أ؛nh bâ”œأ­o SMS\"\r\n                description=\"Chأںâ•—أ« nâ”œآ¬n bأںâ•‘آ،t cho sأںâ•—â–’ kiأںâ•—أ§n quan trأںâ•—أ¬ng â”€أ¦أںâ•—أ¢ trâ”œأ­nh spam.\"\r\n              >\r\n                <div className=\"flex items-center justify-between\">\r\n                  <Label htmlFor=\"sms-overdue\" className=\"cursor-pointer\">\r\n                    Gأںâ•—آ،i SMS khi task quâ”œأ­ hأںâ•‘أ­n\r\n                  </Label>\r\n                  <Switch\r\n                    id=\"sms-overdue\"\r\n                    checked={notifications.smsOnOverdue}\r\n                    onCheckedChange={() => handleNotificationChange('smsOnOverdue')}\r\n                  />\r\n                <