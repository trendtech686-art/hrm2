       <Check className=\"h-3 w-3 mr-1\" /> â”€أ‰â”œأ؛ xâ”œأ­c nhأںâ•‘آ،n {format(new Date(ack!.acknowledgedAt), 'dd/MM HH:mm', { locale: vi })}\r\n                  </Badge>\r\n                ) : (\r\n                  <div className=\"flex gap-2\">\r\n                    <TooltipProvider delayDuration={0}>\r\n                      <Tooltip>\r\n                        <TooltipTrigger asChild>\r\n                          <Button variant=\"outline\" size=\"sm\" onClick={() => handleAcknowledge(alert)}>\r\n                            <Check className=\"h-4 w-4 mr-1\" /> â”€أ‰â”œأ؛ xأںâ•—آ، lâ”œâ•œ\r\n                          </Button>\r\n                        </TooltipTrigger>\r\n                        <TooltipContent side=\"top\" className=\"max-w-xs\">\r\n                          {alert.slaType === 'follow-up' ? (\r\n                            <p>Xâ”œأ­c nhأںâ•‘آ،n â”€أ¦â”œأ؛ liâ”œآ¬n hأںâ•—أ§ khâ”œأ­ch hâ”œأ،ng. Ngâ”œأ،y liâ”œآ¬n hأںâ•—أ§ cuأںâ•—أ¦i sأںâ•‘â•œ â”€أ¦â•‍â–‘أںâ•—أ؛c cأںâ•‘آ،p nhأںâ•‘آ،t vâ”œأ، chu kأںâ•—â”‚ SLA â”€أ¦â•‍â–‘أںâ•—أ؛c lâ”œأ،m mأںâ•—آ¢i.</p>\r\n                          ) : alert.slaType === 're-engagement' ? (\r\n                            <p>Xâ”œأ­c nhأںâ•‘آ،n â”€أ¦â”œأ؛ tiأںâ•‘â”گp cأںâ•‘آ،n lأںâ•‘أ­i khâ”œأ­ch hâ”œأ،ng. Cأںâ•‘أ؛nh bâ”œأ­o sأںâ•‘â•œ â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦â”œأ­nh dأںâ•‘أ‘u â”€أ¦â”œأ؛ xأںâ•—آ، lâ”œâ•œ.</p>\r\n                          ) : (\r\n                            <p>Xâ”œأ­c nhأںâ•‘آ،n â”€أ¦â”œأ؛ xأںâ•—آ، lâ”œâ•œ SLA nâ”œأ،y. Cأںâ•‘أ؛nh bâ”œأ­o sأںâ•‘â•œ â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦â”œأ­nh dأںâ•‘أ‘u hoâ”œأ،n thâ”œأ،nh.</p>\r\n                          )}\r\n                        </TooltipContent>\r\n                      </Tooltip>\r\n                    </TooltipProvider>\r\n                    <TooltipProvider delayDuration={0}>\r\n                      <Tooltip>\r\n                        <TooltipTrigger asChild>\r\n                          <DropdownMenu>\r\n                            <DropdownMenuTr