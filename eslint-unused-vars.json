rface EcommerceTabProps {\r\n  product: Product;\r\n}\r\n\r\nexport function EcommerceTab({ product }: EcommerceTabProps) {\r\n  const [isPushingPkgx, setIsPushingPkgx] = React.useState(false);\r\n  const [isSyncingPrice, setIsSyncingPrice] = React.useState(false);\r\n  const [isSyncingStock, setIsSyncingStock] = React.useState(false);\r\n  const [isSyncingSeo, setIsSyncingSeo] = React.useState(false);\r\n  const [isSyncingDesc, setIsSyncingDesc] = React.useState(false);\r\n  const [isSyncingFlags, setIsSyncingFlags] = React.useState(false);\r\n  const [isUnlinking, setIsUnlinking] = React.useState(false);\r\n  \r\n  const queryClient = useQueryClient();\r\n  const pkgxSettings = usePkgxSettingsStore();\r\n  const { update: updateMutation } = useProductMutations();\r\n  const updateProduct = (systemId: string, data: Partial<Product>) => \r\n    updateMutation.mutate({ systemId, ...data });\r\n  \r\n  const isPkgxLinked = !!product.pkgxId;\r\n  const isTrendtechLinked = !!product.trendtechId;\r\n  \r\n  // Get category mapping for this product\r\n  const pkgxCategoryMapping = React.useMemo(() => {\r\n    if (!product.categorySystemId) return null;\r\n    return null; // getCategoryMappingByHrmId not available\r\n  }, [product.categorySystemId]);\r\n  \r\n  // Get brand mapping for this product\r\n  const pkgxBrandMapping = React.useMemo(() => {\r\n    if (!product.brandSystemId) return null;\r\n    return null; // getBrandMappingByHrmId not available\r\n  }, [product.brandSystemId]);\r\n  \r\n  // Check if product can be pushed to PKGX\r\n  const canPushToPkgx = React.useMemo(() => {\r\n    if (!(pkgxSettings as any)?.apiUrl || !(pkgxSettings as any)?.apiKey) return false;\r\n    if (!(pkgxSettings as any)?.enabled) return false;\r\n    // Must have category mapping\r\n    if (!pkgxCategoryMapping) return false;\r\n    return true;\r\n  }, [pkgxSettings, pkgxCategoryMapping]);\r\n  \r\n  // Push product to PKGX\r\n  const handlePushToPkgx = async () => {\r\n    if (!canPushToPkgx) {\r\n      toast.error('Châ•‍â–‘a cأںâ•‘أ‘u hâ”œآ¼nh â”€أ¦أںâ•—آ؛ thâ”œâ”¤ng tin â”€أ¦أںâ•—أ¢ â”€أ¦أںâ•‘âŒگy lâ”œآ¬n PKGX');\r\n      return;\r\n    }\r\n    \r\n    setIsPushingPkgx(true);\r\n    try {\r\n      const payload = mapHrmToPkgxPayload(product);\r\n      \r\n      let response;\r\n      if (isPkgxLinked) {\r\n        // Update existing\r\n        response = await pkgxApi.updateProduct(product.pkgxId!, payload, pkgxSettings as any);\r\n      } else {\r\n        // Create new\r\n        response = await pkgxApi.createProduct(payload, pkgxSettings as any);\r\n      }\r\n      \r\n      if (response.success && response.data) {\r\n        // Update product with PKGX ID if newly created\r\n        if (!isPkgxLinked && response.data.goods_id) {\r\n          updateProduct(product.systemId, { \r\n            pkgxId: response.data.goods_id,\r\n            updatedAt: new Date().toISOString(),\r\n          });\r\n          \r\n          // Invalidate React Query cache so list page refreshes immediately\r\n          queryClient.invalidateQueries({ queryKey: ['products'] });\r\n        }\r\n        \r\n        pkgxSettings.addLog({\r\n          action: isPkgxLinked ? 'update_product' : 'create_product',\r\n          status: 'success',\r\n          message: `${isPkgxLinked ? 'Cأںâ•‘آ،p nhأںâ•‘آ،t' : 'Tأںâ•‘أ­o mأںâ•—آ¢i'} sأںâ•‘أ؛n phأںâ•‘âŒگm trâ”œآ¬n PKGX: ${product.name}`,\r\n          details: { productId: product.systemId, pkgxId: response.data.goods_id || product.pkgxId },\r\n        });\r\n        \r\n        toast.success(isPkgxLinked ? 'â”€أ‰â”œأ؛ cأںâ•‘آ،p nhأںâ•‘آ،t sأںâ•‘أ؛n phأںâ•‘âŒگm trâ”œآ¬n PKGX' : 'â”€أ‰â”œأ؛ â”€أ¦أںâ•‘âŒگy sأںâ•‘أ؛n phأںâ•‘âŒگm lâ”œآ¬n PKGX');\r\n      } else {\r\n        throw new Error(response.error || 'Lأںâ•—أ¹i khâ”œâ”¤ng xâ”œأ­c â”€أ¦أںâ•—أ¯nh');\r\n      }\r\n    } catch (error) {\r\n      pkgxSettings.addLog({\r\n        action: isPkgxLinked ? 'update_product' : 'create_product',\r\n        status: 'error',\r\n        message: `Lأںâ•—أ¹i ${isPkgxLinked ? 'cأںâ•‘آ،p nhأںâ•‘آ،t' : 'tأںâ•‘أ­o'} sأںâ•‘أ؛n phأںâ•‘âŒگm: ${product.name}`,\r\n        details: { error: error instanceof Error ? error.message : String(error) },\r\n      });\r\n      toast.error(error instanceof Error ? error.message : 'Lأںâ•—أ¹i khi â”€أ¦أںâ•‘âŒگy sأںâ•‘أ؛n phأںâ•‘âŒگm lâ”œآ¬n PKGX');\r\n    } finally {\r\n      setIsPushingPkgx(false);\r\n    }\r\n  };\r\n  \r\n  // Sync price to PKGX\r\n  const handleSyncPrice = async () => {\r\n    if (!isPkgxLinked) {\r\n      toast.error('Sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i PKGX');\r\n      return;\r\n    }\r\n    \r\n    setIsSyncingPrice(true);\r\n    try {\r\n      const pricePayload = createPriceUpdatePayload(product);\r\n      \r\n      const response = await pkgxApi.updateProduct(product.pkgxId!, pricePayload, pkgxSettings as any);\r\n      \r\n      if (response.success) {\r\n        pkgxSettings.addLog({\r\n          action: 'sync_price',\r\n          status: 'success',\r\n          message: `â”€أ‰أںâ•—أ´ng bأںâ•—أ– giâ”œأ­ thâ”œأ،nh câ”œâ”¤ng: ${product.name}`,\r\n          details: { productId: product.systemId, pkgxId: product.pkgxId },\r\n        });\r\n        toast.success('â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– giâ”œأ­ lâ”œآ¬n PKGX');\r\n      } else {\r\n        throw new Error(response.error || 'Lأںâ•—أ¹i khâ”œâ”¤ng xâ”œأ­c â”€أ¦أںâ•—أ¯nh');\r\n      }\r\n    } catch (error) {\r\n      pkgxSettings.addLog({\r\n        action: 'sync_price',\r\n        status: 'error',\r\n        message: `Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– giâ”œأ­: ${product.name}`,\r\n        details: { error: error instanceof Error ? error.message : String(error) },\r\n      });\r\n      toast.error(error instanceof Error ? error.message : 'Lأںâ•—أ¹i khi â”€أ¦أںâ•—أ´ng bأںâ•—أ– giâ”œأ­');\r\n    } finally {\r\n      setIsSyncingPrice(false);\r\n    }\r\n  };\r\n  \r\n  // Sync stock to PKGX\r\n  const handleSyncStock = async () => {\r\n    if (!isPkgxLinked) {\r\n      toast.error('Sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i PKGX');\r\n      return;\r\n    }\r\n    \r\n    setIsSyncingStock(true);\r\n    try {\r\n      const totalStock = getTotalInventory(product);\r\n      \r\n      const response = await pkgxApi.updateProductStock(product.pkgxId!, totalStock);\r\n      \r\n      if (response.success) {\r\n        pkgxSettings.addLog({\r\n          action: 'sync_inventory',\r\n          status: 'success',\r\n          message: `â”€أ‰أںâ•—أ´ng bأںâ•—أ– tأںâ•—أ´n kho thâ”œأ،nh câ”œâ”¤ng: ${product.name} (${totalStock})`,\r\n          details: { productId: product.systemId, pkgxId: product.pkgxId, inventory: totalStock },\r\n        });\r\n        toast.success(`â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– tأںâ•—أ´n kho: ${totalStock} ${product.unit}`);\r\n      } else {\r\n        throw new Error(response.error || 'Lأںâ•—أ¹i khâ”œâ”¤ng xâ”œأ­c â”€أ¦أںâ•—أ¯nh');\r\n      }\r\n    } catch (error) {\r\n      pkgxSettings.addLog({\r\n        action: 'sync_inventory',\r\n        status: 'error',\r\n        message: `Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– tأںâ•—أ´n kho: ${product.name}`,\r\n        details: { error: error instanceof Error ? error.message : String(error) },\r\n      });\r\n      toast.error(error instanceof Error ? error.message : 'Lأںâ•—أ¹i khi â”€أ¦أںâ•—أ´ng bأںâ•—أ– tأںâ•—أ´n kho');\r\n    } finally {\r\n      setIsSyncingStock(false);\r\n    }\r\n  };\r\n  \r\n  // Sync SEO to PKGX\r\n  const handleSyncSeo = async () => {\r\n    if (!isPkgxLinked) {\r\n      toast.error('Sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i PKGX');\r\n      return;\r\n    }\r\n    \r\n    setIsSyncingSeo(true);\r\n    try {\r\n      const seoPayload = createSeoUpdatePayload(product);\r\n      const response = await pkgxApi.updateProduct(product.pkgxId!, seoPayload);\r\n      \r\n      if (response.success) {\r\n        pkgxSettings.addLog({\r\n          action: 'sync_seo',\r\n          status: 'success',\r\n          message: `â”€أ‰أںâ•—أ´ng bأںâ•—أ– SEO thâ”œأ،nh câ”œâ”¤ng: ${product.name}`,\r\n          details: { productId: product.systemId, pkgxId: product.pkgxId },\r\n        });\r\n        toast.success('â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– SEO lâ”œآ¬n PKGX');\r\n      } else {\r\n        throw new Error(response.error || 'Lأںâ•—أ¹i khâ”œâ”¤ng xâ”œأ­c â”€أ¦أںâ•—أ¯nh');\r\n      }\r\n    } catch (error) {\r\n      pkgxSettings.addLog({\r\n        action: 'sync_seo',\r\n        status: 'error',\r\n        message: `Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– SEO: ${product.name}`,\r\n        details: { error: error instanceof Error ? error.message : String(error) },\r\n      });\r\n      toast.error(error instanceof Error ? error.message : 'Lأںâ•—أ¹i khi â”€أ¦أںâ•—أ´ng bأںâ•—أ– SEO');\r\n    } finally {\r\n      setIsSyncingSeo(false);\r\n    }\r\n  };\r\n  \r\n  // Sync Description to PKGX\r\n  const handleSyncDescription = async () => {\r\n    if (!isPkgxLinked) {\r\n      toast.error('Sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i PKGX');\r\n      return;\r\n    }\r\n    \r\n    setIsSyncingDesc(true);\r\n    try {\r\n      const descPayload = createDescriptionUpdatePayload(product);\r\n      const response = await pkgxApi.updateProduct(product.pkgxId!, descPayload);\r\n      \r\n      if (response.success) {\r\n        pkgxSettings.addLog({\r\n          action: 'update_product',\r\n          status: 'success',\r\n          message: `â”€أ‰أںâ•—أ´ng bأںâ•—أ– mâ”œâ”¤ tأںâ•‘أ؛ thâ”œأ،nh câ”œâ”¤ng: ${product.name}`,\r\n          details: { productId: product.systemId, pkgxId: product.pkgxId },\r\n        });\r\n        toast.success('â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– mâ”œâ”¤ tأںâ•‘أ؛ lâ”œآ¬n PKGX');\r\n      } else {\r\n        throw new Error(response.error || 'Lأںâ•—أ¹i khâ”œâ”¤ng xâ”œأ­c â”€أ¦أںâ•—أ¯nh');\r\n      }\r\n    } catch (error) {\r\n      pkgxSettings.addLog({\r\n        action: 'update_product',\r\n        status: 'error',\r\n        message: `Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– mâ”œâ”¤ tأںâ•‘أ؛: ${product.name}`,\r\n        details: { error: error instanceof Error ? error.message : String(error) },\r\n      });\r\n      toast.error(error instanceof Error ? error.message : 'Lأںâ•—أ¹i khi â”€أ¦أںâ•—أ´ng bأںâ•—أ– mâ”œâ”¤ tأںâ•‘أ؛');\r\n    } finally {\r\n      setIsSyncingDesc(false);\r\n    }\r\n  };\r\n  \r\n  // Sync Flags to PKGX\r\n  const handleSyncFlags = async () => {\r\n    if (!isPkgxLinked) {\r\n      toast.error('Sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i PKGX');\r\n      return;\r\n    }\r\n    \r\n    setIsSyncingFlags(true);\r\n    try {\r\n      const flagsPayload = createFlagsUpdatePayload(product);\r\n      const response = await pkgxApi.updateProduct(product.pkgxId!, flagsPayload);\r\n      \r\n      if (response.success) {\r\n        pkgxSettings.addLog({\r\n          action: 'update_product',\r\n          status: 'success',\r\n          message: `â”€أ‰أںâ•—أ´ng bأںâ•—أ– flags thâ”œأ،nh câ”œâ”¤ng: ${product.name}`,\r\n          details: { productId: product.systemId, pkgxId: product.pkgxId },\r\n        });\r\n        toast.success('â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– flags lâ”œآ¬n PKGX');\r\n      } else {\r\n        throw new Error(response.error || 'Lأںâ•—أ¹i khâ”œâ”¤ng xâ”œأ­c â”€أ¦أںâ•—أ¯nh');\r\n      }\r\n    } catch (error) {\r\n      pkgxSettings.addLog({\r\n        action: 'update_product',\r\n        status: 'error',\r\n        message: `Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– flags: ${product.name}`,\r\n        details: { error: error instanceof Error ? error.message : String(error) },\r\n      });\r\n      toast.error(error instanceof Error ? error.message : 'Lأںâ•—أ¹i khi â”€أ¦أںâ•—أ´ng bأںâ•—أ– flags');\r\n    } finally {\r\n      setIsSyncingFlags(false);\r\n    }\r\n  };\r\n  \r\n  // View on PKGX website\r\n  const handleViewOnPkgx = () => {\r\n    if (!isPkgxLinked) {\r\n      toast.error('Sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i PKGX');\r\n      return;\r\n    }\r\n    \r\n    const slug = product.pkgxSlug || `product-${product.pkgxId}`;\r\n    const url = `https://phukiengiaxuong.com.vn/${slug}.html`;\r\n    window.open(url, '_blank');\r\n  };\r\n  \r\n  // Unlink from PKGX\r\n  const handleUnlinkPkgx = async () => {\r\n    if (!isPkgxLinked) return;\r\n    \r\n    setIsUnlinking(true);\r\n    try {\r\n      updateProduct(product.systemId, { \r\n        pkgxId: undefined,\r\n        updatedAt: new Date().toISOString(),\r\n      });\r\n      \r\n      pkgxSettings.addLog({\r\n        action: 'unlink_product',\r\n        status: 'success',\r\n        message: `Hأںâ•—آ؛y liâ”œآ¬n kأںâ•‘â”گt sأںâ•‘أ؛n phأںâ•‘âŒگm: ${product.name}`,\r\n        details: { productId: product.systemId, pkgxId: product.pkgxId },\r\n      });\r\n      \r\n      toast.success('â”€أ‰â”œأ؛ hأںâ•—آ؛y liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i PKGX');\r\n    } catch (_error) {\r\n      toast.error('Lأںâ•—أ¹i khi hأںâ•—آ؛y liâ”œآ¬n kأںâ•‘â”گt');\r\n    } finally {\r\n      setIsUnlinking(false);\r\n    }\r\n  };\r\n  \r\n  return (\r\n    <div className=\"space-y-4\">\r\n      {/* PKGX Section */}\r\n      <Card>\r\n        <CardHeader>\r\n          <div className=\"flex items-center justify-between\">\r\n            <div className=\"flex items-center gap-2\">\r\n              <Globe className=\"h-5 w-5 text-orange-500\" />\r\n              <CardTitle className=\"text-lg\">PKGX (phukiengiaxuong.com.vn)</CardTitle>\r\n            </div>\r\n            {isPkgxLinked ? (\r\n              <Badge variant=\"default\" className=\"bg-green-500\">\r\n                <CheckCircle2 className=\"h-3 w-3 mr-1\" />\r\n                â”€أ‰â”œأ؛ liâ”œآ¬n kأںâ•‘â”گt\r\n              </Badge>\r\n            ) : (\r\n              <Badge variant=\"secondary\">Châ•‍â–‘a liâ”œآ¬n kأںâ•‘â”گt</Badge>\r\n            )}\r\n          </div>\r\n          <CardDescription>\r\n            Quأںâ•‘أ؛n lâ”œâ•œ sأںâ•‘أ؛n phأںâ•‘âŒگm trâ”œآ¬n website PKGX\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          {/* Status Info */}\r\n          {isPkgxLinked && (\r\n            <div className=\"flex items-center gap-4 p-3 bg-muted/50 rounded-lg\">\r\n              <div className=\"flex-1 grid grid-cols-2 md:grid-cols-4 gap-4 text-sm\">\r\n                <div>\r\n                  <span className=\"text-muted-foreground\">ID PKGX:</span>\r\n                  <span className=\"ml-2 font-mono font-medium\">{product.pkgxId}</span>\r\n                </div>\r\n                <div>\r\n                  <span className=\"text-muted-foreground\">Slug:</span>\r\n                  <span className=\"ml-2 font-mono text-xs\">{product.pkgxSlug || '-'}</span>\r\n                </div>\r\n              </div>\r\n              <Button\r\n                variant=\"outline\"\r\n                size=\"sm\"\r\n                onClick={() => window.open(`https://phukiengiaxuong.com.vn/goods-${product.pkgxId}.html`, '_blank')}\r\n              >\r\n                <ExternalLink className=\"h-4 w-4 mr-1\" />\r\n                Xem\r\n              </Button>\r\n            </div>\r\n          )}\r\n          \r\n          {/* Mapping Status */}\r\n          <div className=\"space-y-2\">\r\n            <p className=\"text-sm font-medium text-muted-foreground\">Trأںâ•‘أ­ng thâ”œأ­i mapping:</p>\r\n            <div className=\"flex flex-wrap gap-2\">\r\n              <Badge variant={pkgxCategoryMapping ? 'default' : 'destructive'} className=\"text-xs\">\r\n                {pkgxCategoryMapping ? (\r\n                  <>خ“آ£أ´ Danh mأںâ•—أ‘c: {(pkgxCategoryMapping as any).pkgxCatName}</>\r\n                ) : (\r\n                  <>خ“آ£أ¹ Châ•‍â–‘a mapping danh mأںâ•—أ‘c</>\r\n                )}\r\n              </Badge>\r\n              <Badge variant={pkgxBrandMapping ? 'default' : 'secondary'} className=\"text-xs\">\r\n                {pkgxBrandMapping ? (\r\n                  <>خ“آ£أ´ Thâ•‍â–‘â•‍أ­ng hiأںâ•—أ§u: {(pkgxBrandMapping as any).pkgxBrandName}</>\r\n                ) : (\r\n                  <>- Khâ”œâ”¤ng câ”œâ”‚ thâ•‍â–‘â•‍أ­ng hiأںâ•—أ§u</>\r\n                )}\r\n              </Badge>\r\n            </div>\r\n          </div>\r\n          \r\n          {/* Warnings */}\r\n          {!canPushToPkgx && (\r\n            <Alert variant=\"destructive\">\r\n              <AlertCircle className=\"h-4 w-4\" />\r\n              <AlertTitle>Khâ”œâ”¤ng thأںâ•—أ¢ â”€أ¦أںâ•‘âŒگy lâ”œآ¬n PKGX</AlertTitle>\r\n              <AlertDescription>\r\n                <ul className=\"list-disc list-inside text-sm mt-1\">\r\n                  {!pkgxSettings.settings.enabled && <li>PKGX châ•‍â–‘a â”€أ¦â•‍â–‘أںâ•—أ؛c bأںâ•‘آ،t</li>}\r\n                  {!pkgxSettings.settings.apiUrl && <li>Châ•‍â–‘a cأںâ•‘أ‘u hâ”œآ¼nh API URL</li>}\r\n                  {!pkgxSettings.settings.apiKey && <li>Châ•‍â–‘a cأںâ•‘أ‘u hâ”œآ¼nh API Key</li>}\r\n                  {!pkgxCategoryMapping && <li>Danh mأںâ•—أ‘c sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a â”€أ¦â•‍â–‘أںâ•—أ؛c mapping vأںâ•—آ¢i PKGX</li>}\r\n                </ul>\r\n              </AlertDescription>\r\n            </Alert>\r\n          )}\r\n          \r\n          <Separator />\r\n          \r\n          {/* Actions */}\r\n          <div className=\"flex flex-wrap gap-2\">\r\n            <Button\r\n              onClick={handlePushToPkgx}\r\n              disabled={!canPushToPkgx || isPushingPkgx}\r\n            >\r\n              {isPushingPkgx ? (\r\n                <Loader2 className=\"h-4 w-4 mr-2 animate-spin\" />\r\n              ) : (\r\n                <Upload className=\"h-4 w-4 mr-2\" />\r\n              )}\r\n              {isPkgxLinked ? 'Cأںâ•‘آ،p nhأںâ•‘آ،t PKGX' : 'â”€أ‰أںâ•‘âŒگy lâ”œآ¬n PKGX'}\r\n            </Button>\r\n            \r\n            {isPkgxLinked && (\r\n              <>\r\n                <Button\r\n                  variant=\"outline\"\r\n                  onClick={handleSyncPrice}\r\n                  disabled={isSyncingPrice}\r\n                >\r\n                  {isSyncingPrice ? (\r\n                    <Loader2 className=\"h-4 w-4 mr-2 animate-spin\" />\r\n                  ) : (\r\n                    <DollarSign className=\"h-4 w-4 mr-2\" />\r\n                  )}\r\n                  Sync giâ”œأ­\r\n                </Button>\r\n                \r\n                <Button\r\n                  variant=\"outline\"\r\n                  onClick={handleSyncStock}\r\n                  disabled={isSyncingStock}\r\n                >\r\n                  {isSyncingStock ? (\r\n                    <Loader2 className=\"h-4 w-4 mr-2 animate-spin\" />\r\n                  ) : (\r\n                    <Package className=\"h-4 w-4 mr-2\" />\r\n                  )}\r\n                  Sync tأںâ•—أ´n kho\r\n                </Button>\r\n                \r\n                <Button\r\n                  variant=\"outline\"\r\n                  onClick={handleSyncSeo}\r\n                  disabled={isSyncingSeo}\r\n                >\r\n                  {isSyncingSeo ? (\r\n                    <Loader2 className=\"h-4 w-4 mr-2 animate-spin\" />\r\n                  ) : (\r\n                    <Search className=\"h-4 w-4 mr-2\" />\r\n                  )}\r\n                  Sync SEO\r\n                </Button>\r\n                \r\n                <Button\r\n                  variant=\"outline\"\r\n                  onClick={handleSyncDescription}\r\n                  disabled={isSyncingDesc}\r\n                >\r\n                  {isSyncingDesc ? (\r\n                    <Loader2 className=\"h-4 w-4 mr-2 animate-spin\" />\r\n                  ) : (\r\n                    <FileText className=\"h-4 w-4 mr-2\" />\r\n                  )}\r\n                  Sync mâ”œâ”¤ tأںâ•‘أ؛\r\n                </Button>\r\n                \r\n                <Button\r\n                  variant=\"outline\"\r\n                  onClick={handleSyncFlags}\r\n                  disabled={isSyncingFlags}\r\n                >\r\n                  {isSyncingFlags ? (\r\n                    <Loader2 className=\"h-4 w-4 mr-2 animate-spin\" />\r\n                  ) : (\r\n                    <Star className=\"h-4 w-4 mr-2\" />\r\n                  )}\r\n                  Sync flags\r\n                </Button>\r\n                \r\n                <Button\r\n                  variant=\"outline\"\r\n                  onClick={handleViewOnPkgx}\r\n                >\r\n                  <ExternalLink className=\"h-4 w-4 mr-2\" />\r\n                  Xem trâ”œآ¬n web\r\n                </Button>\r\n                \r\n                <Button\r\n                  variant=\"ghost\"\r\n                  onClick={handleUnlinkPkgx}\r\n                  disabled={isUnlinking}\r\n                  className=\"text-destructive hover:text-destructive\"\r\n                >\r\n                  {isUnlinking ? (\r\n                    <Loader2 className=\"h-4 w-4 mr-2 animate-spin\" />\r\n                  ) : (\r\n                    <Unlink className=\"h-4 w-4 mr-2\" />\r\n                  )}\r\n                  Hأںâ•—آ؛y liâ”œآ¬n kأںâ•‘â”گt\r\n                </Button>\r\n              </>\r\n            )}\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n      \r\n      {/* Trendtech Section */}\r\n      <Card>\r\n        <CardHeader>\r\n          <div className=\"flex items-center justify-between\">\r\n            <div className=\"flex items-center gap-2\">\r\n              <Globe className=\"h-5 w-5 text-blue-500\" />\r\n              <CardTitle className=\"text-lg\">Trendtech</CardTitle>\r\n            </div>\r\n            {isTrendtechLinked ? (\r\n              <Badge variant=\"default\" className=\"bg-green-500\">\r\n                <CheckCircle2 className=\"h-3 w-3 mr-1\" />\r\n                â”€أ‰â”œأ؛ liâ”œآ¬n kأںâ•‘â”گt\r\n              </Badge>\r\n            ) : (\r\n              <Badge variant=\"secondary\">Châ•‍â–‘a liâ”œآ¬n kأںâ•‘â”گt</Badge>\r\n            )}\r\n          </div>\r\n          <CardDescription>\r\n            Quأںâ•‘أ؛n lâ”œâ•œ sأںâ•‘أ؛n phأںâ•‘âŒگm trâ”œآ¬n website Trendtech\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent>\r\n          {isTrendtechLinked ? (\r\n            <div className=\"space-y-4\">\r\n              <div className=\"flex items-center gap-4 p-3 bg-muted/50 rounded-lg\">\r\n                <div className=\"flex-1\">\r\n                  <span className=\"text-muted-foreground text-sm\">ID Trendtech:</span>\r\n                  <span className=\"ml-2 font-mono font-medium\">{product.trendtechId}</span>\r\n                </div>\r\n              </div>\r\n              <p className=\"text-sm text-muted-foreground\">\r\n                Chأںâ•—âŒگc nâ”€أ¢ng sync Trendtech sأںâ•‘â•œ sأںâ•—آ¢m â”€أ¦â•‍â–‘أںâ•—أ؛c triأںâ•—أ¢n khai.\r\n              </p>\r\n            </div>\r\n          ) : (\r\n            <div className=\"text-center py-6 text-muted-foreground\">\r\n              <Globe className=\"h-12 w-12 mx-auto mb-3 opacity-30\" />\r\n              <p>Trendtech API châ•‍â–‘a sأںâ•‘â•،n sâ”œأ،ng</p>\r\n              <p className=\"text-sm mt-1\">Chأںâ•—âŒگc nâ”€أ¢ng sأںâ•‘â•œ â”€أ¦â•‍â–‘أںâ•—أ؛c kâ”œآ،ch hoأںâ•‘أ­t khi API hoâ”œأ،n thiأںâ•—أ§n</p>\r\n            </div>\r\n          )}\r\n        </CardContent>\r\n      </Card>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\products\\components\\in-transit-stock-dialog.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\products\\components\\mobile-product-card.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\products\\components\\pkgx-link-dialog.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"The 'cachedPkgxProducts' logical expression could make the dependencies of useEffect Hook (at line 74) change on every render. Move it inside the useEffect callback. Alternatively, wrap the initialization of 'cachedPkgxProducts' in its own useMemo() Hook.","line":36,"column":9,"nodeType":"VariableDeclarator","endLine":36,"endColumn":62},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":48,"column":23,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":48,"endColumn":26,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1825,1828],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1825,1828],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import * as React from 'react';\r\nimport { Link2 } from 'lucide-react';\r\nimport { toast } from 'sonner';\r\nimport { Button } from '@/components/ui/button';\r\nimport {\r\n  Dialog,\r\n  DialogContent,\r\n  DialogDescription,\r\n  DialogFooter,\r\n  DialogHeader,\r\n  DialogTitle,\r\n} from '@/components/ui/dialog';\r\nimport { VirtualizedCombobox, type ComboboxOption } from '@/components/ui/virtualized-combobox';\r\nimport { useAllProducts } from '../hooks/use-all-products';\r\nimport { useProductMutations } from '../hooks/use-products';\r\nimport type { Product } from '../types';\r\nimport type { PkgxProduct } from '@/features/settings/pkgx/types';\r\nimport { usePkgxSettings, usePkgxProductsMutations } from '@/features/settings/pkgx/hooks/use-pkgx-settings';\r\n\r\ninterface PkgxLinkDialogProps {\r\n  open: boolean;\r\n  onOpenChange: (open: boolean) => void;\r\n  product: Product | null;\r\n  onSuccess?: (pkgxId: number) => void;\r\n}\r\n\r\nexport function PkgxLinkDialog({\r\n  open,\r\n  onOpenChange,\r\n  product,\r\n  onSuccess,\r\n}: PkgxLinkDialogProps) {\r\n  const { update: updateMutation } = useProductMutations();\r\n  const { data: pkgxSettings } = usePkgxSettings();\r\n  const { setPkgxProducts: setProducts } = usePkgxProductsMutations();\r\n  const cachedPkgxProducts = pkgxSettings?.pkgxProducts ?? [];\r\n  \r\n  const [selectedPkgxProduct, setSelectedPkgxProduct] = React.useState<ComboboxOption | null>(null);\r\n  const [pkgxProducts, setPkgxProductsLocal] = React.useState<PkgxProduct[]>([]);\r\n  const [isLoading, setIsLoading] = React.useState(false);\r\n  const [isSyncing, setIsSyncing] = React.useState(false);\r\n  const [hasFetched, setHasFetched] = React.useState(false);\r\n\r\n  const loadPkgxProducts = React.useCallback(async () => {\r\n    setIsLoading(true);\r\n    try {\r\n      // fetchPkgxProducts not available - use placeholder\r\n      const response: any = { success: false, data: null };\r\n      if (response.success && response.data && response.data.data) {\r\n        // API trأںâ•‘أ؛ vأںâ•—أ¼ { data: PkgxProduct[], pagination: {...} }\r\n        const productsArray = Array.isArray(response.data.data) ? response.data.data : [];\r\n        setPkgxProductsLocal(productsArray);\r\n        setProducts.mutate(productsArray); // Lâ•‍â–‘u vâ”œأ،o store â”€أ¦أںâ•—أ¢ dâ”œâ•£ng chung\r\n        setHasFetched(true);\r\n      }\r\n    } catch (error) {\r\n      console.error('Failed to load PKGX products:', error);\r\n      toast.error('Khâ”œâ”¤ng thأںâ•—أ¢ tأںâ•‘أ؛i danh sâ”œأ­ch sأںâ•‘أ؛n phأںâ•‘âŒگm PKGX');\r\n    } finally {\r\n      setIsLoading(false);\r\n    }\r\n  }, [setProducts]);\r\n\r\n  // Load PKGX products khi mأںâ•—ئ’ dialog - chأںâ•—أ« chأںâ•‘أ­y 1 lأںâ•‘آ؛n\r\n  React.useEffect(() => {\r\n    if (open && !hasFetched) {\r\n      if (cachedPkgxProducts && cachedPkgxProducts.length > 0) {\r\n        setPkgxProductsLocal(cachedPkgxProducts);\r\n        setHasFetched(true);\r\n      } else {\r\n        loadPkgxProducts();\r\n      }\r\n    }\r\n  }, [open, hasFetched, cachedPkgxProducts, loadPkgxProducts]);\r\n\r\n  // Reset state khi â”€أ¦â”œâ”‚ng dialog\r\n  React.useEffect(() => {\r\n    if (!open) {\r\n      setSelectedPkgxProduct(null);\r\n    }\r\n  }, [open]);\r\n\r\n  // Filter out products that are already linked\r\n  const { data: hrmProducts } = useAllProducts();\r\n  const linkedPkgxIds = React.useMemo(() => {\r\n    return new Set(hrmProducts.filter(p => p.pkgxId).map(p => p.pkgxId));\r\n  }, [hrmProducts]);\r\n\r\n  // Convert PKGX products to combobox options\r\n  const pkgxOptions: ComboboxOption[] = React.useMemo(() => {\r\n    return pkgxProducts\r\n      .filter(p => !linkedPkgxIds.has(p.goods_id)) // Exclude already linked\r\n      .map(p => ({\r\n        value: String(p.goods_id),\r\n        label: p.goods_name,\r\n        subtitle: `ID: ${p.goods_id} | Mâ”œأ؛: ${p.goods_sn || '-'}`,\r\n        metadata: p,\r\n      }));\r\n  }, [pkgxProducts, linkedPkgxIds]);\r\n\r\n  const handleConfirmLink = async () => {\r\n    if (!product || !selectedPkgxProduct) {\r\n      toast.error('Vui lâ”œâ–“ng chأںâ•—أ¬n sأںâ•‘أ؛n phأںâ•‘âŒگm PKGX â”€أ¦أںâ•—أ¢ liâ”œآ¬n kأںâ•‘â”گt');\r\n      return;\r\n    }\r\n\r\n    setIsSyncing(true);\r\n    try {\r\n      const pkgxId = Number(selectedPkgxProduct.value);\r\n      \r\n      // Update HRM product with pkgxId\r\n      updateMutation.mutate({ systemId: product.systemId, pkgxId });\r\n      \r\n      // Log to console\r\n\r\n      toast.success(`â”€أ‰â”œأ؛ liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i sأںâ•‘أ؛n phأںâ•‘âŒگm PKGX: ${selectedPkgxProduct.label}`);\r\n      onSuccess?.(pkgxId);\r\n      onOpenChange(false);\r\n    } catch (error) {\r\n      console.error('[PKGX Link Error]', error);\r\n      toast.error('Lأںâ•—أ¹i khi liâ”œآ¬n kأںâ•‘â”گt sأںâ•‘أ؛n phأںâ•‘âŒگm');\r\n    } finally {\r\n      setIsSyncing(false);\r\n    }\r\n  };\r\n\r\n  if (!product) return null;\r\n\r\n  return (\r\n    <Dialog open={open} onOpenChange={onOpenChange}>\r\n      <DialogContent className=\"sm:max-w-[500px]\">\r\n        <DialogHeader>\r\n          <DialogTitle>Liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i sأںâ•‘أ؛n phأںâ•‘âŒگm PKGX</DialogTitle>\r\n          <DialogDescription>\r\n            Chأںâ•—أ¬n sأںâ•‘أ؛n phأںâ•‘âŒگm PKGX â”€أ¦أںâ•—أ¢ liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i sأںâ•‘أ؛n phأںâ•‘âŒگm HRM nâ”œأ،y\r\n          </DialogDescription>\r\n        </DialogHeader>\r\n\r\n        <div className=\"space-y-4 py-4\">\r\n          {/* HRM Product Info */}\r\n          <div className=\"rounded-lg bg-muted p-3\">\r\n            <p className=\"text-sm font-medium\">Sأںâ•‘أ؛n phأںâ•‘âŒگm HRM:</p>\r\n            <p className=\"text-sm\">{product.name}</p>\r\n            <p className=\"text-xs text-muted-foreground\">\r\n              Mâ”œأ؛: {product.id} | SystemID: {product.systemId}\r\n            </p>\r\n          </div>\r\n\r\n          {/* PKGX Product Selector */}\r\n          <div className=\"space-y-2\">\r\n            <label className=\"text-sm font-medium\">Chأںâ•—أ¬n sأںâ•‘أ؛n phأںâ•‘âŒگm PKGX</label>\r\n            <VirtualizedCombobox\r\n              value={selectedPkgxProduct}\r\n              onChange={setSelectedPkgxProduct}\r\n              options={pkgxOptions}\r\n              placeholder=\"Tâ”œآ¼m vâ”œأ، chأںâ•—أ¬n sأںâ•‘أ؛n phأںâ•‘âŒگm PKGX...\"\r\n              searchPlaceholder=\"Tâ”œآ¼m theo tâ”œآ¬n hoأںâ•‘â•–c mâ”œأ؛...\"\r\n              emptyPlaceholder={isLoading ? 'â”€أ‰ang tأںâ•‘أ؛i...' : 'Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y sأںâ•‘أ؛n phأںâ•‘âŒگm PKGX'}\r\n              isLoading={isLoading}\r\n              disabled={isLoading}\r\n            />\r\n            {pkgxOptions.length === 0 && !isLoading && (\r\n              <p className=\"text-xs text-muted-foreground\">\r\n                Tأںâ•‘أ‘t cأںâ•‘أ؛ sأںâ•‘أ؛n ph