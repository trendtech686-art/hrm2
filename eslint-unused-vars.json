 const penaltyForPrint = convertPenaltyForPrint(row, { employee });\r\n                return {\r\n                    data: mapPenaltyToPrintData(penaltyForPrint, penaltyStoreSettings),\r\n                    lineItems: [],\r\n                };\r\n            });\r\n\r\n            printMultiple('penalty', printOptionsList);\r\n            toast.success(`â”€أ‰ang in ${printOptionsList.length} phiأںâ•‘â”گu phأںâ•‘أ­t...`);\r\n        };\r\n\r\n        const handleExportExcel = async (rows: Penalty[]) => {\r\n            if (rows.length === 0) {\r\n                toast.error('Châ•‍â–‘a chأںâ•—أ¬n phiأںâ•‘â”گu phأںâ•‘أ­t nâ”œأ،o');\r\n                return;\r\n            }\r\n\r\n            const headers = ['Mâ”œأ؛ phiأںâ•‘â”گu', 'Lâ”œâ•œ do', 'Ngâ”œأ،y lأںâ•‘آ،p', 'Trأںâ•‘أ­ng thâ”œأ­i', 'Sأںâ•—أ¦ tiأںâ•—أ¼n'];\r\n            const mappedData = rows.map(row => ({\r\n                'Mâ”œأ؛ phiأںâ•‘â”گu': row.id,\r\n                'Lâ”œâ•œ do': row.reason,\r\n                'Ngâ”œأ،y lأںâ•‘آ،p': formatDateDisplay(row.issueDate),\r\n                'Trأںâ•‘أ­ng thâ”œأ­i': row.status,\r\n                'Sأںâ•—أ¦ tiأںâ•—أ¼n': row.amount,\r\n            }));\r\n\r\n            await exportToExcel(mappedData, headers, 'PhieuPhat', `PhieuPhat_${employee?.id || 'NV'}_selected.xlsx`);\r\n            toast.success(`â”€أ‰â”œأ؛ xuأںâ•‘أ‘t ${rows.length} phiأںâ•‘â”گu phأںâ•‘أ­t ra Excel`);\r\n        };\r\n\r\n        return [\r\n            {\r\n                label: 'In phiأںâ•‘â”گu phأںâ•‘أ­t',\r\n                icon: Printer,\r\n                onSelect: handlePrintPenalties,\r\n            },\r\n            {\r\n                label: 'Xuأںâ•‘أ‘t Excel',\r\n                icon: FileSpreadsheet,\r\n                onSelect: handleExportExcel,\r\n            },\r\n        ];\r\n    }, [employee, storeInfo, printMultiple]);\r\n\r\n    // خ“آ£أ  Custom bulk actions cho tab Lأںâ•—أ¯ch sأںâ•—آ، nghأںâ•—أ« phâ”œâŒگp\r\n    const leaveBulkActions = React.useMemo(() => {\r\n        const handlePrintLeaves = (rows: LeaveRequest[]) => {\r\n            if (rows.length === 0) {\r\n                toast.error('Châ•‍â–‘a chأںâ•—أ¬n â”€أ¦â•‍أ­n nghأںâ•—أ« phâ”œâŒگp nâ”œأ،o');\r\n                return;\r\n            }\r\n\r\n            const leaveStoreSettings = createLeaveStoreSettings(storeInfo);\r\n            const printOptionsList = rows.map(row => {\r\n                const leaveForPrint = convertLeaveForPrint(row, { employee });\r\n                return {\r\n                    data: mapLeaveToPrintData(leaveForPrint, leaveStoreSettings),\r\n                    lineItems: [],\r\n                };\r\n            });\r\n\r\n            printMultiple('leave', printOptionsList);\r\n            toast.success(`â”€أ‰ang in ${printOptionsList.length} â”€أ¦â•‍أ­n nghأںâ•—أ« phâ”œâŒگp...`);\r\n        };\r\n\r\n        const handleExportExcel = async (rows: LeaveRequest[]) => {\r\n            if (rows.length === 0) {\r\n                toast.error('Châ•‍â–‘a chأںâ•—أ¬n â”€أ¦â•‍أ­n nghأںâ•—أ« phâ”œâŒگp nâ”œأ،o');\r\n                return;\r\n            }\r\n\r\n            const headers = ['Mâ”œأ؛ â”€أ¦â•‍أ­n', 'Loأںâ•‘أ­i phâ”œâŒگp', 'Tأںâ•—آ½ ngâ”œأ،y', 'â”€أ‰أںâ•‘â”گn ngâ”œأ،y', 'Sأںâ•—أ¦ ngâ”œأ،y', 'Lâ”œâ•œ do', 'Trأںâ•‘أ­ng thâ”œأ­i'];\r\n            const mappedData = rows.map(row => ({\r\n                'Mâ”œأ؛ â”€أ¦â•‍أ­n': row.id,\r\n                'Loأںâ•‘أ­i phâ”œâŒگp': row.leaveTypeName,\r\n                'Tأںâ•—آ½ ngâ”œأ،y': formatDateDisplay(row.startDate),\r\n                'â”€أ‰أںâ•‘â”گn ngâ”œأ،y': formatDateDisplay(row.endDate),\r\n                'Sأںâ•—أ¦ ngâ”œأ،y': row.numberOfDays,\r\n                'Lâ”œâ•œ do': row.reason,\r\n                'Trأںâ•‘أ­ng thâ”œأ­i': row.status,\r\n            }));\r\n\r\n            await exportToExcel(mappedData, headers, 'NghiPhep', `NghiPhep_${employee?.id || 'NV'}_selected.xlsx`);\r\n            toast.success(`â”€أ‰â”œأ؛ xuأںâ•‘أ‘t ${rows.length} â”€أ¦â•‍أ­n nghأںâ•—أ« phâ”œâŒگp ra Excel`);\r\n        };\r\n\r\n        return [\r\n            {\r\n                label: 'In â”€أ¦â•‍أ­n nghأںâ•—أ« phâ”œâŒگp',\r\n                icon: Printer,\r\n                onSelect: handlePrintLeaves,\r\n            },\r\n            {\r\n                label: 'Xuأںâ•‘أ‘t Excel',\r\n                icon: FileSpreadsheet,\r\n                onSelect: handleExportExcel,\r\n            },\r\n        ];\r\n    }, [employee, storeInfo, printMultiple]);\r\n\r\n    // خ“آ£أ  Helper functions cho in â”€أ¦â•‍أ­n lأںâ•‘â•—\r\n    const handlePrintSinglePenalty = React.useCallback((row: Penalty) => {\r\n        const penaltyStoreSettings = createPenaltyStoreSettings(storeInfo);\r\n        const penaltyForPrint = convertPenaltyForPrint(row, { employee });\r\n        print('penalty', {\r\n            data: mapPenaltyToPrintData(penaltyForPrint, penaltyStoreSettings),\r\n            lineItems: [],\r\n        });\r\n    }, [employee, storeInfo, print]);\r\n\r\n    const handlePrintSingleLeave = React.useCallback((row: LeaveRequest) => {\r\n        const leaveStoreSettings = createLeaveStoreSettings(storeInfo);\r\n        const leaveForPrint = convertLeaveForPrint(row, { employee });\r\n        print('leave', {\r\n            data: mapLeaveToPrintData(leaveForPrint, leaveStoreSettings),\r\n            lineItems: [],\r\n        });\r\n    }, [employee, storeInfo, print]);\r\n\r\n    const handleExportSinglePenalty = React.useCallback(async (row: Penalty) => {\r\n        const headers = ['Mâ”œأ؛ phiأںâ•‘â”گu', 'Lâ”œâ•œ do', 'Ngâ”œأ،y lأںâ•‘آ،p', 'Trأںâ•‘أ­ng thâ”œأ­i', 'Sأںâ•—أ¦ tiأںâ•—أ¼n'];\r\n        const mappedData = [{\r\n            'Mâ”œأ؛ phiأںâ•‘â”گu': row.id,\r\n            'Lâ”œâ•œ do': row.reason,\r\n            'Ngâ”œأ،y lأںâ•‘آ،p': formatDateDisplay(row.issueDate),\r\n            'Trأںâ•‘أ­ng thâ”œأ­i': row.status,\r\n            'Sأںâ•—أ¦ tiأںâ•—أ¼n': row.amount,\r\n        }];\r\n        await exportToExcel(mappedData, headers, 'PhieuPhat', `PhieuPhat_${row.id}.xlsx`);\r\n        toast.success('â”€أ‰â”œأ؛ xuأںâ•‘أ‘t phiأںâ•‘â”گu phأںâ•‘أ­t ra Excel');\r\n    }, []);\r\n\r\n    const handleExportSingleLeave = React.useCallback(async (row: LeaveRequest) => {\r\n        const headers = ['Mâ”œأ؛ â”€أ¦â•‍أ­n', 'Loأںâ•‘أ­i phâ”œâŒگp', 'Tأںâ•—آ½ ngâ”œأ،y', 'â”€أ‰أںâ•‘â”گn ngâ”œأ،y', 'Sأںâ•—أ¦ ngâ”œأ،y', 'Lâ”œâ•œ do', 'Trأںâ•‘أ­ng thâ”œأ­i'];\r\n        const mappedData = [{\r\n            'Mâ”œأ؛ â”€أ¦â•‍أ­n': row.id,\r\n            'Loأںâ•‘أ­i phâ”œâŒگp': row.leaveTypeName,\r\n            'Tأںâ•—آ½ ngâ”œأ،y': formatDateDisplay(row.startDate),\r\n            'â”€أ‰أںâ•‘â”گn ngâ”œأ،y': formatDateDisplay(row.endDate),\r\n            'Sأںâ•—أ¦ ngâ”œأ،y': row.numberOfDays,\r\n            'Lâ”œâ•œ do': row.reason,\r\n            'Trأںâ•‘أ­ng thâ”œأ­i': row.status,\r\n        }];\r\n        await exportToExcel(mappedData, headers, 'NghiPhep', `NghiPhep_${row.id}.xlsx`);\r\n        toast.success('â”€أ‰â”œأ؛ xuأںâ•‘أ‘t â”€أ¦â•‍أ­n nghأںâ•—أ« phâ”œâŒگp ra Excel');\r\n    }, []);\r\n\r\n    // خ“آ£أ  Dynamic columns cho Phiأںâ•‘â”گu phأںâ•‘أ­t (câ”œâ”‚ action column)\r\n    const penaltyColumns: ColumnDef<Penalty>[] = React.useMemo(() => [\r\n        { id: 'id', accessorKey: 'id', header: 'Mâ”œأ؛ Phiأںâ•‘â”گu', cell: ({ row }) => <span className=\"font-medium\">{row.id}</span>, meta: { displayName: 'Mâ”œأ؛ Phiأںâ•‘â”گu' } },\r\n        { id: 'reason', accessorKey: 'reason', header: 'Lâ”œâ•œ do', cell: ({ row }) => row.reason, meta: { displayName: 'Lâ”œâ•œ do' } },\r\n        { id: 'issueDate', accessorKey: 'issueDate', header: 'Ngâ”œأ،y', cell: ({ row }) => formatDateDisplay(row.issueDate), meta: { displayName: 'Ngâ”œأ،y' } },\r\n        { id: 'status', accessorKey: 'status', header: 'Trأںâ•‘أ­ng thâ”œأ­i', cell: ({ row }) => <Badge variant={penaltyStatusVariants[row.status]}>{row.status}</Badge>, meta: { displayName: 'Trأںâ•‘أ­ng thâ”œأ­i' } },\r\n        { id: 'amount', accessorKey: 'amount', header: 'Sأںâ•—أ¦ tiأںâ•—أ¼n', cell: ({ row }) => <span className=\"text-destructive font-semibold\">{formatCurrency(row.amount)}</span>, meta: { displayName: 'Sأںâ•—أ¦ tiأںâ•—أ¼n' } },\r\n        { \r\n            id: 'actions', \r\n            header: () => <div className=\"text-center\">Thao tâ”œأ­c</div>, \r\n            cell: ({ row }) => (\r\n                <div className=\"flex items-center justify-center\">\r\n                    <DropdownMenu>\r\n                        <DropdownMenuTrigger asChild>\r\n                            <Button variant=\"ghost\" size=\"sm\" className=\"h-8 w-8 p-0\">\r\n                                <MoreHorizontal className=\"h-4 w-4\" />\r\n                            </Button>\r\n                        </DropdownMenuTrigger>\r\n                        <DropdownMenuContent align=\"end\">\r\n                            <DropdownMenuItem onClick={() => handlePrintSinglePenalty(row)}>\r\n                                <Printer className=\"mr-2 h-4 w-4\" />\r\n                                In phiأںâ•‘â”گu phأںâ•‘أ­t\r\n                            </DropdownMenuItem>\r\n                            <DropdownMenuItem onClick={() => handleExportSinglePenalty(row)}>\r\n                                <FileSpreadsheet className=\"mr-2 h-4 w-4\" />\r\n                                Xuأںâ•‘أ‘t Excel\r\n                            </DropdownMenuItem>\r\n                            <DropdownMenuItem onClick={() => router.push(`/penalties/${row.systemId}`)}>\r\n                                <Eye className=\"mr-2 h-4 w-4\" />\r\n                                Xem chi tiأںâ•‘â”گt\r\n                            </DropdownMenuItem>\r\n                        </DropdownMenuContent>\r\n                    </DropdownMenu>\r\n                </div>\r\n            ), \r\n            meta: { displayName: 'Thao tâ”œأ­c', sticky: 'right' as const } \r\n        },\r\n    ], [handlePrintSinglePenalty, handleExportSinglePenalty, router]);\r\n\r\n    // خ“آ£أ  Dynamic columns cho Lأںâ•—أ¯ch sأںâ•—آ، nghأںâ•—أ« phâ”œâŒگp (câ”œâ”‚ action column)\r\n    const leaveColumns: ColumnDef<LeaveRequest>[] = React.useMemo(() => [\r\n        { id: 'id', accessorKey: 'id', header: 'Mâ”œأ؛ â”€أ¦â•‍أ­n', cell: ({ row }) => <span className=\"font-medium\">{row.id}</span>, meta: { displayName: 'Mâ”œأ؛ â”€أ¦â•‍أ­n' } },\r\n        { id: 'leaveTypeName', accessorKey: 'leaveTypeName', header: 'Loأںâ•‘أ­i phâ”œâŒگp', cell: ({ row }) => row.leaveTypeName, meta: { displayName: 'Loأںâ•‘أ­i phâ”œâŒگp' } },\r\n        { id: 'dateRange', header: 'Thأںâ•—آ¥i gian', cell: ({ row }) => `${formatDateDisplay(row.startDate)} - ${formatDateDisplay(row.endDate)}`, meta: { displayName: 'Thأںâ•—آ¥i gian' } },\r\n        { id: 'numberOfDays', accessorKey: 'numberOfDays', header: 'Sأںâ•—أ¦ ngâ”œأ،y', cell: ({ row }) => row.numberOfDays, meta: { displayName: 'Sأںâ•—أ¦ ngâ”œأ،y' } },\r\n        { id: 'reason', accessorKey: 'reason', header: 'Lâ”œâ•œ do', cell: ({ row }) => <span className=\"truncate max-w-[200px] block\">{row.reason}</span>, meta: { displayName: 'Lâ”œâ•œ do' } },\r\n        { id: 'status', accessorKey: 'status', header: 'Trأںâ•‘أ­ng thâ”œأ­i', cell: ({ row }) => <Badge variant={leaveStatusVariants[row.status]}>{row.status}</Badge>, meta: { displayName: 'Trأںâ•‘أ­ng thâ”œأ­i' } },\r\n        { \r\n            id: 'actions', \r\n            header: () => <div className=\"text-center\">Thao tâ”œأ­c</div>, \r\n            cell: ({ row }) => (\r\n                <div className=\"flex items-center justify-center\">\r\n                    <DropdownMenu>\r\n                        <DropdownMenuTrigger asChild>\r\n                            <Button variant=\"ghost\" size=\"sm\" className=\"h-8 w-8 p-0\">\r\n                                <MoreHorizontal className=\"h-4 w-4\" />\r\n                            </Button>\r\n                        </DropdownMenuTrigger>\r\n                        <DropdownMenuContent align=\"end\">\r\n                            <DropdownMenuItem onClick={() => handlePrintSingleLeave(row)}>\r\n                                <Printer className=\"mr-2 h-4 w-4\" />\r\n                                In â”€أ¦â•‍أ­n nghأںâ•—أ« phâ”œâŒگp\r\n                            </DropdownMenuItem>\r\n                            <DropdownMenuItem onClick={() => handleExportSingleLeave(row)}>\r\n                                <FileSpreadsheet className=\"mr-2 h-4 w-4\" />\r\n                                Xuأںâ•‘أ‘t Excel\r\n                            </DropdownMenuItem>\r\n                            <DropdownMenuItem onClick={() => router.push(`/leaves/${row.systemId}`)}>\r\n                                <Eye className=\"mr-2 h-4 w-4\" />\r\n                                Xem chi tiأںâ•‘â”گt\r\n                            </DropdownMenuItem>\r\n                        </DropdownMenuContent>\r\n                    </DropdownMenu>\r\n                </div>\r\n            ), \r\n            meta: { displayName: 'Thao tâ”œأ­c', sticky: 'right' as const } \r\n        },\r\n    ], [handlePrintSingleLeave, handleExportSingleLeave, router]);\r\n\r\n    // خ“آ£أ  Task row type for RelatedDataTable\r\n    type TaskRow = {\r\n        systemId: string;\r\n        title: string;\r\n        type: string;\r\n        dueDate?: string;\r\n        statusVariant: \"default\" | \"secondary\" | \"warning\" | \"success\" | \"destructive\";\r\n        statusName: string;\r\n        link: string;\r\n    };\r\n\r\n    // خ“آ£أ  Bulk actions cho tab Câ”œâ”¤ng viأںâ•—أ§c\r\n    const taskBulkActions = React.useMemo(() => {\r\n        const handleExportExcel = async (rows: TaskRow[]) => {\r\n            if (rows.length === 0) {\r\n                toast.error('Châ•‍â–‘a chأںâ•—أ¬n câ”œâ”¤ng viأںâ•—أ§c nâ”œأ،o');\r\n                return;\r\n            }\r\n\r\n            const headers = ['Câ”œâ”¤ng viأںâ•—أ§c', 'â”€أ‰أںâ•—أ– â•‍â–‘u tiâ”œآ¬n', 'Hأںâ•‘أ­n châ”œâ”‚t', 'Trأںâ•‘أ­ng thâ”œأ­i'];\r\n            const mappedData = rows.map(row => ({\r\n                'Câ”œâ”¤ng viأںâ•—أ§c': row.title,\r\n                'â”€أ‰أںâ•—أ– â•‍â–‘u tiâ”œآ¬n': row.type,\r\n                'Hأںâ•‘أ­n châ”œâ”‚t': formatDateDisplay(row.dueDate),\r\n                'Trأںâ•‘أ­ng thâ”œأ­i': row.statusName,\r\n            }));\r\n\r\n            // Lazy load XLSX\r\n            const XLSX = await import('xlsx');\r\n            const ws = XLSX.utils.json_to_sheet(mappedData, { header: headers });\r\n            const wb = XLSX.utils.book_new();\r\n            XLSX.utils.book_append_sheet(wb, ws, 'CongViec');\r\n            XLSX.writeFile(wb, `CongViec_${employee?.id || 'NV'}_selected.xlsx`);\r\n            toast.success(`â”€أ‰â”œأ؛ xuأںâ•‘أ‘t ${rows.length} câ”œâ”¤ng viأںâ•—أ§c ra Excel`);\r\n        };\r\n\r\n        return [\r\n            {\r\n                label: 'Xuأںâ•‘أ‘t Excel',\r\n                icon: FileSpreadsheet,\r\n                onSelect: handleExportExcel,\r\n            },\r\n        ];\r\n    }, [employee]);\r\n\r\n    // خ“آ£أ  Helper export single task\r\n    const handleExportSingleTask = React.useCallback(async (row: TaskRow) => {\r\n        const headers = ['Câ”œâ”¤ng viأںâ•—أ§c', 'â”€أ‰أںâ•—أ– â•‍â–‘u tiâ”œآ¬n', 'Hأںâ•‘أ­n châ”œâ”‚t', 'Trأںâ•‘أ­ng thâ”œأ­i'];\r\n        const mappedData = [{\r\n            'Câ”œâ”¤ng viأںâ•—أ§c': row.title,\r\n            'â”€أ‰أںâ•—أ– â•‍â–‘u tiâ”œآ¬n': row.type,\r\n            'Hأںâ•‘أ­n châ”œâ”‚t': formatDateDisplay(row.dueDate),\r\n            'Trأںâ•‘أ­ng thâ”œأ­i': row.statusName,\r\n        }];\r\n        // Lazy load XLSX\r\n        const XLSX = await import('xlsx');\r\n        const ws = XLSX.utils.json_to_sheet(mappedData, { header: headers });\r\n        const wb = XLSX.utils.book_new();\r\n        XLSX.utils.book_append_sheet(wb, ws, 'CongViec');\r\n        XLSX.writeFile(wb, `CongViec_${row.systemId}.xlsx`);\r\n        toast.success('â”€أ‰â”œأ؛ xuأںâ•‘أ‘t câ”œâ”¤ng viأںâ•—أ§c ra Excel');\r\n    }, []);\r\n\r\n    // خ“آ£أ  Dynamic columns cho Câ”œâ”¤ng viأںâ•—أ§c (câ”œâ”‚ action column)\r\n    const taskColumns: ColumnDef<TaskRow>[] = React.useMemo(() => [\r\n        { id: 'title', accessorKey: 'title', header: 'Câ”œâ”¤ng viأںâ•—أ§c', cell: ({ row }) => <span className=\"font-medium\">{row.title}</span>, meta: { displayName: 'Câ”œâ”¤ng viأںâ•—أ§c' } },\r\n        { id: 'type', accessorKey: 'type', header: 'â”€أ‰أںâ•—أ– â•‍â–‘u tiâ”œآ¬n', cell: ({ row }) => row.type, meta: { displayName: 'â”€أ‰أںâ•—أ– â•‍â–‘u tiâ”œآ¬n' } },\r\n        { id: 'dueDate', accessorKey: 'dueDate', header: 'Hأںâ•‘أ­n châ”œâ”‚t', cell: ({ row }) => formatDateDisplay(row.dueDate), meta: { displayName: 'Hأںâ•‘أ­n châ”œâ”‚t' } },\r\n        { id: 'status', accessorKey: 'statusName', header: 'Trأںâ•‘أ­ng thâ”œأ­i', cell: ({ row }) => <Badge variant={row.statusVariant}>{row.statusName}</Badge>, meta: { displayName: 'Trأںâ•‘أ­ng thâ”œأ­i' } },\r\n        { \r\n            id: 'actions', \r\n            header: () => <div className=\"text-center\">Thao tâ”œأ­c</div>, \r\n            cell: ({ row }) => (\r\n                <div className=\"flex items-center justify-center\">\r\n                    <DropdownMenu>\r\n                        <DropdownMenuTrigger asChild>\r\n                            <Button variant=\"ghost\" size=\"sm\" className=\"h-8 w-8 p-0\">\r\n                                <MoreHorizontal className=\"h-4 w-4\" />\r\n                            </Button>\r\n                        </DropdownMenuTrigger>\r\n                        <DropdownMenuContent align=\"end\">\r\n                            <DropdownMenuItem onClick={() => handleExportSingleTask(row)}>\r\n                                <FileSpreadsheet className=\"mr-2 h-4 w-4\" />\r\n                                Xuأںâ•‘أ‘t Excel\r\n                            </DropdownMenuItem>\r\n                            <DropdownMenuItem onClick={() => router.push(row.link)}>\r\n                                <Eye className=\"mr-2 h-4 w-4\" />\r\n                                Xem chi tiأںâ•‘â”گt\r\n                            </DropdownMenuItem>\r\n                        </DropdownMenuContent>\r\n                    </DropdownMenu>\r\n                </div>\r\n            ), \r\n            meta: { displayName: 'Thao tâ”œأ­c', sticky: 'right' as const } \r\n        },\r\n    ], [handleExportSingleTask, router]);\r\n\r\n    const { batches: payrollBatches, payslips: payrollPayslips } = usePayrollBatchStore();\r\n    const payrollHistory = React.useMemo(() => {\r\n        if (!employee) return [] as Array<{ slip: typeof payrollPayslips[number]; batch?: typeof payrollBatches[number] }>;\r\n        return payrollPayslips\r\n            .filter((slip) => slip.employeeSystemId === employee.systemId)\r\n            .map((slip) => ({\r\n                slip,\r\n                batch: payrollBatches.find((batch) => batch.systemId === slip.batchSystemId),\r\n            }))\r\n            .sort((a, b) => {\r\n                const dateA = new Date(a.batch?.payrollDate ?? a.slip.createdAt).getTime();\r\n                const dateB = new Date(b.batch?.payrollDate ?? b.slip.createdAt).getTime();\r\n                return dateB - dateA;\r\n            });\r\n    }, [employee, payrollPayslips, payrollBatches]);\r\n\r\n    const _latestPayslip = payrollHistory[0];\r\n    const displayedPayrollHistory = payrollHistory.slice(0, 5);\r\n\r\n    // State for payslip detail dialog\r\n    const [selectedPayslip, setSelectedPayslip] = React.useState<typeof payrollHistory[number] | null>(null);\r\n    const [isPayslipDialogOpen, setIsPayslipDialogOpen] = React.useState(false);\r\n\r\n    // State for attendance detail dialog\r\n    const [selectedAttendance, setSelectedAttendance] = React.useState<typeof attendanceHistory[number] | null>(null);\r\n    const [isAttendanceDialogOpen, setIsAttendanceDialogOpen] = React.useState(false);\r\n\r\n    // Transform payroll history for RelatedDataTable\r\n    const payrollHistoryTableData: PayrollHistoryRow[] = React.useMemo(() => \r\n        displayedPayrollHistory.map(({ slip, batch }) => ({\r\n            systemId: slip.systemId,\r\n            batchId: batch?.id ?? 'خ“أ‡أ¶',\r\n            monthLabel: formatMonthLabel(batch?.payPeriod.monthKey ?? slip.periodMonthKey),\r\n            payDate: formatDate(batch?.payrollDate || slip.createdAt) || 'خ“أ‡أ¶',\r\n            status: batch?.status ?? 'draft',\r\n            grossEarnings: slip.totals.grossEarnings ?? slip.totals.earnings ?? 0,\r\n            totalInsurance: slip.totals.totalEmployeeInsurance ?? 0,\r\n            personalIncomeTax: slip.totals.personalIncomeTax ?? 0,\r\n            otherDeductions: (slip.totals.penaltyDeductions ?? 0) + (slip.totals.otherDeductions ?? 0),\r\n            totalDeductions: slip.totals.deductions ?? 0,\r\n            netPay: slip.totals.netPay,\r\n            batchSystemId: batch?.systemId,\r\n            payslipSystemId: slip.systemId,\r\n            slip,\r\n            batch,\r\n        })),\r\n    [displayedPayrollHistory]);\r\n\r\n    // Handle print payslip\r\n    // خ“آ£أ  Handler in phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng â”€أ¦â•‍أ­n lأںâ•‘â•— - sأںâ•—آ، dأںâ•—أ‘ng 4-layer print system\r\n    const handlePrintSinglePayslip = React.useCallback((row: PayrollHistoryRow) => {\r\n        if (!row.slip || !employee) {\r\n            toast.error('Khâ”œâ”¤ng thأںâ•—أ¢ in', { description: 'Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y dأںâ•—آ» liأںâ•—أ§u phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng.' });\r\n            return;\r\n        }\r\n\r\n        const storeSettings = createStoreSettings(storeInfo);\r\n        const payslipForPrint = convertPayslipForPrint(\r\n            row.slip,\r\n            row.batch || {\r\n                systemId: '',\r\n                id: row.batchId,\r\n                title: `Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng ${row.monthLabel}`,\r\n                status: row.status,\r\n                payPeriod: { monthKey: row.slip.periodMonthKey },\r\n                payrollDate: row.payDate,\r\n            },\r\n            {\r\n                employee: {\r\n                    fullName: employee.fullName,\r\n                    id: employee.id,\r\n                    department: employee.department,\r\n                    position: employee.positionName,\r\n                },\r\n                departmentName: employee.department,\r\n            }\r\n        );\r\n\r\n        print('payslip', {\r\n            data: mapPayslipToPrintData(payslipForPrint, storeSettings),\r\n            lineItems: mapPayslipComponentLineItems(payslipForPrint.components || []),\r\n        });\r\n\r\n        toast.success('â”€أ‰ang in phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng...', { description: `${employee.fullName} - ${row.monthLabel}` });\r\n    }, [employee, storeInfo, print]);\r\n\r\n    // Payroll columns for RelatedDataTable\r\n    const payrollColumns: ColumnDef<PayrollHistoryRow>[] = React.useMemo(() => [\r\n        { id: 'batchId', accessorKey: 'batchId', header: 'Mâ”œأ؛ BL', size: 95, cell: ({ row }) => (\r\n            <Link href={row.batchSystemId ? ROUTES.PAYROLL.DETAIL.replace(':systemId', row.batchSystemId) : '#'}\r\n                className=\"font-mono text-xs text-primary hover:underline\"\r\n                onClick={(e) => e.stopPropagation()}\r\n            >\r\n                {row.batchId}\r\n            </Link>\r\n        ), meta: { displayName: 'Mâ”œأ؛ BL' } },\r\n        { id: 'monthLabel', accessorKey: 'monthLabel', header: 'Kأںâ•—â”‚ lâ•‍â–‘â•‍أ­ng', size: 110, cell: ({ row }) => <span className=\"whitespace-nowrap\">{row.monthLabel}</span>, meta: { displayName: 'Kأںâ•—â”‚ lâ•‍â–‘â•‍أ­ng' } },\r\n        { id: 'payDate', accessorKey: 'payDate', header: 'Ngâ”œأ،y trأںâ•‘أ؛', size: 100, cell: ({ row }) => <span className=\"whitespace-nowrap\">{row.payDate}</span>, meta: { displayName: 'Ngâ”œأ،y trأںâ•‘أ؛' } },\r\n        { id: 'status', accessorKey: 'status', header: 'Trأںâ•‘أ­ng thâ”œأ­i', size: 90, cell: ({ row }) => <PayrollStatusBadge status={row.status} />, meta: { displayName: 'Trأںâ•‘أ­ng thâ”œأ­i' } },\r\n        { id: 'grossEarnings', accessorKey: 'grossEarnings', header: () => <span className=\"text-right w-full block\">Tأںâ•—أ²ng TN</span>, size: 115, cell: ({ row }) => <span className=\"text-right block tabular-nums\">{formatCurrency(row.grossEarnings)}</span>, meta: { displayName: 'Tأںâ•—أ²ng thu nhأںâ•‘آ،p' } },\r\n        { id: 'totalInsurance', accessorKey: 'totalInsurance', header: () => <span className=\"text-right w-full block\">Bأںâ•‘أ؛o hiأںâ•—أ¢m</span>, size: 100, cell: ({ row }) => <span className=\"text-right block tabular-nums text-orange-600\">{row.totalInsurance > 0 ? `-${formatCurrency(row.totalInsurance)}` : 'خ“أ‡أ¶'}</span>, meta: { displayName: 'Bأںâ•‘أ؛o hiأںâ•—أ¢m' } },\r\n        { id: 'personalIncomeTax', accessorKey: 'personalIncomeTax', header: () => <span className=\"text-right w-full block\">Thuأںâ•‘â”گ TNCN</span>, size: 100, cell: ({ row }) => <span className=\"text-right block tabular-nums text-purple-600\">{row.personalIncomeTax > 0 ? `-${formatCurrency(row.personalIncomeTax)}` : 'خ“أ‡أ¶'}</span>, meta: { displayName: 'Thuأںâ•‘â”گ TNCN' } },\r\n        { id: 'otherDeductions', accessorKey: 'otherDeductions', header: () => <span className=\"text-right w-full block\">Khâ”œأ­c</span>, size: 90, cell: ({ row }) => <span className=\"text-right block tabular-nums text-gray-600\">{row.otherDeductions > 0 ? `-${formatCurrency(row.otherDeductions)}` : 'خ“أ‡أ¶'}</span>, meta: { displayName: 'Khأںâ•‘أ‘u trأںâ•—آ½ khâ”œأ­c' } },\r\n        { id: 'totalDeductions', accessorKey: 'totalDeductions', header: () => <span className=\"text-right w-full block\">Tأںâ•—أ²ng trأںâ•—آ½</span>, size: 110, cell: ({ row }) => <span className=\"text-right block tabular-nums text-destructive font-medium\">{formatCurrency(row.totalDeductions)}</span>, meta: { displayName: 'Tأںâ•—أ²ng khأںâ•‘أ‘u trأںâ•—آ½' } },\r\n        { id: 'netPay', accessorKey: 'netPay', header: () => <span className=\"text-right w-full block\">Thأںâ•—â–’c lâ”€âŒگnh</span>, size: 120, cell: ({ row }) => <span className=\"text-right block tabular-nums font-bold text-green-600\">{formatCurrency(row.netPay)}</span>, meta: { displayName: 'Thأںâ•—â–’c lâ”€âŒگnh' } },\r\n        { \r\n            id: 'actions', \r\n            header: '', \r\n            size: 50,\r\n            cell: ({ row }) => (\r\n                <div onClick={(e) => e.stopPropagation()}>\r\n                    <DropdownMenu>\r\n                        <DropdownMenuTrigger asChild>\r\n                            <Button variant=\"ghost\" size=\"icon\" className=\"h-8 w-8\">\r\n                                <MoreHorizontal className=\"h-4 w-4\" />\r\n                                <span className=\"sr-only\">Mأںâ•—ئ’ menu</span>\r\n                            </Button>\r\n                        </DropdownMenuTrigger>\r\n                        <DropdownMenuContent align=\"end\">\r\n                            <DropdownMenuItem onClick={() => {\r\n                                setSelectedPayslip({ slip: row.slip, batch: row.batch });\r\n                                setIsPayslipDialogOpen(true);\r\n                            }}>\r\n                                <Eye className=\"mr-2 h-4 w-4\" />\r\n                                Xem chi tiأںâ•‘â”گt\r\n                            </DropdownMenuItem>\r\n                            <DropdownMenuItem onClick={() => handlePrintSinglePayslip(row)}>\r\n                                <Printer className=\"mr-2 h-4 w-4\" />\r\n                                In phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng\r\n                            </DropdownMenuItem>\r\n                            <DropdownMenuItem onClick={() => {\r\n                                if (row.batchSystemId) {\r\n                                    router.push(ROUTES.PAYROLL.DETAIL.replace(':systemId', row.batchSystemId));\r\n                                }\r\n                            }}>\r\n                                <ExternalLink className=\"mr-2 h-4 w-4\" />\r\n                                Xem bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng\r\n                            </DropdownMenuItem>\r\n                        </DropdownMenuContent>\r\n                    </DropdownMenu>\r\n                </div>\r\n            ), \r\n            meta: { displayName: 'Thao tâ”œأ­c', sticky: 'right' as const } \r\n        },\r\n    ], [router, handlePrintSinglePayslip]);\r\n\r\n    const handlePayrollRowClick = React.useCallback((row: PayrollHistoryRow) => {\r\n        const historyItem = displayedPayrollHistory.find(h => h.slip.systemId === row.systemId);\r\n        if (historyItem) {\r\n            setSelectedPayslip(historyItem);\r\n            setIsPayslipDialogOpen(true);\r\n        }\r\n    }, [displayedPayrollHistory]);\r\n\r\n    const handleViewPayroll = React.useCallback(\r\n        (batchSystemId?: string) => {\r\n            if (!batchSystemId) return;\r\n            router.push(ROUTES.PAYROLL.DETAIL.replace(':systemId', batchSystemId));\r\n        },\r\n        [router]\r\n    );\r\n\r\n    // خ“آ£أ  Custom bulk actions for payroll table - sأںâ•—آ، dأںâ•—أ‘ng 4-layer print system\r\n    const payrollBulkActions = React.useMemo(() => {\r\n        const handlePrintPayslips = (rows: PayrollHistoryRow[]) => {\r\n            if (rows.length === 0) {\r\n                toast.error('Châ•‍â–‘a chأںâ•—أ¬n phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng nâ”œأ،o');\r\n                return;\r\n            }\r\n\r\n            const storeSettings = createStoreSettings(storeInfo);\r\n\r\n            // In nhiأںâ•—أ¼u phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng câ”œâ•£ng lâ”œâ•‘c\r\n            const printOptionsList = rows.map(row => {\r\n                const payslipForPrint = convertPayslipForPrint(\r\n                    row.slip,\r\n                    row.batch || {\r\n                        systemId: '',\r\n                        id: row.batchId,\r\n                        title: `Bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng ${row.monthLabel}`,\r\n                        status: row.status,\r\n                        payPeriod: { monthKey: row.slip.periodMonthKey },\r\n                        payrollDate: row.payDate,\r\n                    },\r\n                    {\r\n                        employee: employee ? {\r\n                            fullName: employee.fullName,\r\n                            id: employee.id,\r\n                            department: employee.department,\r\n                            position: employee.positionName,\r\n                        } : undefined,\r\n                        departmentName: employee?.department,\r\n                    }\r\n                );\r\n\r\n                return {\r\n                    data: mapPayslipToPrintData(payslipForPrint, storeSettings),\r\n                    lineItems: mapPayslipComponentLineItems(payslipForPrint.components || []),\r\n                };\r\n            });\r\n\r\n            // Sأںâ•—آ، dأںâ•—أ‘ng printMultiple â”€أ¦أںâ•—أ¢ in nhiأںâ•—أ¼u phiأںâ•‘â”گu câ”œâ•£ng lâ”œâ•‘c\r\n            printMultiple('payslip', printOptionsList);\r\n            toast.success(`â”€أ‰ang in ${rows.length} phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng...`);\r\n        };\r\n\r\n        const handleExportExcel = async (rows: PayrollHistoryRow[]) => {\r\n            if (rows.length === 0) {\r\n                toast.error('Châ•‍â–‘a chأںâ•—أ¬n dأںâ•—آ» liأںâ•—أ§u nâ”œأ،o');\r\n                return;\r\n            }\r\n\r\n            const headers = ['Mâ”œأ؛ BL', 'Kأںâ•—â”‚ lâ•‍â–‘â•‍أ­ng', 'Ngâ”œأ،y trأںâ•‘أ؛', 'Trأںâ•‘أ­ng thâ”œأ­i', 'Tأںâ•—أ²ng TN', 'Bأںâ•‘أ؛o hiأںâ•—أ¢m', 'Thuأںâ•‘â”گ TNCN', 'Khأںâ•‘أ‘u trأںâ•—آ½ khâ”œأ­c', 'Tأںâ•—أ²ng trأںâ•—آ½', 'Thأںâ•—â–’c lâ”€âŒگnh'];\r\n            const mappedData = rows.map(row => ({\r\n                'Mâ”œأ؛ BL': row.batchId,\r\n                'Kأںâ•—â”‚ lâ•‍â–‘â•‍أ­ng': row.monthLabel,\r\n                'Ngâ”œأ،y trأںâ•‘أ؛': row.payDate,\r\n                'Trأںâ•‘أ­ng thâ”œأ­i': row.status,\r\n                'Tأںâ•—أ²ng TN': row.grossEarnings,\r\n                'Bأںâ•‘أ؛o hiأںâ•—أ¢m': row.totalInsurance,\r\n                'Thuأںâ•‘â”گ TNCN': row.personalIncomeTax,\r\n                'Khأںâ•‘أ‘u trأںâ•—آ½ khâ”œأ­c': row.otherDeductions,\r\n                'Tأںâ•—أ²ng trأںâ•—آ½': row.totalDeductions,\r\n                'Thأںâ•—â–’c lâ”€âŒگnh': row.netPay,\r\n            }));\r\n\r\n            // Lazy load XLSX\r\n            const XLSX = await import('xlsx');\r\n            const ws = XLSX.utils.json_to_sheet(mappedData, { header: headers });\r\n            const wb = XLSX.utils.book_new();\r\n            XLSX.utils.book_append_sheet(wb, ws, 'Lâ•‍â–‘â•‍أ­ng');\r\n            XLSX.writeFile(wb, `Luong_${employee?.id || 'NV'}_selected.xlsx`);\r\n            toast.success(`â”€أ‰â”œأ؛ xuأںâ•‘أ‘t ${rows.length} dâ”œâ–“ng ra Excel`);\r\n        };\r\n\r\n        return [\r\n            {\r\n                label: 'In phiأںâ•‘â”گu lâ•‍â–‘â•‍أ­ng',\r\n                icon: Printer,\r\n                onSelect: handlePrintPayslips,\r\n            },\r\n            {\r\n                label: 'Xuأںâ•‘أ‘t Excel',\r\n                icon: FileSpreadsheet,\r\n                onSelect: handleExportExcel,\r\n            },\r\n        ];\r\n    }, [employee, storeInfo, printMultiple]);\r\n\r\n    // Actions for detail page\r\n    const headerActions = React.useMemo(() => [\r\n        <Button key=\"back\" variant=\"outline\" size=\"sm\" className=\"h-9\" onClick={() => router.push('/employees')}>\r\n            <ArrowLeft className=\"mr-2 h-4 w-4\" />\r\n            Quay lأںâ•‘أ­i\r\n        </Button>,\r\n        <Button key=\"edit\" size=\"sm\" className=\"h-9\" onClick={() => router.push(`/employees/${systemId}/edit`)}>\r\n            <Edit className=\"mr-2 h-4 w-4\" />\r\n            Chأںâ•—أ«nh sأںâ•—آ،a\r\n        </Button>\r\n    ], [router, systemId]);\r\n\r\n  // خ“آ£أ  Auto-generate breadcrumb\r\n  const breadcrumb = React.useMemo(() => {\r\n    if (!employee) return [\r\n      { label: 'Trang chأںâ•—آ؛', href: '/', isCurrent: false },\r\n      { label: 'Nhâ”œأ³n viâ”œآ¬n', href: '/employees', isCurrent: false },\r\n      { label: 'Chi tiأںâ•‘â”گt', href: '', isCurrent: true }\r\n    ];\r\n    return [\r\n      { label: 'Trang chأںâ•—آ؛', href: '/', isCurrent: false },\r\n      { label: 'Nhâ”œأ³n viâ”œآ¬n', href: '/employees', isCurrent: false },\r\n            { label: employee.fullName, href: '', isCurrent: true }\r\n    ];\r\n  }, [employee]);\r\n\r\n    const headerBadge = React.useMemo(() => renderEmploymentStatusBadge(employee?.employmentStatus), [employee?.employmentStatus]);\r\n\r\n  usePageHeader({\r\n        title: employee?.fullName || 'Chi tiأںâ•‘â”گt Nhâ”œأ³n viâ”œآ¬n',\r\n        badge: headerBadge,\r\n    actions: headerActions,\r\n        breadcrumb\r\n  });\r\n\r\n  // Loading state while React Query is fetching\r\n  if (isLoading) {\r\n    return (\r\n      <div className=\"space-y-6 p-6\">\r\n        <div className=\"flex items-center gap-4\">\r\n          <Skeleton className=\"h-24 w-24 rounded-full\" />\r\n          <div className=\"space-y-2\">\r\n            <Skeleton className=\"h-6 w-48\" />\r\n            <Skeleton className=\"h-4 w-32\" />\r\n            <Skeleton className=\"h-4 w-24\" />\r\n          </div>\r\n        </div>\r\n        <div className=\"grid grid-cols-1 md:grid-cols-4 gap-4\">\r\n          <Skeleton className=\"h-24\" />\r\n          <Skeleton className=\"h-24\" />\r\n          <Skeleton className=\"h-24\" />\r\n          <Skeleton className=\"h-24\" />\r\n        </div>\r\n        <Card>\r\n          <CardHeader>\r\n            <Skeleton className=\"h-5 w-32\" />\r\n          </CardHeader>\r\n          <CardContent className=\"space-y-4\">\r\n            <Skeleton className=\"h-4 w-full\" />\r\n            <Skeleton className=\"h-4 w-3/4\" />\r\n          </CardContent>\r\n        </Card>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  if (!employee) {\r\n    return (\r\n      <div className=\"flex h-full items-center justify-center\">\r\n        <div className=\"text-center\">\r\n          <h2 className=\"text-h3 font-bold\">Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y nhâ”œأ³n viâ”œآ¬n</h2>\r\n          <p className=\"text-muted-foreground mt-2\">Nhâ”œأ³n viâ”œآ¬n bأںâ•‘أ­n â”€أ¦ang tâ”œآ¼m kiأںâ•‘â”گm khâ”œâ”¤ng tأںâ•—أ´n tأںâ•‘أ­i.</p>\r\n          <Button onClick={() => router.push('/employees')} className=\"mt-4\" size=\"sm\">\r\n            <ArrowLeft className=\"mr-2 h-4 w-4\" />\r\n            Quay vأںâ•—أ¼ danh sâ”œأ­ch\r\n          </Button>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  const getInitials = (name: string) => {\r\n    return name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);\r\n  };\r\n\r\n  const calculateWorkDuration = () => {\r\n    if (!employee.hireDate) return '0 thâ”œأ­ng';\r\n    const months = getMonthsDiff(employee.hireDate, new Date());\r\n    const years = Math.floor(months / 12);\r\n    const remainingMonths = months % 12;\r\n    if (years > 0) {\r\n      return `${years} nâ”€أ¢m ${remainingMonths > 0 ? `${remainingMonths} thâ”œأ­ng` : ''}`;\r\n    }\r\n    return `${months} thâ”œأ­ng`;\r\n  };\r\n\r\n  return (\r\n    <div className=\"w-full h-full\">\r\n      <div className=\"space-y-6\">\r\n        {/* Profile Card */}\r\n        <Card>\r\n            <CardContent className=\"pt-6\">\r\n                <div className=\"flex flex-col sm:flex-row gap-6\">\r\n                    <Avatar className=\"h-20 w-20\">\r\n                        <AvatarImage src={employee.avatarUrl} alt={employee.fullName} />\r\n                        <AvatarFallback>{getInitials(employee.fullName)}</AvatarFallback>\r\n                    </Avatar>\r\n                    <div className=\"flex-1 space-y-3\">\r\n                        <div className=\"grid gap-1\">\r\n                            <div className=\"flex items-center gap-2 text-sm text-muted-foreground\">\r\n                                <Mail className=\"h-4 w-4\" />\r\n                                <span>{employee.workEmail || 'خ“أ‡أ¶'}</span>\r\n                            </div>\r\n                            <div className=\"flex items-center gap-2 text-sm text-muted-foreground\">\r\n                                <Phone className=\"h-4 w-4\" />\r\n                                <span>{employee.phone || 'خ“أ‡أ¶'}</span>\r\n                            </div>\r\n                            <div className=\"flex items-center gap-2 text-sm text-muted-foreground\">\r\n                                <Building2 className=\"h-4 w-4\" />\r\n                                {employee.branchSystemId ? (\r\n                                    <Link href={`/branches/${employee.branchSystemId}`}\r\n                                        className=\"hover:underline text-primary\"\r\n                                    >\r\n                                        {branchName}\r\n                                    </Link>\r\n                                ) : (\r\n                                    <span>{branchName}</span>\r\n                                )}\r\n                            </div>\r\n                            <div className=\"flex items-center gap-2 text-sm text-muted-foreground\">\r\n                                <Calendar className=\"h-4 w-4\" />\r\n                                <span>Lâ”œأ،m viأںâ•—أ§c {calculateWorkDuration()}</span>\r\n                            </div>\r\n                        </div>\r\n                        <div className=\"flex flex-wrap gap-2\">\r\n                            <Badge variant={(employee.employmentStatus as any) === \"ACTIVE\" || employee.employmentStatus?.includes(\"lâ”œأ،m viأںâ•—أ§c\") ? \"default\" : (employee.employmentStatus as any) === \"ON_LEAVE\" || employee.employmentStatus?.includes(\"nghأںâ•—أ«\") ? \"secondary\" : \"destructive\"}>\r\n                                {formatEmploymentStatusDisplay(employee.employmentStatus)}\r\n                            </Badge>\r\n                            <Badge variant=\"outline\">{formatEmployeeTypeDisplay(employee.employeeType)}</Badge>\r\n                            <Badge variant=\"outline\">{employee.id}</Badge>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </CardContent>\r\n        </Card>\r\n\r\n        {/* Stats */}\r\n        <div className=\"grid gap-4 md:grid-cols-2 lg:grid-cols-4\">\r\n            <StatsCard\r\n                title=\"Lâ•‍â–‘â•‍أ­ng câ•‍أ­ bأںâ•‘أ؛n\"\r\n                value={formatCurrency(employee.baseSalary)}\r\n                icon={DollarSign}\r\n                description=\"/ thâ”œأ­ng\"\r\n            />\r\n            <StatsCard\r\n                title=\"Ngâ”œأ،y phâ”œâŒگp câ”œâ–“n lأںâ•‘أ­i\"\r\n                value={12 - (employee.leaveTaken || 0)}\r\n                icon={Calendar}\r\n                description={`â”€أ‰â”œأ؛ dâ”œâ•£ng ${employee.leaveTaken || 0}/12 ngâ”œأ،y`}\r\n            />\r\n            <StatsCard\r\n                title=\"Câ”œâ”¤ng viأںâ•—أ§c\"\r\n                value={employeeTasks.length}\r\n                icon={Briefcase}\r\n                description={`${employeeTasks.filter((t) => t.statusName !== 'Hoâ”œأ،n thâ”œأ،nh').length} â”€أ¦ang lâ”œأ،m`}\r\n            />\r\n        </div>\r\n\r\n        <Tabs defaultValue=\"personal\">\r\n            <div className=\"w-full overflow-x-auto overflow-y-hidden mb-4 pb-1\" style={{ WebkitOverflowScrolling: 'touch', scrollbarWidth: 'thin' }}>\r\n                <TabsList className=\"inline-flex w-auto gap-1 p-1 h-auto justify-start\">\r\n                    <TabsTrigger value=\"personal\" className=\"flex-shrink-0 px-3 py-2 text-sm font-normal whitespace-nowrap\">Thâ”œâ”¤ng tin câ”œأ­ nhâ”œأ³n</TabsTrigger>\r\n                    <TabsTrigger value=\"addresses\" className=\"flex-shrink-0 px-3 py-2 text-sm font-normal whitespace-nowrap\">â”€أ‰أںâ•—أ¯a chأںâ•—أ«</TabsTrigger>\r\n                    <TabsTrigger value=\"work\" className=\"flex-shrink-0 px-3 py-2 text-sm font-normal whitespace-nowrap\">Thâ”œâ”¤ng tin câ”œâ”¤ng viأںâ•—أ§c</TabsTrigger>\r\n                    <TabsTrigger value=\"account\" className=\"flex-shrink-0 px-3 py-2 text-sm font-normal whitespace-nowrap\">Thâ”œâ”¤ng tin â”€أ¦â”€أ¢ng nhأںâ•‘آ،p</TabsTrigger>\r\n                    <TabsTrigger value=\"documents\" className=\"flex-shrink-0 px-3 py-2 text-sm font-normal whitespace-nowrap\">Tâ”œأ،i liأںâ•—أ§u</TabsTrigger>\r\n                    <TabsTrigger value=\"penalties\" className=\"flex-shrink-0 px-3 py-2 text-sm font-normal whitespace-nowrap\">Phiأںâ•‘â”گu phأںâ•‘أ­t</TabsTrigger>\r\n                    <TabsTrigger value=\"leaves\" className=\"flex-shrink-0 px-3 py-2 text-sm font-normal whitespace-nowrap\">Lأںâ•—أ¯ch sأںâ•—آ، nghأںâ•—أ« phâ”œâŒگp</TabsTrigger>\r\n                    <TabsTrigger value=\"kpi\" className=\"flex-shrink-0 px-3 py-2 text-sm font-normal whitespace-nowrap\">KPI</TabsTrigger>\r\n                    <TabsTrigger value=\"tasks\" className=\"flex-shrink-0 px-3 py-2 text-sm font-normal whitespace-nowrap\">Câ”œâ”¤ng viأںâ•—أ§c</TabsTrigger>\r\n                    <TabsTrigger value=\"payroll\" className=\"flex-shrink-0 px-3 py-2 text-sm font-normal whitespace-nowrap\">Lâ•‍â–‘â•‍أ­ng & chأںâ•‘أ‘m câ”œâ”¤ng</TabsTrigger>\r\n                </TabsList>\r\n            </div>\r\n\r\n            <TabsContent value=\"personal\" className=\"space-y-4\">\r\n                <div className=\"grid gap-4 md:grid-cols-2\">\r\n                    {/* Personal Information */}\r\n                    <Card>\r\n                        <CardHeader>\r\n                            <CardTitle className=\"text-h6\">Thâ”œâ”¤ng tin câ”œأ­ nhâ”œأ³n</CardTitle>\r\n                        </CardHeader>\r\n                        <CardContent className=\"grid gap-4\">\r\n                            <InfoItem label=\"Giأںâ•—آ¢i tâ”œآ،nh\" value={formatGenderDisplay(employee.gender)} />\r\n                            <InfoItem label=\"Ngâ”œأ،y sinh\" value={formatDate(employee.dob)} />\r\n                            <InfoItem label=\"Nâ•‍أ­i sinh\" value={employee.placeOfBirth} />\r\n                            <InfoItem label=\"Tâ”œآ¼nh trأںâ•‘أ­ng hâ”œâ”¤n nhâ”œأ³n\" value={employee.maritalStatus} />\r\n                            <InfoItem label=\"Sأںâ•—أ¦ â”€أ¦iأںâ•—أ§n thoأںâ•‘أ­i\" value={employee.phone} />\r\n                            <InfoItem label=\"Email câ”œأ­ nhâ”œأ³n\" value={employee.personalEmail} />\r\n                        </CardContent>\r\n                    </Card>\r\n\r\n                    {/* Identification & Bank */}\r\n                    <Card>\r\n                        <CardHeader>\r\n                            <CardTitle className=\"text-h6\">â”€أ‰أںâ•—أ¯nh danh & Ngâ”œأ³n hâ”œأ،ng</CardTitle>\r\n                        </CardHeader>\r\n                        <CardContent className=\"grid gap-4\">\r\n                            <InfoItem label=\"Sأںâ•—أ¦ CCCD\" value={employee.nationalId} />\r\n                            <InfoItem label=\"Ngâ”œأ،y cأںâ•‘أ‘p\" value={formatDate(employee.nationalIdIssueDate)} />\r\n                            <InfoItem label=\"Nâ•‍أ­i cأںâ•‘أ‘p\" value={employee.nationalIdIssuePlace} />\r\n                            <InfoItem label=\"Mâ”œأ؛ sأںâ•—أ¦ thuأںâ•‘â”گ\" value={employee.personalTaxId} />\r\n                            <InfoItem label=\"Sأںâ•—أ¦ sأںâ•—أ² BHXH\" value={employee.socialInsuranceNumber} />\r\n                            <InfoItem label=\"Ngâ”œأ³n hâ”œأ،ng\" value={employee.bankName} />\r\n                            <InfoItem label=\"Chi nhâ”œأ­nh\" value={employee.bankBranch} />\r\n                            <InfoItem label=\"Sأںâ•—أ¦ tâ”œأ،i khoأںâ•‘أ؛n\" value={employee.bankAccountNumber} />\r\n                        </CardContent>\r\n                    </Card>\r\n\r\n                    {/* Emergency Contact */}\r\n                    <Card className=\"md:col-span-2\">\r\n                        <CardHeader>\r\n                            <CardTitle className=\"text-h6\">Liâ”œآ¬n hأںâ•—أ§ khأںâ•‘âŒگn cأںâ•‘أ‘p</CardTitle>\r\n                        </CardHeader>\r\n                        <CardContent className=\"grid gap-4 md:grid-cols-2\">\r\n                            <InfoItem label=\"Tâ”œآ¬n ngâ•‍â–‘أںâ•—آ¥i thâ”œأ³n\" value={employee.emergencyContactName} />\r\n                            <InfoItem label=\"Sâ”€أ‰T ngâ•‍â–‘أںâ•—آ¥i thâ”œأ³n\" value={employee.emergencyContactPhone} />\r\n                        </CardContent>\r\n                    </Card>\r\n                </div>\r\n            </TabsContent>\r\n\r\n            <TabsContent value=\"addresses\" className=\"space-y-4\">\r\n                <div className=\"grid gap-4 md:grid-cols-2\">\r\n                    <Card>\r\n                        <CardHeader>\r\n                            <CardTitle className=\"text-h6\">â”€أ‰أںâ•—أ¯a chأںâ•—أ« thâ•‍â–‘أںâ•—آ¥ng trâ”œâ•‘</CardTitle>\r\n                        </CardHeader>\r\n                        <CardContent className=\"grid gap-4\">\r\n                             {employee.permanentAddress ? (\r\n                                <>\r\n                                    <InfoItem label=\"Sأںâ•—أ¦ nhâ”œأ،, â”€أ¦â•‍â–‘أںâ•—آ¥ng\" value={employee.permanentAddress.street} />\r\n                                    <InfoItem label=\"Phâ•‍â–‘أںâ•—آ¥ng/Xâ”œأ؛\" value={employee.permanentAddress.ward} />\r\n                                    {employee.permanentAddress.inputLevel === '3-level' && (\r\n                                        <InfoItem label=\"Quأںâ•‘آ،n/Huyأںâ•—أ§n\" value={employee.permanentAddress.district} />\r\n                                    )}\r\n                                    <InfoItem label=\"Tأںâ•—أ«nh/Thâ”œأ،nh phأںâ•—أ¦\" value={employee.permanentAddress.province} />\r\n                                    <InfoItem label=\"â”€أ‰أںâ•‘آ؛y â”€أ¦أںâ•—آ؛\" value={formatAddressDisplay(employee.permanentAddress)} />\r\n                                </>\r\n                             ) : (\r\n                                 <p className=\"text-sm text-muted-foreground\">Châ•‍â–‘a cأںâ•‘آ،p nhأںâ•‘آ،t</p>\r\n                             )}\r\n                        </CardContent>\r\n                    </Card>\r\n                    <Card>\r\n                        <CardHeader>\r\n                            <CardTitle className=\"text-h6\">â”€أ‰أںâ•—أ¯a chأںâ•—أ« tأںâ•‘أ­m trâ”œâ•‘</CardTitle>\r\n                        </CardHeader>\r\n                        <CardContent className=\"grid gap-4\">\r\n                             {employee.temporaryAddress ? (\r\n                                <>\r\n                                    <InfoItem label=\"Sأںâ•—أ¦ nhâ”œأ،, â”€أ¦â•‍â–‘أںâ•—آ¥ng\" value={employee.temporaryAddress.street} />\r\n                                    <InfoItem label=\"Phâ•‍â–‘أںâ•—آ¥ng/Xâ”œأ؛\" value={employee.temporaryAddress.ward} />\r\n                                    {employee.temporaryAddress.inputLevel === '3-level' && (\r\n                                        <InfoItem label=\"Quأںâ•‘آ،n/Huyأںâ•—أ§n\" value={employee.temporaryAddress.district} />\r\n                                    )}\r\n                                    <InfoItem label=\"Tأںâ•—أ«nh/Thâ”œأ،nh phأںâ•—أ¦\" value={employee.temporaryAddress.province} />\r\n                                    <InfoItem label=\"â”€أ‰أںâ•‘آ؛y â”€أ¦أںâ•—آ؛\" value={formatAddressDisplay(employee.temporaryAddress)} />\r\n                                </>\r\n                             ) : (\r\n                                 <p className=\"text-sm text-muted-foreground\">Châ•‍â–‘a cأںâ•‘آ،p nhأںâ•‘آ،t</p>\r\n                             )}\r\n                        </CardContent>\r\n                    </Card>\r\n                </div>\r\n            </TabsContent>\r\n\r\n            <TabsContent value=\"work\" className=\"space-y-4\">\r\n                <div className=\"grid gap-4 md:grid-cols-2\">\r\n                    {/* Work Information */}\r\n                    <Card>\r\n                        <CardHeader>\r\n                            <CardTitle className=\"text-h6\">Thâ”œâ”¤ng tin câ”œâ”¤ng viأںâ•—أ§c</CardTitle>\r\n                        </CardHeader>\r\n                        <CardContent className=\"grid gap-4\">\r\n                            <InfoItem label=\"Email câ”œâ”¤ng viأںâ•—أ§c\" value={employee.workEmail} />\r\n                            <InfoItem label=\"Chi nhâ”œأ­nh\">\r\n                                {employee.branchSystemId ? (\r\n                                    <Link href={`/branches/${employee.branchSystemId}`}\r\n                                        className=\"hover:underline text-primary\"\r\n                                    >\r\n                                        {branchName}\r\n                                    </Link>\r\n                                ) : (\r\n                                    <span>{branchName}</span>\r\n                                )}\r\n                            </InfoItem>\r\n                            <InfoItem label=\"Phâ”œâ–“ng ban\" value={typeof employee.department === 'object' ? (employee.department as { name?: string })?.name : employee.department} />\r\n                            <InfoItem label=\"Chأںâ•—âŒگc danh\" value={typeof employee.jobTitle === 'object' ? (employee.jobTitle as { name?: string })?.name : employee.jobTitle} />\r\n                            <InfoItem label=\"Sأںâ•—أ¦ hأںâ•—أ؛p â”€أ¦أںâ•—أ´ng\" value={employee.contractNumber} />\r\n                            <InfoItem label=\"Ngâ”œأ،y kâ”œâ•œ Hâ”€أ‰\" value={formatDate(employee.contractStartDate)} />\r\n                            <InfoItem label=\"Ngâ”œأ،y hأںâ•‘â”گt hأںâ•‘أ­n Hâ”€أ‰\" value={formatDate(employee.contractEndDate)} />\r\n                            <InfoItem label=\"Ngâ”œأ،y vâ”œأ،o lâ”œأ،m\" value={formatDate(employee.hireDate)} />\r\n                            <InfoItem label=\"Loأںâ•‘أ­i nhâ”œأ³n viâ”œآ¬n\" value={formatEmployeeTypeDisplay(employee.employeeType)} />\r\n                            <InfoItem label=\"Trأںâ•‘أ­ng thâ”œأ­i\">\r\n                                <Badge variant={(employee.employmentStatus as any) === \"ACTIVE\" || employee.employmentStatus?.includes(\"lâ”œأ،m viأںâ•—أ§c\") ? \"default\" : (employee.employmentStatus as any) === \"ON_LEAVE\" || employee.employmentStatus?.includes(\"nghأںâ•—أ«\") ? \"secondary\" : \"destructive\"}>\r\n                                    {formatEmploymentStatusDisplay(employee.employmentStatus)}\r\n                                </Badge>\r\n                            </InfoItem>\r\n                            {employee.terminationDate && (\r\n                                <InfoItem label=\"Ngâ”œأ،y nghأںâ•—أ« viأںâ•—أ§c\" value={formatDate(employee.terminationDate)} />\r\n                            )}\r\n                            {employee.reasonForLeaving && (\r\n                                <InfoItem label=\"Lâ”œâ•œ do nghأںâ•—أ« viأںâ•—أ§c\" value={employee.reasonForLeaving} />\r\n                            )}\r\n                        </CardContent>\r\n                    </Card>\r\n\r\n                    {/* Salary & Allowances */}\r\n                    <Card>\r\n                        <CardHeader>\r\n                            <CardTitle className=\"text-h6\">Lâ•‍â–‘â•‍أ­ng & Phأںâ•—أ‘ cأںâ•‘أ‘p</CardTitle>\r\n                        </CardHeader>\r\n                        <CardContent className=\"grid gap-4\">\r\n                            <InfoItem label=\"Lâ•‍â–‘â•‍أ­ng câ•‍أ­ bأںâ•‘أ؛n\" value={formatCurrency(employee.baseSalary)} />\r\n                            <InfoItem label=\"Lâ•‍â–‘â•‍أ­ng â”€أ¦â”œâ”‚ng BHXH\" value={formatCurrency(employee.socialInsuranceSalary)} />\r\n                            <InfoItem label=\"Phأںâ•—أ‘ cأںâ•‘أ‘p chأںâ•—âŒگc vأںâ•—أ‘\" value={formatCurrency(employee.positionAllowance)} />\r\n                            <InfoItem label=\"Phأںâ•—أ‘ cأںâ•‘أ‘p â”€أ¢n trâ•‍â–‘a\" value={formatCurrency(employee.mealAllowance)} />\r\n                            <InfoItem label=\"Phأںâ•—أ‘ cأںâ•‘أ‘p khâ”œأ­c\" value={formatCurrency(employee.otherAllowances)} />\r\n                            <InfoItem label=\"Phâ”œâŒگp â”€أ¦â”œأ؛ nghأںâ•—أ«\" value={`${employee.leaveTaken || 0} / 12 ngâ”œأ،y`} />\r\n                        </CardContent>\r\n                    </Card>\r\n                </div>\r\n            </TabsContent>\r\n\r\n            <TabsContent value=\"account\" className=\"space-y-4\">\r\n                <EmployeeAccountTab employee={employee} />\r\n            </TabsContent>\r\n\r\n            <TabsContent value=\"documents\" className=\"space-y-4\">\r\n                <EmployeeDocuments employeeSystemId={employee.systemId || employee.id} />\r\n            </TabsContent>\r\n\r\n            <TabsContent value=\"penalties\" className=\"space-y-4\">\r\n                <Card>\r\n                    <CardContent className=\"p-4\">\r\n                        <RelatedDataTable \r\n                            data={employeePenalties} \r\n                            columns={penaltyColumns} \r\n                            searchKeys={['reason', 'id']} \r\n                            searchPlaceholder=\"Tâ”œآ¼m theo lâ”œâ•œ do...\" \r\n                            dateFilterColumn=\"issueDate\" \r\n                            dateFilterTitle=\"Ngâ”œأ،y lأںâ•‘آ،p phiأںâ•‘â”گu\" \r\n                            exportFileName={`Lich_su_phat_${employee.id}`} \r\n                            onRowClick={(row) => router.push(`/penalties/${row.systemId}`)} \r\n                            showCheckbox\r\n                            customBulkActions={penaltyBulkActions}\r\n                        />\r\n                    </CardContent>\r\n                </Card>\r\n            </TabsContent>\r\n\r\n            <TabsContent value=\"leaves\" className=\"space-y-4\"