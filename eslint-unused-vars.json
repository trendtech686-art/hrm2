أ،ng (DH001) - câ”œâ”‚ thأںâ•—أ¢ â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng nأںâ•‘â”گu muأںâ•—أ¦n auto-gen\r\n  customerId: string;           // Mâ”œأ؛ khâ”œأ­ch hâ”œأ،ng - chأںâ•—أ« cأںâ•‘آ؛n â”€أ¦iأںâ•—أ¼n أںâ•—ئ’ dâ”œâ–“ng â”€أ¦أںâ•‘آ؛u mأںâ•—أ¹i â”€أ¦â•‍أ­n\r\n  branchName?: string;          // Chi nhâ”œأ­nh (tâ”œآ¬n hoأںâ•‘â•–c mâ”œأ؛)\r\n  salespersonName?: string;     // Nhâ”œأ³n viâ”œآ¬n bâ”œأ­n (tâ”œآ¬n hoأںâ•‘â•–c mâ”œأ؛)\r\n  productSku: string;           // SKU sأںâ•‘أ؛n phأںâ•‘âŒگm\r\n  quantity: number;             // Sأںâ•—أ¦ lâ•‍â–‘أںâ•—أ؛ng\r\n  unitPrice?: number;           // â”€أ‰â•‍أ­n giâ”œأ­ (nأںâ•‘â”گu khâ”œâ”¤ng câ”œâ”‚ thâ”œآ¼ lأںâ•‘أ‘y tأںâ•—آ½ SP)\r\n  lineNote?: string;            // Ghi châ”œâ•‘ dâ”œâ–“ng sأںâ•‘أ؛n phأںâ•‘âŒگm\r\n  orderNote?: string;           // Ghi châ”œâ•‘ â”€أ¦â•‍أ­n hâ”œأ،ng\r\n  orderDate?: string;           // Ngâ”œأ،y â”€أ¦أںâ•‘â•–t hâ”œأ،ng\r\n  source?: string;              // Nguأںâ•—أ´n â”€أ¦â•‍أ­n\r\n  tags?: string;                // Tags (comma separated)\r\n}\r\n\r\n// ============================================\r\n// FIELD CONFIGURATION\r\n// ============================================\r\n\r\nexport const orderFields: FieldConfig<OrderImportRow>[] = [\r\n  // ===== Thâ”œâ”¤ng tin â”€أ¦â•‍أ­n hâ”œأ،ng =====\r\n  {\r\n    key: 'orderId',\r\n    label: 'Mâ”œأ؛ â”€أ¦â•‍أ­n hâ”œأ،ng (*)',\r\n    type: 'string',\r\n    required: true,  // Bأںâ•‘آ»t buأںâ•—أ–c â”€أ¦iأںâ•—أ¼n أںâ•—ئ’ dâ”œâ–“ng â”€أ¦أںâ•‘آ؛u, câ”œأ­c dâ”œâ–“ng SP sau câ”œâ”‚ thأںâ•—أ¢ â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng\r\n    example: 'DH001',\r\n    group: 'â”€أ‰â•‍أ­n hâ”œأ،ng',\r\n    defaultSelected: true,\r\n    // preProcessRows sأںâ•‘â•œ fill-down cho câ”œأ­c dâ”œâ–“ng SP sau\r\n  },\r\n  {\r\n    key: 'customerId',\r\n    label: 'Mâ”œأ؛ khâ”œأ­ch hâ”œأ،ng (*)',\r\n    type: 'string',\r\n    required: true,  // Bأںâ•‘آ»t buأںâ•—أ–c â”€أ¦iأںâ•—أ¼n أںâ•—ئ’ dâ”œâ–“ng â”€أ¦أںâ•‘آ؛u, câ”œأ­c dâ”œâ–“ng SP sau câ”œâ”‚ thأںâ•—أ¢ â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng\r\n    example: 'KH001',\r\n    group: 'â”€أ‰â•‍أ­n hâ”œأ،ng',\r\n    defaultSelected: true,\r\n    // preProcessRows sأںâ•‘â•œ fill-down cho câ”œأ­c dâ”œâ–“ng SP sau\r\n  },\r\n  {\r\n    key: 'branchName',\r\n    label: 'Chi nhâ”œأ­nh',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Chi nhâ”œأ­nh Hâ”œأ، Nأںâ•—أ–i',\r\n    group: 'â”€أ‰â•‍أ­n hâ”œأ،ng',\r\n    defaultSelected: true,\r\n    validator: (value) => {\r\n      if (value && String(value).trim() !== '') {\r\n        const branch = (findBranch as any)(String(value));\r\n        if (!branch) {\r\n          return `Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y chi nhâ”œأ­nh \"${value}\"`;\r\n        }\r\n      }\r\n      return true;\r\n    },\r\n  },\r\n  {\r\n    key: 'salespersonName',\r\n    label: 'Nhâ”œأ³n viâ”œآ¬n bâ”œأ­n hâ”œأ،ng',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Nguyأںâ•—أ n Vâ”€أ¢n A',\r\n    group: 'â”€أ‰â•‍أ­n hâ”œأ،ng',\r\n    defaultSelected: true,\r\n    validator: (value) => {\r\n      if (value && String(value).trim() !== '') {\r\n        const employee = (findEmployee as any)(String(value));\r\n        if (!employee) {\r\n          return `Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y nhâ”œأ³n viâ”œآ¬n \"${value}\"`;\r\n        }\r\n      }\r\n      return true;\r\n    },\r\n  },\r\n  {\r\n    key: 'orderDate',\r\n    label: 'Ngâ”œأ،y â”€أ¦أںâ•‘â•–t hâ”œأ،ng',\r\n    type: 'date',\r\n    required: false,\r\n    example: '19/12/2024',\r\n    group: 'â”€أ‰â•‍أ­n hâ”œأ،ng',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'source',\r\n    label: 'Nguأںâ•—أ´n â”€أ¦â•‍أ­n',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Website',\r\n    group: 'â”€أ‰â•‍أ­n hâ”œأ،ng',\r\n    defaultSelected: false,\r\n  },\r\n  {\r\n    key: 'tags',\r\n    label: 'Tags',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'VIP, Gأںâ•‘أ‘p',\r\n    group: 'â”€أ‰â•‍أ­n hâ”œأ،ng',\r\n    defaultSelected: false,\r\n  },\r\n  {\r\n    key: 'orderNote',\r\n    label: 'Ghi châ”œâ•‘ â”€أ¦â•‍أ­n hâ”œأ،ng',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Giao buأںâ•—أ²i sâ”œأ­ng',\r\n    group: 'â”€أ‰â•‍أ­n hâ”œأ،ng',\r\n    defaultSelected: true,\r\n  },\r\n\r\n  // ===== Thâ”œâ”¤ng tin sأںâ•‘أ؛n phأںâ•‘âŒگm =====\r\n  {\r\n    key: 'productSku',\r\n    label: 'SKU sأںâ•‘أ؛n phأںâ•‘âŒگm (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'SP001',\r\n    group: 'Sأںâ•‘أ؛n phأںâ•‘âŒگm',\r\n    defaultSelected: true,\r\n    validator: (value) => {\r\n      if (!value || String(value).trim() === '') {\r\n        return 'SKU sأںâ•‘أ؛n phأںâ•‘âŒگm khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng';\r\n      }\r\n      const product = (findProductBySku as any)(String(value));\r\n      if (!product) {\r\n        return `Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y sأںâ•‘أ؛n phأںâ•‘âŒگm vأںâ•—آ¢i SKU \"${value}\"`;\r\n      }\r\n      return true;\r\n    },\r\n  },\r\n  {\r\n    key: 'quantity',\r\n    label: 'Sأںâ•—أ¦ lâ•‍â–‘أںâ•—أ؛ng (*)',\r\n    type: 'number',\r\n    required: true,\r\n    example: '2',\r\n    group: 'Sأںâ•‘أ؛n phأںâ•‘âŒگm',\r\n    defaultSelected: true,\r\n    validator: (value) => {\r\n      const qty = Number(value);\r\n      if (isNaN(qty) || qty <= 0) {\r\n        return 'Sأںâ•—أ¦ lâ•‍â–‘أںâ•—أ؛ng phأںâ•‘أ؛i lâ”œأ، sأںâ•—أ¦ dâ•‍â–‘â•‍أ­ng';\r\n      }\r\n      return true;\r\n    },\r\n    importTransform: (value) => {\r\n      const num = Number(value);\r\n      return isNaN(num) ? 1 : Math.max(1, Math.floor(num));\r\n    },\r\n  },\r\n  {\r\n    key: 'unitPrice',\r\n    label: 'â”€أ‰â•‍أ­n giâ”œأ­',\r\n    type: 'number',\r\n    required: false,\r\n    example: '150000',\r\n    group: 'Sأںâ•‘أ؛n phأںâ•‘âŒگm',\r\n    defaultSelected: true,\r\n    importTransform: (value) => {\r\n      if (value === undefined || value === null || value === '') return undefined;\r\n      const num = Number(value);\r\n      return isNaN(num) ? undefined : Math.max(0, num);\r\n    },\r\n  },\r\n  {\r\n    key: 'lineNote',\r\n    label: 'Ghi châ”œâ•‘ SP',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Mâ”œأ،u â”€أ¦أںâ•—أ…',\r\n    group: 'Sأںâ•‘أ؛n phأںâ•‘âŒگm',\r\n    defaultSelected: false,\r\n  },\r\n];\r\n\r\n// ============================================\r\n// FIELD GROUPS FOR EXPORT\r\n// ============================================\r\n\r\nexport const orderFieldGroups = [\r\n  {\r\n    id: 'order-info',\r\n    label: 'Thâ”œâ”¤ng tin â”€أ¦â•‍أ­n hâ”œأ،ng',\r\n    columns: [\r\n      { key: 'id', label: 'Mâ”œأ؛ â”€أ¦â•‍أ­n hâ”œأ،ng', defaultSelected: true },\r\n      { key: 'orderDate', label: 'Ngâ”œأ،y â”€أ¦أںâ•‘â•–t', defaultSelected: true },\r\n      { key: 'status', label: 'Trأںâ•‘أ­ng thâ”œأ­i', defaultSelected: true },\r\n      { key: 'source', label: 'Nguأںâ•—أ´n â”€أ¦â•‍أ­n', defaultSelected: false },\r\n      { key: 'tags', label: 'Tags', defaultSelected: false },\r\n      { key: 'notes', label: 'Ghi châ”œâ•‘', defaultSelected: false },\r\n    ],\r\n  },\r\n  {\r\n    id: 'customer-info',\r\n    label: 'Thâ”œâ”¤ng tin khâ”œأ­ch hâ”œأ،ng',\r\n    columns: [\r\n      { key: 'customerId', label: 'Mâ”œأ؛ KH', defaultSelected: true },\r\n      { key: 'customerName', label: 'Tâ”œآ¬n khâ”œأ­ch hâ”œأ،ng', defaultSelected: true },\r\n      { key: 'customerPhone', label: 'Sâ”€أ‰T khâ”œأ­ch', defaultSelected: true },\r\n      { key: 'shippingAddress', label: 'â”€أ‰أںâ•—أ¯a chأںâ•—أ« giao', defaultSelected: true },\r\n    ],\r\n  },\r\n  {\r\n    id: 'product-info',\r\n    label: 'Thâ”œâ”¤ng tin sأںâ•‘أ؛n phأںâ•‘âŒگm',\r\n    columns: [\r\n      { key: 'productSku', label: 'SKU', defaultSelected: true },\r\n      { key: 'productName', label: 'Tâ”œآ¬n sأںâ•‘أ؛n phأںâ•‘âŒگm', defaultSelected: true },\r\n      { key: 'quantity', label: 'Sأںâ•—أ¦ lâ•‍â–‘أںâ•—أ؛ng', defaultSelected: true },\r\n      { key: 'unitPrice', label: 'â”€أ‰â•‍أ­n giâ”œأ­', defaultSelected: true },\r\n      { key: 'lineTotal', label: 'Thâ”œأ،nh tiأںâ•—أ¼n', defaultSelected: true },\r\n      { key: 'lineNote', label: 'Ghi châ”œâ•‘ SP', defaultSelected: false },\r\n    ],\r\n  },\r\n  {\r\n    id: 'payment-info',\r\n    label: 'Thanh toâ”œأ­n',\r\n    columns: [\r\n      { key: 'subtotal', label: 'Tأںâ•‘أ­m tâ”œآ،nh', defaultSelected: true },\r\n      { key: 'shippingFee', label: 'Phâ”œآ، ship', defaultSelected: false },\r\n      { key: 'orderDiscount', label: 'Chiأںâ•‘â”گt khأںâ•‘أ‘u', defaultSelected: false },\r\n      { key: 'grandTotal', label: 'Tأںâ•—أ²ng tiأںâ•—أ¼n', defaultSelected: true },\r\n      { key: 'paidAmount', label: 'â”€أ‰â”œأ؛ thanh toâ”œأ­n', defaultSelected: true },\r\n      { key: 'paymentStatus', label: 'Trأںâ•‘أ­ng thâ”œأ­i TT', defaultSelected: true },\r\n    ],\r\n  },\r\n  {\r\n    id: 'delivery-info',\r\n    label: 'Vأںâ•‘آ،n chuyأںâ•—أ¢n',\r\n    columns: [\r\n      { key: 'deliveryMethod', label: 'Phâ•‍â–‘â•‍أ­ng thأںâ•—âŒگc giao', defaultSelected: true },\r\n      { key: 'deliveryStatus', label: 'Trأںâ•‘أ­ng thâ”œأ­i giao', defaultSelected: true },\r\n      { key: 'trackingCode', label: 'Mâ”œأ؛ vأںâ•‘آ،n â”€أ¦â•‍أ­n', defaultSelected: false },\r\n      { key: 'carrier', label: 'â”€أ‰VVC', defaultSelected: false },\r\n    ],\r\n  },\r\n  {\r\n    id: 'branch-staff',\r\n    label: 'Chi nhâ”œأ­nh & Nhâ”œأ³n viâ”œآ¬n',\r\n    columns: [\r\n      { key: 'branchName', label: 'Chi nhâ”œأ­nh', defaultSelected: true },\r\n      { key: 'salesperson', label: 'Nhâ”œأ³n viâ”œآ¬n bâ”œأ­n', defaultSelected: true },\r\n    ],\r\n  },\r\n];\r\n\r\n// ============================================\r\n// MAIN CONFIG\r\n// ============================================\r\n\r\nexport const orderImportExportConfig: ImportExportConfig<Order> = {\r\n  entityType: 'orders',\r\n  entityDisplayName: 'â”€أ‰â•‍أ­n hâ”œأ،ng',\r\n  \r\n  fields: orderFields as unknown as FieldConfig<Order>[],\r\n  \r\n  templateFileName: 'Mau_Nhap_Don_Hang.xlsx',\r\n  sheetName: 'â”€أ‰â•‍أ­n hâ”œأ،ng',\r\n  \r\n  // Import settings\r\n  upsertKey: 'id',\r\n  allowUpdate: false,  // Chأںâ•—أ« cho phâ”œâŒگp thâ”œآ¬m mأںâ•—آ¢i, khâ”œâ”¤ng update â”€أ¦â•‍أ­n hâ”œأ،ng qua import\r\n  allowInsert: true,\r\n  \r\n  requirePreview: true,\r\n  maxRows: 1000,\r\n  maxErrorsAllowed: 0,  // Khâ”œâ”¤ng cho phâ”œâŒگp lأںâ•—أ¹i\r\n  \r\n  // Pre-process: Fill empty orderId/customerId from previous row\r\n  // User must fill orderId + customerId on first row of each order\r\n  // Subsequent product rows can leave them empty خ“أ¥أ† will inherit from previous row\r\n  preProcessRows: (rows: unknown[]) => {\r\n    const importRows = rows as OrderImportRow[];\r\n    let currentOrderId = '';\r\n    let currentCustomerId = '';\r\n    \r\n    for (const row of importRows) {\r\n      // If orderId is provided, use it and update current\r\n      if (row.orderId?.trim()) {\r\n        currentOrderId = row.orderId.trim();\r\n        // Also update customerId if provided on the same row\r\n        if (row.customerId?.trim()) {\r\n          currentCustomerId = row.customerId.trim();\r\n        }\r\n      } else if (currentOrderId) {\r\n        // Fill from previous row's orderId (for subsequent product lines)\r\n        row.orderId = currentOrderId;\r\n      }\r\n      // Note: if orderId is empty and no previous orderId خ“أ¥أ† validation will catch it\r\n      \r\n      // Fill customerId if empty (inherit from previous row)\r\n      if (!row.customerId?.trim() && currentCustomerId) {\r\n        row.customerId = currentCustomerId;\r\n      } else if (row.customerId?.trim()) {\r\n        currentCustomerId = row.customerId.trim();\r\n      }\r\n    }\r\n    \r\n    return importRows;\r\n  },\r\n  \r\n  // Validate row (after pre-processing)\r\n  validateRow: (row, _index, existingData, mode) => {\r\n    const errors: Array<{ field?: string; message: string }> = [];\r\n    const importRow = row as unknown as OrderImportRow;\r\n    \r\n    // Check required fields - orderId must be filled on first row of each order\r\n    if (!importRow.orderId) {\r\n      errors.push({ field: 'orderId', message: 'Mâ”œأ؛ â”€أ¦â•‍أ­n hâ”œأ،ng khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng (bأںâ•‘آ»t buأںâ•—أ–c â”€أ¦iأںâ•—أ¼n أںâ•—ئ’ dâ”œâ–“ng â”€أ¦أںâ•‘آ؛u cأںâ•—آ؛a mأںâ•—أ¹i â”€أ¦â•‍أ­n)' });\r\n    }\r\n    if (!importRow.customerId) {\r\n      errors.push({ field: 'customerId', message: 'Mâ”œأ؛ khâ”œأ­ch hâ”œأ،ng khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng (â”€أ¦iأںâ•—أ¼n أںâ•—ئ’ dâ”œâ–“ng â”€أ¦أںâ•‘آ؛u cأںâ•—آ؛a mأںâ•—أ¹i â”€أ¦â•‍أ­n)' });\r\n    }\r\n    if (!importRow.productSku) {\r\n      errors.push({ field: 'productSku', message: 'SKU sأںâ•‘أ؛n phأںâ•‘âŒگm khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    // Validate customer\r\n    if (importRow.customerId) {\r\n      const customer = (findCustomerById as any)(importRow.customerId);\r\n      if (!customer) {\r\n        errors.push({ field: 'customerId', message: `Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y khâ”œأ­ch hâ”œأ،ng \"${importRow.customerId}\"` });\r\n      }\r\n    }\r\n    \r\n    // Validate product\r\n    if (importRow.productSku) {\r\n      const product = (findProductBySku as any)(importRow.productSku);\r\n      if (!product) {\r\n        errors.push({ field: 'productSku', message: `Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y sأںâ•‘أ؛n phأںâ•‘âŒگm \"${importRow.productSku}\"` });\r\n      }\r\n    }\r\n    \r\n    // Validate branch if provided\r\n    if (importRow.branchName) {\r\n      const branch = (findBranch as any)(importRow.branchName);\r\n      if (!branch) {\r\n        errors.push({ field: 'branchName', message: `Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y chi nhâ”œأ­nh \"${importRow.branchName}\"` });\r\n      }\r\n    }\r\n    \r\n    // Validate salesperson if provided\r\n    if (importRow.salespersonName) {\r\n      const employee = (findEmployee as any)(importRow.salespersonName);\r\n      if (!employee) {\r\n        errors.push({ field: 'salespersonName', message: `Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y nhâ”œأ³n viâ”œآ¬n \"${importRow.salespersonName}\"` });\r\n      }\r\n    }\r\n    \r\n    // Validate quantity\r\n    if (importRow.quantity !== undefined) {\r\n      const qty = Number(importRow.quantity);\r\n      if (isNaN(qty) || qty <= 0) {\r\n        errors.push({ field: 'quantity', message: 'Sأںâ•—أ¦ lâ•‍â–‘أںâ•—أ؛ng phأںâ•‘أ؛i lâ”œأ، sأںâ•—أ¦ dâ•‍â–‘â•‍أ­ng' });\r\n      }\r\n    }\r\n    \r\n    // Check duplicate order ID in existing data (only in insert-only mode)\r\n    if (mode === 'insert-only' && importRow.orderId) {\r\n      const duplicate = existingData.find(o => \r\n        o.id.toUpperCase() === importRow.orderId.toUpperCase()\r\n      );\r\n      if (duplicate) {\r\n        errors.push({ field: 'orderId', message: `Mâ”œأ؛ â”€أ¦â•‍أ­n hâ”œأ،ng \"${importRow.orderId}\" â”€أ¦â”œأ؛ tأںâ•—أ´n tأںâ•‘أ­i` });\r\n      }\r\n    }\r\n    \r\n    return errors;\r\n  },\r\n  \r\n  // Transform: Group rows by orderId and build Order objects\r\n  // This is handled in postTransformRow and beforeImport\r\n  beforeImport: async (data: Order[]) => {\r\n    // data here is actually OrderImportRow[] after field transforms\r\n    const importRows = data as unknown as OrderImportRow[];\r\n    \r\n    // Group rows by orderId\r\n    const orderMap = new Map<string, {\r\n      rows: OrderImportRow[];\r\n      customer?: Customer;\r\n      branch?: ReturnType<typeof findBranch>;\r\n      employee?: ReturnType<typeof findEmployee>;\r\n    }>();\r\n    \r\n    for (const row of importRows) {\r\n      const orderId = row.orderId?.trim().toUpperCase();\r\n      if (!orderId) continue;\r\n      \r\n      if (!orderMap.has(orderId)) {\r\n        const customer = (findCustomerById as any)(row.customerId);\r\n        const branch = row.branchName ? (findBranch as any)(row.branchName) : (getDefaultBranch as any)();\r\n        const employee = row.salespersonName ? (findEmployee as any)(row.salespersonName) : undefined;\r\n        \r\n        orderMap.set(orderId, {\r\n          rows: [],\r\n          customer,\r\n          branch,\r\n          employee,\r\n        });\r\n      }\r\n      orderMap.get(orderId)!.rows.push(row);\r\n    }\r\n    \r\n    // Build Order objects\r\n    const orders: Order[] = [];\r\n    const now = new Date().toISOString();\r\n    \r\n    for (const [orderId, { rows, customer, branch, employee }] of orderMap.entries()) {\r\n      if (!customer || rows.length === 0) continue;\r\n      \r\n      // Build line items\r\n      const lineItems: LineItem[] = [];\r\n      for (const row of rows) {\r\n        const product = (findProductBySku as any)(row.productSku);\r\n        if (!product) continue;\r\n        \r\n        const quantity = Math.max(1, Math.floor(Number(row.quantity) || 1));\r\n        const unitPrice = row.unitPrice ?? product.sellingPrice ?? product.costPrice ?? 0;\r\n        \r\n        lineItems.push({\r\n          productSystemId: product.systemId,\r\n          productId: product.id,\r\n          productName: product.name,\r\n          quantity,\r\n          unitPrice,\r\n          discount: 0,\r\n          discountType: 'fixed',\r\n          note: row.lineNote,\r\n        });\r\n      }\r\n      \r\n      if (lineItems.length === 0) continue;\r\n      \r\n      // Calculate totals\r\n      const subtotal = lineItems.reduce((sum, item) => {\r\n        return sum + (item.unitPrice * item.quantity);\r\n      }, 0);\r\n      \r\n      // Get first row for order-level data\r\n      const firstRow = rows[0];\r\n      \r\n      // Parse order date\r\n      let orderDate = now;\r\n      if (firstRow.orderDate) {\r\n        const parsed = new Date(firstRow.orderDate);\r\n        if (!isNaN(parsed.getTime())) {\r\n          orderDate = parsed.toISOString();\r\n        }\r\n      }\r\n      \r\n      // Build shipping address from customer\r\n      const shippingAddress = getCustomerShippingAddress(customer);\r\n      \r\n      // Parse tags\r\n      const tags = firstRow.tags \r\n        ? firstRow.tags.split(',').map(t => t.trim()).filter(Boolean)\r\n        : undefined;\r\n      \r\n      const order: Order = {\r\n        systemId: asSystemId(''), // Will be assigned by store\r\n        id: asBusinessId(orderId),\r\n        customerSystemId: customer.systemId,\r\n        customerName: customer.name,\r\n        branchSystemId: branch?.systemId || asSystemId(''),\r\n        branchName: branch?.name || '',\r\n        salespersonSystemId: employee?.systemId || asSystemId(''),\r\n        salesperson: employee?.fullName || '',\r\n        orderDate,\r\n        \r\n        // Statuses - all new orders start with \"â”€أ‰أںâ•‘â•–t hâ”œأ،ng\"\r\n        status: 'â”€أ‰أںâ•‘â•–t hâ”œأ،ng',\r\n        paymentStatus: 'Châ•‍â–‘a thanh toâ”œأ­n',\r\n        deliveryStatus: 'Chأںâ•—آ¥ â”€أ¦â”œâ”‚ng gâ”œâ”‚i',\r\n        printStatus: 'Châ•‍â–‘a in',\r\n        stockOutStatus: 'Châ•‍â–‘a xuأںâ•‘أ‘t kho',\r\n        returnStatus: 'Châ•‍â–‘a trأںâ•‘أ؛ hâ”œأ،ng',\r\n        deliveryMethod: 'Dأںâ•—أ¯ch vأںâ•—أ‘ giao hâ”œأ،ng',\r\n        \r\n        // Address\r\n        shippingAddress,\r\n        \r\n        // Line items\r\n        lineItems,\r\n        \r\n        // Totals (no discount, no shipping fee from import)\r\n        subtotal,\r\n        shippingFee: 0,\r\n        tax: 0,\r\n        grandTotal: subtotal,\r\n        paidAmount: 0,\r\n        codAmount: 0,\r\n        \r\n        // Arrays\r\n        payments: [],\r\n        packagings: [],\r\n        \r\n        // Optional fields\r\n        notes: firstRow.orderNote,\r\n        source: firstRow.source,\r\n        tags,\r\n        \r\n        // Timestamps\r\n        createdAt: now,\r\n        updatedAt: now,\r\n      };\r\n      \r\n      orders.push(order);\r\n    }\r\n    \r\n    return orders;\r\n  },\r\n};\r\n\r\n// ============================================\r\n// EXPORT HELPERS\r\n// ============================================\r\n\r\n/**\r\n * Flatten orders to rows for export (1 row per line item)\r\n * @param orders - Array of orders to flatten\r\n * @param customers - Optional array of customers for lookup. If not provided, customer info will be limited to what's stored in order.\r\n */\r\nexport function flattenOrdersForExport(orders: Order[], customers?: Customer[]): Array<Record<string, unknown>> {\r\n  const rows: Array<Record<string, unknown>> = [];\r\n  \r\n  for (const order of orders) {\r\n    // Get customer info from provided array or fallback to order data\r\n    const customer = customers ? findCustomerById(order.customerSystemId, customers) : undefined;\r\n    \r\n    // Get latest packaging for tracking info\r\n    const latestPackaging = order.packagings?.[order.packagings.length - 1];\r\n    \r\n    for (const item of order.lineItems) {\r\n      rows.push({\r\n        // Order info\r\n        id: order.id,\r\n        orderDate: order.orderDate,\r\n        status: order.status,\r\n        source: order.source || '',\r\n        tags: order.tags?.join(', ') || '',\r\n        notes: order.notes || '',\r\n        \r\n        // Customer info\r\n        customerId: customer?.id || '',\r\n        customerName: order.customerName,\r\n        customerPhone: customer?.phone || '',\r\n        shippingAddress: typeof order.shippingAddress === 'string' \r\n          ? order.shippingAddress \r\n          : (order.shippingAddress as OrderAddress)?.formattedAddress || '',\r\n        \r\n        // Product info\r\n        productSku: item.productId,\r\n        productName: item.productName,\r\n        quantity: item.quantity,\r\n        unitPrice: item.unitPrice,\r\n        lineTotal: item.unitPrice * item.quantity,\r\n        lineNote: item.note || '',\r\n        \r\n        // Payment info\r\n        subtotal: order.subtotal,\r\n        shippingFee: order.shippingFee,\r\n        orderDiscount: order.orderDiscount || 0,\r\n        grandTotal: order.grandTotal,\r\n        paidAmount: order.paidAmount,\r\n        paymentStatus: order.paymentStatus,\r\n        \r\n        // Delivery info\r\n        deliveryMethod: order.deliveryMethod,\r\n        deliveryStatus: order.deliveryStatus,\r\n        trackingCode: latestPackaging?.trackingCode || '',\r\n        carrier: latestPackaging?.carrier || '',\r\n        \r\n        // Branch & Staff\r\n        branchName: order.branchName,\r\n        salesperson: order.salesperson,\r\n      });\r\n    }\r\n  }\r\n  \r\n  return rows;\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\lib\\import-export\\configs\\packaging.config.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\lib\\import-export\\configs\\payment.config.ts","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":260,"column":48,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":260,"endColumn":51,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[7684,7687],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[7684,7687],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":261,"column":62,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":261,"endColumn":65,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[7754,7757],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[7754,7757],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"m