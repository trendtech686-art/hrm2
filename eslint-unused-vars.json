                            {formatCurrency(calculatedDebt)}\r\n                              </p>\r\n                            </div>\r\n                            <div className=\"space-y-1\">\r\n                              <p className=\"text-body-xs text-muted-foreground\">Tأںâ•—أ²ng â”€أ¦â•‍أ­n nhأںâ•‘آ،p</p>\r\n                              <p className=\"text-body-sm font-semibold\">\r\n                                {formatCurrency(supplierPurchaseOrders.reduce((sum, po) => sum + po.grandTotal, 0))}\r\n                              </p>\r\n                            </div>\r\n                            <div className=\"space-y-1\">\r\n                              <p className=\"text-body-xs text-muted-foreground\">Trأںâ•‘أ؛ hâ”œأ،ng</p>\r\n                              <p className=\"text-body-sm font-semibold text-orange-600\">\r\n                                {formatCurrency(totalReturnValueForSupplier)}\r\n                              </p>\r\n                            </div>\r\n                          </div>\r\n                        </div>\r\n                      </CardContent>\r\n                  </Card>\r\n              </div>\r\n\r\n              <div className=\"lg:col-span-1\">\r\n                  <Card className=\"h-[300px] flex flex-col\">\r\n                      <CardHeader>\r\n                        <CardTitle className=\"text-h3\">Thâ”œâ”¤ng tin â”€أ¦â•‍أ­n nhأںâ•‘آ،p hâ”œأ،ng</CardTitle>\r\n                      </CardHeader>\r\n                      <CardContent className=\"flex-1 overflow-y-auto text-body-sm space-y-3\">\r\n                          <DetailField label=\"Chi nhâ”œأ­nh\" value={purchaseOrder.branchName} />\r\n                          <DetailField label=\"Châ”œآ،nh sâ”œأ­ch giâ”œأ­\" value=\"Giâ”œأ­ nhأںâ•‘آ،p\" />\r\n                          <DetailField label=\"Nhâ”œأ³n viâ”œآ¬n phأںâ•—أ‘ trâ”œأ­ch\" value={purchaseOrder.buyer} />\r\n                          <DetailField label=\"Ngâ”œأ،y â”€أ¦أںâ•‘â•–