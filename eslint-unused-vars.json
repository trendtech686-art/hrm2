\n      </Button>,\r\n      <Button \r\n        key=\"process\" \r\n        variant=\"outline\"\r\n        onClick={handleProcessRecurring}\r\n      >\r\n        <Repeat className=\"mr-2 h-4 w-4\" />\r\n        Xأںâ•—آ، lâ”œâ•œ ngay\r\n      </Button>\r\n    ],\r\n  });\r\n\r\n  const activeTasks = recurringTasks?.filter(t => t.isActive && !t.isPaused) ?? [];\r\n  const pausedTasks = recurringTasks?.filter(t => t.isActive && t.isPaused) ?? [];\r\n\r\n  const handleCreateRecurring = () => {\r\n    if (!formData.title.trim()) {\r\n      toast.error('Vui lâ”œâ–“ng nhأںâ•‘آ،p tiâ”œآ¬u â”€أ¦أںâ•—أ¼');\r\n      return;\r\n    }\r\n    if (!formData.startDate) {\r\n      toast.error('Vui lâ”œâ–“ng chأںâ•—أ¬n ngâ”œأ،y bأںâ•‘آ»t â”€أ¦أںâ•‘آ؛u');\r\n      return;\r\n    }\r\n    if (formData.assignees.length === 0) {\r\n      toast.error('Vui lâ”œâ–“ng chأںâ•—أ¬n ngâ•‍â–‘أںâ•—آ¥i thأںâ•—â–’c hiأںâ•—أ§n');\r\n      return;\r\n    }\r\n\r\n    const pattern: RecurrencePattern = {\r\n      frequency: formData.frequency,\r\n      interval: formData.interval,\r\n    };\r\n\r\n    const owner = formData.assignees.find(a => a.role === 'owner') || formData.assignees[0];\r\n\r\n    const recurringTask: Omit<RecurringTask, 'systemId'> = {\r\n      id: '',\r\n      title: formData.title,\r\n      description: formData.description,\r\n      priority: formData.priority,\r\n      estimatedHours: formData.estimatedHours,\r\n      assignees: formData.assignees,\r\n      assignerId: owner.employeeSystemId,\r\n      assignerName: owner.employeeName,\r\n      recurrencePattern: pattern,\r\n      startDate: formData.startDate,\r\n      nextOccurrenceDate: formData.startDate,\r\n      createDaysBefore: formData.createDaysBefore,\r\n      durationDays: formData.durationDays,\r\n      isActive: true,\r\n      isPaused: false,\r\n      createdTaskIds: [],\r\n      occurrenceCount: 0,\r\n      createdBy: 'CURRENT_USER',\r\n      createdAt: new Date().toISOString(),\r\n      updatedAt: new Date().toISOString(),\r\n    };\r\n\r\n    (createRecurring as any).mutate(recurringTask);\r\n    toast.success('â”€أ‰â”œأ؛ tأںâ•‘أ­o câ”œâ”¤ng viأںâ•—أ§c lأںâ•‘â•–p lأںâ•‘أ­i');\r\n    setShowCreateDialog(false);\r\n    \r\n    // Reset form\r\n    setFormData({\r\n      title: '',\r\n      description: '',\r\n      priority: 'Trung bâ”œآ¼nh',\r\n      estimatedHours: 8,\r\n      assignees: [],\r\n      frequency: 'weekly',\r\n      interval: 1,\r\n      startDate: '',\r\n      durationDays: 1,\r\n      createDaysBefore: 0,\r\n    });\r\n  };\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      {/* Stats */}\r\n      <div className=\"grid gap-4 md:grid-cols-4\">\r\n        <Card>\r\n          <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n            <CardTitle className=\"text-sm font-medium\">â”€أ‰ang hoأںâ•‘أ­t â”€أ¦أںâ•—أ–ng</CardTitle>\r\n            <Play className=\"h-4 w-4 text-green-600\" />\r\n          </CardHeader>\r\n          <CardContent>\r\n            <div className=\"text-2xl font-bold\">{activeTasks.length}</div>\r\n          </CardContent>\r\n        </Card>\r\n\r\n        <Card>\r\n          <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n            <CardTitle className=\"text-sm font-medium\">Tأںâ•‘أ­m dأںâ•—آ½ng</CardTitle>\r\n            <Pause className=\"h-4 w-4 text-orange-600\" />\r\n          </CardHeader>\r\n          <CardContent>\r\n            <div className=\"text-2xl font-bold\">{pausedTasks.length}</div>\r\n          </CardContent>\r\n        </Card>\r\n\r\n        <Card>\r\n          <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n            <CardTitle className=\"text-sm font-medium\">Tأںâ•—أ²ng câ”œâ”¤ng viأںâ•—أ§c â”€أ¦â”œأ؛ tأںâ•‘أ­o</CardTitle>\r\n            <CheckCircle2 className=\"h-4 w-4 text-blue-600\" />\r\n          </CardHeader>\r\n          <CardContent>\r\n            <div className=\"text-2xl font-bold\">\r\n              {recurringTasks?.reduce((sum, rt) => sum + (rt.occurrenceCount || 0), 0) ?? 0}\r\n            </div>\r\n          </CardContent>\r\n        </Card>\r\n\r\n        <Card>\r\n          <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n            <CardTitle className=\"text-sm font-medium\">Sأںâ•‘آ»p tأںâ•—آ¢i hâ”œâ”¤m nay</CardTitle>\r\n            <Calendar className=\"h-4 w-4 text-purple-600\" />\r\n          </CardHeader>\r\n          <CardContent>\r\n            <div className=\"text-2xl font-bold\">\r\n              {0} {/* Note: getTasksToCreateToday needs implementation */}\r\n            </div>\r\n          </CardContent>\r\n        </Card>\r\n      </div>\r\n\r\n      {/* Active Tasks */}\r\n      {activeTasks.length > 0 && (\r\n        <div className=\"space-y-4\">\r\n          <h2 className=\"text-xl font-semibold\">â”€أ‰ang hoأںâ•‘أ­t â”€أ¦أںâ•—أ–ng</h2>\r\n          <div className=\"grid gap-4 md:grid-cols-2 lg:grid-cols-3\">\r\n            {activeTasks.map(task => (\r\n              <RecurringTaskCard\r\n                key={task.systemId}\r\n                task={task}\r\n                onTogglePause={() => (updateRecurring as any).mutate({ systemId: task.systemId, isPaused: !task.isPaused })}\r\n                onDeactivate={() => (updateRecurring as any).mutate({ systemId: task.systemId, isActive: false })}\r\n              />\r\n            ))}\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Paused Tasks */}\r\n      {pausedTasks.length > 0 && (\r\n        <div className=\"space-y-4\">\r\n          <h2 className=\"text-xl font-semibold\">Tأںâ•‘أ­m dأںâ•—آ½ng</h2>\r\n          <div className=\"grid gap-4 md:grid-cols-2 lg:grid-cols-3\">\r\n            {pausedTasks.map(task => (\r\n              <RecurringTaskCard\r\n                key={task.systemId}\r\n                task={task}\r\n                onTogglePause={() => (updateRecurring as any).mutate({ systemId: task.systemId, isPaused: !task.isPaused })}\r\n                onDeactivate={() => (updateRecurring as any).mutate({ systemId: task.systemId, isActive: false })}\r\n              />\r\n            ))}\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Empty State */}\r\n      {activeTasks.length === 0 && pausedTasks.length === 0 && (\r\n        <Card>\r\n          <CardContent className=\"py-12 text-center\">\r\n            <Repeat className=\"mx-auto h-12 w-12 text-muted-foreground mb-4\" />\r\n            <h3 className=\"text-lg font-semibold mb-2\">Châ•‍â–‘a câ”œâ”‚ câ”œâ”¤ng viأںâ•—أ§c lأںâ•‘â•–p lأںâ•‘أ­i</h3>\r\n            <p className=\"text-muted-foreground mb-4\">\r\n              Tأںâ•‘أ­o câ”œâ”¤ng viأںâ•—أ§c lأںâ•‘â•–p lأںâ•‘أ­i â”€أ¦أںâ•—أ¢ tأںâ•—â–’ â”€أ¦أںâ•—أ–ng hâ”œâ”‚a câ”œأ­c tâ”œأ­c vأںâ•—أ‘ â”€أ¦أںâ•—أ¯nh kأںâ•—â”‚\r\n            </p>\r\n            <Button onClick={() => setShowCreateDialog(true)}>\r\n              <Plus className=\"mr-2 h-4 w-4\" />\r\n              Tأںâ•‘أ­o câ”œâ”¤ng viأںâ•—أ§c lأںâ•‘â•–p lأںâ•‘أ­i\r\n            </Button>\r\n          </CardContent>\r\n        </Card>\r\n      )}\r\n\r\n      {/* Create Dialog */}\r\n      <Dialog open={showCreateDialog} onOpenChange={setShowCreateDialog}>\r\n        <DialogContent className=\"max-w-2xl max-h-[90vh] overflow-y-auto\">\r\n          <DialogHeader>\r\n            <DialogTitle>Tأںâ•‘أ­o câ”œâ”¤ng viأںâ•—أ§c lأںâ•‘â•–p lأںâ•‘أ­i</DialogTitle>\r\n            <DialogDescription>\r\n              Thiأںâ•‘â”گt lأںâ•‘آ،p câ”œâ”¤ng viأںâ•—أ§c sأںâ•‘â•œ tأںâ•—â–’ â”€أ¦أںâ•—أ–ng tأںâ•‘أ­o theo lأںâ•—أ¯ch trâ”œآ¼nh\r\n            </DialogDescription>\r\n          </DialogHeader>\r\n\r\n          <div className=\"space-y-4 py-4\">\r\n            <div>\r\n              <Label>Tiâ”œآ¬u â”€أ¦أںâ•—أ¼ *</Label>\r\n              <Input\r\n                value={formData.title}\r\n                onChange={(e) => setFormData({ ...formData, title: e.target.value })}\r\n                placeholder=\"Bâ”œأ­o câ”œأ­o tuأںâ•‘آ؛n...\"\r\n              />\r\n            </div>\r\n\r\n            <div>\r\n              <Label>Mâ”œâ”¤ tأںâ•‘أ؛</Label>\r\n              <Textarea\r\n                value={formData.description}\r\n                onChange={(e) => setFormData({ ...formData, description: e.target.value })}\r\n                placeholder=\"Mâ”œâ”¤ tأںâ•‘أ؛ câ”œâ”¤ng viأںâ•—أ§c...\"\r\n                rows={3}\r\n              />\r\n            </div>\r\n\r\n            <div className=\"grid grid-cols-2 gap-4\">\r\n              <div>\r\n                <Label>â”€أ‰أںâ•—أ– â•‍â–‘u tiâ”œآ¬n</Label>\r\n                <Select value={formData.priority} onValueChange={(v) => setFormData({ ...formData, priority: v as TaskPriority })}>\r\n                  <SelectTrigger>\r\n                    <SelectValue />\r\n                  </SelectTrigger>\r\n                  <SelectContent>\r\n                    <SelectItem value=\"Thأںâ•‘أ‘p\">Thأںâ•‘أ‘p</SelectItem>\r\n                    <SelectItem value=\"Trung bâ”œآ¼nh\">Trung bâ”œآ¼nh</SelectItem>\r\n                    <SelectItem value=\"Cao\">Cao</SelectItem>\r\n                    <SelectItem value=\"Khأںâ•‘âŒگn cأںâ•‘أ‘p\">Khأںâ•‘âŒگn cأںâ•‘أ‘p</SelectItem>\r\n                  </SelectContent>\r\n                </Select>\r\n              </div>\r\n\r\n              <div>\r\n                <Label>â•‍آ»أںâ•—آ¢c tâ”œآ،nh (giأںâ•—آ¥)</Label>\r\n                <Input\r\n                  type=\"number\"\r\n                  value={formData.estimatedHours}\r\n                  onChange={(e) => setFormData({ ...formData, estimatedHours: parseInt(e.target.value) })}\r\n                />\r\n              </div>\r\n            </div>\r\n\r\n            <div>\r\n              <Label>Ngâ•‍â–‘أںâ•—آ¥i thأںâ•—â–’c hiأںâ•—أ§n *</Label>\r\n              <AssigneeMultiSelect\r\n                assignees={formData.assignees}\r\n                availableEmployees={employees.map(e => ({\r\n                  systemId: e.systemId,\r\n                  name: e.fullName,\r\n                }))}\r\n                onChange={(assignees) => setFormData({ ...formData, assignees })}\r\n                showRoles={true}\r\n              />\r\n            </div>\r\n\r\n            <div className=\"border-t pt-4\">\r\n              <h3 className=\"font-semibold mb-4\">Lأںâ•—أ¯ch lأںâ•‘â•–p lأںâ•‘أ­i</h3>\r\n              \r\n              <div className=\"grid grid-cols-2 gap-4\">\r\n                <div>\r\n                  <Label>Tأںâ•‘آ؛n suأںâ•‘أ‘t</Label>\r\n                  <Select value={formData.frequency} onValueChange={(v) => setFormData({ ...formData, frequency: v as RecurrenceFrequency })}>\r\n                    <SelectTrigger>\r\n                      <SelectValue />\r\n                    </SelectTrigger>\r\n                    <SelectContent>\r\n                      <SelectItem value=\"daily\">Hâ”œأ،ng ngâ”œأ،y</SelectItem>\r\n                      <SelectItem value=\"weekly\">Hâ”œأ،ng tuأںâ•‘آ؛n</SelectItem>\r\n                      <SelectItem value=\"monthly\">Hâ”œأ،ng thâ”œأ­ng</SelectItem>\r\n                      <SelectItem value=\"yearly\">Hâ”œأ،ng nâ”€أ¢m</SelectItem>\r\n                    </SelectContent>\r\n                  </Select>\r\n                </div>\r\n\r\n                <div>\r\n                  <Label>Mأںâ•—أ¹i</Label>\r\n                  <Input\r\n                    type=\"number\"\r\n                    min={1}\r\n                    value={formData.interval}\r\n                    onChange={(e) => setFormData({ ...formData, interval: parseInt(e.target.value) })}\r\n                  />\r\n                  <p className=\"text-xs text-muted-foreground mt-1\">\r\n                    {formData.frequency === 'daily' && `ngâ”œأ،y`}\r\n                    {formData.frequency === 'weekly' && `tuأںâ•‘آ؛n`}\r\n                    {formData.frequency === 'monthly' && `thâ”œأ­ng`}\r\n                    {formData.frequency === 'yearly' && `nâ”€أ¢m`}\r\n                  </p>\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"grid grid-cols-3 gap-4 mt-4\">\r\n                <div>\r\n                  <Label>Ngâ”œأ،y bأںâ•‘آ»t â”€أ¦أںâ•‘آ؛u *</Label>\r\n                  <Input\r\n                    type=\"date\"\r\n                    value={formData.startDate}\r\n                    onChange={(e) => setFormData({ ...formData, startDate: e.target.value })}\r\n                  />\r\n                </div>\r\n\r\n                <div>\r\n                  <Label>Thأںâ•—آ¥i lâ•‍â–‘أںâ•—أ؛ng (ngâ”œأ،y)</Label>\r\n                  <Input\r\n                    type=\"number\"\r\n                    min={1}\r\n                    value={formData.durationDays}\r\n                    onChange={(e) => setFormData({ ...formData, durationDays: parseInt(e.target.value) })}\r\n                  />\r\n                </div>\r\n\r\n                <div>\r\n                  <Label>Tأںâ•‘أ­o trâ•‍â–‘أںâ•—آ¢c (ngâ”œأ،y)</Label>\r\n                  <Input\r\n                    type=\"number\"\r\n                    min={0}\r\n                    value={formData.createDaysBefore}\r\n                    onChange={(e) => setFormData({ ...formData, createDaysBefore: parseInt(e.target.value) })}\r\n                  />\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <DialogFooter>\r\n            <Button variant=\"outline\" onClick={() => setShowCreateDialog(false)}>\r\n              Hأںâ•—آ؛y\r\n            </Button>\r\n            <Button onClick={handleCreateRecurring}>\r\n              <Plus className=\"mr-2 h-4 w-4\" />\r\n              Tأںâ•‘أ­o\r\n            </Button>\r\n          </DialogFooter>\r\n        </DialogContent>\r\n      </Dialog>\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction RecurringTaskCard({\r\n  task,\r\n  onTogglePause,\r\n  onDeactivate,\r\n}: {\r\n  task: RecurringTask;\r\n  onTogglePause: () => void;\r\n  onDeactivate: () => void;\r\n}) {\r\n  return (\r\n    <Card className={cn(task.isPaused && 'opacity-60')}>\r\n      <CardHeader>\r\n        <div className=\"flex items-start justify-between\">\r\n          <div className=\"space-y-1 flex-1\">\r\n            <CardTitle className=\"text-base\">{task.title}</CardTitle>\r\n            <CardDescription className=\"line-clamp-2\">\r\n              {task.description || 'Khâ”œâ”¤ng câ”œâ”‚ mâ”œâ”¤ tأںâ•‘أ؛'}\r\n            </CardDescription>\r\n          </div>\r\n          <Badge variant=\"outline\">\r\n            {frequencyLabels[task.recurrencePattern.frequency]}\r\n          </Badge>\r\n        </div>\r\n      </CardHeader>\r\n      <CardContent className=\"space-y-4\">\r\n        <div className=\"flex items-center gap-4 text-sm text-muted-foreground\">\r\n          <div className=\"flex items-center gap-1\">\r\n            <Calendar className=\"h-3 w-3\" />\r\n            <span>Lأںâ•‘آ؛n sau: {task.nextOccurrenceDate || 'N/A'}</span>\r\n          </div>\r\n        </div>\r\n\r\n        <div className=\"flex items-center gap-4 text-sm text-muted-foreground\">\r\n          <div className=\"flex items-center gap-1\">\r\n            <CheckCircle2 className=\"h-3 w-3\" />\r\n            <span>â”€أ‰â”œأ؛ tأںâ•‘أ­o: {task.occurrenceCount} lأںâ•‘آ؛n</span>\r\n          </div>\r\n        </div>\r\n\r\n        <div className=\"flex gap-2 pt-2\">\r\n          <Button\r\n            size=\"sm\"\r\n            variant={task.isPaused ? 'default' : 'outline'}\r\n            className=\"flex-1\"\r\n            onClick={onTogglePause}\r\n          >\r\n            {task.isPaused ? (\r\n              <>\r\n                <Play className=\"mr-1 h-3 w-3\" />\r\n                Tiأںâ•‘â”گp tأںâ•—أ‘c\r\n              </>\r\n            ) : (\r\n              <>\r\n                <Pause className=\"mr-1 h-3 w-3\" />\r\n                Tأںâ•‘أ­m dأںâ•—آ½ng\r\n              </>\r\n            )}\r\n          </Button>\r\n    