•—آ،a sau khi trأںâ•‘أ؛ lâ•‍â–‘â•‍أ­ng.\r\n                </AlertDescription>\r\n                <div className=\"mt-3\">\r\n                  <Button size=\"sm\" className=\"h-8\" onClick={() => router.push(ROUTES.HRM.ATTENDANCE)}>\r\n                    Mأںâ•—ئ’ trang Chأںâ•‘أ‘m câ”œâ”¤ng\r\n                  </Button>\r\n                </div>\r\n              </Alert>\r\n            )}\r\n\r\n            {!latestLockedMonth && (\r\n              <Alert className=\"border-amber-200 bg-amber-50 text-amber-900 dark:border-amber-400/40 dark:bg-amber-950/40\">\r\n                <AlertTitle>Châ•‍â–‘a câ”œâ”‚ thâ”œأ­ng chأںâ•‘أ‘m câ”œâ”¤ng nâ”œأ،o â”€أ¦â•‍â–‘أںâ•—أ؛c khâ”œâ”‚a</AlertTitle>\r\n                <AlertDescription>\r\n                  Bأںâ•‘أ­n vأںâ•‘آ½n câ”œâ”‚ thأںâ•—أ¢ chأںâ•‘أ­y bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng vأںâ•—آ¢i dأںâ•—آ» liأںâ•—أ§u hiأںâ•—أ§n tأںâ•‘أ­i nhâ•‍â–‘ng hâ”œأ؛y khâ”œâ”‚a thâ”œأ­ng trong Chأںâ•‘أ‘m câ”œâ”¤ng â”€أ¦أںâ•—أ¢ trâ”œأ­nh sai lأںâ•—أ§ch.\r\n                </AlertDescription>\r\n              </Alert>\r\n            )}\r\n          </CardContent>\r\n        </Card>\r\n      )}\r\n\r\n      {currentStep === 1 && (\r\n        <Card>\r\n          <CardHeader>\r\n            <CardTitle className=\"text-h4\">Chأںâ•—أ¬n nhâ”œأ³n viâ”œآ¬n ({formState.selectedEmployeeSystemIds.length})</CardTitle>\r\n          </CardHeader>\r\n          <CardContent className=\"space-y-4\">\r\n            <div className=\"flex flex-col gap-2 md:flex-row md:items-center md:justify-between\">\r\n              <Input\r\n                placeholder=\"Tâ”œآ¼m theo tâ”œآ¬n hoأںâ•‘â•–c mâ”œأ؛\"\r\n                value={searchKeyword}\r\n                onChange={(event) => setSearchKeyword(event.target.value)}\r\n                className=\"h-9 md:w-64\"\r\n              />\r\n            </div>\r\n\r\n            <ResponsiveDataTable<Employee>\r\n              data={paginatedEmployees}\r\n              columns={employeeSelectionColumns}\r\n              isLoad