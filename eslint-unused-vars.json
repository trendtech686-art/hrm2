MethodSystemId: asSystemId(selectedPaymentMethod.systemId as string),\r\n        paymentMethodName: selectedPaymentMethod.name,\r\n        \r\n        // Account & Type - From settings\r\n        accountSystemId: asSystemId(values.accountSystemId || ''),\r\n        paymentReceiptTypeSystemId: paymentType.systemId,\r\n        paymentReceiptTypeName: paymentType.name,\r\n        \r\n        // Branch info\r\n        branchSystemId: asSystemId(branchSystemId || ''),\r\n        branchName: branchName || '',\r\n        \r\n        // Status & Category\r\n        status: 'completed', // Xuأںâ•‘أ‘t tiأںâ•—أ¼n luâ”œâ”¤n\r\n        category: 'warranty_refund',\r\n        \r\n        // Links to warranty and order\r\n        linkedWarrantySystemId: asSystemId(warrantySystemId), // Link â”€أ¦أںâ•‘â”گn phiأںâ•‘â”گu bأںâ•‘أ؛o hâ”œأ،nh\r\n        linkedOrderSystemId: linkedOrderSystemId ? asSystemId(linkedOrderSystemId) : undefined, // Link â”€أ¦أںâ•‘â”گn â”€أ¦â•‍أ­n hâ”œأ،ng (nأںâ•‘â”گu trأںâ•—آ½ vâ”œأ،o â”€أ¦â•‍أ­n)\r\n        originalDocumentId: warrantyId,\r\n        customerSystemId: undefined,\r\n        customerName: customer.name,\r\n        \r\n        // Financial\r\n        affectsDebt: false,\r\n        \r\n        createdBy: asSystemId(currentUserSystemId),\r\n        createdAt: toISODateTime(now) || now.toISOString(),\r\n      };\r\n\r\n      const newPayment = addPayment(payment);\r\n\r\n      // ============================================================\r\n      // UPDATE ORDER if this is order_deduction\r\n      // ============================================================\r\n      if (linkedOrderSystemId) {\r\n        const order = orders.find(o => o.systemId === linkedOrderSystemId);\r\n        if (order) {\r\n          // Create OrderPayment object\r\n          const orderPayment = {\r\n            systemId: newPayment.systemId,\r\n            id: newPayment.id,\r\n            date: newPayment.date,\r\n            method: selectedPaymentMethod?.name || 'N/A',\r\n            amount: -values.amount, // â”œأ©M vâ”œآ¼ â”€أ¦â”œأ³y lâ”œأ، trأںâ•‘أ؛ tiأںâ•—أ¼n khâ”œأ­ch (giأںâ•‘أ؛m câ”œâ”¤ng nأںâ•—أ؛)\r\n            createdBy: newPayment.createdBy,\r\n            description: `Trأںâ•—آ½ tiأںâ•—أ¼n bأںâ•‘أ؛o hâ”œأ،nh ${warrantyId}`,\r\n            linkedWarrantySystemId: asSystemId(warrantySystemId),\r\n          };\r\n\r\n          // Update order: add payment and increase paidAmount\r\n          const updatedPayments = [...order.payments, orderPayment];\r\n          const newPaidAmount = (order.paidAmount || 0) + values.amount;\r\n\r\n          await updateOrder.mutateAsync({\r\n            id: asSystemId(linkedOrderSystemId),\r\n            payments: updatedPayments,\r\n            paidAmount: newPaidAmount,\r\n          });\r\n        }\r\n      }\r\n\r\n      // Add history to warranty vأںâ•—آ¢i metadata\r\n      const settlementLabel = values.settlementType === 'order_deduction' \r\n        ? `Trأںâ•—آ½ vâ”œأ،o â”€أ¦â•‍أ­n hâ”œأ،ng (${paymentType.name})` \r\n        : `${selectedPaymentMethod.name} (${paymentType.name})`;\r\n      \r\n      addHistory(\r\n        asSystemId(warrantySystemId), \r\n        `Tأںâ•‘أ­o phiأںâ•‘â”گu chi ${newPayment.id}`,\r\n        currentUserName,\r\n        `Sأںâ•—أ¦ tiأںâ•—أ¼n: ${values.amount.toLocaleString('vi-VN')}â”€أ¦ - Phâ•‍â–‘â•‍أ­ng thأںâ•—âŒگc: ${settlementLabel}`,\r\n        { paymentSystemId: newPayment.systemId } // خ“آ£أ  Lâ•‍â–‘u systemId vâ”œأ،o metadata\r\n      );\r\n\r\n      recordWarrantySettlementMethods({\r\n        ticket,\r\n        settlementType: settlementRecordType,\r\n        totalAmount: totalPaymentFromTicket,\r\n        methods: [{\r\n          type: settlementRecordType,\r\n          amount: values.amount,\r\n          status: 'completed',\r\n          paymentVoucherId: newPayment.systemId,\r\n          linkedOrderSystemId: linkedOrderSystemId ? asSystemId(linkedOrderSystemId) : undefined,\r\n          notes: settlementLabel,\r\n          createdAt: newPayment.createdAt,\r\n          completedAt: newPayment.status === 'completed' ? newPayment.createdAt : undefined,\r\n        }],\r\n      });\r\n\r\n      toast.success(`â”€أ‰â”œأ؛ tأںâ•‘أ­o phiأںâ•‘â”گu chi ${newPayment.id}`, {\r\n        description: `â”€أ‰â”œأ؛ xuأںâ•‘أ‘t tiأںâ•—أ¼n (${values.amount.toLocaleString('vi-VN')} â”€أ¦)`,\r\n        action: {\r\n          label: 'Xem phiأںâ•‘â”گu chi',\r\n          onClick: () => router.push(`/payments/${newPayment.systemId}`),\r\n        },\r\n      });\r\n\r\n      setOpen(false);\r\n    } catch (error) {\r\n      console.error('Error creating payment voucher:', error);\r\n      toast.error('Khâ”œâ”¤ng thأںâ•—أ¢ tأںâ•‘أ­o phiأںâ•‘â”گu chi');\r\n    }\r\n  };\r\n\r\n  return (\r\n    <Dialog open={open} onOpenChange={setOpen}>\r\n      <DialogTrigger asChild>\r\n        <Button \r\n          variant=\"default\" \r\n          size=\"lg\"\r\n          className=\"h-9 flex-1\"\r\n        >\r\n          Tأںâ•‘أ­o phiأںâ•‘â”گu chi\r\n        </Button>\r\n      </DialogTrigger>\r\n      \r\n      <DialogContent className=\"max-w-2xl max-h-[90vh] overflow-y-auto\">\r\n        <DialogHeader>\r\n          <DialogTitle>Tأںâ•‘أ­o phiأںâ•‘â”گu chi - Hoâ”œأ،n tiأںâ•—أ¼n bأںâ•‘أ؛o hâ”œأ،nh</DialogTitle>\r\n        </DialogHeader>\r\n\r\n        <form onSubmit={handleSubmit(onSubmit)} className=\"space-y-4\">\r\n          {/* Warning if payment types not found */}\r\n          {(!warrantyRefundType || !warrantyOrderDeductionType) && (\r\n            <Alert variant=\"destructive\">\r\n              <AlertCircle className=\"h-4 w-4\" />\r\n              <AlertDescription>\r\n                <strong>Thiأںâ•‘â”گu cأںâ•‘أ‘u hâ”œآ¼nh:</strong> Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y loأںâ•‘أ­i phiأںâ•‘â”گu chi phâ”œâ•£ hأںâ•—أ؛p trong câ”œأ،i â”€أ¦أںâ•‘â•–t.\r\n                Vui lâ”œâ–“ng vâ”œأ،o <strong>Câ”œأ،i â”€أ¦أںâ•‘â•–t {'>'} Loأںâ•‘أ­i phiأںâ•‘â”گu chi</strong> â”€أ¦أںâ•—أ¢ kiأںâ•—أ¢m tra câ”œأ­c loأںâ•‘أ­i:\r\n                <ul className=\"mt-2 ml-4 list-disc text-sm\">\r\n                  {!warrantyRefundType && <li><strong>HOANTIEN_BH</strong> - Hoâ”œأ،n tiأںâ•—أ¼n bأںâ•‘أ؛o hâ”œأ،nh</li>}\r\n                  {!warrantyOrderDeductionType && <li><strong>TRAVAO_DONHANG</strong> - Trأںâ•‘أ؛ bأںâ•‘أ؛o hâ”œأ،nh vâ”œأ،o â”€أ¦â•‍أ­n hâ”œأ،ng</li>}\r\n                </ul>\r\n              </AlertDescription>\r\n            </Alert>\r\n          )}\r\n\r\n          {/* Warranty Info */}\r\n          <Alert>\r\n            <AlertCircle className=\"h-4 w-4\" />\r\n            <AlertDescription className=\"space-y-1\">\r\n              <div className=\"flex items-center gap-2\">\r\n                <span className=\"font-medium\">Phiأںâ•‘â”گu bأںâ•‘أ؛o hâ”œأ،nh:</span>\r\n                <span className=\"font-mono\">{warrantyId}</span>\r\n              </div>\r\n              <div className=\"flex items-center gap-2\">\r\n                <span className=\"font-medium\">Khâ”œأ­ch hâ”œأ،ng:</span>\r\n                <span>{customer.name} خ“أ‡أ³ {customer.phone}</span>\r\n              </div>\r\n              <div className=\"flex items-center gap-2\">\r\n                <span className=\"font-medium\">Cأںâ•‘آ؛n bâ”œâ•£ trأںâ•—آ½:</span>\r\n                <span className=\"font-semibold text-red-600\">{actualRemainingAmount.toLocaleString('vi-VN')} â”€أ¦</span>\r\n              </div>\r\n            </AlertDescription>\r\n          </Alert>\r\n\r\n\r\n          {/* Settlement Type */}\r\n          <div className=\"space-y-2\">\r\n            <Label htmlFor=\"settlementType\">Phâ•‍â–‘â•‍أ­ng thأںâ•—âŒگc *</Label>\r\n            <Controller\r\n              name=\"settlementType\"\r\n              control={control}\r\n              render={({ field }) => (\r\n                <Select value={field.value} onValueChange={field.onChange}>\r\n                  <SelectTrigger id=\"settlementType\">\r\n                    <SelectValue />\r\n                  </SelectTrigger>\r\n                  <SelectContent>\r\n                    <SelectItem value=\"direct_payment\">Trأںâ•‘أ؛ tiأںâ•—أ¼n trأںâ•—â–’c tiأںâ•‘â”گp</SelectItem>\r\n                    <SelectItem value=\"order_deduction\">Trأںâ•—آ½ vâ”œأ،o â”€أ¦â•‍أ­n hâ”œأ،ng</SelectItem>\r\n                    <SelectItem value=\"mixed\">Bâ”œâ•£ trأںâ•—آ½ â”€أ¦â•‍أ­n + Chi tiأںâ•—أ¼n</SelectItem>\r\n                  </SelectContent>\r\n                </Select>\r\n              )}\r\n            />\r\n          </div>\r\n\r\n          {/* Payment Method - Show for direct payment and mixed (cash portion) */}\r\n          {(settlementType === 'direct_payment' || settlementType === 'mixed') && (\r\n            <>\r\n              <div className=\"space-y-2\">\r\n                <Label htmlFor=\"paymentMethodSystemId\">Hâ”œآ¼nh thأںâ•—âŒگc thanh toâ”œأ­n *</Label>\r\n                <Controller\r\n                  name=\"paymentMethodSystemId\"\r\n                  control={control}\r\n                  rules={{ required: settlementType === 'direct_payment' || settlementType === 'mixed' }}\r\n                  render={({ field }) => (\r\n                    <Select value={field.value} onValueChange={field.onChange}>\r\n                      <SelectTrigger id=\"paymentMethodSystemId\">\r\n                        <SelectValue placeholder=\"-- Chأںâ•—أ¬n hâ”œآ¼nh thأںâ•—âŒگc --\" />\r\n                      </SelectTrigger>\r\n                      <SelectContent>\r\n                        {paymentMethods.filter(m => m.isActive).map((method) => (\r\n                          <SelectItem key={method.systemId} value={method.systemId}>\r\n                            <div className=\"flex items-center gap-2\">\r\n                              <span>{method.name}</span>\r\n                            </div>\r\n                          </SelectItem>\r\n                        ))}\r\n                      </SelectContent>\r\n                    </Select>\r\n                  )}\r\n                />\r\n                <p className=\"text-xs text-muted-foreground\">\r\n                  Chأںâ•—أ¬n hâ”œآ¼nh thأںâ•—âŒگc thanh toâ”œأ­n phâ”œâ•£ hأںâ•—أ؛p tأںâ•—آ½ câ”œأ،i â”€أ¦أںâ•‘â•–t hأںâ•—أ§ thأںâ•—أ¦ng\r\n                </p>\r\n              </div>\r\n\r\n              {/* Account Selection - Show for direct payment */}\r\n              <div className=\"space-y-2\">\r\n                <Label htmlFor=\"accountSystemId\">Tâ”œأ،i khoأںâ•‘أ؛n chi *</Label>\r\n                <Controller\r\n                  name=\"accountSystemId\"\r\n                  control={control}\r\n                  rules={{ required: settlementType === 'direct_payment' || settlementType === 'mixed' }}\r\n                  render={({ field }) => (\r\n                    <Select value={field.value} onValueChange={field.onChange}>\r\n                      <SelectTrigger id=\"accountSystemId\">\r\n                        <SelectValue placeholder=\"-- Chأںâ•—أ¬n tâ”œأ،i khoأںâ•‘أ؛n --\" />\r\n                      </SelectTrigger>\r\n                      <SelectContent>\r\n                        {filteredAccounts.length === 0 ? (\r\n                          <div className=\"p-4 text-sm text-muted-foreground text-center\">\r\n                            Khâ”œâ”¤ng câ”œâ”‚ tâ”œأ،i khoأںâ•‘أ؛n khأںâ•‘أ؛ dأںâ•—أ‘ng\r\n                          </div>\r\n                        ) : (\r\n                          filteredAccounts.map((account) => (\r\n                            <SelectItem key={account.systemId} value={account.systemId}>\r\n                              <div className=\"flex items-center gap-2\">\r\n                                <span>{account.name}</span>\r\n                              </div>\r\n                            </SelectItem>\r\n                          ))\r\n                        )}\r\n                      </SelectContent>\r\n                    </Select>\r\n                  )}\r\n                />\r\n                <p className=\"text-xs text-muted-foreground\">\r\n                  {selectedPaymentMethod?.name === 'Tiأںâ•—أ¼n mأںâ•‘â•–t' \r\n                    ? 'Hiأںâ•—أ¢n thأںâ•—أ¯ tâ”œأ،i khoأںâ•‘أ؛n quأںâ•—â•£ tiأںâ•—أ¼n mأںâ•‘â•–t' \r\n                    : 'Hiأںâ•—أ¢n thأںâ•—أ¯ tâ”œأ،i khoأںâ•‘أ؛n ngâ”œأ³n hâ”œأ،ng'}\r\n                </p>\r\n              </div>\r\n            </>\r\n          )}\r\n\r\n          {/* Order Selection - Show for order deduction and mixed */}\r\n          {(settlementType === 'order_deduction' || settlementType === 'mixed') && (\r\n            <div className=\"space-y-2\">\r\n              <Label htmlFor=\"selectedOrderId\">Chأںâ•—أ¬n â”€أ¦â•‍أ­n hâ”œأ،ng *</Label>\r\n              <div className=\"text-xs text-muted-foreground mb-2\">\r\n                Nhأںâ•‘آ،p mâ”œأ؛ â”€أ¦â•‍أ­n hâ”œأ،ng hoأںâ•‘â•–c tâ”œآ¬n khâ”œأ­ch â”€أ¦أںâ•—أ¢ tâ”œآ¼m nhanh. \r\n                Hأںâ•—أ§ thأںâ•—أ¦ng tأںâ•—â–’ â”€أ¦أںâ•—أ–ng lأںâ•—أ¬c kأںâ•‘â”گt quأںâ•‘أ؛ tأںâ•—آ½ â”€أ¦â•‍أ­n hâ”œأ،ng.\r\n              </div>\r\n              <VirtualizedCombobox\r\n                options={orderSearchResults}\r\n                value={selectedOrderValue}\r\n                onChange={(option) => setValue('selectedOrderId', option?.value || '')}\r\n                onSearchChange={(query) => setOrderSearchQuery(query)}\r\n                placeholder=\"Tâ”œآ¼m kiأںâ•‘â”گm â”€أ¦â•‍أ­n hâ”œأ،ng...\"\r\n                searchPlaceholder=\"Nhأںâ•‘آ،p mâ”œأ؛ â”€أ¦â•‍أ­n hoأںâ•‘â•–c tâ”œآ¬n khâ”œأ­ch hâ”œأ،ng...\"\r\n                emptyPlaceholder={\r\n                  orderSearchQuery \r\n                    ? \"Khâ”œâ”¤ng tâ”œآ¼m thأںâ•‘أ‘y â”€أ¦â•‍أ­n hâ”œأ،ng phâ”œâ•£ hأںâ•—أ؛p\" \r\n                    : \"Nhأںâ•‘آ،p tأںâ•—آ½ khâ”œâ”‚a â”€أ¦أںâ•—أ¢ tâ”œآ¼m kiأںâ•‘â”گm â”€أ¦â•‍أ­n hâ”œأ،ng\"\r\n                }\r\n                isLoading={isSearchingOrders}\r\n                minSearchLength={0}\r\n                estimatedItemHeight={56}\r\n                maxHeight={400}\r\n              />\r\n              <p className=\"text-xs text-muted-foreground\">\r\n                Chأںâ•—أ« hiأںâ•—أ¢n thأںâ•—أ¯ â”€أ¦â•‍أ­n hâ”œأ،ng <strong>châ•‍â–‘a xuأںâ•‘أ‘t kho</strong> vâ”œأ، <strong>câ”œâ–“n sأںâ•—أ¦ dâ•‍â–‘ câ”œâ”‚ thأںâ•—أ¢ trأںâ•—آ½</strong>.\r\n              </p>\r\n            </div>\r\n          )}\r\n\r\n          {shouldShowInsufficientWarning && (\r\n            <Alert className=\"border-yellow-400 bg-yellow-50 text-yellow-900\">\r\n              <div className=\"flex items-start gap-3\">\r\n                <AlertTriangle className=\"h-4 w-4 mt-0.5\" />\r\n                <div className=\"space-y-1 text-sm\">\r\n                  <p className=\"font-medium\">â”€أ‰â•‍أ­n {selectedOrder?.id} khâ”œâ”¤ng â”€أ¦أںâ•—آ؛ â”€أ¦أںâ•—أ¢ trأںâ•—آ½ toâ”œأ،n bأںâ•—أ–.</p>\r\n                  <p className=\"text-xs\">\r\n                    Thiأںâ•‘â”گu <strong>{shortageAmount.toLocaleString('vi-VN')} â”€أ¦</strong> so vأںâ•—آ¢i sأںâ•—أ¦ tiأںâ•—أ¼n cأںâ•‘آ؛n hoâ”œأ،n. Chأںâ•—أ¬n câ”œأ­ch xأںâ•—آ، lâ”œâ•œ bâ”œآ¬n dâ•‍â–‘أںâ•—آ¢i.\r\n                  </p>\r\n                  <Button\r\n                    type=\"button\"\r\n                    size=\"sm\"\r\n                    variant=\"secondary\"\r\n                    className=\"mt-1\"\r\n                    onClick={() => setInsufficientDialogOpen(true)}\r\n                  >\r\n                    Mأںâ•—ئ’ gأںâ•—أ؛i â”œâ•œ xأںâ•—آ، lâ”œâ•œ\r\n                  </Button>\r\n                </div>\r\n              </div>\r\n            </Alert>\r\n          )}\r\n          {/* Amount Input */}\r\n          <div className=\"space-y-2\">\r\n            <Label htmlFor=\"amount\">Sأںâ•—أ¦ tiأںâ•—أ¼n *</Label>\r\n            <Controller\r\n              name=\"amount\"\r\n              control={control}\r\n              rules={{ \r\n                required: 'Vui lâ”œâ–“ng nhأںâ•‘آ،p sأںâ•—أ¦ tiأںâ•—أ¼n',\r\n                min: { value: 1, message: 'Sأںâ•—أ¦ tiأںâ•—أ¼n phأںâ•‘أ؛i lأںâ•—آ¢n hâ•‍أ­n 0' },\r\n                max: { \r\n                  value: maxAmount, \r\n                  message: settlementType === 'order_deduction' && selectedOrder\r\n                    ? (() => {\r\n                        const orderPaidAmount = selectedOrder.paidAmount || 0;\r\n                        const orderRemainingAmount = selectedOrder.grandTotal - orderPaidAmount;\r\n                        return `Sأںâ•—أ¦ tiأںâ•—أ¼n khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c vâ•‍â–‘أںâ•—أ؛t quâ”œأ­ sأںâ•—أ¦ tiأںâ•—أ¼n câ”œâ–“n lأںâ•‘أ­i cأںâ•—آ؛a â”€أ¦â•‍أ­n hâ”œأ،ng (${orderRemainingAmount.toLocaleString('vi-VN')} â”€أ¦)`;\r\n                      })()\r\n                    : `Sأںâ•—أ¦ tiأںâ•—أ¼n khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c vâ•‍â–‘أںâ•—أ؛t quâ”œأ­ ${actualRemainingAmount.toLocaleString('vi-VN')} â”€أ¦`\r\n                }\r\n              }}\r\n              render={({ field, fieldState }) => (\r\n                <div className=\"space-y-1\">\r\n                  <CurrencyInput\r\n                    value={field.value}\r\n                    onChange={field.onChange}\r\n                    disabled={settlementType === 'mixed'}\r\n                    placeholder=\"0\"\r\n                  />\r\n                  {fieldState.error && (\r\n                    <p className=\"text-xs text-destructive\">{fieldState.error.message}</p>\r\n                  )}\r\n                  <p className=\"text-xs text-muted-foreground\">\r\n                    {settlementType === 'order_deduction' && selectedOrder ? (\r\n                      <>\r\n                        {(() => {\r\n                          const orderPaidAmount = selectedOrder.paidAmount || 0;\r\n                          const orderRemainingAmount = selectedOrder.grandTotal - orderPaidAmount;\r\n                          const maxAllowed = Math.min(actualRemainingAmount, orderRemainingAmount);\r\n                          \r\n                          return (\r\n                            <>\r\n                              Sأںâ•—أ¦ tiأںâ•—أ¼n tأںâ•—أ¦i â”€أ¦a: {maxAllowed.toLocaleString('vi-VN')} â”€أ¦\r\n                              {orderPaidAmount > 0 && (\r\n                                <span className=\"text-blue-600 font-medium\">\r\n                                  {' '}(â”€أ‰â”œأ؛ trأںâ•—آ½: {orderPaidAmount.toLocaleString('vi-VN')} â”€أ¦ / {selectedOrder.grandTotal.toLocaleString('vi-VN')} â”€أ¦)\r\n                                </span>\r\n                              )}\r\n                            </>\r\n                          );\r\n                        })()}\r\n                      </>\r\n                    ) : settlementType === 'mixed' ? (\r\n                      `Tiأںâ•—أ¼n mأںâ•‘â•–t cأںâ•‘آ؛n chi: ${(mixedCashAmount || 0).toLocaleString('vi-VN')} â”€أ¦ (tأںâ•—â–’ â”€أ¦أںâ•—أ–ng tأںâ•—آ½ phأںâ•‘آ؛n bâ”œâ•£ trأںâ•—آ½)`\r\n                    ) : (\r\n                      `Sأںâ•—أ¦ tiأںâ•—أ¼n tأںâ•—أ¦i â”€أ¦a: ${actualRemainingAmount.toLocaleString('vi-VN')} â”€أ¦`\r\n                    )}\r\n                  </p>\r\n                </div>\r\n              )}\r\n            />\r\n          </div>\r\n\r\n          {settlementType === 'mixed' && (\r\n            <div className=\"space-y-3 rounded-lg border p-3 bg-muted/40\">\r\n              <div className=\"text-sm font-medium\">Phâ”œأ³n bأںâ•—أ² bâ”œâ•£ trأںâ•—آ½</div>\r\n              <div className=\"text-xs text-muted-foreground\">\r\n                Tأںâ•—أ²ng cأںâ•‘آ؛n hoâ”œأ،n: <strong>{actualRemainingAmount.toLocaleString('vi-VN')} â”€أ¦</strong>. â”€أ‰iأںâ•—أ¼u chأںâ•—أ«nh sأںâ•—أ¦ tiأںâ•—أ¼n trأںâ•—آ½ vâ”œأ،o â”€أ¦â•‍أ­n, phأںâ•‘آ؛n câ”œâ–“n lأںâ•‘أ­i sأںâ•‘â•œ chi trأںâ•—â–’c tiأںâ•‘â”گp.\r\n              </div>\r\n              <div className=\"grid gap-3 md:grid-cols-2\">\r\n                <div className=\"space-y-1\">\r\n                  <Label>Trأںâ•—آ½ vâ”œأ،o â”€أ¦â•‍أ­n</Label>\r\n                  <CurrencyInput\r\n                    value={mixedOrderAmount || 0}\r\n                    onChange={(value) => setValue('mixedOrderAmoun