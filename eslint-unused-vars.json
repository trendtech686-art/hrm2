tCardColors(prev => ({\r\n      ...prev,\r\n      [key]: !prev[key],\r\n    }));\r\n  };\r\n\r\n  const handleStatusColorChange = (status: StatusColorKey, value: string) => {\r\n    setCardColors(prev => ({\r\n      ...prev,\r\n      statusColors: {\r\n        ...prev.statusColors,\r\n        [status]: value,\r\n      },\r\n    }));\r\n  };\r\n\r\n  const handlePriorityColorChange = (priority: PriorityColorKey, value: string) => {\r\n    setCardColors(prev => ({\r\n      ...prev,\r\n      priorityColors: {\r\n        ...prev.priorityColors,\r\n        [priority]: value,\r\n      },\r\n    }));\r\n  };\r\n\r\n  const handleOverdueColorChange = (value: string) => {\r\n    setCardColors(prev => ({\r\n      ...prev,\r\n      overdueColor: value,\r\n    }));\r\n  };\r\n\r\n  const handleSaveCardColors = () => {\r\n    updateSection.mutate({ type: 'cardColors', data: cardColors }, {\r\n      onSuccess: () => toast.success('â”€أ‰â”œأ؛ lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t mâ”œأ،u card'),\r\n    });\r\n  };\r\n\r\n  const _handleResetCardColors = () => {\r\n    const defaults = clone(defaultCardColors);\r\n    setCardColors(defaults);\r\n    updateSection.mutate({ type: 'cardColors', data: defaults }, {\r\n      onSuccess: () => toast.info('â”€أ‰â”œأ؛ khâ”œâ”¤i phأںâ•—أ‘c câ”œأ،i â”€أ¦أںâ•‘â•–t mأںâ•‘â•–c â”€أ¦أںâ•—أ¯nh'),\r\n    });\r\n  };\r\n\r\n  React.useEffect(() => {\r\n    if (activeTab !== 'card-colors') {\r\n      return;\r\n    }\r\n\r\n    registerCardColorActions([\r\n      <SettingsActionButton key=\"save-card-colors\" onClick={handleSaveCardColors}>\r\n        <Save className=\"h-4 w-4\" /> Lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t\r\n      </SettingsActionButton>,\r\n    ]);\r\n  // eslint-disable-next-line react-hooks/exhaustive-deps\r\n  }, [activeTab, registerCardColorActions]);\r\n\r\n  // ============================================\r\n  // NOTIFICATION & REMINDER HANDLERS\r\n  // ============================================\r\n\r\n  const handleNotificationChange = (key: keyof NotificationSettings) => {\r\n    setNotifications(prev => ({\r\n      ...prev,\r\n      [key]: !prev[key],\r\n    }));\r\n  };\r\n\r\n  const handleSaveNotifications = () => {\r\n    updateSection.mutate({ type: 'notifications', data: notifications }, {\r\n      onSuccess: () => toast.success('â”€أ‰â”œأ؛ lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t thâ”œâ”¤ng bâ”œأ­o'),\r\n    });\r\n  };\r\n\r\n  const _handleResetNotifications = () => {\r\n    const defaults = clone(defaultNotifications);\r\n    setNotifications(defaults);\r\n    updateSection.mutate({ type: 'notifications', data: defaults }, {\r\n      onSuccess: () => toast.info('â”€أ‰â”œأ؛ khâ”œâ”¤i phأںâ•—أ‘c câ”œأ،i â”€أ¦أںâ•‘â•–t mأںâ•‘â•–c â”€أ¦أںâ•—أ¯nh'),\r\n    });\r\n  };\r\n\r\n  const handleReminderChange = (field: keyof ReminderSettings, value: boolean | number) => {\r\n    setReminders(prev => ({\r\n      ...prev,\r\n      [field]: value,\r\n    }));\r\n  };\r\n\r\n  const handleSaveReminders = () => {\r\n    updateSection.mutate({ type: 'reminders', data: reminders }, {\r\n      onSuccess: () => toast.success('â”€أ‰â”œأ؛ lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t nhأںâ•‘آ»c nhأںâ•—ئ’'),\r\n    });\r\n  };\r\n\r\n  const _handleResetReminders = () => {\r\n    const defaults = clone(defaultReminders);\r\n    setReminders(defaults);\r\n    updateSection.mutate({ type: 'reminders', data: defaults }, {\r\n      onSuccess: () => toast.info('â”€أ‰â”œأ؛ khâ”œâ”¤i phأںâ•—أ‘c câ”œأ،i â”€أ¦أںâ•‘â•–t mأںâ•‘â•–c â”€أ¦أںâ•—أ¯nh'),\r\n    });\r\n  };\r\n\r\n  React.useEffect(() => {\r\n    if (activeTab !== 'notifications') {\r\n      return;\r\n    }\r\n\r\n    registerNotificationActions([\r\n      <SettingsActionButton\r\n        key=\"save-notifications\"\r\n        onClick={() => {\r\n          handleSaveNotifications();\r\n          handleSaveReminders();\r\n        }}\r\n      >\r\n        <Save className=\"h-4 w-4\" /> Lâ•‍â–‘u câ”œأ،i â”€أ¦أںâ•‘â•–t\r\n      </SettingsActionButton>,\r\n    ]);\r\n  // eslint-disable-next-line react-hooks/exhaustive-deps\r\n  }, [activeTab, registerNotificationActions]);\r\n\r\n  // ============================================\r\n  // TEMPLATE HANDLERS\r\n  // ============================================\r\n\r\n  const handleAddTemplate = () => {\r\n    setEditingTemplate({\r\n      id: Date.now().toString(),\r\n      name: '',\r\n      title: '',\r\n      description: '',\r\n      category: 'general',\r\n      estimatedHours: 0,\r\n      order: templates.length + 1,\r\n    });\r\n    setIsAddingTemplate(true);\r\n  };\r\n\r\n  const handleSaveTemplate = () => {\r\n    if (!editingTemplate) return;\r\n\r\n    if (!editingTemplate.name.trim() || !editingTemplate.title.trim()) {\r\n      toast.error('Vui lâ”œâ–“ng â”€أ¦iأںâ•—أ¼n â”€أ¦أںâ•‘آ؛y â”€أ¦أںâ•—آ؛ tâ”œآ¬n vâ”œأ، tiâ”œآ¬u â”€أ¦أںâ•—أ¼ mأںâ•‘آ½u');\r\n      return;\r\n    }\r\n\r\n    let updatedTemplates: TaskTemplate[];\r\n    \r\n    if (isAddingTemplate) {\r\n      updatedTemplates = [...templates, editingTemplate];\r\n    } else {\r\n      updatedTemplates = templates.map(t => \r\n        t.id === editingTemplate.id ? editingTemplate : t\r\n      );\r\n    }\r\n\r\n    setTemplates(updatedTemplates);\r\n    updateSection.mutate({ type: 'templates', data: updatedTemplates }, {\r\n      onSuccess: () => {\r\n        toast.success(isAddingTemplate ? 'â”€أ‰â”œأ؛ thâ”œآ¬m mأںâ•‘آ½u' : 'â”€أ‰â”œأ؛ cأںâ•‘آ،p nhأںâ•‘آ،t mأںâ•‘آ½u');\r\n        setEditingTemplate(null);\r\n        setIsAddingTemplate(false);\r\n      },\r\n    });\r\n  };\r\n\r\n  const handleDeleteTemplate = (id: string) => {\r\n    const updatedTemplates = templates.filter(t => t.id !== id);\r\n    setTemplates(updatedTemplates);\r\n    updateSection.mutate({ type: 'templates', data: updatedTemplates }, {\r\n      onSuccess: () => {\r\n        toast.success('â”€أ‰â”œأ؛ xâ”œâ”‚a mأںâ•‘آ½u');\r\n        setDeleteTemplateId(null);\r\n      },\r\n    });\r\n  };\r\n\r\n  const _handleResetTemplates = () => {\r\n    const defaults = clone(defaultTemplates);\r\n    setTemplates(defaults);\r\n    updateSection.mutate({ type: 'templates', data: defaults }, {\r\n      onSuccess: () => toast.info('â”€أ‰â”œأ؛ khâ”œâ”¤i phأںâ•—أ‘c mأںâ•‘آ½u mأںâ•‘â•–c â”€أ¦أںâ•—أ¯nh'),\r\n    });\r\n  };\r\n\r\n  React.useEffect(() => {\r\n    if (activeTab !== 'templates') {\r\n      return;\r\n    }\r\n\r\n    registerTemplateActions([\r\n      <SettingsActionButton key=\"add-template\" onClick={handleAddTemplate}>\r\n        <Plus className=\"h-4 w-4\" /> Thâ”œآ¬m mأںâ•‘آ½u\r\n      </SettingsActionButton>,\r\n    ]);\r\n  // eslint-disable-next-line react-hooks/exhaustive-deps\r\n  }, [activeTab, registerTemplateActions]);\r\n\r\n  const tabs = React.useMemo(\r\n    () => [\r\n      { value: 'sla', label: 'SLA' },\r\n      { value: 'task-types', label: 'Loأںâ•‘أ­i CV' },\r\n      { value: 'evidence', label: 'Bأںâ•‘â–’ng chأںâ•—âŒگng' },\r\n      { value: 'card-colors', label: 'Mâ”œأ،u card' },\r\n      { value: 'templates', label: 'Mأںâ•‘آ½u CV' },\r\n      { value: 'notifications', label: 'Thâ”œâ”¤ng bâ”œأ­o' },\r\n    ],\r\n    [],\r\n  );\r\n\r\n  // ============================================\r\n  // RENDER\r\n  // ============================================\r\n\r\n  return (\r\n    <SettingsVerticalTabs value={activeTab} onValueChange={setActiveTab} tabs={tabs}>\r\n      {/* TAB 1: SLA SETTINGS */}\r\n      <TabsContent value=\"sla\" className=\"mt-0 space-y-4\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle className=\"text-lg font-semibold\">Câ”œأ،i â”€أ¦أںâ•‘â•–t SLA (Service Level Agreement)</CardTitle>\r\n              <CardDescription>\r\n                Thiأںâ•‘â”گt lأںâ•‘آ،p thأںâ•—آ¥i gian phأںâ•‘أ؛n hأںâ•—أ´i vâ”œأ، hoâ”œأ،n thâ”œأ،nh câ”œâ”¤ng viأںâ•—أ§c theo mأںâ•—âŒگc â”€أ¦أںâ•—أ– â•‍â–‘u tiâ”œآ¬n\r\n              </CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-5\">\r\n              {TASK_PRIORITY_CONFIGS.map(({ key, label, description, indicatorClass }) => (\r\n                <SettingsFormSection\r\n                  key={key}\r\n                  title={label}\r\n                  description={description}\r\n                  badge={(\r\n                    <div className=\"flex items-center gap-2 text-sm text-muted-foreground\">\r\n                      <span className={`h-2.5 w-2.5 rounded-full ${indicatorClass}`} />\r\n                      {key}\r\n                    </div>\r\n                  )}\r\n                >\r\n                  <SettingsFormGrid>\r\n                    <div className=\"space-y-2\">\r\n                      <Label htmlFor={`sla-${key}-response`}>Thأںâ•—آ¥i gian phأںâ•‘أ؛n hأںâ•—أ´i tأںâ•—أ¦i â”€أ¦a (phâ”œâ•‘t)</Label>\r\n                      <Input\r\n                        id={`sla-${key}-response`}\r\n                        type=\"number\"\r\n                        className=\"h-9\"\r\n                        value={sla[key].responseTime}\r\n                        onChange={(e) => handleSLAChange(key, 'responseTime', e.target.value)}\r\n                        min=\"0\"\r\n                      />\r\n                    </div>\r\n                    <div className=\"space-y-2\">\r\n                      <Label htmlFor={`sla-${key}-complete`}>Thأںâ•—آ¥i gian hoâ”œأ،n thâ”œأ،nh tأںâ•—أ¦i â”€أ¦a (giأںâ•—آ¥)</Label>\r\n                      <Input\r\n                        id={`sla-${key}-complete`}\r\n                        type=\"number\"\r\n                        className=\"h-9\"\r\n                        value={sla[key].completeTime}\r\n                        onChange={(e) => handleSLAChange(key, 'completeTime', e.target.value)}\r\n                        min=\"0\"\r\n                      />\r\n                    </div>\r\n                  </SettingsFormGrid>\r\n                </SettingsFormSection>\r\n              ))}\r\n\r\n            </CardContent>\r\n          </Card>\r\n      </TabsContent>\r\n\r\n      {/* TAB 2: TASK TYPES */}\r\n      <TabsContent value=\"task-types\" className=\"mt-0 space-y-4\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle className=\"text-lg font-semibold\">Loأںâ•‘أ­i câ”œâ”¤ng viأںâ•—أ§c</CardTitle>\r\n              <CardDescription>\r\n                Quأںâ•‘أ؛n lâ”œâ•œ câ”œأ­c loأںâ•‘أ­i câ”œâ”¤ng viأںâ•—أ§c â”€أ¦أںâ•—أ¢ phâ”œأ³n loأںâ•‘أ­i vâ”œأ، lأںâ•—أ¬c task dأںâ•—أ  dâ”œأ،ng hâ•‍أ­n\r\n              </CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-6\">\r\n              <SettingsFormSection\r\n                title=\"Danh sâ”œأ­ch loأںâ•‘أ­i câ”œâ”¤ng viأںâ•—أ§c\"\r\n                description=\"Chuأںâ•‘âŒگn hâ”œâ”‚a bأںâ•—أ– lأںâ•—أ¬c vâ”œأ، automation theo tأںâ•—آ½ng nhâ”œâ”‚m task.\"\r\n                contentClassName=\"space-y-4\"\r\n              >\r\n                <div className=\"rounded-lg border\">\r\n                  <Table>\r\n                    <TableHeader>\r\n                      <TableRow>\r\n                        <TableHead>Tâ”œآ¬n loأںâ•‘أ­i</TableHead>\r\n                        <TableHead>Mâ”œâ”¤ tأںâ•‘أ؛</TableHead>\r\n                        <TableHead className=\"w-[100px]\">Trأںâ•‘أ­ng thâ”œأ­i</TableHead>\r\n                        <TableHead className=\"w-[120px]\">Thao tâ”œأ­c</TableHead>\r\n                      </TableRow>\r\n                    </TableHeader>\r\n                    <TableBody>\r\n                      {taskTypes.length === 0 ? (\r\n                        <TableRow>\r\n                          <TableCell colSpan={4} className=\"text-center text-muted-foreground\">\r\n                            Châ•‍â–‘a câ”œâ”‚ loأںâ•‘أ­i câ”œâ”¤ng viأںâ•—أ§c nâ”œأ،o\r\n                          </TableCell>\r\n                        </TableRow>\r\n                      ) : (\r\n                        taskTypes.map((type) => (\r\n                          <TableRow key={type.id}>\r\n                            <TableCell className=\"font-medium\">{type.name}</TableCell>\r\n                            <TableCell className=\"text-sm text-muted-foreground\">\r\n                              {type.description}\r\n                            </TableCell>\r\n                            <TableCell>\r\n                              <Switch\r\n                                checked={type.isActive}\r\n                                onCheckedChange={() => handleToggleTypeActive(type.id)}\r\n                              />\r\n                            </TableCell>\r\n                            <TableCell>\r\n                              <DropdownMenu>\r\n                                <DropdownMenuTrigger asChild>\r\n                                  <Button variant=\"ghost\" size=\"icon\" className=\"h-8 w-8\">\r\n                                    <MoreHorizontal className=\"h-4 w-4\" />\r\n                                  </Button>\r\n                                </DropdownMenuTrigger>\r\n                                <DropdownMenuContent align=\"end\">\r\n                                  <DropdownMenuItem\r\n                                    onClick={() => {\r\n                                      setEditingType(type);\r\n                                      setIsAddingType(false);\r\n                                    }}\r\n                                  >\r\n                                    Sأںâ•—آ،a\r\n                                  </DropdownMenuItem>\r\n                                  <DropdownMenuItem\r\n                                    className=\"text-destructive\"\r\n                                    onClick={() => setDeleteTypeId(type.id)}\r\n                                  >\r\n                                    Xâ”œâ”‚a\r\n                                  </DropdownMenuItem>\r\n                                </DropdownMenuContent>\r\n                              </DropdownMenu>\r\n                            </TableCell>\r\n                          </TableRow>\r\n                        ))\r\n                      )}\r\n                    </TableBody>\r\n                  </Table>\r\n                </div>\r\n              </SettingsFormSection>\r\n            </CardContent>\r\n          </Card>\r\n\r\n      {/* Dialog chأںâ•—أ«nh sأںâ•—آ،a loأںâ•‘أ­i câ”œâ”¤ng viأںâ•—أ§c */}\r\n      <Dialog open={!!editingType} onOpenChange={(open) => {\r\n        if (!open) {\r\n          setEditingType(null);\r\n          setIsAddingType(false);\r\n        }\r\n      }}>\r\n        <DialogContent className=\"sm:max-w-[500px]\">\r\n          <DialogHeader>\r\n            <DialogTitle>{isAddingType ? 'Thâ”œآ¬m loأںâ•‘أ­i câ”œâ”¤ng viأںâ•—أ§c mأںâ•—آ¢i' : 'Chأںâ•—أ«nh sأںâ•—آ،a loأںâ•‘أ­i câ”œâ”¤ng viأںâ•—أ§c'}</DialogTitle>\r\n            <DialogDescription>\r\n              â”€أ‰iأںâ•—أ¼n thâ”œâ”¤ng tin hiأںâ•—أ¢n thأںâ•—أ¯ trâ”œآ¬n task board vâ”œأ، bأںâ•—أ– lأںâ•—أ¬c.\r\n            </DialogDescription>\r\n          </DialogHeader>\r\n          {editingType && (\r\n            <div className=\"space-y-4\">\r\n              <div className=\"space-y-2\">\r\n                <Label htmlFor=\"type-name\">Tâ”œآ¬n loأںâ•‘أ­i câ”œâ”¤ng viأںâ•—أ§c *</Label>\r\n                <Input\r\n                  id=\"type-name\"\r\n                  className=\"h-9\"\r\n                  value={editingType.name}\r\n                  onChange={(e) => setEditingType({ ...editingType, name: e.target.value })}\r\n                  placeholder=\"VD: Phâ”œأ­t triأںâ•—أ¢n\"\r\n                />\r\n              </div>\r\n\r\n              <div className=\"space-y-2\">\r\n                <Label htmlFor=\"type-description\">Mâ”œâ”¤ tأںâ•‘أ؛</Label>\r\n                <Textarea\r\n                  id=\"type-description\"\r\n                  value={editingType.description}\r\n                  onChange={(e) => setEditingType({ ...editingType, description: e.target.value })}\r\n                  placeholder=\"VD: Câ”œâ”¤ng viأںâ•—أ§c liâ”œآ¬n quan â”€أ¦أںâ•‘â”گn code/development\"\r\n                  rows={3}\r\n                />\r\n              </div>\r\n\r\n              <div className=\"flex items-center gap-2\">\r\n                <Switch\r\n                  id=\"type-active\"\r\n                  checked={editingType.isActive}\r\n                  onCheckedChange={(checked) => setEditingType({ ...editingType, isActive: checked })}\r\n                />\r\n                <Label htmlFor=\"type-active\" className=\"cursor-pointer\">\r\n                  Kâ”œآ،ch hoأںâ•‘أ­t\r\n                </Label>\r\n              </div>\r\n            </div>\r\n          )}\r\n          <DialogFooter>\r\n            <Button\r\n              variant=\"outline\"\r\n              onClick={() => {\r\n                setEditingType(null);\r\n                setIsAddingType(false);\r\n              }}\r\n            >\r\n              Hأںâ•—آ؛y\r\n            </Button>\r\n            <Button onClick={handleSaveType}>\r\n              <Save className=\"h-4 w-4 mr-2\" />\r\n              {isAddingType ? 'Thâ”œآ¬m loأںâ•‘أ­i' : 'Lâ•‍â–‘u thay â”€أ¦أںâ•—أ²i'}\r\n            </Button>\r\n          </DialogFooter>\r\n        </DialogContent>\r\n      </Dialog>\r\n\r\n      {/* AlertDialog xâ”œأ­c nhأںâ•‘آ،n xâ”œâ”‚a loأںâ•‘أ­i câ”œâ”¤ng viأںâ•—أ§c */}\r\n      <AlertDialog open={!!deleteTypeId} onOpenChange={(open) => !open && setDeleteTypeId(null)}>\r\n        <AlertDialogContent>\r\n          <AlertDialogHeader>\r\n            <AlertDialogTitle>Xâ”œأ­c nhأںâ•‘آ،n xâ”œâ”‚a</AlertDialogTitle>\r\n            <AlertDialogDescription>\r\n              Bأںâ•‘أ­n câ”œâ”‚ chأںâ•‘آ»c chأںâ•‘آ»n muأںâ•—أ¦n xâ”œâ”‚a loأںâ•‘أ­i câ”œâ”¤ng viأںâ•—أ§c nâ”œأ،y? Hâ”œأ،nh â”€أ¦أںâ•—أ–ng nâ”œأ،y khâ”œâ”¤ng thأںâ•—أ¢ hoâ”œأ،n tâ”œأ­c.\r\n            </AlertDialogDescription>\r\n          </AlertDialogHeader>\r\n          <AlertDialogFooter>\r\n            <AlertDialogCancel>Hأںâ•—آ؛y</AlertDialogCancel>\r\n            <AlertDialogAction\r\n              className=\"bg-destructive text-destructive-foreground hover:bg-destructive/90\"\r\n              onClick={() => deleteTypeId && handleDeleteType(deleteTypeId)}\r\n            >\r\n              Xâ”œâ”‚a\r\n            </AlertDialogAction>\r\n          </AlertDialogFooter>\r\n        </AlertDialogContent>\r\n      </AlertDialog>\r\n      </TabsContent>\r\n\r\n      {/* TAB 3: EVIDENCE SETTINGS */}\r\n      <TabsContent value=\"evidence\" className=\"mt-0 space-y-4\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle className=\"text-lg font-semibold\">Câ”œأ،i â”€أ¦أںâ•‘â•–t bأںâ•‘â–’ng chأںâ•—âŒگng hoâ”œأ،n thâ”œأ،nh</CardTitle>\r\n              <CardDescription>\r\n                Cأںâ•‘أ‘u hâ”œآ¼nh yâ”œآ¬u cأںâ•‘آ؛u vأںâ•—أ¼ hâ”œآ¼nh أںâ•‘أ؛nh vâ”œأ، ghi châ”œâ•‘ khi hoâ”œأ،n thâ”œأ،nh câ”œâ”¤ng viأںâ•—أ§c\r\n              </CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-6\">\r\n              <SettingsFormSection\r\n                title=\"Giأںâ•—آ¢i hأںâ•‘أ­n أںâ•‘أ؛nh & dung lâ•‍â–‘أںâ•—أ؛ng\"\r\n                description=\"â”œأ¼p dأںâ•—أ‘ng khi nhâ”œأ³n viâ”œآ¬n tأںâ•‘أ؛i أںâ•‘أ؛nh hoâ”œأ،n thâ”œأ،nh task.\"\r\n              >\r\n                <SettingsFormGrid>\r\n                  <div className=\"space-y-2\">\r\n                    <Label htmlFor=\"max-images\">Sأںâ•—أ¦ lâ•‍â–‘أںâ•—أ؛ng أںâ•‘أ؛nh tأںâ•—أ¦i â”€أ¦a</Label>\r\n                    <Input\r\n                      id=\"max-images\"\r\n                      type=\"number\"\r\n                      className=\"h-9\"\r\n                      value={evidence.maxImages}\r\n                      onChange={(e) => handleEvidenceChange('maxImages', parseInt(e.target.value) || 1)}\r\n                      min=\"1\"\r\n                      max=\"10\"\r\n                    />\r\n                    <p className=\"text-xs text-muted-foreground\">Giأںâ•—آ¢i hأںâ•‘أ­n tأںâ•—آ½ 1-10 أںâ•‘أ؛nh mأںâ•—أ¹i lأںâ•‘آ؛n gأںâ•—آ،i.</p>\r\n                  </div>\r\n\r\n                  <div className=\"space-y-2\">\r\n                    <Label htmlFor=\"max-size\">Kâ”œآ،ch thâ•‍â–‘أںâ•—آ¢c file tأںâ•—أ¦i â”€أ¦a (MB)</Label>\r\n                    <Input\r\n                      id=\"max-size\"\r\n                      type=\"number\"\r\n                      className=\"h-9\"\r\n                      value={evidence.imageMaxSizeMB}\r\n                      onChange={(e) => handleEvidenceChange('imageMaxSizeMB', parseInt(e.target.value) || 1)}\r\n                      min=\"1\"\r\n                      max=\"50\"\r\n                    />\r\n                    <p className=\"text-xs text-muted-foreground\">Chأںâ•‘أ‘p nhأںâ•‘آ،n tأںâ•—آ½ 1-50MB cho mأںâ•—أ¹i أںâ•‘أ؛nh.</p>\r\n                  </div>\r\n\r\n                  <div className=\"space-y-2\">\r\n                    <Label htmlFor=\"min-note\">â”€أ‰أںâ•—أ– dâ”œأ،i ghi châ”œâ•‘ tأںâ•—أ¦i thiأںâ•—أ¢u (kâ”œâ•œ tأںâ•—â–’)</Label>\r\n                    <Input\r\n                      id=\"min-note\"\r\n                      type=\"number\"\r\n                      className=\"h-9\"\r\n                      value={evidence.minNoteLength}\r\n                      onChange={(e) => handleEvidenceChange('minNoteLength', parseInt(e.target.value) || 0)}\r\n                      min=\"0\"\r\n                      max=\"500\"\r\n                    />\r\n                    <p className=\"text-xs text-muted-foreground\">0 = khâ”œâ”¤ng bأںâ•‘آ»t buأںâ•—أ–c ghi châ”œâ•‘.</p>\r\n                  </div>\r\n                </SettingsFormGrid>\r\n              </SettingsFormSection>\r\n\r\n              <SettingsFormSection\r\n                title=\"Ghi châ”œâ•‘ & â”€أ¦أںâ•—أ¯nh dأںâ•‘أ­ng file\"\r\n                description=\"â”€أ‰أںâ•‘أ؛m bأںâ•‘أ؛o bأںâ•‘â–’ng chأںâ•—âŒگng câ”œâ”‚ thâ”œâ”¤ng tin â”€أ¦أںâ•‘آ؛y â”€أ¦أںâ•—آ؛ khi gأںâ•—آ،i duyأںâ•—أ§t.\"\r\n              >\r\n                <div className=\"space-y-4\">\r\n                  <div className=\"flex items-center gap-3\">\r\n                    <Switch\r\n                      id=\"require-note\"\r\n                      checked={evidence.requireNoteWithImages}\r\n                      onCheckedChange={(checked) => handleEvidenceChange('requireNoteWithImages', checked)}\r\n                    />\r\n                    <div>\r\n                      <Label htmlFor=\"require-note\" className=\"cursor-pointer\">\r\n                        Bأںâ•‘آ»t buأںâ•—أ–c ghi châ”œâ•‘ khi â”€أ¦â”œآ،nh kâ”œآ؟m أںâ•‘أ؛nh\r\n                      </Label>\r\n                      <p className=\"text-xs text-muted-foreground\">Tâ”€أ¢ng chأںâ•‘أ‘t lâ•‍â–‘أںâ•—أ؛ng bأںâ•‘â–’ng chأںâ•—âŒگng khi gأںâ•—آ،i cho quأںâ•‘أ؛n lâ”œâ•œ.</p>\r\n                    </div>\r\n                  </div>\r\n\r\n                  <div className=\"bg-blue-50 border border-blue-200 rounded-lg p-4 dark:bg-blue-950 dark:border-blue-800\">\r\n                    <p className=\"text-sm font-medium text-blue-900 dark:text-blue-100 mb-2\">\r\n                      â‰،ئ’أ†أ­ â”€أ‰أںâ•—أ¯nh dأںâ•‘أ­ng أںâ•‘أ؛nh â”€أ¦â•‍â–‘أںâ•—أ؛c hأںâ•—أ¹ trأںâ•—أ؛\r\n                    </p>\r\n                    <ul className=\"text-sm text-blue-800 dark:text-blue-200 space-y-1 list-disc list-inside\">\r\n                      <li>JPEG (.jpg, .jpeg)</li>\r\n                      <li>PNG (.png)</li>\r\n                      <li>WebP (.webp)</li>\r\n                    </ul>\r\n                  </div>\r\n                </div>\r\n              </SettingsFormSection>\r\n\r\n            </CardContent>\r\n          </Card>\r\n      </TabsContent>\r\n\r\n      {/* TAB 4: CARD COLORS */}\r\n      <TabsContent value=\"card-colors\" className=\"mt-0 space-y-4\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle className=\"text-lg font-semibold\">Mâ”œأ،u sأںâ•‘آ»c card câ”œâ”¤ng viأںâ•—أ§c</CardTitle>\r\n              <CardDescription>\r\n                â”€أ‰أںâ•—أ´ng bأںâ•—أ– mâ”œأ،u card giأںâ•—آ»a task board vâ”œأ، timeline â”€أ¦أںâ•—أ¢ dأںâ•—أ  quâ”œâŒگt trأںâ•‘أ­ng thâ”œأ­i\r\n              </CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-6\">\r\n              <SettingsFormSection\r\n                title=\"Quy tأںâ•‘آ»c â”œأ­p dأںâ•—أ‘ng mâ”œأ،u\"\r\n                description=\"Chأںâ•—أ¬n nhâ”œâ”‚m hiأںâ•—أ¢n thأںâ•—أ¯ mâ”œأ،u cho board.\"\r\n              >\r\n                <div className=\"space-y-4\">\r\n                  <div className=\"flex items-center justify-between\">\r\n                    <div className=\"space-y-0.5\">\r\n                      <Label htmlFor=\"enable-status\">Mâ”œأ،u theo trأںâ•‘أ­ng thâ”œأ­i</Label>\r\n                      <p className=\"text-sm text-muted-foreground\">Giâ”œâ•‘p nhأںâ•‘آ،n biأںâ•‘â”گt tiأںâ•‘â”گn â”€أ¦أںâ•—أ– task theo lifecycle.</p>\r\n                    </div>\r\n                    <Switch\r\n                      id=\"enable-status\"\r\n                      checked={cardColors.enableStatusColors}\r\n                      onCheckedChange={() => handleCardColorToggle('enableStatusColors')}\r\n                    />\r\n                  </div>\r\n\r\n                  <div className=\"flex items-center justify-between\">\r\n                    <div className=\"space-y-0.5\">\r\n                      <Label htmlFor=\"enable-priority\">Mâ”œأ،u theo â”€أ¦أںâ•—أ– â•‍â–‘u tiâ”œآ¬n</Label>\r\n                      <p className=\"text-sm text-muted-foreground\">â”€أ‰أںâ•—أ²i mâ”œأ،u dأںâ•—â–’a trâ”œآ¬n priority (Low خ“أ¥أ† Urgent).</p>\r\n                    </div>\r\n                    <Switch\r\n                      id=\"enable-priority\"\r\n                      checked={cardColors.enablePriorityColors}\r\n                      onCheckedChange={() => handleCardColorToggle('enablePriorityColors')}\r\n                    />\r\n                  </div>\r\n\r\n                  <div className=\"flex items-center justify-between\">\r\n                    <div className=\"space-y-0.5\">\r\n                      <Label htmlFor=\"enable-overdue\">Mâ”œأ،u cأںâ•‘أ؛nh bâ”œأ­o quâ”œأ­ hأںâ•‘أ­n</Label>\r\n                      <p className=\"text-sm text-muted-foreground\">â”€أ‰أںâ•—أ²i mâ”œأ،u card thâ”œأ،nh â”€أ¦أںâ•—أ… khi task trأںâ•—أ  SLA.</p>\r\n                    </div>\r\n                    <Switch\r\n                      id=\"enable-overdue\"\r\n                      checked={cardColors.enableOverdueColor}\r\n                      onCheckedChange={() => handleCardColorToggle('enableOverdueColor')}\r\n                    />\r\n                  </div>\r\n                </div>\r\n              </SettingsFormSection>\r\n\r\n              {cardColors.enableStatusColors && (\r\n                <SettingsFormSection\r\n                  title=\"Mâ”œأ،u theo trأںâ•‘أ­ng thâ”œأ­i\"\r\n                  description=\"Câ”œأ­ nhâ”œأ³n hâ”œâ”‚a mâ”œأ،u nأںâ•—أ¼n card cho tأںâ•—آ½ng trأںâ•‘أ­ng thâ”œأ­i task.\"\r\n                >\r\n                  <SettingsFormGrid>\r\n                    {STATUS_COLOR_CONFIGS.map(({ key, label, helper }) => (\r\n                      <div key={key} className=\"space-y-2\">\r\n                        <TailwindColorPicker\r\n                          label={`Mâ”œأ،u cho trأںâ•‘أ­ng thâ”œأ­i \"${label}\"`}\r\n                          value={cardColors.statusColors[key]}\r\n                          onChange={(value) => handleStatusColorChange(key, value)}\r\n                          placeholder=\"bg-blue-50 border-blue-200\"\r\n                        />\r\n                        <p className=\"text-xs text-muted-foreground\">{helper}</p>\r\n                      </div>\r\n                    ))}\r\n                  </SettingsFormGrid>\r\n                </SettingsFormSection>\r\n              )}\r\n\r\n              {cardColors.enablePriorityColors && (\r\n                <SettingsFormSection\r\n                  title=\"Mâ”œأ،u theo â”€أ¦أںâ•—أ– â•‍â–‘u tiâ”œآ¬n\"\r\n                  description=\"â”œأ¼p dأںâ•—أ‘ng khi board hiأںâ•—أ¢n thأںâ•—أ¯ priority nأںâ•—أ²i bأںâ•‘آ،t.\"\r\n                >\r\n                  <SettingsFormGrid>\r\n                    {PRIORITY_COLOR_CONFIGS.map(({ key, label, helper }) => (\r\n                      <div key={key} className=\"space-y-2\">\r\n                        <TailwindColorPicker\r\n                          label={`Mâ”œأ،u cho ${label}`}\r\n                          value={cardColors.priorityColors[key]}\r\n                          onChange={(value) => handlePriorityColorChange(key, value)}\r\n                          placeholder=\"bg-amber-50 border-amber-200\"\r\n                        />\r\n                        <p className=\"text-xs text-muted-foreground\">{helper}</p>\r\n                      </div>\r\n                    ))}\r\n                  </SettingsFormGrid>\r\n                </SettingsFormSection>\r\n              )}\r\n\r\n              {cardColors.enableOverdueColor && (\r\n                <SettingsFormSection\r\n                  title=\"Mâ”œأ،u cأںâ•‘أ؛nh bâ”œأ­o quâ”œأ­ hأںâ•‘أ­n\"\r\n                  description=\"â•‍آ»u tiâ”œآ¬n hiأںâ•—أ¢n thأںâ•—أ¯ mâ”œأ،u cأںâ•‘أ؛nh bâ”œأ­o trâ”œآ¬n mأںâ•—أ¬i card quâ”œأ­ hأںâ•‘أ­n.\"\r\n                >\r\n                  <div className=\"space-y-2\">\r\n                    <TailwindColorPicker\r\n                      label=\"Mâ”œأ،u card quâ”œأ­ hأںâ•‘أ­n\"\r\n                      value={cardColors.overdueColor}\r\n                      onChange={handleOverdueColorChange}\r\n                      placeholder=\"bg-red-50 border-red-400\"\r\n                    />\r\n                    <p className=\"text-xs text-muted-foreground\">\r\n                      Khi bأںâ•‘آ،t, mâ”œأ،u nâ”œأ،y sأںâ•‘â•œ ghi â”€أ¦â”œآ؟ mأںâ•—أ¬i cأںâ•‘أ‘u hâ”œآ¼nh khâ”œأ­c cho task trأںâ•—أ  deadline.\r\n                    </p>\r\n                  </div>\r\n                </SettingsFormSection>\r\n              )}\r\n\r\n            </CardContent>\r\n          </Card>\r\n      </TabsContent>\r\n\r\n      {/* TAB 5: TEMPLATES */}\r\n      <TabsContent value=\"templates\" className=\"mt-0 space-y-4\">\r\n          <Card>\r\n            <CardHeader>\r\n              <div>\r\n                <CardTitle className=\"text-lg font-semibold\">Mأںâ•‘آ½u câ”œâ”¤ng viأںâ•—أ§c</CardTitle>\r\n                <CardDescription>\r\n                  Tأںâ•‘أ­o vâ”œأ، quأںâ•‘أ؛n lâ”œâ•œ câ”œأ­c mأںâ•‘آ½u câ”œâ”¤ng viأںâ•—أ§c â”€أ¦أںâ•—أ¢ tأںâ•‘أ­o task nhanh hâ•‍أ­n\r\n                </CardDescription>\r\n              </div>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-6\">\r\n              <SettingsFormSection\r\n                title=\"Danh sâ”œأ­ch mأںâ•‘آ½u câ”œâ”¤ng viأںâ•—أ§c\"\r\n                description=\"Chuأںâ•‘âŒگn hâ”œâ”‚a nأںâ•—أ–i dung mâ”œâ”¤ tأںâ•‘أ؛, checklist vâ”œأ، thأںâ•—آ¥i gian â•‍â–‘أںâ•—آ¢c tâ”œآ،nh.\"\r\n                contentClassName=\"space-y-4\"\r\n              >\r\n                {templates.length === 0 ? (\r\n                  <div className=\"text-center py-8 text-muted-foreground\">\r\n                    Châ•‍â–‘a câ”œâ”‚ mأںâ•‘آ½u nâ”œأ،o. Nhأںâ•‘أ‘n \"Thâ”œآ¬m mأںâ•‘آ½u\" â”€أ¦أںâ•—أ¢ tأںâ•‘أ­o mأںâ•‘آ½u mأںâ•—آ¢i.\r\n                  </div>\r\n                ) : (\r\n                  <div className=\"rounded-lg border overflow-x-auto\">\r\n                    <Table>\r\n                      <TableHeader>\r\n                        <TableRow>\r\n                          <TableHead>Tâ”œآ¬n mأںâ•‘آ½u</TableHead>\r\n                          <TableHead>Danh mأںâ•—أ‘c</TableHead>\r\n                          <TableHead>â•‍آ»أںâ•—آ¢c tâ”œآ،nh (giأںâ•—آ¥)</TableHead>\r\n                          <TableHead className=\"text-right\">Thao tâ”œأ­c</TableHead>\r\n                        </TableRow>\r\n                      </TableHeader>\r\n                      <TableBody>\r\n                        {templates.map(template => (\r\n                          <TableRow key={template.id}>\r\n                            <TableCell className=\"font-medium\">{template.name}</TableCell>\r\n                            <TableCell>\r\n                              <span className=\"text-xs px-2 py-1 rounded-md bg-muted\">\r\n                                {template.category === 'development' && 'Phâ”œأ­t triأںâ•—أ¢n'}\r\n                                {template.category === 'design' && 'Thiأںâ•‘â”گt kأںâ•‘â”گ'}\r\n                                {template.category === 'marketing' && 'Marketing'}\r\n                                {template.category === 'admin' && 'Quأںâ•‘أ؛n trأںâ•—أ¯'}\r\n                                {template.category === 'general' && 'Chung'}\r\n                              </span>\r\n                            </TableCell>\r\n                            <TableCell>{template.estimatedHours}h</TableCell>\r\n                            <TableCell className=\"text-right\">\r\n                              <DropdownMenu>\r\n                                <DropdownMenuTrigger asChild>\r\n                                  <Button variant=\"ghost\" size=\"icon\" className=\"h-8 w-8\">\r\n                                    <MoreHorizontal className=\"h-4 w-4\" />\r\n                                  </Button>\r\n                                </DropdownMenuTrigger>\r\n                                <DropdownMenuContent align=\"end\">\r\n                                  <DropdownMenuItem\r\n                                    onClick={() => {\r\n                                      setEditingTemplate(template);\r\n                                      setIsAddingTemplate(false);\r\n                                    }}\r\n                                  >\r\n                                    Sأںâ•—آ،a\r\n                                  </DropdownMenuItem>\r\n                                  <DropdownMenuItem\r\n                                    className=\"text-destructive\"\r\n                                    onClick={() => setDeleteTemplateId(template.id)}\r\n                                  >\r\n                                    Xâ”œâ”‚a\r\n                                  </DropdownMenuItem>\r\n                                </DropdownMenuContent>\r\n                              </DropdownMenu>\r\n                            </TableCell>\r\n                          </TableRow>\r\n                        ))}\r\n                      </TableBody>\r\n                    </Table>\r\n                  </div>\r\n                )}\r\n              </SettingsFormSection>\r\n            </CardContent>\r\n          </Card>\r\n\r\n      {/* Dialog chأںâ•—أ«nh sأںâ•—آ،a mأںâ•‘آ½u câ”œâ”¤ng viأںâ•—أ§c */}\r\n      <Dialog open={!!editingTemplate} onOpenChange={(open) => {\r\n        if (!open) {\r\n          setEditingTemplate(null);\r\n          setIsAddingTemplate(false);\r\n        }\r\n      }}>\r\n        <DialogContent className=\"sm:max-w-[600px]\">\r\n          <DialogHeader>\r\n            <DialogTitle>{isAddingTemplate ? 'Thâ”œآ¬m mأںâ•‘آ½u mأںâ•—آ¢i' : 'Chأںâ•—أ«nh sأںâ•—آ،a mأںâ•‘آ½u'}</DialogTitle>\r\n            <DialogDescription>\r\n              â”€أ‰iأںâ•—أ¼n chi tiأںâ•‘â”گt template dâ”œâ•£ng khi tأںâ•‘أ­o nhanh câ”œâ”¤ng viأںâ•—أ§c.\r\n            </DialogDescription>\r\n          </DialogHeader>\r\n          {editingTemplate && (\r\n            <div className=\"space-y-4\">\r\n              <SettingsFormGrid>\r\n                <div className=\"space-y-2\">\r\n                  <Label htmlFor=\"template-name\">Tâ”œآ¬n mأںâ•‘آ½u *</Label>\r\n                  <Input\r\n                    id=\"template-name\"\r\n                    className=\"h-9\"\r\n                    value={editingTemplate.name}\r\n                    onChange={(e) => setEditingTemplate({ ...editingTemplate, name: e.target.value })}\r\n                    placeholder=\"VD: Bug Fix\"\r\n                  />\r\n                </div>\r\n\r\n                <div className=\"space-y-2\">\r\n                  <Label htmlFor=\"template-category\">Danh mأںâ•—أ‘c</Label>\r\n                  <Select\r\n                    value={editingTemplate.category}\r\n                    onValueChange={(value) => setEditingTemplate({ \r\n                      ...editingTemplate, \r\n                      category: value as TaskTemplate['category']\r\n                    })}\r\n                  >\r\n                    <SelectTrigger id=\"template-category\" className=\"h-9\">\r\n                      <SelectValue />\r\n                    </SelectTrigger>\r\n                    <SelectContent>\r\n                      <SelectItem value=\"development\">Phâ”œأ­t triأںâ•—أ¢n</SelectItem>\r\n                      <SelectItem value=\"design\">Thiأںâ•‘â”گt kأںâ•‘â”گ</SelectItem>\r\n                      <SelectItem value=\"marketing\">Marketing</SelectItem>\r\n                      <SelectItem value=\"admin\">Quأںâ•‘أ؛n trأںâ•—أ¯</SelectItem>\r\n                      <SelectItem value=\"general\">Chung</SelectItem>\r\n                    </SelectContent>\r\n                  </Select>\r\n                </div>\r\n\r\n                <div className=\"space-y-2 md:col-span-2\">\r\n                  <Label htmlFor=\"template-title\">Tiâ”œآ¬u â”€أ¦أںâ•—أ¼ mأںâ•‘آ½u *</Label>\r\n                  <Input\r\n                    id=\"template-title\"\r\n                    className=\"h-9\"\r\n                    value={editingTemplate.title}\r\n                    onChange={(e) => setEditingTemplate({ ...editingTemplate, title: e.target.value })}\r\n                    placeholder=\"VD: Sأںâ•—آ،a lأںâ•—أ¹i: [Tâ”œآ¬n lأںâ•—أ¹i]\"\r\n                  />\r\n                </div>\r\n\r\n                <div className=\"space-y-2 md:col-span-2\">\r\n                  <Label>Mâ”œâ”¤ tأںâ•‘أ؛ mأںâ•‘آ½u</Label>\r\n                  <TipTapEditor\r\n                    content={editingTemplate.description}\r\n                    onChange={(content) => setEditingTemplate({ ...editingTemplate, description: content })}\r\n                    placeholder=\"Nhأںâ•‘آ،p mâ”œâ”¤ tأںâ•‘أ؛ chi tiأںâ•‘â”گt...\"\r\n                    minHeight=\"150px\"\r\n                  />\r\n                </div>\r\n\r\n                <div className=\"space-y-2\">\r\n                  <Label htmlFor=\"template-hours\">â•‍آ»أںâ•—آ¢c tâ”œآ،nh thأںâ•—آ¥i gian (giأںâ•—آ¥)</Label>\r\n                  <Input\r\n                    id=\"template-hours\"\r\n                    type=\"number\"\r\n                    className=\"h-9\"\r\n                    value={editingTemplate.estimatedHours}\r\n                    onChange={(e) => setEditingTemplate({ \r\n                      ...editingTemplate, \r\n                      estimatedHours: parseInt(e.target.value) || 0 \r\n                    })}\r\n                    min=\"0\"\r\n                  />\r\n                </div>\r\n              </SettingsFormGrid>\r\n            </div>\r\n          )}\r\n          <DialogFooter>\r\n            <Button variant=\"outline\" onClick={() => {\r\n              setEditingTemplate(null);\r\n              setIsAddingTemplate(false);\r\n            }}>\r\n              Hأںâ•—آ؛y\r\n            </Button>\r\n            <Button onClick={handleSaveTemplate}>\r\n              <Save className=\"h-4 w-4 mr-2\" />\r\n              Lâ•‍â–‘u\r\n            </Button>\r\n          </DialogFooter>\r\n        </DialogContent>\r\n      </Dialog>\r\n\r\n      {/* AlertDialog xâ”œأ­c nhأںâ•‘آ،n xâ”œâ”‚a mأںâ•‘آ½u */}\r\n      <AlertDialog open={!!deleteTemplateId} onOpenChange={(open) => !open && setDeleteTemplateId(null)}>\r\n        <AlertDialogContent>\r\n          <AlertDialogHeader>\r\n            <AlertDialogTitle>Xâ”œأ­c nhأںâ•‘آ،n xâ”œâ”‚a</AlertDialogTitle>\r\n            <AlertDialogDescription>\r\n              Bأںâ•‘أ­n câ”œâ”‚ chأںâ•‘آ»c chأںâ•‘آ»n muأںâ•—أ¦n xâ”œâ”‚a mأںâ•‘آ½u câ”œâ”¤ng viأںâ•—أ§c nâ”œأ،y? Hâ”œأ،nh â”€أ¦أںâ•—أ–ng nâ”œأ،y khâ”œâ”¤ng thأںâ•—أ¢ hoâ”œأ،n tâ”œأ­c.\r\n            </AlertDialogDescription>\r\n          </AlertDialogHeader>\r\n          <AlertDialogFooter>\r\n            <AlertDialogCancel>Hأںâ•—آ؛y</AlertDialogCancel>\r\n            <AlertDialogAction\r\n              className=\"bg-destructive text-destructive-foreground hover:bg-destructive/90\"\r\n              onClick={() => deleteTemplateId && handleDeleteTemplate(deleteTemplateId)}\r\n            >\r\n              Xâ”œâ”‚a\r\n            </AlertDialogAction>\r\n          </AlertDialogFooter>\r\n        </AlertDialogContent>\r\n      </AlertDialog>\r\n      </TabsContent>\r\n\r\n      {/* TAB 6: NOTIFICATIONS & REMINDERS */}\r\n      <TabsContent value=\"notifications\" className=\"mt-0 space-y-4\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle className=\"text-lg font-semibold\">Câ”œأ،i â”€أ¦أںâ•‘â•–t thâ”œâ”¤ng bâ”œأ­o & nhأںâ•‘آ»c nhأںâ•—ئ’</CardTitle>\r\n              <CardDescription>\r\n                Quأںâ•‘أ؛n lâ”œâ•œ thâ”œâ”¤ng bâ”œأ­o vâ”œأ، nhأںâ•‘آ»c nhأںâ•—ئ’ tأںâ•—â–’ â”€أ¦أںâ•—أ–ng cho câ”œâ”¤ng viأںâ•—أ§c\r\n              </CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-6\">\r\n              <SettingsFormSection\r\n                title=\"Thâ”œâ”¤ng bâ”œأ­o Email\"\r\n                description=\"Gأںâ•—آ،i cأںâ•‘آ،p nhأںâ•‘آ،t tأںâ•—آ¢i ngâ•‍â–‘أںâ•—آ¥i phأںâ•—أ‘ trâ”œأ­ch vâ”œأ، quأںâ•‘أ؛n lâ”œâ•œ theo tأںâ•—آ½ng giai â”€أ¦oأںâ•‘أ­n.\"\r\n                contentClassName=\"space-y-3\"\r\n              >\r\n                <div className=\"flex items-center justify-between\">\r\n                  <Label htmlFor=\"email-create\" className=\"cursor-pointer\">\r\n                    Khi câ”œâ”¤ng viأںâ•—أ§c mأںâ•—آ¢i â”€أ¦â•‍â–‘أںâ•—أ؛c tأںâ•‘أ­o\r\n                  </Label>\r\n                  <Switch\r\n                    id=\"email-create\"\r\n                    checked={notifications.emailOnCreate}\r\n                    onCheck