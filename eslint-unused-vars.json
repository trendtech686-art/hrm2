penReason, setReopenReason] = React.useState('');\r\n  const { user: _currentUser } = useAuth();\r\n  const { update } = useWarrantyMutations({\r\n    onUpdateSuccess: () => toast.success('â”€أ‰â”œأ؛ mأںâ•—ئ’ lأںâ•‘أ­i phiأںâ•‘â”گu bأںâ•‘أ؛o hâ”œأ،nh'),\r\n    onError: (err) => toast.error(err.message)\r\n  });\r\n\r\n  const handleReopen = React.useCallback(() => {\r\n    if (!ticket || !reopenReason.trim()) {\r\n      toast.error('Vui lâ”œâ–“ng nhأںâ•‘آ،p lâ”œâ•œ do mأںâ•—ئ’ lأںâ•‘أ­i');\r\n      return;\r\n    }\r\n\r\n    try {\r\n      // Determine target status based on current status\r\n      const targetStatus = ticket.status === 'completed' ? 'returned' : 'processed';\r\n      \r\n      // خ“أœأ،âˆ©â••أ… KHâ”œأ¶NG â”€أ‰أںâ•—أ؟NG CHأںâ•‘أ،M Gâ”œأ® KHI Mأںâ•—â‚§ Lأںâ•‘أ،I Tأںâ•—آ¬ COMPLETED\r\n      // Lâ”œâ•œ do:\r\n      // - Kأںâ•‘â”گt thâ”œâ•‘c = â”€أ‰â•‍أ­n â”€أ¦â”œأ؛ xong, hâ”œأ،ng â”€أ¦â”œأ؛ xuأںâ•‘أ‘t, tiأںâ•—أ¼n â”€أ¦â”œأ؛ thanh toâ”œأ­n\r\n      // - Mأںâ•—ئ’ lأںâ•‘أ­i CHأںâ•—أھ â”€أ¦أںâ•—أ¢ xem lأںâ•‘أ­i, khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c sأںâ•—آ،a/thay â”€أ¦أںâ•—أ²i gâ”œآ¼\r\n      // - Nأںâ•‘â”گu muأںâ•—أ¦n â”€أ¦iأںâ•—أ¼u chأںâ•—أ«nh خ“أ¥أ† Phأںâ•‘أ؛i thao tâ”œأ­c thâ”œآ¬m (tأںâ•‘أ­o phiأںâ•‘â”گu mأںâ•—آ¢i, hoâ”œأ،n hâ”œأ،ng thأںâ•—آ؛ câ”œâ”¤ng, etc.)\r\n      if (ticket.status === 'completed') {\r\n        // No-op: Completed tickets are reopened for viewing only\r\n      }\r\n      \r\n      // خ“آ£أ  Pass lâ”œâ•œ do mأںâ•—ئ’ lأںâ•‘أ­i vâ”œأ،o note parameter\r\n      (update as any).mutate({ systemId: ticket.systemId, data: { status: targetStatus } });\r\n      \r\n      // Clear returnedAt vâ”œأ، linkedOrderSystemId only when going back to processed (not from completed)\r\n      if (targetStatus === 'processed') {\r\n        (update as any).mutate({ systemId: ticket.systemId, data: {\r\n          returnedAt: undefined,\r\n          linkedOrderSystemId: undefined,\r\n        }});\r\n      }\r\n      \r\n      onOpenChange(false);\r\n      setReopenReason('');\r\n      toast.success(`â”€أ‰â”œأ؛ mأںâ•—ئ’ lأںâ•‘أ­i phiأںâ•‘â”گu`, {\r\n        description: ticket.status === 'completed' \r\n          ? 'Phiأںâ•‘â”گu â”€أ¦â”œأ؛ mأںâ•—ئ’ lأںâ•‘أ­i â”€أ¦أںâ•—أ¢ xem. Khâ”œâ”¤ng thay â”€أ¦أںâ•—أ²i kho hâ”œأ،ng hay thanh toâ”œأ­n.' \r\n          : undefined\r\n      });\r\n    } catch (error) {\r\n      console.error('Failed to reopen ticket:', error);\r\n      toast.error('Khâ”œâ”¤ng thأںâ•—أ¢ mأںâ•—ئ’ lأںâ•‘أ­i phiأںâ•‘â”گu');\r\n    }\r\n  }, [ticket, reopenReason, update, updateStatus, onOpenChange]);\r\n\r\n  return (\r\n    <AlertDialog open={open} onOpenChange={onOpenChange}>\r\n      <AlertDialogContent>\r\n        <AlertDialogHeader>\r\n          <AlertDialogTitle>Xâ”œأ­c nhأںâ•‘آ،n mأںâ•—ئ’ lأںâ•‘أ­i phiأںâ•‘â”گu â”€أ¦â”œأ؛ trأںâ•‘أ؛</AlertDialogTitle>\r\n          <AlertDialogDescription>\r\n            Phiأںâ•‘â”گu nâ”œأ،y â”€أ¦â”œأ؛ trأںâ•‘أ؛ hâ”œأ،ng cho khâ”œأ­ch. Vui lâ”œâ–“ng nhأںâ•‘آ،p lâ”œâ•œ do cأںâ•‘آ؛n mأںâ•—ئ’ lأںâ•‘أ­i.\r\n          </AlertDialogDescription>\r\n        </AlertDialogHeader>\r\n        <Textarea\r\n          value={reopenReason}\r\n          onChange={(e) => setReopenReason(e.target.value)}\r\n          placeholder=\"Nhأںâ•‘آ،p lâ”œâ•œ do mأںâ•—ئ’ lأںâ•‘أ­i (bأںâ•‘آ»t buأںâ•—أ–c)...\"\r\n          className=\"min-h-[100px]\"\r\n        />\r\n        <AlertDialogFooter>\r\n          <AlertDialogCancel onClick={() => setReopenReason('')}>Hأںâ•—آ؛y</AlertDialogCancel>\r\n          <AlertDialogAction onClick={handleReopen}>\r\n            Mأںâ•—ئ’ lأںâ•‘أ­i\r\n          </AlertDialogAction>\r\n        </AlertDialogFooter>\r\n      </AlertDialogContent>\r\n    </AlertDialog>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\warranty\\components\\dialogs\\warranty-return-method-dialog.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath"