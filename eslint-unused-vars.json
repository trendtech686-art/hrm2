line\"\r\n                className=\"h-9\"\r\n              >\r\n                Chأںâ•—أ¬n nhiأںâ•—أ¼u\r\n              </Button>\r\n            </div>\r\n          )}\r\n\r\n          {/* Edit mode message */}\r\n          {isEditMode && (\r\n            <div className=\"bg-muted/50 border rounded-lg p-4 text-body-sm text-muted-foreground\">\r\n              أںâ•—â‚§ chأںâ•‘â”گ â”€أ¦أںâ•—أ– sأںâ•—آ،a, bأںâ•‘أ­n chأںâ•—أ« câ”œâ”‚ thأںâ•—أ¢ chأںâ•—أ«nh sأںâ•—آ،a <strong>Ghi châ”œâ•‘</strong> vâ”œأ، <strong>Tags</strong>. Khâ”œâ”¤ng thأںâ•—أ¢ thay â”€أ¦أںâ•—أ²i sأںâ•‘أ؛n phأںâ•‘âŒگm hoأںâ•‘â•–c sأںâ•—أ¦ lâ•‍â–‘أںâ•—أ؛ng.\r\n            </div>\r\n          )}\r\n\r\n          {items.length === 0 ? (\r\n            <div className=\"text-center py-12 text-muted-foreground border rounded-lg\">\r\n              <Package className=\"h-12 w-12 mx-auto mb-3 opacity-50\" />\r\n              <p>Châ•‍â–‘a câ”œâ”‚ sأںâ•‘أ؛n phأںâ•‘âŒگm nâ”œأ،o</p>\r\n              <p className=\"text-body-sm mt-1\">Tâ”œآ¼m kiأںâ•‘â”گm hoأںâ•‘â•–c chأںâ•—أ¬n sأںâ•‘أ؛n phأںâ•‘âŒگm â”€أ¦أںâ•—أ¢ thâ”œآ¬m</p>\r\n            </div>\r\n          ) : (\r\n            <>\r\n              {/* Tabs for filtering - Only in create mode */}\r\n              {!isEditMode && (\r\n                <div className=\"flex gap-2 mb-4 border-b\">\r\n                  <button\r\n                    onClick={() => setActiveTab('all')}\r\n                    className={`px-4 py-2 text-body-sm font-medium border-b-2 transition-colors ${\r\n                      activeTab === 'all' \r\n                        ? 'border-primary text-primary' \r\n                        : 'border-transparent text-muted-foreground hover:text-foreground'\r\n                    }`}\r\n                  >\r\n                    Tأںâ•‘أ‘t cأںâ•‘أ؛ ({items.length})\r\n                  </button>\r\n                  <button\r\n                    onClick={() => setActiveTab('unchecked')}\r\n                    className={`px-4 py-2 text-body-sm font-medium border-b-2 transition-colors ${\r\n                      activeTab === 'unchecked' \r\n                        ? 'border-primary text-primary' \r\n                        : 'border-transparent text-muted-foreground hover:text-foreground'\r\n                    }`}\r\n                  >\r\n                    Châ•‍â–‘a kiأںâ•—أ¢m ({stats.unchecked})\r\n                  </button>\r\n                  <button\r\n                    onClick={() => setActiveTab('matched')}\r\n                    className={`px-4 py-2 text-body-sm font-medium border-b-2 transition-colors ${\r\n                      activeTab === 'matched' \r\n                        ? 'border-primary text-primary' \r\n                        : 'border-transparent text-muted-foreground hover:text-foreground'\r\n                    }`}\r\n                  >\r\n                    Khأںâ•—آ¢p ({stats.matched})\r\n                  </button>\r\n                  <button\r\n                    onClick={() => setActiveTab('different')}\r\n                    className={`px-4 py-2 text-body-sm font-medium border-b-2 transition-colors ${\r\n                      activeTab === 'different' \r\n                        ? 'border-primary text-primary' \r\n                        : 'border-transparent text-muted-foreground hover:text-foreground'\r\n                    }`}\r\n                  >\r\n                    Lأںâ•—أ§ch ({stats.different})\r\n                  </button>\r\n                </div>\r\n              )}\r\n\r\n              {/* Simple Table */}\r\n              <div className=\"border rounded-lg overflow-hidden\">\r\n                <div className=\"overflow-x-auto\">\r\n                  <table className=\"w-full\">\r\n                    <thead className=\"bg-muted/50\">\r\n                      <tr className=\"border-b\">\r\n                        <th className=\"px-3 py-2 text-left text-body-sm font-medium\">STT</th>\r\n                        <th className=\"px-3 py-2 text-left te