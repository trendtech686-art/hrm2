     <Calendar className=\"h-4 w-4 text-blue-600\" />\r\n                                                    Nghأںâ•—أ« phâ”œâŒگp\r\n                                                </div>\r\n                                            </SelectItem>\r\n                                            <SelectItem value=\"absent\">\r\n                                                <div className=\"flex items-center gap-2\">\r\n                                                    <XCircle className=\"h-4 w-4 text-red-600\" />\r\n                                                    Vأںâ•‘آ»ng\r\n                                                </div>\r\n                                            </SelectItem>\r\n                                        </SelectContent>\r\n                                    </Select>\r\n                                    <FormMessage />\r\n                                </FormItem>\r\n                            )}\r\n                        />\r\n                        {targetDate && (\r\n                            <div className=\"rounded-md border border-border p-3 text-body-xs space-y-2\">\r\n                                <div className=\"flex items-center justify-between\">\r\n                                    <span className=\"font-medium\">Ngâ”œأ،y {formattedTargetDate}</span>\r\n                                    {hasApprovedLeave ? (\r\n                                        <Badge variant=\"secondary\" className=\"text-emerald-600\">Câ”œâ”‚ {overlappingLeaves.length} â”€أ¦â•‍أ­n â”€أ¦â”œأ؛ duyأںâ•—أ§t</Badge>\r\n                                    ) : (\r\n                                        <Badge variant=\"outline\">Châ•‍â–‘a câ”œâ”‚ â”€أ¦â•‍أ­n nghأںâ•—أ«</Badge>\r\n                                    )}\r\n                                </div>\r\n                                {hasApprovedLeave ? (\r\n                                    <ul className=\"space-y-1\">\r\n                                        {overlappingLeaves.map((leave) => (\r\n                                            <li key={leave.systemId} className=\"flex flex-col rounded bg-muted/60 px-2 py-1\">\r\n                                                <span className=\"text-body-sm font-medium\">{leave.leaveTypeName}</span>\r\n                                                <span className=\"text-muted-foreground text-body-xs\">{formatDate(leave.startDate)} خ“أ¥أ† {formatDate(leave.endDate)} â”¬â•– {leave.id}</span>\r\n                                            </li>\r\n                                        ))}\r\n                                    </ul>\r\n                                ) : (\r\n                                    <p className=\"text-muted-foreground\">Châ•‍â–‘a câ”œâ”‚ â”€أ¦â•‍أ­n nghأںâ•—أ« phâ”œâŒگp cho ngâ”œأ،y nâ”œأ،y.</p>\r\n                                )}\r\n                            </div>\r\n                        )}\r\n                        {(status === 'present' || status === 'half-day') && (\r\n                             <div className=\"space-y-4\">\r\n                                <div className=\"grid grid-cols-2 gap-4\">\r\n                                    <FormField control={control} name=\"checkIn\" render={({ field }) => (\r\n                                        <FormItem>\r\n                                            <FormLabel>Giأںâ•—آ¥ vâ”œأ،o</FormLabel>\r\n                                            <FormControl><TimePicker {...field} value={field.value ?? \"\"} /></FormControl>\r\n                                            <FormMessage />\r\n                                        </FormItem>\r\n                                    )} />\r\n                                    <FormField control={control} name=\"checkOut\" render={({ field }) => (\r\n                                        <FormItem>\r\n                                            <FormLabel>Giأںâ•—آ¥ ra</FormLabel>\r\n                                            <FormControl><TimePicker {...field} value={field.value ?? \"\"} /></FormControl>\r\n                                            <FormMessage />\r\n                                        </FormItem>\r\n                                    )} />\r\n                                </div>\r\n                                <div className=\"grid grid-cols-2 gap-4\">\r\n                                     <FormField control={control} name=\"overtimeCheckIn\" render={({ field }) => (\r\n                                        <FormItem>\r\n                                            <FormLabel>Tâ”€أ¢ng ca (Vâ”œأ،o)</FormLabel>\r\n                                            <FormControl><TimePicker {...field} value={field.value ?? \"\"} /></FormControl>\r\n                                            <FormMessage />\r\n                                        </FormItem>\r\n                                    )} />\r\n                                     <FormField control={control} name=\"overtimeCheckOut\" render={({ field }) => (\r\n                                        <FormItem>\r\n                                            <FormLabel>Tâ”€أ¢ng ca (Ra)</FormLabel>\r\n                                            <FormControl><TimePicker {...field} value={field.value ?? \"\"} /></FormControl>\r\n                                            <FormMessage />\r\n                                        </FormItem>\r\n                                    )} />\r\n                                </div>\r\n                            </div>\r\n                        )}\r\n                       \r\n                        <FormField\r\n                            control={control}\r\n                            name=\"notes\"\r\n                            render={({ field }) => (\r\n                                <FormItem>\r\n                                    <FormLabel>Ghi châ”œâ•‘</FormLabel>\r\n                                    <FormControl>\r\n                                        <Textarea placeholder=\"Thâ”œآ¬m ghi châ”œâ•‘...\" {...field} value={field.value || ''} />\r\n                                    </FormControl>\r\n                                    <FormMessage />\r\n                                </FormItem>\r\n                            )}\r\n                        />\r\n\r\n                        <DialogFooter className=\"gap-2\">\r\n                            <Button type=\"button\" variant=\"outline\" onClick={handleClose} className=\"h-9\">\r\n                                Hأںâ•—آ؛y\r\n                            </Button>\r\n                            <Button type=\"submit\" className=\"h-9\">\r\n                                <CheckCircle2 className=\"mr-2 h-4 w-4\" />\r\n                                Lâ•‍â–‘u thay â”€أ¦أںâ•—أ²i\r\n                            </Button>\r\n                        </DialogFooter>\r\n                    </form>\r\n                </Form>\r\n            </DialogContent>\r\n        </Dialog>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\attendance\\components\\attendance-import-dialog.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\attendance\\components\\bulk-edit-dialog.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\attendance\\components\\daily-status-cell.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\attendance\\components\\penalty-confirm-dialog.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDepr