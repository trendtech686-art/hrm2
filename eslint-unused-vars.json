:"'Employee' is defined but never used. Allowed unused vars must match /^_/u.","line":18,"column":32,"nodeType":null,"messageId":"unusedVar","endLine":18,"endColumn":40}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * Inventory Check (Kiأںâ•—أ¢m kâ”œآ¬) Import/Export Configuration\r\n * \r\n * Nhأںâ•‘آ،p/Xuأںâ•‘أ‘t phiأںâ•‘â”گu kiأںâ•—أ¢m kâ”œآ¬\r\n * \r\n * FORMAT:\r\n * - Multi-line: 1 phiأںâ•‘â”گu kiأںâ•—أ¢m kâ”œآ¬ câ”œâ”‚ thأںâ•—أ¢ câ”œâ”‚ nhiأںâ•—أ¼u dâ”œâ–“ng sأںâ•‘أ؛n phأںâ•‘âŒگm\r\n * - Câ”œأ­c dâ”œâ–“ng câ”œâ•£ng Mâ”œأ؛ phiأںâ•‘â”گu sأںâ•‘â•œ â”€أ¦â•‍â–‘أںâ•—أ؛c nhâ”œâ”‚m thâ”œأ،nh 1 phiأںâ•‘â”گu kiأںâ•—أ¢m kâ”œآ¬\r\n */\r\n\r\nimport type { \r\n  InventoryCheck, \r\n  InventoryCheckItem, \r\n  InventoryCheckStatus, \r\n  DifferenceReason \r\n} from '@/lib/types/prisma-extended';\r\nimport type { ImportExportConfig, FieldConfig } from '@/lib/import-export/types';\r\nimport type { Product, Branch, Employee } from '@/lib/types/prisma-extended';\r\nimport { asBusinessId, asSystemId } from '@/lib/id-types';\r\n\r\n// ============================================\r\n// HELPER FUNCTIONS (Accept data as parameters)\r\n// ============================================\r\n\r\nconst findProduct = (identifier: string, products: Product[]) => {\r\n  if (!identifier || !products) return undefined;\r\n  const normalized = identifier.trim().toUpperCase();\r\n  \r\n  const byId = products.find(p => p.id.toUpperCase() === normalized);\r\n  if (byId) return byId;\r\n  \r\n  const bySku = products.find(p => p.sku?.toUpperCase() === normalized);\r\n  return bySku;\r\n};\r\n\r\nconst findBranch = (identifier: string, branches: Branch[]) => {\r\n  if (!identifier || !branches) return undefined;\r\n  const normalized = identifier.trim().toLowerCase();\r\n  \r\n  const byId = branches.find(b => b.id.toLowerCase() === normalized);\r\n  if (byId) return byId;\r\n  \r\n  return branches.find(b => b.name.toLowerCase().includes(normalized));\r\n};\r\n\r\nconst getDefaultBranch = (branches: Branch[]) => {\r\n  if (!branches || branches.length === 0) return undefined;\r\n  return branches.find(b => b.isDefault) || branches[0];\r\n};\r\n\r\n// ============================================\r\n// IMPORT ROW TYPE\r\n// ============================================\r\n\r\ninterface InventoryCheckImportRow {\r\n  checkId: string;\r\n  branchIdOrName: string;\r\n  status?: string;\r\n  createdAt?: string;\r\n  note?: string;\r\n  // Line item\r\n  productIdOrSku: string;\r\n  productName?: string;\r\n  unit?: string;\r\n  systemQuantity: number;\r\n  actualQuantity: number;\r\n  reason?: string;\r\n  itemNote?: string;\r\n}\r\n\r\n// ============================================\r\n// FIELD CONFIGURATION\r\n// ============================================\r\n\r\nexport const inventoryCheckFields: FieldConfig<InventoryCheckImportRow>[] = [\r\n  // Phiأںâ•‘â”گu kiأںâ•—أ¢m kâ”œآ¬\r\n  {\r\n    key: 'checkId',\r\n    label: 'Mâ”œأ؛ phiأںâ•‘â”گu (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'PKK001',\r\n    group: 'Phiأںâ•‘â”گu kiأںâ•—أ¢m kâ”œآ¬',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'branchIdOrName',\r\n    label: 'Chi nhâ”œأ­nh (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'Chi nhâ”œأ­nh châ”œآ،nh',\r\n    group: 'Phiأںâ•‘â”گu kiأںâ•—أ¢m kâ”œآ¬',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'status',\r\n    label: 'Trأںâ•‘أ­ng thâ”œأ­i',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'draft',\r\n    group: 'Phiأںâ•‘â”گu kiأںâ•—أ¢m kâ”œآ¬',\r\n  },\r\n  {\r\n    key: 'createdAt',\r\n    label: 'Ngâ”œأ،y tأںâ•‘أ­o',\r\n    type: 'string',\r\n    required: false,\r\n    example: '2024-01-15',\r\n    group: 'Phiأںâ•‘â”گu kiأںâ•—أ¢m kâ”œآ¬',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'note',\r\n    label: 'Ghi châ”œâ•‘',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Kiأںâ•—أ¢m kâ”œآ¬ â”€أ¦أںâ•—أ¯nh kأںâ•—â”‚',\r\n    group: 'Phiأںâ•‘â”گu kiأںâ•—أ¢m kâ”œآ¬',\r\n  },\r\n  \r\n  // Sأںâ•‘أ؛n phأںâ•‘âŒگm\r\n  {\r\n    key: 'productIdOrSku',\r\n    label: 'Mâ”œأ؛ SP/SKU (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'SP001',\r\n    group: 'Sأںâ•‘أ؛n phأںâ•‘âŒگm',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'unit',\r\n    label: 'â”€أ‰â•‍أ­n vأںâ•—أ¯',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Câ”œأ­i',\r\n    group: 'Sأںâ•‘أ؛n phأںâ•‘âŒگm',\r\n  },\r\n  {\r\n    key: 'systemQuantity',\r\n    label: 'SL hأںâ•—أ§ thأںâ•—أ¦ng (*)',\r\n    type: 'number',\r\n    required: true,\r\n    example: '100',\r\n    group: 'Sأںâ•‘أ؛n phأںâ•‘âŒگm',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'actualQuantity',\r\n    label: 'SL thأںâ•—â–’c tأںâ•‘â”گ (*)',\r\n    type: 'number',\r\n    required: true,\r\n    example: '98',\r\n    group: 'Sأںâ•‘أ؛n phأںâ•‘âŒگm',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'reason',\r\n    label: 'Lâ”œâ•œ do châ”œآ¬nh lأںâ•—أ§ch',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'damaged',\r\n    group: 'Sأںâ•‘أ؛n phأںâ•‘âŒگm',\r\n  },\r\n  {\r\n    key: 'itemNote',\r\n    label: 'Ghi châ”œâ•‘ SP',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Hâ•‍â–‘ hأںâ•—أ…ng do vأںâ•‘آ،n chuyأںâ•—أ¢n',\r\n    group: 'Sأںâ•‘أ؛n phأںâ•‘âŒگm',\r\n  },\r\n];\r\n\r\n// ============================================\r\n// STATUS & REASON MAPPING\r\n// ============================================\r\n\r\nconst STATUS_MAP: Record<string, InventoryCheckStatus> = {\r\n  'DRAFT': 'draft',\r\n  'draft': 'draft',\r\n  'Nhâ”œأ­p': 'draft',\r\n  'IN_PROGRESS': 'in_progress',\r\n  'in_progress': 'in_progress',\r\n  'â”€أ‰ang kiأںâ•—أ¢m': 'in_progress',\r\n  'COMPLETED': 'completed',\r\n  'completed': 'completed',\r\n  'balanced': 'completed',\r\n  'Câ”œأ³n bأںâ•‘â–’ng': 'completed',\r\n  'â”€أ‰â”œأ؛ câ”œأ³n bأںâ•‘â–’ng': 'completed',\r\n  'Hoâ”œأ،n thâ”œأ،nh': 'completed',\r\n  'CANCELLED': 'cancelled',\r\n  'cancelled': 'cancelled',\r\n  'â”€أ‰â”œأ؛ hأںâ•—آ؛y': 'cancelled',\r\n};\r\n\r\nconst REASON_MAP: Record<string, DifferenceReason> = {\r\n  'other': 'other',\r\n  'Khâ”œأ­c': 'other',\r\n  'damaged': 'damaged',\r\n  'Hâ•‍â–‘ hأںâ•—أ…ng': 'damaged',\r\n  'wear': 'wear',\r\n  'Hao mâ”œâ–“n': 'wear',\r\n  'return': 'return',\r\n  'Trأںâ•‘أ؛ hâ”œأ،ng': 'return',\r\n  'transfer': 'transfer',\r\n  'Chuyأںâ•—أ¢n hâ”œأ،ng': 'transfer',\r\n  'production': 'production',\r\n  'Sأںâ•‘أ؛n xuأںâ•‘أ‘t': 'production',\r\n};\r\n\r\n// ============================================\r\n// MAIN CONFIG\r\n// ============================================\r\n\r\nexport const inventoryCheckImportExportConfig: ImportExportConfig<InventoryCheck> = {\r\n  entityType: 'inventory-checks',\r\n  entityDisplayName: 'Phiأںâ•‘â”گu kiأںâ•—أ¢m kâ”œآ¬',\r\n  \r\n  fields: inventoryCheckFields as unknown as FieldConfig<InventoryCheck>[],\r\n  \r\n  templateFileName: 'Mau_Kiem_Ke.xlsx',\r\n  sheetName: 'KiemKe',\r\n  \r\n  // Import settings\r\n  upsertKey: 'id',\r\n  allowUpdate: false,\r\n  allowInsert: true,\r\n  \r\n  requirePreview: true,\r\n  maxRows: 5000,\r\n  maxErrorsAllowed: 0,\r\n  \r\n  // Fill-down for multi-line\r\n  preProcessRows: (rows) => {\r\n    let lastCheckId = '';\r\n    let lastBranch = '';\r\n    let lastStatus = '';\r\n    let lastCreatedAt = '';\r\n    let lastNote = '';\r\n    \r\n    return rows.map((row: Record<string, unknown>) => {\r\n      if (row.checkId) {\r\n        lastCheckId = String(row.checkId);\r\n        lastBranch = String(row.branchIdOrName || '');\r\n        lastStatus = String(row.status || '');\r\n        lastCreatedAt = String(row.createdAt || '');\r\n        lastNote = String(row.note || '');\r\n      }\r\n      \r\n      return {\r\n        ...row,\r\n        checkId: row.checkId || lastCheckId,\r\n        branchIdOrName: row.branchIdOrName || lastBranch,\r\n        status: row.status || lastStatus,\r\n        createdAt: row.createdAt || lastCreatedAt,\r\n        note: row.note || lastNote,\r\n      };\r\n    });\r\n  },\r\n  \r\n  // Validate each row\r\n  validateRow: (row, _index, existingData, mode) => {\r\n    const errors: Array<{ field?: string; message: string }> = [];\r\n    const importRow = row as unknown as InventoryCheckImportRow;\r\n    \r\n    if (!importRow.checkId) {\r\n      errors.push({ field: 'checkId', message: 'Mâ”œأ؛ phiأںâ•‘â”گu khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    if (!importRow.branchIdOrName) {\r\n      errors.push({ field: 'branchIdOrName', message: 'Chi nhâ”œأ­nh khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    if (!importRow.productIdOrSku) {\r\n      errors.push({ field: 'productIdOrSku', message: 'Mâ”œأ؛ SP khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    if (importRow.systemQuantity === undefined || importRow.systemQuantity < 0) {\r\n      errors.push({ field: 'systemQuantity', message: 'SL hأںâ•—أ§ thأںâ•—أ¦ng khâ”œâ”¤ng hأںâ•—أ؛p lأںâ•—أ§' });\r\n    }\r\n    \r\n    if (importRow.actualQuantity === undefined || importRow.actualQuantity < 0) {\r\n      errors.push({ field: 'actualQuantity', message: 'SL thأںâ•—â–’c tأںâ•‘â”گ khâ”œâ”¤ng hأںâ•—أ؛p lأںâ•—أ§' });\r\n    }\r\n    \r\n    // Check duplicate\r\n    if (mode === 'insert-only' && importRow.checkId) {\r\n      const duplicate = existingData.find(c => \r\n        c.id.toUpperCase() === importRow.checkId.toUpperCase()\r\n      );\r\n      if (duplicate) {\r\n        // Warning only - same check can have multiple lines\r\n      }\r\n    }\r\n    \r\n    return errors;\r\n  },\r\n  \r\n  // Transform: Group rows by checkId and build InventoryCheck objects\r\n  beforeImport: async (data: InventoryCheck[]) => {\r\n    const importRows = data as unknown as InventoryCheckImportRow[];\r\n    \r\n    // Group rows by checkId\r\n    const checkMap = new Map<string, InventoryCheckImportRow[]>();\r\n    \r\n    for (const row of importRows) {\r\n      const checkId = row.checkId?.trim();\r\n      if (!checkId) continue;\r\n      \r\n      if (!checkMap.has(checkId)) {\r\n        checkMap.set(checkId, []);\r\n      }\r\n      checkMap.get(checkId)!.push(row);\r\n    }\r\n    \r\n    // Build InventoryCheck objects\r\n    const checks: InventoryCheck[] = [];\r\n    const now = new Date().toISOString();\r\n    const defaultBranch = getDefaultBranch();\r\n    \r\n    for (const [checkId, rows] of checkMap.entries()) {\r\n      if (rows.length === 0) continue;\r\n      \r\n      const firstRow = rows[0];\r\n      \r\n      // Lookup branch\r\n      const branch = findBranch(firstRow.branchIdOrName || '') || defaultBranch;\r\n      \r\n      if (!branch) continue;\r\n      \r\n      // Build items\r\n      const items: InventoryCheckItem[] = [];\r\n      for (const row of rows) {\r\n        if (!row.productIdOrSku) continue;\r\n        \r\n        const product = findProduct(row.productIdOrSku || '');\r\n        \r\n        const systemQuantity = Math.max(0, Math.floor(Number(row.systemQuantity) || 0));\r\n        const actualQuantity = Math.max(0, Math.floor(Number(row.actualQuantity) || 0));\r\n        const difference = actualQuantity - systemQuantity;\r\n        \r\n        items.push({\r\n          productSystemId: product?.systemId || asSystemId(''),\r\n          productId: asBusinessId(product?.id || row.productIdOrSku || ''),\r\n          productName: product?.name || row.productName || '',\r\n          unit: product?.unit || row.unit || '',\r\n          systemQuantity,\r\n          actualQuantity,\r\n          difference,\r\n          reason: REASON_MAP[row.reason || ''] || (difference !== 0 ? 'other' : undefined),\r\n          note: row.itemNote,\r\n        });\r\n      }\r\n      \r\n      if (items.length === 0) continue;\r\n      \r\n      // Map status\r\n      const status = STATUS_MAP[firstRow.status || ''] || 'draft';\r\n      \r\n      // Build InventoryCheck object\r\n      const check: InventoryCheck = {\r\n        systemId: asSystemId(''), // Will be generated\r\n        id: asBusinessId(checkId),\r\n        \r\n        branchSystemId: branch.systemId,\r\n        branchName: branch.name,\r\n        \r\n        status,\r\n        items,\r\n        \r\n        createdBy: asSystemId(''),\r\n        createdAt: firstRow.createdAt || now,\r\n        note: firstRow.note,\r\n      };\r\n      \r\n      checks.push(check);\r\n    }\r\n    \r\n    return checks;\r\n  },\r\n};\r\n\r\n// Flatten checks for export (multi-line per product)\r\nexport function flattenInventoryChecksForExport(checks: InventoryCheck[]): InventoryCheckImportRow[] {\r\n  const rows: InventoryCheckImportRow[] = [];\r\n  \r\n  for (const check of checks) {\r\n    for (let i = 0; i < check.items.length; i++) {\r\n      const item = check.items[i];\r\n      rows.push({\r\n        checkId: i === 0 ? check.id : '',\r\n        branchIdOrName: i === 0 ? (check.branchName ?? '') : '',\r\n        status: i === 0 ? check.status : '',\r\n        createdAt: i === 0 ? (check.createdAt instanceof Date ? check.createdAt.toISOString() : check.createdAt || '') : '',\r\n        note: i === 0 ? (check.note ?? undefined) : '',\r\n        productIdOrSku: item.productId,\r\n        productName: item.productName,\r\n        unit: item.unit,\r\n        systemQuantity: item.systemQuantity,\r\n        actualQuantity: item.actualQuantity,\r\n        reason: item.reason,\r\n        itemNote: item.note,\r\n      });\r\n    }\r\n  }\r\n  \r\n  return rows;\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\lib\\import-export\\configs\\inventory-receipt.config.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\lib\\import-export\\configs\\order-sapo.config.ts","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":579,"column":49,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":579,"endColumn":52,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[16449,16452],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[16449,16452],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * Order Sapo Import Configuration\r\n * \r\n * Import â”€أ¦â•‍أ­n hâ”œأ،ng tأںâ•—آ½ file export cأںâ•—آ؛a Sapo POS\r\n * \r\n * FORMAT FILE SAPO:\r\n * - Multi-line: 1 â”€أ¦â•‍أ­n hâ”œأ،ng câ”œâ”‚ thأںâ•—أ¢ câ”œâ”‚ nhiأںâ•—أ¼u dâ”œâ–“ng sأںâ•‘أ؛n phأںâ•‘âŒگm\r\n * - Câ”œأ­c dâ”œâ–“ng câ”œâ•£ng Mâ”œأ؛ â”€أ‰H sأںâ•‘â•œ â”€أ¦â•‍â–‘أںâ•—أ؛c nhâ”œâ”‚m thâ”œأ،nh 1 â”€أ¦â•‍أ­n hâ”œأ،ng\r\n * - Dأںâ•—آ» liأںâ•—أ§u phong phâ”œâ•‘: thâ”œâ”¤ng tin KH, sأںâ•‘أ؛n phأںâ•‘âŒگm, giao hâ”œأ،ng, thanh toâ”œأ­n, trأںâ•‘أ؛ hâ”œأ،ng\r\n * \r\n * MAPPING SAPO خ“أ¥أ† HRM:\r\n * - Mâ”œأ؛ â”€أ‰H خ“أ¥أ† orderId\r\n * - Mâ”œأ؛ KH خ“أ¥أ† Lookup customer by id\r\n * - Mâ”œأ؛ hâ”œأ،ng خ“أ¥أ† Lookup product by id/sku\r\n * - Trأںâ•‘أ­ng thâ”œأ­i â”€أ¦â•‍أ­n hâ”œأ،ng خ“أ¥أ† status\r\n * - Trأںâ•‘أ­ng thâ”œأ­i thanh toâ”œأ­n خ“أ¥أ† paymentStatus\r\n * - Trأںâ•‘أ­ng thâ”œأ­i â”€أ¦â”œâ”‚ng gâ”œâ”‚i خ“أ¥أ† packagingStatus\r\n * - Trأںâ•‘أ­ng thâ”œأ­i xuأںâ•‘أ‘t kho خ“أ¥أ† stockOutStatus\r\n */\r\n\r\nimport type { Order, LineItem, OrderAddress, OrderMainStatus, OrderPaymentStatus, OrderDeliveryStatus, OrderPrintStatus, OrderStockOutStatus, OrderReturnStatus, OrderDeliveryMethod, PackagingStatus } from '@/lib/types/prisma-extended';\r\nimport type { ImportExportConfig, FieldConfig } from '@/lib/import-export/types';\r\nimport type { Customer, Product, Branch, Employee } from '@/lib/types/prisma-extended';\r\nimport { asBusinessId, asSystemId } from '@/lib/id-types';\r\n\r\n// ============================================\r\n// SAPO COLUMN MAPPING\r\n// ============================================\r\n\r\n/**\r\n * Mapping cأںâ•—أ–t Sapo خ“أ¥أ† field key nأںâ•—أ–i bأںâ•—أ–\r\n */\r\nexport const SAPO_COLUMN_MAP: Record<string, string> = {\r\n  // Thâ”œâ”¤ng tin â”€أ¦â•‍أ­n hâ”œأ،ng\r\n  'STT': 'stt',\r\n  'Mâ”œأ؛ â”€أ‰H': 'orderId',\r\n  'Ngâ”œأ،y chأںâ•—âŒگng tأںâ•—آ½': 'orderDate',\r\n  'Ngâ”œأ،y duyأںâ•—أ§t â”€أ¦â•‍أ­n': 'approvedDate',\r\n  'Chi nhâ”œأ­nh': 'branchName',\r\n  'Nguأںâ•—أ´n': 'source',\r\n  'Ngâ”œأ،y hأںâ•‘â•£n giao': 'expectedDeliveryDate',\r\n  'Ngâ”œأ،y hoâ”œأ،n thâ”œأ،nh': 'completedDate',\r\n  'Ngâ”œأ،y hأںâ•—آ؛y â”€أ¦â•‍أ­n': 'cancelDate',\r\n  'Trأںâ•‘أ­ng thâ”œأ­i â”€أ¦â•‍أ­n hâ”œأ،ng': 'status',\r\n  'Lâ”œâ•œ do hأںâ•—آ؛y â”€أ¦â•‍أ­n': 'cancelReason',\r\n  'Trأںâ•‘أ­ng thâ”œأ­i xأںâ•—آ، lâ”œâ•œ': 'processStatus',\r\n  'Trأںâ•‘أ­ng thâ”œأ­i â”€أ¦â”œâ”‚ng gâ”œâ”‚i': 'packagingStatus',\r\n  'Trأںâ•‘أ­ng thâ”œأ­i xuأںâ•‘أ‘t kho': 'stockOutStatus',\r\n  'Trأںâ•‘أ­ng thâ”œأ­i thanh toâ”œأ­n': 'paymentStatus',\r\n  'Trأںâ•‘أ­ng thâ”œأ­i trأںâ•‘أ؛ hâ”œأ،ng': 'returnStatus',\r\n  \r\n  // Thâ”œâ”¤ng tin khâ”œأ­ch hâ”œأ،ng\r\n  'Mâ”œأ؛ KH': 'customerId',\r\n  'Tâ”œآ¬n khâ”œأ­ch hâ”œأ،ng': 'customerName',\r\n  'â”€أ‰iأںâ•—أ§n thoأںâ•‘أ­i KH': 'customerPhone',\r\n  'Email': 'customerEmail',\r\n  'â”€أ‰أںâ•—أ¯a chأںâ•—أ« KH': 'customerAddress',\r\n  'Liâ”œآ¬n hأںâ•—أ§': 'contactName',\r\n  \r\n  // Nhâ”œأ³n viâ”œآ¬n\r\n  'Nhâ”œأ³n viâ”œآ¬n tأںâ•‘أ­o â”€أ¦â•‍أ­n': 'createdByName',\r\n  'Nhâ”œأ³n viâ”œآ¬n gâ”œأ­n cho â”€أ¦â•‍أ­n': 'salesperson',\r\n  'Bأںâ•‘أ؛ng giâ”œأ­': 'priceList',\r\n  \r\n  // Thâ”œâ”¤ng tin sأںâ•‘أ؛n phأںâ•‘âŒگm (line item)\r\n  'Mâ”œأ؛ hâ”œأ،ng': 'productId',\r\n  'Mâ”œأ؛ barcode': 'barcode',\r\n  'Tâ”œآ¬n hâ”œأ،ng': 'productName',\r\n  'Loأںâ•‘أ­i sأںâ•‘أ؛n phأںâ•‘âŒگm': 'productType',\r\n  'Ghi châ”œâ•‘ sأںâ•‘أ؛n phأںâ•‘âŒگm': 'productNote',\r\n  'Sأںâ•—أ¦ lâ•‍â–‘أںâ•—أ؛ng': 'quantity',\r\n  'Serial': 'serial',\r\n  'Mâ”œأ؛ lâ”œâ”¤ date': 'batchCode',\r\n  'â”€أ‰â•‍أ­n vأںâ•—أ¯ tâ”œآ،nh': 'unit',\r\n  'â”€أ‰â•‍أ­n giâ”œأ­': 'unitPrice',\r\n  'CK sأںâ•‘أ؛n phأںâ•‘âŒگm(VNâ”€أ‰)': 'lineDiscountAmount',\r\n  'CK sأںâ•‘أ؛n phأںâ•‘âŒگm(%)': 'lineDiscountPercent',\r\n  'Tأںâ•—أ²ng tiأںâ•—أ¼n hâ”œأ،ng': 'lineTotal',\r\n  'Thuأںâ•‘â”گ cho tأںâ•—آ½ng sأںâ•‘أ؛n phأںâ•‘âŒگm': 'lineTax',\r\n  \r\n  // Tأںâ•—أ²ng â”€أ¦â•‍أ­n hâ”œأ،ng\r\n  'CK â”€أ¦â•‍أ­n hâ”œأ،ng(VNâ”€أ‰)': 'orderDiscountAmount',\r\n  'CK â”€أ¦â•‍أ­n hâ”œأ،ng(%)': 'orderDiscountPercent',\r\n  'Phâ”œآ، vأںâ•‘آ،n chuyأںâ•—أ¢n': 'shippingFee',\r\n  'Khâ”œأ­ch phأںâ•‘أ؛i trأںâ•‘أ؛': 'grandTotal',\r\n  'Khâ”œأ­ch â”€أ¦â”œأ؛ trأںâ•‘أ؛': 'paidAmount',\r\n  'Ghi châ”œâ•‘': 'notes',\r\n  'Tham chiأںâ•‘â”گu': 'reference',\r\n  'Tag': 'tags',\r\n  'â”€أ‰â•‍أ­n trâ”œآ¬n kâ”œآ¬nh': 'channelOrderId',\r\n  \r\n  // Gâ”œâ”‚i hâ”œأ،ng\r\n  'Mâ”œأ؛ gâ”œâ”‚i hâ”œأ،ng': 'packageId',\r\n  'Mâ”œأ؛ vأںâ•‘آ،n â”€أ¦â•‍أ­n': 'trackingCode',\r\n  'Ngâ”œأ،y â”€أ¦â”œâ”‚ng gâ”œâ”‚i': 'packagingDate',\r\n  'Nhâ”œأ³n viâ”œآ¬n â”€أ¦â”œâ”‚ng gâ”œâ”‚i': 'packagerName',\r\n  'Ngâ”œأ،y xuأںâ•‘أ‘t kho': 'stockOutDate',\r\n  'Nhâ”œأ³n viâ”œآ¬n xuأںâ•‘أ‘t kho': 'stockOutByName',\r\n  \r\n  // Giao hâ”œأ،ng\r\n  'â”€أ‰أںâ•—أ¦i tâ”œأ­c giao hâ”œأ،ng': 'carrier',\r\n  'Tâ”œآ¼nh trأںâ•‘أ­ng gâ”œâ”‚i hâ”œأ،ng': 'packageStatus',\r\n  'Lâ”œâ•œ do hأںâ•—آ؛y giao hâ”œأ،ng': 'deliveryCancelReason',\r\n  'Trأںâ•‘أ­ng thâ”œأ­i â”€أ¦أںâ•—أ¦i soâ”œأ­t': 'reconciliationStatus',\r\n  'Ngâ•‍â–‘أںâ•—آ¥i nhأںâ•‘آ،n hâ”œأ،ng': 'recipientName',\r\n  'Sأںâ•—أ¦ â”€أ¦iأںâ•—أ§n thoأںâ•‘أ­i': 'recipientPhone',\r\n  'â”€أ‰أںâ•—أ¯a chأںâ•—أ« giao hâ”œأ،ng': 'shippingStreet',\r\n  'Phâ•‍â–‘أںâ•—آ¥ng xâ”œأ؛': 'shippingWard',\r\n  'Quأںâ•‘آ،n huyأںâ•—أ§n': 'shippingDistrict',\r\n  'Tأںâ•—أ«nh thâ”œأ،nh': 'shippingProvince',\r\n  'Tiأںâ•—أ¼n thu hأںâ•—أ–': 'codAmount',\r\n  'Phâ”œآ، trأںâ•‘أ؛ â”€أ¦أںâ•—أ¦i tâ”œأ­c': 'carrierFee',\r\n  \r\n  // Thanh toâ”œأ­n\r\n  'Ngâ”œأ،y thanh toâ”œأ­n': 'paymentDate',\r\n  'Mâ”œأ؛ phiأںâ•‘â”گu': 'paymentId',\r\n  'Nhâ”œأ³n viâ”œآ¬n': 'paymentByName',\r\n  'Sأںâ•—أ¦ tiأںâ•—أ¼n thanh toâ”œأ­n': 'paymentAmount',\r\n  'Phâ•‍â–‘â•‍أ­ng thأںâ•—âŒگc thanh toâ”œأ­n': 'paymentMethod',\r\n  'Loأںâ•‘أ­i phâ•‍â–‘â•‍أ­ng thأںâ•—âŒگc thanh toâ”œأ­n': 'paymentMethodType',\r\n  'Tham chiأںâ•‘â”گu thanh toâ”œأ­n': 'paymentReference',\r\n  \r\n  // Trأںâ•‘أ؛ hâ”œأ،ng\r\n  'Ngâ”œأ،y trأںâ•‘أ؛ hâ”œأ،ng': 'returnDate',\r\n  'Mâ”œأ؛ â”€أ¦â•‍أ­n trأںâ•‘أ؛': 'returnOrderId',\r\n  'Trأںâ•‘أ­ng thâ”œأ­i hoâ”œأ،n tiأںâ•—أ¼n': 'refundStatus',\r\n  'Lâ”œâ•œ do trأںâ•‘أ؛ hâ”œأ،ng': 'returnReason',\r\n  'Trأںâ•‘أ­ng thâ”œأ­i nhأںâ•‘آ،n hâ”œأ،ng': 'returnReceiveStatus',\r\n  'Mâ”œأ؛ hâ”œأ،ng trأںâ•‘أ؛': 'returnProductId',\r\n  'Tâ”œآ¬n hâ”œأ،ng trأںâ•‘أ؛': 'returnProductName',\r\n  'Giâ”œأ­ hâ”œأ،ng trأںâ•‘أ؛': 'returnPrice',\r\n  'Tأںâ•—أ²ng tiأںâ•—أ¼n trأںâ•‘أ؛ khâ”œأ­ch': 'returnTotal',\r\n};\r\n\r\n// ============================================\r\n// SAPO STATUS MAPPING\r\n// ============================================\r\n\r\nconst SAPO_ORDER_STATUS_MAP: Record<string, OrderMainStatus> = {\r\n  'â”€أ‰أںâ•‘â•–t hâ”œأ،ng': 'â”€أ‰أںâ•‘â•–t hâ”œأ،ng',\r\n  'â”€أ‰ang giao dأںâ•—أ¯ch': 'â”€أ‰ang giao dأںâ•—أ¯ch',\r\n  'Hoâ”œأ،n thâ”œأ،nh': 'Hoâ”œأ،n thâ”œأ،nh',\r\n  'â”€أ‰â”œأ؛ hأںâ•—آ؛y': 'â”€أ‰â”œأ؛ hأںâ•—آ؛y',\r\n};\r\n\r\nconst SAPO_PAYMENT_STATUS_MAP: Record<string, OrderPaymentStatus> = {\r\n  'Châ•‍â–‘a thanh toâ”œأ­n': 'Châ•‍â–‘a thanh toâ”œأ­n',\r\n  'Thanh toâ”œأ­n mأںâ•—أ–t phأںâ•‘آ؛n': 'Thanh toâ”œأ­n 1 phأںâ•‘آ؛n',\r\n  'Thanh toâ”œأ­n toâ”œأ،n bأںâ•—أ–': 'Thanh toâ”œأ­n toâ”œأ،n bأںâ•—أ–',\r\n  'â”€أ‰â”œأ؛ thanh toâ”œأ­n': 'Thanh toâ”œأ­n toâ”œأ،n bأںâ•—أ–',\r\n};\r\n\r\nconst SAPO_PACKAGING_STATUS_MAP: Record<string, PackagingStatus> = {\r\n  'Châ•‍â–‘a â”€أ¦â”œâ”‚ng gâ”œâ”‚i': 'Chأںâ•—آ¥ â”€أ¦â”œâ”‚ng gâ”œâ”‚i',\r\n  'â”€أ‰â”œâ”‚ng gâ”œâ”‚i mأںâ•—أ–t phأںâ•‘آ؛n': 'Chأںâ•—آ¥ â”€أ¦â”œâ”‚ng gâ”œâ”‚i',\r\n  'â”€أ‰â”œâ”‚ng gâ”œâ”‚i toâ”œأ،n bأںâ•—أ–': 'â”€أ‰â”œأ؛ â”€أ¦â”œâ”‚ng gâ”œâ”‚i',\r\n  'â”€أ‰â”œأ؛ â”€أ¦â”œâ”‚ng gâ”œâ”‚i': 'â”€أ‰â”œأ؛ â”€أ¦â”œâ”‚ng gâ”œâ”‚i',\r\n};\r\n\r\nconst SAPO_STOCK_OUT_STATUS_MAP: Record<string, OrderStockOutStatus> = {\r\n  'Châ•‍â–‘a xuأںâ•‘أ‘t kho': 'Châ•‍â–‘a xuأںâ•‘أ‘t kho',\r\n  'Xuأںâ•‘أ‘t kho mأںâ•—أ–t phأںâ•‘آ؛n': 'Châ•‍â–‘a xuأںâ•‘أ‘t kho', // HRM chأںâ•—أ« câ”œâ”‚ 2 trأںâ•‘أ­ng thâ”œأ­i\r\n  'â”€أ‰â”œأ؛ xuأںâ•‘أ‘t kho': 'Xuأںâ•‘أ‘t kho toâ”œأ،n bأںâ•—أ–',\r\n  'Xuأںâ•‘أ‘t kho toâ”œأ،n bأںâ•—أ–': 'Xuأںâ•‘أ‘t kho toâ”œأ،n bأںâ•—أ–',\r\n};\r\n\r\nconst SAPO_DELIVERY_STATUS_MAP: Record<string, OrderDeliveryStatus> = {\r\n  'Chأںâ•—آ¥ â”€أ¦â”œâ”‚ng gâ”œâ”‚i': 'Chأںâ•—آ¥ â”€أ¦â”œâ”‚ng gâ”œâ”‚i',\r\n  'â”€أ‰ang giao hâ”œأ،ng': 'â”€أ‰ang giao hâ”œأ،ng',\r\n  'â”€أ‰â”œأ؛ giao hâ”œأ،ng': 'â”€أ‰â”œأ؛ giao hâ”œأ،ng',\r\n  'Giao hâ”œأ،ng thأںâ•‘أ‘t bأںâ•‘أ­i': 'Chأںâ•—آ¥ giao lأںâ•‘أ­i', // Map thأںâ•‘أ‘t bأںâ•‘أ­i sang chأںâ•—آ¥ giao lأںâ•‘أ­i\r\n};\r\n\r\nconst SAPO_RETURN_STATUS_MAP: Record<string, OrderReturnStatus> = {\r\n  'Châ•‍â–‘a trأںâ•‘أ؛ hâ”œأ،ng': 'Châ•‍â–‘a trأںâ•‘أ؛ hâ”œأ،ng',\r\n  'Trأںâ•‘أ؛ mأںâ•—أ–t phأںâ•‘آ؛n': 'Trأںâ•‘أ؛ hâ”œأ،ng mأںâ•—أ–t phأںâ•‘آ؛n',\r\n  'â”€أ‰â”œأ؛ trأںâ•‘أ؛ hâ”œأ،ng': 'Trأںâ•‘أ؛ hâ”œأ،ng toâ”œأ،n bأںâ•—أ–',\r\n  'Trأںâ•‘أ؛ hâ”œأ،ng toâ”œأ،n bأںâ•—أ–': 'Trأںâ•‘أ؛ hâ”œأ،ng toâ”œأ،n bأںâ•—أ–',\r\n};\r\n\r\n// ============================================\r\n// HELPER FUNCTIONS (Accept data as parameters)\r\n// ============================================\r\n\r\n// Lookup customer by id or name\r\nconst findCustomer = (identifier: string, customers: Customer[]) => {\r\n  if (!identifier || !customers) return undefined;\r\n  const normalized = identifier.trim().toUpperCase();\r\n  \r\n  // Find by id first\r\n  const byId = customers.find(c => c.id.toUpperCase() === normalized);\r\n  if (byId) return byId;\r\n  \r\n  // Find by name\r\n  const byName = customers.find(c => c.name.toUpperCase() === normalized);\r\n  return byName;\r\n};\r\n\r\n// Lookup product by id/sku/barcode\r\nconst findProduct = (identifier: string, products: Product[]) => {\r\n  if (!identifier || !products) return undefined;\r\n  const normalized = identifier.trim().toUpperCase();\r\n  \r\n  // Find by id\r\n  const byId = products.find(p => p.id.toUpperCase() === normalized);\r\n  if (byId) return byId;\r\n  \r\n  // Find by sku\r\n  const bySku = products.find(p => p.sku?.toUpperCase() === normalized);\r\n  if (bySku) return bySku;\r\n  \r\n  // Find by barcode\r\n  const byBarcode = products.find(p => p.barcode?.toUpperCase() === normalized);\r\n  return byBarcode;\r\n};\r\n\r\n// Lookup branch by name\r\nconst findBranch = (name: string, branches: Branch[]) => {\r\n  if (!name || !branches) return undefined;\r\n  const normalized = name.trim().toLowerCase();\r\n  return branches.find(b => b.name.toLowerCase().includes(normalized));\r\n};\r\n\r\n// Lookup employee by name\r\nconst findEmployee = (name: string, employees: Employee[]) => {\r\n  if (!name || !employees) return undefined;\r\n  const normalized = name.trim().toLowerCase();\r\n  return employees.find(e => e.fullName?.toLowerCase().includes(normalized));\r\n};\r\n\r\n// Get default branch\r\nconst getDefaultBranch = (branches: Branch[]) => {\r\n  if (!branches || branches.length === 0) return undefined;\r\n  return branches.find(b => b.isDefault) || branches[0];\r\n};\r\n\r\n// Parse date from Sapo format (dd/MM/yyyy HH:mm:ss)\r\nconst parseSapoDate = (dateStr: string | undefined): string | undefined => {\r\n  if (!dateStr) return undefined;\r\n  \r\n  // Format: 04/12/2025 16:22:43\r\n  const match = dateStr.match(/^(\\d{2})\\/(\\d{2})\\/(\\d{4})\\s+(\\d{2}):(\\d{2}):(\\d{2})$/);\r\n  if (match) {\r\n    const [, day, month, year, hour, minute, second] = match;\r\n    return `${year}-${month}-${day}T${hour}:${minute}:${second}`;\r\n  }\r\n  \r\n  // Try standard format\r\n  const date = new Date(dateStr);\r\n  if (!isNaN(date.getTime())) {\r\n    return date.toISOString();\r\n  }\r\n  \r\n  return undefined;\r\n};\r\n\r\n// ============================================\r\n// SAPO IMPORT ROW TYPE\r\n// ============================================\r\n\r\nexport interface SapoOrderImportRow {\r\n  stt?: number;\r\n  orderId: string;\r\n  orderDate?: string;\r\n  approvedDate?: string;\r\n  branchName?: string;\r\n  source?: string;\r\n  expectedDeliveryDate?: string;\r\n  completedDate?: string;\r\n  cancelDate?: string;\r\n  status?: string;\r\n  cancelReason?: string;\r\n  processStatus?: string;\r\n  packagingStatus?: string;\r\n  stockOutStatus?: string;\r\n  paymentStatus?: string;\r\n  returnStatus?: string;\r\n  \r\n  // Customer\r\n  customerId?: string;\r\n  customerName?: string;\r\n  customerPhone?: string;\r\n  customerEmail?: string;\r\n  customerAddress?: string;\r\n  contactName?: string;\r\n  \r\n  // Staff\r\n  createdByName?: string;\r\n  salesperson?: string;\r\n  priceList?: string;\r\n  \r\n  // Product line item\r\n  productId?: string;\r\n  barcode?: string;\r\n  productName?: string;\r\n  productType?: string;\r\n  productNote?: string;\r\n  quantity?: number;\r\n  serial?: string;\r\n  batchCode?: string;\r\n  unit?: string;\r\n  unitPrice?: number;\r\n  lineDiscountAmount?: number;\r\n  lineDiscountPercent?: number;\r\n  lineTotal?: number;\r\n  lineTax?: number;\r\n  \r\n  // Order totals\r\n  orderDiscountAmount?: number;\r\n  orderDiscountPercent?: number;\r\n  shippingFee?: number;\r\n  grandTotal?: number;\r\n  paidAmount?: number;\r\n  notes?: string;\r\n  reference?: string;\r\n  tags?: string;\r\n  channelOrderId?: string;\r\n  \r\n  // Package info\r\n  packageId?: string;\r\n  trackingCode?: string;\r\n  packagingDate?: string;\r\n  packagerName?: string;\r\n  stockOutDate?: string;\r\n  stockOutByName?: string;\r\n  \r\n  // Shipping\r\n  carrier?: string;\r\n  packageStatus?: string;\r\n  deliveryCancelReason?: string;\r\n  reconciliationStatus?: string;\r\n  recipientName?: string;\r\n  recipientPhone?: string;\r\n  shippingStreet?: string;\r\n  shippingWard?: string;\r\n  shippingDistrict?: string;\r\n  shippingProvince?: string;\r\n  codAmount?: number;\r\n  carrierFee?: number;\r\n  \r\n  // Payment\r\n  paymentDate?: string;\r\n  paymentId?: string;\r\n  paymentByName?: string;\r\n  paymentAmount?: number;\r\n  paymentMethod?: string;\r\n  paymentMethodType?: string;\r\n  paymentReference?: string;\r\n}\r\n\r\n// ============================================\r\n// FIELD CONFIGURATION (for preview/display)\r\n// ============================================\r\n\r\nexport const sapoOrderFields: FieldConfig<SapoOrderImportRow>[] = [\r\n  {\r\n    key: 'orderId',\r\n    label: 'Mâ”œأ؛ â”€أ‰H (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'SON06712',\r\n    group: 'â”€أ‰â•‍أ­n hâ”œأ،ng',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'orderDate',\r\n    label: 'Ngâ”œأ،y chأںâ•—âŒگng tأںâ•—آ½',\r\n    type: 'string',\r\n    required: false,\r\n    example: '04/12/2025 16:22:43',\r\n    group: 'â”€أ‰â•‍أ­n hâ”œأ،ng',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'branchName',\r\n    label: 'Chi nhâ”œأ­nh',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Chi nhâ”œأ­nh mأںâ•‘â•–c â”€أ¦أںâ•—أ¯nh',\r\n    group: 'â”€أ‰â•‍أ­n hâ”œأ،ng',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'source',\r\n    label: 'Nguأںâ•—أ´n',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Khâ”œأ­c',\r\n    group: 'â”€أ‰â•‍أ­n hâ”œأ،ng',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'status',\r\n    label: 'Trأںâ•‘أ­ng thâ”œأ­i â”€أ¦â•‍أ­n hâ”œأ،ng',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Hoâ”œأ،n thâ”œأ،nh',\r\n    g