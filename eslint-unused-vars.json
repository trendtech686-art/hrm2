tSorting={setPreviewSorting}\r\n                      />\r\n                    </>\r\n                  );\r\n                })()}\r\n\r\n                {payrollBlockingReasons.length > 0 && (\r\n                  <Alert variant=\"destructive\">\r\n                    <AlertTitle>Khâ”œâ”¤ng thأںâ•—أ¢ tأںâ•‘أ­o bأںâ•‘أ؛ng lâ•‍â–‘â•‍أ­ng</AlertTitle>\r\n                    <AlertDescription>\r\n                      <ul className=\"list-disc space-y-1 pl-4\">\r\n                        {payrollBlockingReasons.map((reason) => (\r\n                          <li key={reason}>{reason}</li>\r\n                        ))}\r\n                      </ul>\r\n                      <div className=\"mt-4 flex flex-wrap gap-2\">\r\n                        {!isSelectedMonthLocked && (\r\n                          <Button size=\"sm\" className=\"h-8\" onClick={() => router.push(ROUTES.HRM.ATTENDANCE)}>\r\n                            Khâ”œâ”‚a chأںâ•‘أ‘m câ”œâ”¤ng\r\n                          </Button>\r\n                        )}\r\n                        {pendingLeavesInMonth.length > 0 && (\r\n                          <Button\r\n                            variant=\"outline\"\r\n                            size=\"sm\"\r\n                            className=\"h-8\"\r\n                            onClick={() => router.push(ROUTES.HRM.LEAVES)}\r\n                          >\r\n                            Xem â”€أ¦â•‍أ­n nghأںâ•—أ« chأںâ•—آ¥ duyأںâ•—أ§t\r\n                          </Button>\r\n                        )}\r\n                      </div>\r\n                    </AlertDescription>\r\n                  </Alert>\r\n                )}\r\n              </>\r\n            ) : (\r\n              <Alert>\r\n                <AlertTitle>Châ•‍â–‘a câ”œâ”‚ dأںâ•—آ» liأںâ•—أ§u preview</AlertTitle>\r\n                <AlertDescription>\r\n                  Vui lâ”œâ–“ng quay lأںâ•‘أ­i bâ•‍â–‘أںâ•—آ¢c trâ•‍â–‘أںâ•—آ¢c â”€أ¦أںâ•—أ¢ chأںâ•—أ¬n nhâ”œأ³n viâ”œآ¬n, sau â”€أ¦â”œâ”‚ 