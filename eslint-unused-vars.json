nstantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":613,"column":34,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":613,"endColumn":37,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[17500,17503],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[17500,17503],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":632,"column":34,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":632,"endColumn":37,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[18099,18102],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[18099,18102],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":695,"column":34,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":695,"endColumn":37,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[19926,19929],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[19926,19929],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":23,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import type {\r\n  PkgxProduct,\r\n  PkgxProductsResponse,\r\n  PkgxProductPayload,\r\n  PkgxImageUploadResponse,\r\n  PkgxCategoriesResponse,\r\n  PkgxBrandsResponse,\r\n  PkgxBrandFromApi,\r\n  PkgxGalleryResponse,\r\n  PkgxGalleryImage,\r\n  PkgxSettings,\r\n} from '@/lib/types/prisma-extended';\r\nimport { PKGX_API_CONFIG } from '../../features/settings/pkgx/constants';\r\n\r\n// ========================================\r\n// Types\r\n// ========================================\r\n\r\ntype ApiResponse<T> = {\r\n  success: boolean;\r\n  data?: T;\r\n  error?: string;\r\n};\r\n\r\ntype CreateProductResponse = {\r\n  error: boolean;\r\n  message: string;\r\n  goods_id: number;\r\n  created_slug: string;\r\n};\r\n\r\ntype UpdateProductResponse = {\r\n  error: boolean;\r\n  message: string;\r\n  goods_id: number;\r\n  updated_slug?: string;\r\n};\r\n\r\n// ========================================\r\n// Helper Functions\r\n// ========================================\r\n\r\nfunction getApiConfig(settings?: PkgxSettings) {\r\n  return {\r\n    apiUrl: settings?.apiUrl || PKGX_API_CONFIG.baseUrl,\r\n    apiKey: settings?.apiKey || '',\r\n    enabled: settings?.enabled || false,\r\n  };\r\n}\r\n\r\nasync function fetchWithAuth<T>(settings: PkgxSettings, url: string, options: RequestInit = {}): Promise<ApiResponse<T>> {\r\n  const { apiKey, enabled } = getApiConfig(settings);\r\n\r\n  if (!enabled) {\r\n    return { success: false, error: 'Tâ”œآ،ch hأںâ•—أ؛p PKGX châ•‍â–‘a â”€أ¦â•‍â–‘أںâ•—أ؛c bأںâ•‘آ،t' };\r\n  }\r\n\r\n  if (!apiKey) {\r\n    return { success: false, error: 'Châ•‍â–‘a cأںâ•‘أ‘u hâ”œآ¼nh API Key' };\r\n  }\r\n\r\n  // DEBUG: Log request details\r\n  if (options.body) {\r\n    // Debug: console.log('Request body:', options.body);\r\n  }\r\n\r\n  try {\r\n    const fetchOptions: RequestInit = {\r\n      ...options,\r\n      mode: 'cors',\r\n      credentials: 'omit',\r\n      headers: {\r\n        'X-API-KEY': apiKey,\r\n        'Content-Type': 'application/json',\r\n        ...options.headers,\r\n      },\r\n    };\r\n    \r\n    const response = await fetch(url, fetchOptions);\r\n\r\n    const responseText = await response.text();\r\n    \r\n    const data = JSON.parse(responseText);\r\n    \r\n    // DEBUG: Log response\r\n\r\n    if (data.error) {\r\n      return { success: false, error: data.message || 'Lأںâ•—أ¹i tأںâ•—آ½ server PKGX' };\r\n    }\r\n\r\n    return { success: true, data };\r\n  } catch (error) {\r\n    return {\r\n      success: false,\r\n      error: error instanceof Error ? error.message : 'Khâ”œâ”¤ng thأںâ•—أ¢ kأںâ•‘â”گt nأںâ•—أ¦i â”€أ¦أںâ•‘â”گn server PKGX',\r\n    };\r\n  }\r\n}\r\n\r\n// ========================================\r\n// API Functions\r\n// ========================================\r\n\r\n/**\r\n * Lأںâ•‘أ‘y danh sâ”œأ­ch danh mأںâ•—أ‘c tأںâ•—آ½ PKGX\r\n */\r\nexport async function getCategories(settings: PkgxSettings = {} as any): Promise<ApiResponse<PkgxCategoriesResponse>> {\r\n  const { apiUrl } = getApiConfig(settings);\r\n  const url = `${apiUrl}?action=get_categories`;\r\n  return fetchWithAuth<PkgxCategoriesResponse>(settings, url, { method: 'GET' });\r\n}\r\n\r\n/**\r\n * Lأںâ•‘أ‘y danh sâ”œأ­ch thâ•‍â–‘â•‍أ­ng hiأںâ•—أ§u tأںâ•—آ½ PKGX\r\n */\r\nexport async function getBrands(settings: PkgxSettings = {} as any): Promise<ApiResponse<PkgxBrandsResponse>> {\r\n  const { apiUrl } = getApiConfig(settings);\r\n  const url = `${apiUrl}?action=get_brands`;\r\n  return fetchWithAuth<PkgxBrandsResponse>(settings, url, { method: 'GET' });\r\n}\r\n\r\n/**\r\n * Lأںâ•‘أ‘y chi tiأںâ•‘â”گt 1 thâ•‍â–‘â•‍أ­ng hiأںâ•—أ§u tأںâ•—آ½ PKGX theo brand_id\r\n */\r\nexport async function getBrandById(brandId: number, settings: PkgxSettings = {} as any): Promise<ApiResponse<PkgxBrandFromApi | null>> {\r\n  const { apiUrl } = getApiConfig(settings);\r\n  const url = `${apiUrl}?action=get_brands&brand_id=${brandId}`;\r\n  \r\n  const response = await fetchWithAuth<{ error: boolean; message: string; data: PkgxBrandFromApi }>(settings, url, { method: 'GET' });\r\n  \r\n  if (!response.success || !response.data) {\r\n    return { success: false, error: response.error };\r\n  }\r\n  \r\n  return { success: true, data: response.data.data };\r\n}\r\n\r\n/**\r\n * Lأںâ•‘أ‘y danh sâ”œأ­ch sأںâ•‘أ؛n phأںâ•‘âŒگm tأںâ•—آ½ PKGX (câ”œâ”‚ phâ”œأ³n trang)\r\n */\r\nexport async function getProducts(\r\n  page: number = 1,\r\n  limit: number = 50,\r\n  settings: PkgxSettings = {} as any\r\n): Promise<ApiResponse<PkgxProductsResponse>> {\r\n  const { apiUrl } = getApiConfig(settings);\r\n  const url = `${apiUrl}?action=get_products&page=${page}&limit=${limit}`;\r\n  return fetchWithAuth<PkgxProductsResponse>(settings, url, { method: 'GET' });\r\n}\r\n\r\n/**\r\n * Lأںâ•‘أ‘y tأںâ•‘أ‘t cأںâ•‘أ؛ sأںâ•‘أ؛n phأںâ•‘âŒگm tأںâ•—آ½ PKGX (tأںâ•—â–’ â”€أ¦أںâ•—أ–ng phâ”œأ³n trang)\r\n */\r\nexport async function getAllProducts(settings: PkgxSettings = {} as any): Promise<ApiResponse<PkgxProduct[]>> {\r\n  const allProducts: PkgxProduct[] = [];\r\n  let currentPage = 1;\r\n  let totalPages = 1;\r\n\r\n  while (currentPage <= totalPages) {\r\n    const response = await getProducts(currentPage, 100, settings);\r\n\r\n    if (!response.success || !response.data) {\r\n      return { success: false, error: response.error };\r\n    }\r\n\r\n    allProducts.push(...response.data.data);\r\n    totalPages = response.data.pagination.total_pages;\r\n    currentPage++;\r\n  }\r\n\r\n  return { success: true, data: allProducts };\r\n}\r\n\r\n/**\r\n * Lأںâ•‘أ‘y sأںâ•‘أ؛n phأںâ•‘âŒگm theo goods_id (sأںâ•—آ، dأںâ•—أ‘ng API get_products vأںâ•—آ¢i filter)\r\n */\r\nexport async function getProductById(goodsId: number, settings: PkgxSettings = {} as any): Promise<ApiResponse<PkgxProduct | null>> {\r\n  const { apiUrl } = getApiConfig(settings);\r\n  // API khâ”œâ”¤ng câ”œâ”‚ action=get_product, dâ”œâ•£ng get_products vأںâ•—آ¢i goods_id filter\r\n  const url = `${apiUrl}?action=get_products&goods_id=${goodsId}`;\r\n  \r\n  const response = await fetchWithAuth<PkgxProductsResponse>(settings, url, { method: 'GET' });\r\n  \r\n  if (!response.success || !response.data) {\r\n    return { success: false, error: response.error };\r\n  }\r\n  \r\n  // Trأںâ•‘أ؛ vأںâ•—أ¼ sأںâ•‘أ؛n phأںâ•‘âŒگm â”€أ¦أںâ•‘آ؛u tiâ”œآ¬n nأںâ•‘â”گu câ”œâ”‚\r\n  const product = response.data.data?.[0] || null;\r\n  return { success: true, data: product };\r\n}\r\n\r\n/**\r\n * Lأںâ•‘أ‘y gallery أںâ•‘أ؛nh sأںâ•‘أ؛n phأںâ•‘âŒگm theo goods_id\r\n * Note: Cأںâ•‘آ؛n API endpoint `get_gallery` trâ”œآ¬n server PKGX\r\n */\r\nexport async function getProductGallery(goodsId: number, settings: PkgxSettings = {} as any): Promise<ApiResponse<PkgxGalleryImage[]>> {\r\n  const { apiUrl } = getApiConfig(settings);\r\n  const url = `${apiUrl}?action=get_gallery&goods_id=${goodsId}`;\r\n  \r\n  try {\r\n    const response = await fetchWithAuth<PkgxGalleryResponse>(settings, url, { method: 'GET' });\r\n    \r\n    // Debug log\r\n    \r\n    if (!response.success) {\r\n      // Nأںâ•‘â”گu API châ•‍â–‘a câ”œâ”‚ hoأںâ•‘â•–c lأںâ•—أ¹i, trأںâ•‘أ؛ vأںâ•—أ¼ mأںâ•‘أ؛ng rأںâ•—أ¹ng\r\n      return { success: true, data: [] };\r\n    }\r\n    \r\n    // response.data chأںâ•—âŒگa toâ”œأ،n bأںâ•—أ– response tأںâ•—آ½ API: { error, message, goods_id, total, data }\r\n    const galleryData = response.data as PkgxGalleryResponse;\r\n    return { success: true, data: galleryData.data || [] };\r\n  } catch (error) {\r\n    console.error('Gallery API exception:', error);\r\n    return { success: true, data: [] }; // Fallback to empty array\r\n  }\r\n}\r\n\r\n/**\r\n * Tأںâ•‘أ­o sأںâ•‘أ؛n phأںâ•‘âŒگm mأںâ•—آ¢i trâ”œآ¬n PKGX\r\n */\r\nexport async function createProduct(\r\n  payload: PkgxProductPayload,\r\n  settings: PkgxSettings = {} as any\r\n): Promise<ApiResponse<CreateProductResponse>> {\r\n  const { apiUrl } = getApiConfig(settings);\r\n  const url = `${apiUrl}?action=create_product`;\r\n\r\n  return fetchWithAuth<CreateProductResponse>(settings, url, {\r\n    method: 'POST',\r\n    headers: { 'Content-Type': 'application/json' },\r\n    body: JSON.stringify(payload),\r\n  });\r\n}\r\n\r\n/**\r\n * Cأںâ•‘آ،p nhأںâ•‘آ،t sأںâ•‘أ؛n phأںâ•‘âŒگm trâ”œآ¬n PKGX\r\n */\r\nexport async function updateProduct(\r\n  goodsId: number,\r\n  payload: Partial<PkgxProductPayload>,\r\n  settings: PkgxSettings = {} as any\r\n): Promise<ApiResponse<UpdateProductResponse>> {\r\n  const { apiUrl } = getApiConfig(settings);\r\n  const url = `${apiUrl}?action=update_product&goods_id=${goodsId}`;\r\n\r\n  return fetchWithAuth<UpdateProductResponse>(settings, url, {\r\n    method: 'POST',\r\n    headers: { 'Content-Type': 'application/json' },\r\n    body: JSON.stringify(payload),\r\n  });\r\n}\r\n\r\n/**\r\n * Cأںâ•‘آ،p nhأںâ•‘آ،t giâ”œأ­ sأںâ•‘أ؛n phأںâ•‘âŒگm\r\n */\r\nexport async function updateProductPrice(\r\n  goodsId: number,\r\n  prices: {\r\n    shop_price?: number;\r\n    market_price?: number;\r\n    partner_price?: number;\r\n    ace_price?: number;\r\n    deal_price?: number;\r\n  },\r\n  settings: PkgxSettings = {} as any\r\n): Promise<ApiResponse<UpdateProductResponse>> {\r\n  return updateProduct(goodsId, prices, settings);\r\n}\r\n\r\n/**\r\n * Cأںâ•‘آ،p nhأںâ•‘آ،t SEO sأںâ•‘أ؛n phأںâ•‘âŒگm\r\n */\r\nexport async function updateProductSeo(\r\n  goodsId: number,\r\n  seo: {\r\n    meta_title?: string;\r\n    meta_desc?: string;\r\n    keywords?: string;\r\n  },\r\n  settings: PkgxSettings = {} as any\r\n): Promise<ApiResponse<UpdateProductResponse>> {\r\n  return updateProduct(goodsId, seo, settings);\r\n}\r\n\r\n/**\r\n * Cأںâ•‘آ،p nhأںâ•‘آ،t tأںâ•—أ´n kho sأںâ•‘أ؛n phأںâ•‘âŒگm\r\n */\r\nexport async function updateProductStock(\r\n  goodsId: number,\r\n  goodsNumber: number,\r\n  settings: PkgxSettings = {} as any\r\n): Promise<ApiResponse<UpdateProductResponse>> {\r\n  return updateProduct(goodsId, { goods_number: goodsNumber }, settings);\r\n}\r\n\r\n/**\r\n * Upload أںâ•‘أ؛nh sأںâ•‘أ؛n phأںâ•‘âŒگm lâ”œآ¬n PKGX\r\n */\r\nexport async function uploadProductImage(\r\n  imageFile: File,\r\n  options?: {\r\n    filenameSlug?: string;\r\n    goodsId?: number;\r\n  },\r\n  settings: PkgxSettings = {} as any\r\n): Promise<ApiResponse<PkgxImageUploadResponse>> {\r\n  const { apiUrl, apiKey, enabled } = getApiConfig(settings);\r\n\r\n  if (!enabled) {\r\n    return { success: false, error: 'Tâ”œآ،ch hأںâ•—أ؛p PKGX châ•‍â–‘a â”€أ¦â•‍â–‘أںâ•—أ؛c bأںâ•‘آ،t' };\r\n  }\r\n\r\n  if (!apiKey) {\r\n    return { success: false, error: 'Châ•‍â–‘a cأںâ•‘أ‘u hâ”œآ¼nh API Key' };\r\n  }\r\n\r\n  const url = `${apiUrl}?action=upload_product_image`;\r\n  const formData = new FormData();\r\n  formData.append('image_file', imageFile);\r\n\r\n  if (options?.filenameSlug) {\r\n    formData.append('filename_slug', options.filenameSlug);\r\n  }\r\n\r\n  if (options?.goodsId) {\r\n    formData.append('goods_id', options.goodsId.toString());\r\n  }\r\n\r\n  try {\r\n    const response = await fetch(url, {\r\n      method: 'POST',\r\n      headers: { 'X-API-KEY': apiKey },\r\n      body: formData,\r\n    });\r\n\r\n    const data = await response.json();\r\n\r\n    if (data.error) {\r\n      return { success: false, error: data.message };\r\n    }\r\n\r\n    return { success: true, data };\r\n  } catch (error) {\r\n    return {\r\n      success: false,\r\n      error: error instanceof Error ? error.message : 'Khâ”œâ”¤ng thأںâ•—أ¢ upload أںâ•‘أ؛nh',\r\n    };\r\n  }\r\n}\r\n\r\n/**\r\n * Upload أںâ•‘أ؛nh tأںâ•—آ½ URL (server-to-server, trâ”œأ­nh CORS)\r\n * Server PKGX sأںâ•‘â•œ tأںâ•—â–’ download أںâ•‘أ؛nh tأںâ•—آ½ URL rأںâ•—أ´i xأںâ•—آ، lâ”œâ•œ\r\n */\r\nexport async function uploadImageFromUrl(\r\n  imageUrl: string,\r\n  options?: {\r\n    filenameSlug?: string;\r\n    goodsId?: number;\r\n  },\r\n  settings: PkgxSettings = {} as any\r\n): Promise<ApiResponse<PkgxImageUploadResponse>> {\r\n  const { apiUrl, apiKey, enabled } = getApiConfig(settings);\r\n\r\n  if (!enabled) {\r\n    return { success: false, error: 'Tâ”œآ،ch hأںâ•—أ؛p PKGX châ•‍â–‘a â”€أ¦â•‍â–‘أںâ•—أ؛c bأںâ•‘آ،t' };\r\n  }\r\n\r\n  if (!apiKey) {\r\n    return { success: false, error: 'Châ•‍â–‘a cأںâ•‘أ‘u hâ”œآ¼nh API Key' };\r\n  }\r\n\r\n  const url = `${apiUrl}?action=upload_image_from_url`;\r\n  \r\n  const payload: Record<string, unknown> = {\r\n    image_url: imageUrl,\r\n  };\r\n\r\n  if (options?.filenameSlug) {\r\n    payload.filename_slug = options.filenameSlug;\r\n  }\r\n\r\n  if (options?.goodsId) {\r\n    payload.goods_id = options.goodsId;\r\n  }\r\n\r\n  try {\r\n    const response = await fetch(url, {\r\n      method: 'POST',\r\n      headers: { \r\n        'X-API-KEY': apiKey,\r\n        'Content-Type': 'application/json',\r\n      },\r\n      body: JSON.stringify(payload),\r\n    });\r\n\r\n    const data = await response.json();\r\n\r\n    if (data.error) {\r\n      return { success: false, error: data.message };\r\n    }\r\n\r\n    return { success: true, data };\r\n  } catch (error) {\r\n    return {\r\n      success: false,\r\n      error: error instanceof Error ? error.message : 'Khâ”œâ”¤ng thأںâ•—أ¢ upload أںâ•‘أ؛nh tأںâ•—آ½ URL',\r\n    };\r\n  }\r\n}\r\n\r\n/**\r\n * Lأںâ•‘أ‘y chi tiأںâ•‘â”گt danh mأںâ•—أ‘c theo cat_id (bao gأںâ•—أ´m SEO fields)\r\n */\r\nexport async function getCategoryById(catId: number, settings: PkgxSettings = {} as any): Promise<ApiResponse<PkgxCategoriesResponse>> {\r\n  const { apiUrl } = getApiConfig(settings);\r\n  const url = `${apiUrl}?action=get_categories&cat_id=${catId}`;\r\n  return fetchWithAuth<PkgxCategoriesResponse>(settings, url, { method: 'GET' });\r\n}\r\n\r\n/**\r\n * Cأںâ•‘آ،p nhأںâ•‘آ،t thâ”œâ”¤ng tin danh mأںâ•—أ‘c (SEO, mâ”œâ”¤ tأںâ•‘أ؛)\r\n * \r\n * Câ”œأ­c trâ•‍â–‘أںâ•—آ¥ng hأںâ•—أ¹ trأںâ•—أ؛:\r\n * - cat_name: Tâ”œآ¬n danh mأںâ•—أ‘c\r\n * - cat_desc: Mâ”œâ”¤ tأںâ•‘أ؛ chi tiأںâ•‘â”گt (HTML) - tâ•‍â–‘â•‍أ­ng â”€أ¦â•‍â–‘â•‍أ­ng longDescription\r\n * - keywords: Tأںâ•—آ½ khâ”œâ”‚a SEO - tâ•‍â–‘â•‍أ­ng â”€أ¦â•‍â–‘â•‍أ­ng seoKeywords\r\n * - cat_alias: Slug URL\r\n * - meta_title: Tiâ”œآ¬u â”€أ¦أںâ•—أ¼ SEO (NEW)\r\n * - meta_desc: Mâ”œâ”¤ tأںâ•‘أ؛ SEO (NEW)\r\n * - short_desc: Mâ”œâ”¤ tأںâ•‘أ؛ ngأںâ•‘آ»n (NEW)\r\n */\r\nexport async function updateCategory(\r\n  catId: number,\r\n  payload: {\r\n    cat_name?: string;\r\n    cat_desc?: string;  // Mâ”œâ”¤ tأںâ•‘أ؛ ngأںâ•‘آ»n (shortDescription)\r\n    long_desc?: string; // Mâ”œâ”¤ tأںâ•‘أ؛ dâ”œأ،i (longDescription) - HTML\r\n    keywords?: string;\r\n    cat_alias?: string;\r\n    // SEO fields\r\n    meta_title?: string;\r\n    meta_desc?: string;\r\n    short_desc?: string;\r\n  },\r\n  settings: PkgxSettings = {} as any\r\n): Promise<ApiResponse<{ error: boolean; message: string; cat_id: number }>> {\r\n  const { apiUrl } = getApiConfig(settings);\r\n  // Add timestamp to bust cache\r\n  const timestamp = Date.now();\r\n  const url = `${apiUrl}?action=update_category&cat_id=${catId}&_t=${timestamp}`;\r\n\r\n\r\n  return fetchWithAuth(settings, url, {\r\n    method: 'POST',\r\n    headers: { 'Content-Type': 'application/json' },\r\n    body: JSON.stringify(payload),\r\n  });\r\n}\r\n\r\n/**\r\n * Cأںâ•‘آ،p nhأںâ•‘آ،t thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n danh mأںâ•—أ‘c (tâ”œآ¬n, parent, hiأںâ•—أ¢n thأںâ•—أ¯)\r\n * URL: POST ?action=update_category_basic&cat_id=123\r\n * \r\n * Câ”œأ­c trâ•‍â–‘أںâ•—آ¥ng hأںâ•—أ¹ trأںâ•—أ؛:\r\n * - cat_name: Tâ”œآ¬n danh mأںâ•—أ‘c\r\n * - parent_id: ID danh mأںâ•—أ‘c cha (0 = gأںâ•—أ¦c)\r\n * - is_show: 1 = Hiأںâ•—أ¢n thأںâ•—أ¯, 0 = أںâ•‘آ؟n (Display in Category Home)\r\n */\r\nexport async function updateCategoryBasic(\r\n  catId: number,\r\n  payload: {\r\n    cat_name?: string;\r\n    parent_id?: number;\r\n    is_show?: number; // 1 = hiأںâ•—أ¢n thأںâ•—أ¯, 0 = أںâ•‘âŒگn\r\n  },\r\n  settings: PkgxSettings = {} as any\r\n): Promise<ApiResponse<{ error: boolean; message: string; cat_id: number; changes?: Record<string, { old: unknown; new: unknown }> }>> {\r\n  const { apiUrl } = getApiConfig(settings);\r\n  const timestamp = Date.now();\r\n  const url = `${apiUrl}?action=update_category_basic&cat_id=${catId}&_t=${timestamp}`;\r\n\r\n\r\n  return fetchWithAuth(settings, url, {\r\n    method: 'POST',\r\n    headers: { 'Content-Type': 'application/json' },\r\n    body: JSON.stringify(payload),\r\n  });\r\n}\r\n\r\n/**\r\n * Cأںâ•‘آ،p nhأںâ•‘آ،t thâ”œâ”¤ng tin thâ•‍â–‘â•‍أ­ng hiأںâ•—أ§u (SEO, mâ”œâ”¤ tأںâ•‘أ؛)\r\n * \r\n * Câ”œأ­c trâ•‍â–‘أںâ•—آ¥ng hأںâ•—أ¹ trأںâ•—أ؛:\r\n * - brand_name: Tâ”œآ¬n thâ•‍â–‘â•‍أ­ng hiأںâ•—أ§u\r\n * - brand_desc: Mâ”œâ”¤ tأںâ•‘أ؛ chi tiأںâ•‘â”گt (HTML) - tâ•‍â–‘â•‍أ­ng â”€أ¦â•‍â–‘â•‍أ­ng longDescription\r\n * - site_url: Website URL\r\n * - keywords: Tأںâ•—آ½ khâ”œâ”‚a SEO (NEW) - tâ•‍â–‘â•‍أ­ng â”€أ¦â•‍â–‘â•‍أ­ng seoKeywords\r\n * - meta_title: Tiâ”œآ¬u â”€أ¦أںâ•—أ¼ SEO (NEW)\r\n * - meta_desc: Mâ”œâ”¤ tأںâ•‘أ؛ SEO (NEW)\r\n * - short_desc: Mâ”œâ”¤ tأںâ•‘أ؛ ngأںâ•‘آ»n (NEW)\r\n * - long_desc: Mâ”œâ”¤ tأںâ•‘أ؛ dâ”œأ،i (NEW)\r\n */\r\nexport async function updateBrand(\r\n  brandId: number,\r\n  payload: {\r\n    brand_name?: string;\r\n    brand_desc?: string;\r\n    site_url?: string;\r\n    // SEO fields (NEW)\r\n    keywords?: string;\r\n    meta_title?: string;\r\n    meta_desc?: string;\r\n    short_desc?: string;\r\n    long_desc?: string;\r\n  },\r\n  settings: PkgxSettings = {} as any\r\n): Promise<ApiResponse<{ error: boolean; message: string; brand_id: number }>> {\r\n  const { apiUrl } = getApiConfig(settings);\r\n  const url = `${apiUrl}?action=update_brand&brand_id=${brandId}`;\r\n\r\n  return fetchWithAuth(settings, url, {\r\n    method: 'POST',\r\n    headers: { 'Content-Type': 'application/json' },\r\n    body: JSON.stringify(payload),\r\n  });\r\n}\r\n\r\n/**\r\n * Test kأںâ•‘â”گt nأںâ•—أ¦i API\r\n */\r\nexport async function testConnection(settings: PkgxSettings = {} as any): Promise<ApiResponse<{ productCount: number }>> {\r\n  const response = await getProducts(1, 1, settings);\r\n\r\n  if (!response.success) {\r\n    return { success: false, error: response.error };\r\n  }\r\n\r\n  return {\r\n    success: true,\r\n    data: { productCount: response.data?.pagination.total_items || 0 },\r\n  };\r\n}\r\n\r\n// ========================================\r\n// Member Price API (Giâ”œأ­ thâ”œأ،nh viâ”œآ¬n)\r\n// ========================================\r\n\r\ntype MemberRank = {\r\n  rank_id: number;\r\n  rank_name: string;\r\n  min_points: number;\r\n  max_points: number;\r\n  discount: number;\r\n  special_rank: number;\r\n};\r\n\r\ntype MemberRanksResponse = {\r\n  error: boolean;\r\n  message: string;\r\n  total: number;\r\n  data: MemberRank[];\r\n};\r\n\r\ntype MemberPriceResult = {\r\n  user_rank: number;\r\n  rank_name?: string;\r\n  user_price?: number;\r\n  status: 'updated' | 'deleted' | 'skipped';\r\n  reason?: string;\r\n};\r\n\r\ntype CurrentMemberPrice = {\r\n  user_rank: string;\r\n  user_price: string;\r\n  rank_name: string;\r\n};\r\n\r\ntype UpdateMemberPriceResponse = {\r\n  error: boolean;\r\n  message: string;\r\n  goods_id: number;\r\n  goods_name: string;\r\n  results: MemberPriceResult[];\r\n  current_member_prices: CurrentMemberPrice[];\r\n};\r\n\r\n/**\r\n * Lأںâ•‘أ‘y danh sâ”œأ­ch hأںâ•‘أ­ng thâ”œأ،nh viâ”œآ¬n tأںâ•—آ½ PKGX\r\n */\r\nexport async function getMemberRanks(settings: PkgxSettings = {} as any): Promise<ApiResponse<MemberRanksResponse>> {\r\n  const { apiUrl } = getApiConfig(settings);\r\n  const url = `${apiUrl}?action=get_member_ranks`;\r\n  return fetchWithAuth<MemberRanksResponse>(settings, url, { method: 'GET' });\r\n}\r\n\r\n/**\r\n * Cأںâ•‘آ،p nhأںâ•‘آ،t giâ”œأ­ thâ”œأ،nh viâ”œآ¬n cho sأںâ•‘أ؛n phأںâ•‘âŒگm\r\n * \r\n * @param goodsId - ID sأںâ•‘أ؛n phأںâ•‘âŒگm trâ”œآ¬n PKGX\r\n * @param memberPrices - Mأںâ•‘أ؛ng giâ”œأ­ thâ”œأ،nh viâ”œآ¬n theo user_rank\r\n * \r\n * Vâ”œآ، dأںâ•—أ‘:\r\n * - Cأںâ•‘آ،p nhأںâ•‘آ،t 1 giâ”œأ­: updateMemberPrice(8014, [{ user_rank: 8, user_price: 2200000 }])\r\n * - Cأںâ•‘آ،p nhأںâ•‘آ،t nhiأںâ•—أ¼u: updateMemberPrice(8014, [{ user_rank: 8, user_price: 2200000 }, { user_rank: 9, user_price: 1800000 }])\r\n * - Xâ”œâ”‚a giâ”œأ­ (set = 0): updateMemberPrice(8014, [{ user_rank: 8, user_price: 0 }])\r\n */\r\nexport async function updateMemberPrice(\r\n  goodsId: number,\r\n  memberPrices: Array<{ user_rank: number; user_price: number }>,\r\n  settings: PkgxSettings = {} as any\r\n): Promise<ApiResponse<UpdateMemberPriceResponse>> {\r\n  const { apiUrl } = getApiConfig(settings);\r\n  const url = `${apiUrl}?action=update_member_price&goods_id=${goodsId}`;\r\n\r\n  return fetchWithAuth<UpdateMemberPriceResponse>(settings, url, {\r\n    method: 'POST',\r\n    headers: { 'Content-Type': 'application/json' },\r\n    body: JSON.stringify({ member_prices: memberPrices }),\r\n  });\r\n}\r\n\r\n/**\r\n * Cأںâ•‘آ،p nhأںâ•‘آ،t giâ”œأ­ thâ”œأ،nh viâ”œآ¬n theo rank_id â”€أ¦â•‍أ­n lأںâ•‘â•—\r\n */\r\nexport async function updateMemberPriceSingle(\r\n  goodsId: number,\r\n  userRank: number,\r\n  userPrice: number,\r\n  settings: PkgxSettings = {} as any\r\n): Promise<ApiResponse<UpdateMemberPriceResponse>> {\r\n  return updateMemberPrice(goodsId, [{ user_rank: userRank, user_price: userPrice }], settings);\r\n}\r\n\r\n// ========================================\r\n// HTML Image Processing\r\n// ========================================\r\n\r\n/**\r\n * Kiأںâ•—أ¢m tra URL câ”œâ”‚ phأںâ•‘أ؛i lâ”œأ، URL câ”œâ”¤ng khai khâ”œâ”¤ng (khâ”œâ”¤ng phأںâ•‘أ؛i localhost/internal)\r\n */\r\nfunction isPublicUrl(url: string): boolean {\r\n  try {\r\n    const parsed = new URL(url);\r\n    const hostname = parsed.hostname.toLowerCase();\r\n    \r\n    // Loأںâ•‘أ­i bأںâ•—أ… câ”œأ­c URL nأںâ•—أ–i bأںâ•—أ–\r\n    if (hostname === 'localhost' || \r\n        hostname === '127.0.0.1' ||\r\n        hostname.startsWith('192.168.') ||\r\n        hostname.startsWith('10.') ||\r\n        hostname.endsWith('.local')) {\r\n      return false;\r\n    }\r\n    return true;\r\n  } catch {\r\n    return false;\r\n  }\r\n}\r\n\r\n/**\r\n * Kiأںâ•—أ¢m tra xem URL câ”œâ”‚ phأںâ•‘أ؛i lâ”œأ، أںâ•‘أ؛nh base64 khâ”œâ”¤ng\r\n */\r\nfunction isBase64Image(url: string): boolean {\r\n  return url.startsWith('data:image/');\r\n}\r\n\r\n/**\r\n * Kiأںâ•—أ¢m tra xem URL â”€أ¦â”œأ؛ lâ”œأ، URL cأںâ•—آ؛a PKGX CDN châ•‍â–‘a\r\n */\r\nfunction isPkgxCdnUrl(url: string): boolean {\r\n  return url.includes('phukiengiaxuong.com.vn/cdn/');\r\n}\r\n\r\n/**\r\n * Xأںâ•—آ، lâ”œâ•œ HTML â”€أ¦أںâ•—أ¢ upload tأںâ•‘أ‘t cأںâ•‘أ؛ أںâ•‘أ؛nh lâ”œآ¬n PKGX vâ”œأ، thay thأںâ•‘â”گ URL\r\n * \r\n * Hâ”œأ،m nâ”œأ،y sأںâ•‘â•œ:\r\n * 1. Tâ”œآ¼m tأںâ•‘أ‘t cأںâ•‘أ؛ <img> tags trong HTML\r\n * 2. Vأںâ•—آ¢i mأںâ•—أ¹i أںâ•‘أ؛nh câ”œâ”‚ src lâ”œأ، URL câ”œâ”¤ng khai (khâ”œâ”¤ng phأںâ•‘أ؛i localhost):\r\n *    - Upload lâ”œآ¬n PKGX qua upload_image_from_url\r\n *    - Thay thأںâ•‘â”گ src bأںâ•‘â–’ng URL mأںâ•—آ¢i trâ”œآ¬n PKGX CDN\r\n * 3. Vأںâ•—آ¢i أںâ•‘أ؛nh base64: bأںâ•—أ… qua (quâ”œأ­ nأںâ•‘â•–ng, khâ”œâ”¤ng sync)\r\n * 4. Vأںâ•—آ¢i أںâ•‘أ؛nh â”€أ¦â”œأ؛ trâ”œآ¬n PKGX CDN: giأںâ•—آ» nguyâ”œآ¬n\r\n * \r\n * @param html - HTML content cأںâ•‘آ؛n xأںâ•—آ، lâ”œâ•œ\r\n * @param filenamePrefix - Prefix cho tâ”œآ¬n file (optional)\r\n * @returns HTML â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c xأںâ•—آ، lâ”œâ•œ vأںâ•—آ¢i URLs mأںâ•—آ¢i\r\n */\r\nexport async function processHtmlImagesForPkgx(\r\n  html: string,\r\n  filenamePrefix?: string,\r\n  settings: PkgxSettings = {} as any\r\n): Promise<{ processedHtml: string; uploadedCount: number; skippedCount: number; errors: string[] }> {\r\n  if (!html) {\r\n    return { processedHtml: html, uploadedCount: 0, skippedCount: 0, errors: [] };\r\n  }\r\n\r\n  // Regex â”€أ¦أںâ•—أ¢ tâ”œآ¼m tأںâ•‘أ‘t cأںâ•‘أ؛ <img> tags\r\n  const imgRegex = /<img[^>]+src=[\"']([^\"']+)[\"'][^>]*>/gi;\r\n  \r\n  let processedHtml = html;\r\n  let uploadedCount = 0;\r\n  let skippedCount = 0;\r\n  const errors: string[] = [];\r\n  \r\n  // Tâ”œآ¼m tأںâ•‘أ‘t cأںâ•‘أ؛ câ”œأ­c أںâ•‘أ؛nh\r\n  const matches: Array<{ fullMatch: string; src: string }> = [];\r\n  let match;\r\n  while ((match = imgRegex.exec(html)) !== null) {\r\n    matches.push({ fullMatch: match[0], src: match[1] });\r\n  }\r\n\r\n  // Xأںâ•—آ، lâ”œâ•œ tأںâ•—آ½ng أںâ•‘أ؛nh\r\n  for (let i = 0; i < matches.length; i++) {\r\n    const { fullMatch, src } = matches[i];\r\n    \r\n    // Skip base64 images\r\n    if (isBase64Image(src)) {\r\n      skippedCount++;\r\n      errors.push(`Bأںâ•—أ… qua أںâ•‘أ؛nh base64 (khâ”œâ”¤ng hأںâ•—أ¹ trأںâ•—أ؛ upload base64)`);\r\n      continue;\r\n    }\r\n    \r\n    // Skip if already on PKGX CDN\r\n    if (isPkgxCdnUrl(src)) {\r\n      skippedCount++;\r\n      continue;\r\n    }\r\n    \r\n    // Skip localhost/internal URLs\r\n    if (!isPublicUrl(src)) {\r\n      skippedCount++;\r\n      errors.push(`Bأںâ•—أ… qua URL nأںâ•—أ–i bأںâ•—أ–: ${src.substring(0, 50)}...`);\r\n      continue;\r\n    }\r\n    \r\n    // Upload to PKGX\r\n    try {\r\n      const slug = filenamePrefix \r\n        ? `${filenamePrefix}-desc-img-${i + 1}` \r\n        : `desc-img-${Date.now()}-${i + 1}`;\r\n      \r\n      const uploadResult = await uploadImageFromUrl(src, { filenameSlug: slug }, settings);\r\n      \r\n      if (uploadResult.success && uploadResult.data?.data?.full_urls?.original) {\r\n        // Replace src in HTML\r\n        const newSrc = uploadResult.data.data.full_urls.original;\r\n        const newImgTag = fullMatch.replace(src, newSrc);\r\n        processedHtml = processedHtml.replace(fullMatch, newImgTag);\r\n        uploadedCount++;\r\n      } else {\r\n        errors.push(`Lأںâ•—أ¹i upload أںâ•‘أ؛nh: ${uploadResult.error || 'Unknown error'}`);\r\n        skippedCount++;\r\n      }\r\n    } catch (error) {\r\n      errors.push(`Exception upload أںâ•‘أ؛nh: ${error instanceof Error ? error.message : String(error)}`);\r\n      skippedCount++;\r\n    }\r\n  }\r\n\r\n  return { processedHtml, uploadedCount,