eCallback((item: TargetGroup, isActive: boolean) => {\r\n    (update as any).mutate({ systemId: item.systemId, isActive });\r\n    toast.success(isActive ? \"â”€أ‰â”œأ؛ kâ”œآ،ch hoأںâ•‘أ­t\" : \"â”€أ‰â”œأ؛ ngأںâ•—آ½ng hoأںâ•‘أ­t â”€أ¦أںâ•—أ–ng\");\r\n  }, [data, update]);\r\n  \r\n  const confirmDelete = () => {\r\n    if (idToDelete) {\r\n      remove.mutate(idToDelete, {\r\n        onSuccess: () => toast.success(\"â”€أ‰â”œأ؛ xâ”œâ”‚a thâ”œأ،nh câ”œâ”¤ng\"),\r\n        onError: (err) => toast.error(err.message)\r\n      });\r\n    }\r\n    setIsAlertOpen(false);\r\n    setIdToDelete(null);\r\n  };\r\n  \r\n  const handleFormSubmit = (values: TargetGroupFormValues) => {\r\n    try {\r\n      const name = values.name.trim();\r\n      const normalizedId = values.id?.trim().toUpperCase();\r\n      if (editingItem) {\r\n        update.mutate({\r\n          systemId: editingItem.systemId,\r\n          data: {\r\n            name,\r\n            id: normalizedId ? asBusinessId(normalizedId) : editingItem.id,\r\n          }\r\n        }, {\r\n          onSuccess: () => toast.success(\"Cأںâ•‘آ،p nhأںâ•‘آ،t thâ”œأ،nh câ”œâ”¤ng\"),\r\n          onError: (err) => toast.error(err.message)\r\n        });\r\n      } else {\r\n        create.mutate({\r\n          id: normalizedId ? asBusinessId(normalizedId) : asBusinessId(\"\"),\r\n          name,\r\n          isActive: true,\r\n        }, {\r\n          onSuccess: () => toast.success(\"Thâ”œآ¬m mأںâ•—آ¢i thâ”œأ،nh câ”œâ”¤ng\"),\r\n          onError: (err) => toast.error(err.message)\r\n        });\r\n      }\r\n      setIsFormOpen(false);\r\n    } catch (error) {\r\n      toast.error(\"Câ”œâ”‚ lأںâ•—أ¹i xأںâ•‘أ؛y ra\", {\r\n        description: error instanceof Error ? error.message : \"Lأںâ•—أ¹i khâ”œâ”¤ng xâ”œأ­c â”€أ¦أںâ•—أ¯nh\",\r\n      });\r\n    }\r\n  };\r\n\r\n  React.useEffect(() => {\r\n    if (!isActive) {\r\n      return;\r\n    }\r\n\r\n    onRegisterActions([\r\n      <SettingsActionButton key=\"add-target-group\"