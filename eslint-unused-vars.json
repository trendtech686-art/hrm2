\"second-reminder\"\r\n                        type=\"number\"\r\n                        className=\"h-9\"\r\n                        min=\"1\"\r\n                        value={reminders.secondReminderHours}\r\n                        onChange={(e) => handleReminderChange('secondReminderHours', parseInt(e.target.value) || 1)}\r\n                      />\r\n                    </div>\r\n                    <div className=\"space-y-2\">\r\n                      <Label htmlFor=\"escalation\">\r\n                        Bâ”œأ­o â”€أ¦أںâ•—أ–ng leo thang (giأںâ•—آ¥)\r\n                      </Label>\r\n                      <Input\r\n                        id=\"escalation\"\r\n                        type=\"number\"\r\n                        className=\"h-9\"\r\n                        min=\"1\"\r\n                        value={reminders.escalationHours}\r\n                        onChange={(e) => handleReminderChange('escalationHours', parseInt(e.target.value) || 1)}\r\n                      />\r\n                    </div>\r\n                  </SettingsFormGrid>\r\n                )}\r\n              </SettingsFormSection>\r\n\r\n            </CardContent>\r\n          </Card>\r\n      </TabsContent>\r\n    </SettingsVerticalTabs>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\settings\\tasks\\types.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\settings\\tasks\\validation.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\settings\\taxes-page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\