s';\r\nimport { getCurrentUserName } from './base-store';\r\nimport { asSystemId, type SystemId } from '../../../lib/id-types';\r\n\r\n/**\r\n * @deprecated Use server endpoint: POST /api/warranties with stock commit\r\n * Commit stock khi tأںâ•‘أ­o warranty (reserve hâ”œأ،ng cho â”€أ¦أںâ•—أ²i mأںâ•—آ¢i)\r\n * \r\n * خ“أœأ،âˆ©â••أ… UNSAFE: Client-side stock commitment without transaction\r\n */\r\nexport function commitWarrantyStock(\r\n  ticket: WarrantyTicket,\r\n  products: Array<{ id: string; systemId: string; name: string; [key: string]: unknown }>\r\n) {\r\n  console.warn('خ“أœأ،âˆ©â••أ… DEPRECATED: commitWarrantyStock. Use POST /api/warranties endpoint.');\r\n  // Method body removed - use server endpoint\r\n}\r\n\r\n/**\r\n * @deprecated Use server endpoint: POST /api/warranties/:id/cancel with uncommit\r\n * Uncommit stock khi xâ”œâ”‚a warranty (giأںâ•‘أ؛i phâ”œâ”‚ng hâ”œأ،ng giأںâ•—آ» chأںâ•—أ¹)\r\n * \r\n * خ“أœأ،âˆ©â••أ… UNSAFE: Client-side stock uncommitment without transaction\r\n */\r\nexport function uncommitWarrantyStock(\r\n  ticket: WarrantyTicket,\r\n  products: Array<{ id: string; systemId: string; name: string; [key: string]: unknown }>,\r\n  options?: { silent?: boolean }\r\n) {\r\n  console.warn('خ“أœأ،âˆ©â••أ… DEPRECATED: uncommitWarrantyStock. Use POST /api/warranties/:id/cancel endpoint.');\r\n  // Method body removed - use server endpoint\r\n}\r\n\r\n/**\r\n * @deprecated Use server endpoint: POST /api/warranties/:id/complete with stock deduction\r\n * Xuأںâ•‘أ‘t kho khi 'completed' - Dâ”œâ•£ng dispatchStock giأںâ•—أ¦ng â”€أ¦â•‍أ­n hâ”œأ،ng\r\n * \r\n * خ“أœأ،âˆ©â••أ… UNSAFE: Client-side stock deduction + stock history without transaction\r\n */\r\nexport function deductWarrantyStock(\r\n  ticket: WarrantyTicket,\r\n  products: Array<{ id: string; systemId: string; name: string; inventoryByBranch: Record<string, number>; [key: string]: unknown }>\r\n) {\r\n  console.warn('خ“أœأ،âˆ©â••أ… DEPRECATED: deductWarrantyStock. Use POST /api/warranties/:id/complete endpoint.');\r\n  console.error('â‰،ئ’أœآ؟ UNSAFE: This method accesses useProductStore and useStockHistoryStore without transactions.');\r\n  // Method body removed - use server endpoint\r\n}\r\n\r\n/**\r\n * @deprecated Use server endpoint: POST /api/warranties/:id/cancel with stock rollback\r\n * Hoâ”œأ،n kho khi hأںâ•—آ؛y warranty - Ngâ•‍â–‘أںâ•—أ؛c lأںâ•‘أ­i vأںâ•—آ¢i dispatchStock\r\n * \r\n * خ“أœأ،âˆ©â••أ… UNSAFE: Client-side stock rollback + stock history without transaction\r\n */\r\nexport function rollbackWarrantyStock(\r\n  ticket: WarrantyTicket,\r\n  products: Array<{ id: string; systemId: string; name: string; inventoryByBranch: Record<string, number>; [key: string]: unknown }>\r\n) {\r\n  console.warn('خ“أœأ،âˆ©â••أ… DEPRECATED: rollbackWarrantyStock. Use POST /api/warranties/:id/cancel endpoint.');\r\n  console.error('â‰،ئ’أœآ؟ UNSAFE: This method accesses useProductStore and useStockHistoryStore without transactions.');\r\n  // Method body removed - use server endpoint\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\warranty\\tracking-utils.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\warranty\\types.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\warranty\\types\\store.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\warranty\\types\\transactions.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\warranty\\types\\ui