 = pricingPolicies.filter((p) => p.type === 'Bâ”œأ­n hâ”œأ،ng' && p.isActive);\r\n\r\n  const handleChange = (field: keyof NonNullable<typeof settings>['priceMapping'], value: string) => {\r\n    updatePriceMapping.mutate({ field, policyId: value === 'none' ? null : (value as SystemId) });\r\n  };\r\n\r\n  const handleSave = () => {\r\n    // Log the mapping save\r\n    const priceMapping = settings?.priceMapping ?? {};\r\n    const _mappingSummary = PKGX_PRICE_FIELDS\r\n      .filter(pf => priceMapping[pf.key as keyof NonNullable<typeof settings>['priceMapping']])\r\n      .map(pf => {\r\n        const policyId = priceMapping[pf.key as keyof NonNullable<typeof settings>['priceMapping']];\r\n        const policy = pricingPolicies.find(p => p.systemId === policyId);\r\n        return `${pf.field} خ“أ¥أ† ${policy?.name || policyId}`;\r\n      })\r\n      .join(', ');\r\n    \r\n    addLog.mutate({\r\n      action: 'save_mapping',\r\n      status: 'success',\r\n      message: 'â”€أ‰â”œأ؛ lâ•‍â–‘u mapping bأںâ•‘أ؛ng giâ”œأ­',\r\n      details: {\r\n        total: PKGX_PRICE_FIELDS.filter(pf => priceMapping[pf.key as keyof NonNullable<typeof settings>['priceMapping']]).length,\r\n      }\r\n    });\r\n    \r\n    toast.success('â”€أ‰â”œأ؛ lâ•‍â–‘u mapping bأںâ•‘أ؛ng giâ”œأ­');\r\n  };\r\n\r\n  const getPolicyName = (policyId: SystemId | null) => {\r\n    if (!policyId) return '-- Khâ”œâ”¤ng â”œأ­p dأںâ•—أ‘ng --';\r\n    const policy = pricingPolicies.find((p) => p.systemId === policyId);\r\n    return policy?.name || policyId;\r\n  };\r\n\r\n  return (\r\n    <Card>\r\n      <CardHeader>\r\n        <CardTitle className=\"text-lg\">Mapping Bأںâ•‘أ؛ng giâ”œأ­ HRM خ“أ¥أ† PKGX</CardTitle>\r\n        <CardDescription>\r\n          Chأںâ•—أ¬n bأںâ•‘أ؛ng giâ”œأ­ trong HRM tâ•‍â–‘â•‍أ­ng أںâ•—âŒگng vأںâ•—آ¢i mأںâ•—أ¹i loأںâ•‘أ­i giâ”œأ­ trâ”œآ¬n PKGX\r\n        </CardDescription>\r\n      </CardHeader>\r\n      <CardContent className=\"space-y-6\">\r\n        {PKGX_PRICE_FIELDS.map((priceField) => (\r\n          <div key={priceField.key} className=\"grid grid-cols-1 md:grid-cols-2 gap-4 items-start\">\r\n            <div>\r\n              <Label className=\"text-base font-medium\">{priceField.label}</Label>\r\n              <p className=\"text-sm text-muted-foreground\">{priceField.description}</p>\r\n            </div>\r\n            <Select\r\n              value={(settings?.priceMapping ?? {})[priceField.key as keyof NonNullable<typeof settings>['priceMapping']] || 'none'}\r\n              onValueChange={(value) => handleChange(priceField.key as keyof NonNullable<typeof settings>['priceMapping'], value)}\r\n            >\r\n              <SelectTrigger>\r\n                <SelectValue placeholder=\"Chأںâ•—أ¬n bأںâ•‘أ؛ng giâ”œأ­...\" />\r\n              </SelectTrigger>\r\n              <SelectContent>\r\n                <SelectItem value=\"none\">-- Khâ”œâ”¤ng â”œأ­p dأںâ•—أ‘ng --</SelectItem>\r\n                {sellingPolicies.map((policy) => (\r\n                  <SelectItem key={policy.systemId} value={policy.systemId}>\r\n                    {policy.name}\r\n                  </SelectItem>\r\n                ))}\r\n              </SelectContent>\r\n            </Select>\r\n          </div>\r\n        ))}\r\n\r\n        <div className=\"pt-4 border-t\">\r\n          <h4 className=\"font-medium mb-2\">Tâ”œâ”‚m tأںâ•‘آ»t mapping hiأںâ•—أ§n tأںâ•‘أ­i:</h4>\r\n          <div className=\"bg-muted p-4 rounded-lg text-sm space-y-1\">\r\n            {PKGX_PRICE_FIELDS.map((priceField) => (\r\n              <div key={priceField.key} className=\"flex justify-between\">\r\n                <span className=\"text-muted-foreground\">{priceField.field}:</span>\r\n                <span className=\"font-medium\">\r\n                  {getPolicyName((settings?.priceMapping as any)?.[priceField.key])}\r\n                </span>\r\n              </div>\r\n            ))}\r\n          </div>\r\n        </div>\r\n\r\n        <div className=\"flex justif