nyKeyword","messageId":"unexpectedAny","endLine":268,"endColumn":36,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[8111,8114],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[8111,8114],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":7,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * Receipt (Phiأںâ•‘â”گu Thu) Import/Export Configuration\r\n * \r\n * Nhأںâ•‘آ،p/Xuأںâ•‘أ‘t phiأںâ•‘â”گu thu\r\n */\r\n\r\nimport type { Receipt, ReceiptStatus, ReceiptCategory } from '@/lib/types/prisma-extended';\r\nimport type { ImportExportConfig, FieldConfig } from '@/lib/import-export/types';\r\nimport type { Customer, Supplier, Employee, Branch, ReceiptType, PaymentMethod, TargetGroup } from '@/lib/types/prisma-extended';\r\nimport { asBusinessId, asSystemId } from '@/lib/id-types';\r\n\r\n// ============================================\r\n// HELPER FUNCTIONS (Accept data as parameters)\r\n// ============================================\r\n\r\nconst findBranch = (identifier: string, branches: Branch[]) => {\r\n  if (!identifier || !branches) return undefined;\r\n  const normalized = identifier.trim().toLowerCase();\r\n  \r\n  const byId = branches.find(b => b.id.toLowerCase() === normalized);\r\n  if (byId) return byId;\r\n  \r\n  return branches.find(b => b.name.toLowerCase().includes(normalized));\r\n};\r\n\r\nconst getDefaultBranch = (branches: Branch[]) => {\r\n  if (!branches || branches.length === 0) return undefined;\r\n  return branches.find(b => b.isDefault) || branches[0];\r\n};\r\n\r\nconst findReceiptType = (identifier: string, receiptTypes: ReceiptType[]) => {\r\n  if (!identifier || !receiptTypes) return undefined;\r\n  const normalized = identifier.trim().toLowerCase();\r\n  \r\n  return receiptTypes.find(t => \r\n    t.id.toLowerCase() === normalized || \r\n    t.name.toLowerCase().includes(normalized)\r\n  );\r\n};\r\n\r\nconst findPaymentMethod = (identifier: string, paymentMethods: PaymentMethod[]) => {\r\n  if (!identifier || !paymentMethods) return undefined;\r\n  const normalized = identifier.trim().toLowerCase();\r\n  \r\n  return paymentMethods.find(m => \r\n    m.id.toLowerCase() === normalized || \r\n    m.name.toLowerCase().includes(normalized)\r\n  );\r\n};\r\n\r\nconst getDefaultPaymentMethod = (paymentMethods: PaymentMethod[]) => {\r\n  if (!paymentMethods || paymentMethods.length === 0) return undefined;\r\n  return paymentMethods.find(m => m.isDefault) || paymentMethods[0];\r\n};\r\n\r\nconst findTargetGroup = (identifier: string, targetGroups: TargetGroup[]) => {\r\n  if (!identifier || !targetGroups) return undefined;\r\n  const normalized = identifier.trim().toLowerCase();\r\n  \r\n  return targetGroups.find(g => \r\n    g.id.toLowerCase() === normalized || \r\n    g.name.toLowerCase().includes(normalized)\r\n  );\r\n};\r\n\r\nconst findPayer = (payerType: string, payerName: string, customers: Customer[], suppliers: Supplier[], employees: Employee[]) => {\r\n  if (!payerName) return undefined;\r\n  const normalized = payerName.trim().toLowerCase();\r\n  \r\n  if ((payerType.includes('Khâ”œأ­ch hâ”œأ،ng') || payerType === 'KHACHHANG') && customers) {\r\n    return customers.find(c => \r\n      c.id.toLowerCase() === normalized || \r\n      c.name.toLowerCase().includes(normalized)\r\n    );\r\n  }\r\n  \r\n  if ((payerType.includes('Nhâ”œأ، cung cأںâ•‘أ‘p') || payerType === 'NHACUNGCAP') && suppliers) {\r\n    return suppliers.find(s => \r\n      s.id.toLowerCase() === normalized || \r\n      s.name.toLowerCase().includes(normalized)\r\n    );\r\n  }\r\n  \r\n  if ((payerType.includes('Nhâ”œأ³n viâ”œآ¬n') || payerType === 'NHANVIEN') && employees) {\r\n    return employees.find(e => \r\n      e.id.toLowerCase() === normalized || \r\n      e.fullName?.toLowerCase().includes(normalized)\r\n    );\r\n  }\r\n  \r\n  return undefined;\r\n};\r\n\r\n// ============================================\r\n// FIELD CONFIGURATION\r\n// ============================================\r\n\r\nexport const receiptFields: FieldConfig<Receipt>[] = [\r\n  {\r\n    key: 'id',\r\n    label: 'Mâ”œأ؛ phiأںâ•‘â”گu (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'PT001',\r\n    group: 'Thâ”œâ”¤ng tin phiأںâ•‘â”گu',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'date',\r\n    label: 'Ngâ”œأ،y thu (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: '2024-01-15',\r\n    group: 'Thâ”œâ”¤ng tin phiأںâ•‘â”گu',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'amount',\r\n    label: 'Sأںâ•—أ¦ tiأںâ•—أ¼n (*)',\r\n    type: 'number',\r\n    required: true,\r\n    example: '1000000',\r\n    group: 'Thâ”œâ”¤ng tin phiأںâ•‘â”گu',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'description',\r\n    label: 'Diأںâ•—أ n giأںâ•‘أ؛i (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'Thu tiأںâ•—أ¼n bâ”œأ­n hâ”œأ،ng',\r\n    group: 'Thâ”œâ”¤ng tin phiأںâ•‘â”گu',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'payerTypeName' as keyof Receipt,\r\n    label: 'Loأںâ•‘أ­i â”€أ¦أںâ•—أ¦i tâ•‍â–‘أںâ•—أ؛ng (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'Khâ”œأ­ch hâ”œأ،ng',\r\n    group: 'â”€أ‰أںâ•—أ¦i tâ•‍â–‘أںâ•—أ؛ng',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'payerName',\r\n    label: 'Ngâ•‍â–‘أںâ•—آ¥i nأںâ•—أ–p (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'Nguyأںâ•—أ n Vâ”€أ¢n A',\r\n    group: 'â”€أ‰أںâ•—أ¦i tâ•‍â–‘أںâ•—أ؛ng',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'paymentReceiptTypeName',\r\n    label: 'Loأںâ•‘أ­i phiأںâ•‘â”گu thu (*)',\r\n    type: 'string',\r\n    required: true,\r\n    example: 'Thu tiأںâ•—أ¼n khâ”œأ­ch hâ”œأ،ng',\r\n    group: 'Phâ”œأ³n loأںâ•‘أ­i',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'paymentMethodName',\r\n    label: 'Phâ•‍â–‘â•‍أ­ng thأںâ•—âŒگc TT',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Tiأںâ•—أ¼n mأںâ•‘â•–t',\r\n    group: 'Phâ”œأ³n loأںâ•‘أ­i',\r\n    defaultSelected: true,\r\n  },\r\n  {\r\n    key: 'branchName',\r\n    label: 'Chi nhâ”œأ­nh',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'Chi nhâ”œأ­nh châ”œآ،nh',\r\n    group: 'Phâ”œأ³n loأںâ•‘أ­i',\r\n  },\r\n  {\r\n    key: 'status',\r\n    label: 'Trأںâ•‘أ­ng thâ”œأ­i',\r\n    type: 'string',\r\n    required: false,\r\n    example: 'completed',\r\n    group: 'Phâ”œأ³n loأںâ•‘أ­i',\r\n  },\r\n];\r\n\r\n// ============================================\r\n// MAIN CONFIG\r\n// ============================================\r\n\r\nexport const receiptImportExportConfig: ImportExportConfig<Receipt> = {\r\n  entityType: 'receipts',\r\n  entityDisplayName: 'Phiأںâ•‘â”گu thu',\r\n  \r\n  fields: receiptFields,\r\n  \r\n  templateFileName: 'Mau_Phieu_Thu.xlsx',\r\n  sheetName: 'PhieuThu',\r\n  \r\n  // Import settings\r\n  upsertKey: 'id',\r\n  allowUpdate: false,\r\n  allowInsert: true,\r\n  \r\n  requirePreview: true,\r\n  maxRows: 2000,\r\n  maxErrorsAllowed: 0,\r\n  \r\n  // Validate each row\r\n  validateRow: (row, _index, existingData, mode) => {\r\n    const errors: Array<{ field?: string; message: string }> = [];\r\n    const receipt = row as Partial<Receipt>;\r\n    \r\n    if (!receipt.id?.toString().trim()) {\r\n      errors.push({ field: 'id', message: 'Mâ”œأ؛ phiأںâ•‘â”گu khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    if (!receipt.date) {\r\n      errors.push({ field: 'date', message: 'Ngâ”œأ،y thu khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    if (!receipt.amount || receipt.amount <= 0) {\r\n      errors.push({ field: 'amount', message: 'Sأںâ•—أ¦ tiأںâ•—أ¼n phأںâ•‘أ؛i lأںâ•—آ¢n hâ•‍أ­n 0' });\r\n    }\r\n    \r\n    if (!receipt.description?.trim()) {\r\n      errors.push({ field: 'description', message: 'Diأںâ•—أ n giأںâ•‘أ؛i khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    if (!receipt.payerTypeName) {\r\n      errors.push({ field: 'payerTypeName', message: 'Loأںâ•‘أ­i â”€أ¦أںâ•—أ¦i tâ•‍â–‘أںâ•—أ؛ng khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    if (!receipt.payerName?.trim()) {\r\n      errors.push({ field: 'payerName', message: 'Ngâ•‍â–‘أںâ•—آ¥i nأںâ•—أ–p khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    if (!receipt.paymentReceiptTypeName) {\r\n      errors.push({ field: 'paymentReceiptTypeName', message: 'Loأںâ•‘أ­i phiأںâ•‘â”گu thu khâ”œâ”¤ng â”€أ¦â•‍â–‘أںâ•—أ؛c â”€أ¦أںâ•—أ¢ trأںâ•—أ¦ng' });\r\n    }\r\n    \r\n    // Check duplicate\r\n    if (mode === 'insert-only' && receipt.id) {\r\n      const duplicate = existingData.find(r => \r\n        r.id.toString().toUpperCase() === receipt.id!.toString().toUpperCase()\r\n      );\r\n      if (duplicate) {\r\n        errors.push({ field: 'id', message: `Mâ”œأ؛ phiأںâ•‘â”گu \"${receipt.id}\" â”€أ¦â”œأ؛ tأںâ•—أ´n tأںâ•‘أ­i` });\r\n      }\r\n    }\r\n    \r\n    return errors;\r\n  },\r\n  \r\n  // Transform row to Receipt object\r\n  postTransformRow: (row) => {\r\n    const now = new Date().toISOString();\r\n    const defaultBranch = (getDefaultBranch as any)();\r\n    const defaultPaymentMethod = (getDefaultPaymentMethod as any)();\r\n    \r\n    // Lookup entities\r\n    const branch = (findBranch as any)(row.branchName as string) || defaultBranch;\r\n    const receiptType = (findReceiptType as any)(row.paymentReceiptTypeName as string);\r\n    const paymentMethod = (findPaymentMethod as any)(row.paymentMethodName as string) || defaultPaymentMethod;\r\n    const targetGroup = (findTargetGroup as any)(row.payerTypeName as string);\r\n    const payer = (findPayer as any)(row.payerTypeName as string || '', row.payerName as string || '');\r\n    \r\n    return {\r\n      systemId: asSystemId(''), // Will be generated\r\n      id: asBusinessId(String(row.id || '').trim()),\r\n      date: String(row.date || now.split('T')[0]),\r\n      amount: Number(row.amount) || 0,\r\n      \r\n      payerTypeSystemId: targetGroup?.systemId || asSystemId('KHAC'),\r\n      payerTypeName: targetGroup?.name || String(row.payerTypeName || 'Khâ”œأ­c'),\r\n      payerName: String(row.payerName || '').trim(),\r\n      payerSystemId: payer?.systemId,\r\n      \r\n      description: String(row.description || '').trim(),\r\n      \r\n      paymentMethodSystemId: paymentMethod?.systemId || asSystemId(''),\r\n      paymentMethodName: paymentMethod?.name || String(row.paymentMethodName || 'Tiأںâ•—أ¼n mأںâ•‘â•–t'),\r\n      \r\n      accountSystemId: asSystemId(''), // Cash account to be set later\r\n      paymentReceiptTypeSystemId: receiptType?.systemId || asSystemId(''),\r\n      paymentReceiptTypeName: receiptType?.name || String(row.paymentReceiptTypeName || ''),\r\n      \r\n      branchSystemId: branch?.systemId || asSystemId(''),\r\n      branchName: branch?.name || '',\r\n      \r\n      createdBy: asSystemId(''),\r\n      createdAt: now,\r\n      \r\n      status: (row.status as ReceiptStatus) || 'completed',\r\n      category: (row.category as ReceiptCategory) || 'other',\r\n    } as Receipt;\r\n  },\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\lib\\import-export\\configs\\reconciliation.config.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\lib\\import-export\\configs\\sales-return.config.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\lib\\import-export\\configs\\sh