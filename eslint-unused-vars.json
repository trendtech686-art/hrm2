phone(props: React.HTMLAttributes<HTMLDivElement>) { return <div {...props}>â‰،ئ’أ´أ؛</div>; }\r\nfunction DollarSign(props: React.HTMLAttributes<HTMLDivElement>) { return <div {...props}>â‰،ئ’أ†â–‘</div>; }\r\nfunction Headphones(props: React.HTMLAttributes<HTMLDivElement>) { return <div {...props}>â‰،ئ’أ„آ؛</div>; }\r\nfunction Settings(props: React.HTMLAttributes<HTMLDivElement>) { return <div {...props}>خ“أœأ–âˆ©â••أ…</div>; }\r\nfunction Wallet(props: React.HTMLAttributes<HTMLDivElement>) { return <div {...props}>â‰،ئ’أ†â•‌</div>; }\r\nfunction FileText(props: React.HTMLAttributes<HTMLDivElement>) { return <div {...props}>â‰،ئ’أ´أ¤</div>; }\r\n\r\nexport function TaskTemplatesPage() {\r\n  const router = useRouter();\r\n  const { data: templates, getMostUsed, search } = useAllTaskTemplates();\r\n  const { incrementUsage } = useTaskTemplateMutations();\r\n  const { data: employees } = useAllEmployees();\r\n  const { data: tasksData } = useTasks({ limit: 1000 });\r\n  const tasks = tasksData?.data ?? [];\r\n  const { create: createTaskMutation } = useTaskMutations({\r\n    onSuccess: () => {\r\n      toast.success('â”€أ‰â”œأ؛ tأںâ•‘أ­o câ”œâ”¤ng viأںâ•—أ§c tأںâ•—آ½ mأںâ•‘آ½u');\r\n      router.push('/tasks');\r\n    },\r\n    onError: (error) => {\r\n      toast.error('Lأںâ•—أ¹i', { description: error.message });\r\n    }\r\n  });\r\n\r\n  const [searchQuery, setSearchQuery] = React.useState('');\r\n  const [categoryFilter, setCategoryFilter] = React.useState<string>('all');\r\n  const [showUseDialog, setShowUseDialog] = React.useState(false);\r\n  const [selectedTemplate, setSelectedTemplate] = React.useState<TaskTemplate | null>(null);\r\n  \r\n  // Use template form state\r\n  const [useFormData, setUseFormData] = React.useState({\r\n    title: '',\r\n    dueDate: '',\r\n    assignees: [] as TaskAssignee[],\r\n  });\r\n\r\n  usePageHeader({\r\n    actions: [\r\n      <Button key=\"create\" onClick={() => router.push('/tasks/templates/new')}>\r\n        <Plus className=\"mr-2 h-4 w-4\" />\r\n        Tأںâ•‘أ­o mأںâ•‘آ½u mأںâ•—آ¢i\r\n      </Button>\r\n    ],\r\n  });\r\n\r\n  // Filter templates\r\n  const filteredTemplates = React.useMemo(() => {\r\n    let result = templates;\r\n\r\n    if (categoryFilter !== 'all') {\r\n      result = result.filter(t => t.category === categoryFilter);\r\n    }\r\n\r\n    if (searchQuery.trim()) {\r\n      result = search(searchQuery);\r\n    }\r\n\r\n    return result.filter(t => t.isActive);\r\n  }, [templates, searchQuery, categoryFilter, search]);\r\n\r\n  // Group by category\r\n  const groupedTemplates = React.useMemo(() => {\r\n    const groups: Record<string, TaskTemplate[]> = {};\r\n    filteredTemplates.forEach(template => {\r\n      if (!groups[template.category]) {\r\n        groups[template.category] = [];\r\n      }\r\n      groups[template.category].push(template);\r\n    });\r\n    return groups;\r\n  }, [filteredTemplates]);\r\n\r\n  const handleUseTemplate = (template: TaskTemplate) => {\r\n    setSelectedTemplate(template);\r\n    setUseFormData({\r\n      title: '',\r\n      dueDate: '',\r\n      assignees: [],\r\n    });\r\n    setShowUseDialog(true);\r\n  };\r\n\r\n  const handleSubmitUseTemplate = () => {\r\n    if (!selectedTemplate) return;\r\n\r\n    if (!useFormData.title.trim()) {\r\n      toast.error('Vui lâ”œâ–“ng nhأںâ•‘آ،p tiâ”œآ¬u â”€أ¦أںâ•—أ¼ câ”œâ”¤ng viأںâ•—أ§c');\r\n      return;\r\n    }\r\n    if (!useFormData.dueDate) {\r\n      toast.error('Vui lâ”œâ–“ng chأںâ•—أ¬n deadline');\r\n      return;\r\n    }\r\n    if (useFormData.assignees.length === 0) {\r\n      toast.error('Vui lâ”œâ–“ng chأںâ•—أ¬n ngâ•‍â–‘أںâ•—آ¥i thأںâ•—â–’c hiأںâ•—أ§n');\r\n      return;\r\n    }\r\n\r\n    try {\r\n      // Build description with checklist\r\n      let description = selectedTemplate.description;\r\n      if (selectedTemplate.checklistItems && selectedTemplate.checklistItems.length > 0) {\r\n        description += '\\n\\n**Checklist:**\\n';\r\n        selectedTemplate.checklistItems.forEach(item => {\r\n          description += `- [ ] ${item}\\n`;\r\n        });\r\n      }\r\n\r\n      // Convert template subtasks to task subtasks\r\n      const subtasks = selectedTemplate.subtasks.map((st, idx) => ({\r\n        id: `subtask-${Date.now()}-${idx}`,\r\n        title: st.title,\r\n        completed: false,\r\n      }));\r\n\r\n      // Get owner for backward compatibility\r\n      const owner = useFormData.assignees.find(a => a.role === 'owner') || useFormData.assignees[0];\r\n\r\n      // Create task object\r\n      const newTask = {\r\n        title: useFormData.title,\r\n        description,\r\n        assignees: useFormData.assignees,\r\n        assigneeId: owner?.employeeSystemId,\r\n        assigneeName: owner?.employeeName || '',\r\n        priority: selectedTemplate.priority,\r\n        status: 'Châ•‍â–‘a bأںâ•‘آ»t â”€أ¦أںâ•‘آ؛u' as const,\r\n        startDate: new Date().toISOString().split('T')[0],\r\n        dueDate: useFormData.dueDate,\r\n        estimatedHours: selectedTemplate.estimatedHours,\r\n        progress: 0,\r\n        subtasks,\r\n        activities: [],\r\n      };\r\n\r\n      createTaskMutation.mutate(newTask);\r\n      incrementUsage.mutate(selectedTemplate.systemId);\r\n\r\n      setShowUseDialog(false);\r\n    } catch (_error) {\r\n      toast.error('Khâ”œâ”¤ng thأںâ•—أ¢ tأںâ•‘أ­o câ”œâ”¤ng viأںâ•—أ§c tأںâ•—آ½ mأںâ•‘آ½u');\r\n    }\r\n  };\r\n\r\n  const mostUsedTemplates = getMostUsed(3);\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      {/* Header Stats */}\r\n      <div className=\"grid gap-4 md:grid-cols-4\">\r\n        <Card>\r\n          <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n            <CardTitle className=\"text-sm font-medium\">Tأںâ•—أ²ng mأںâ•‘آ½u</CardTitle>\r\n            <FileText className=\"h-4 w-4 text-muted-foreground\" />\r\n          </CardHeader>\r\n          <CardContent>\r\n            <div className=\"text-2xl font-bold\">{templates.filter(t => t.isActive).length}</div>\r\n          </CardContent>\r\n        </Card>\r\n\r\n        <Card>\r\n          <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n            <CardTitle className=\"text-sm font-medium\">Danh mأںâ•—أ‘c</CardTitle>\r\n            <ListChecks className=\"h-4 w-4 text-muted-foreground\" />\r\n          </CardHeader>\r\n          <CardContent>\r\n            <div className=\"text-2xl font-bold\">\r\n              {new Set(templates.filter(t => t.isActive).map(t => t.category)).size}\r\n            </div>\r\n          </CardContent>\r\n        </Card>\r\n\r\n        <Card>\r\n          <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n            <CardTitle className=\"text-sm font-medium\">Dâ”œâ•£ng nhiأںâ•—أ¼u nhأںâ•‘أ‘t</CardTitle>\r\n            <Rocket className=\"h-4 w-4 text-muted-foreground\" />\r\n          </CardHeader>\r\n          <CardContent>\r\n            <div className=\"text-2xl font-bold\">{mostUsedTemplates[0]?.usageCount || 0}</div>\r\n            <p className=\"text-xs text-muted-foreground mt-1\">\r\n              {mostUsedTemplates[0]?.name || 'Châ•‍â–‘a câ”œâ”‚'}\r\n            </p>\r\n          </CardContent>\r\n        </Card>\r\n\r\n        <Card>\r\n          <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n            <CardTitle className=\"text-sm font-medium\">Tأںâ•—أ²ng lâ•‍â–‘أںâ•—أ؛t dâ”œâ•£ng</CardTitle>\r\n            <CheckCircle2 className=\"h-4 w-4 text-muted-foreground\" />\r\n          </CardHeader>\r\n          <CardContent>\r\n            <div className=\"text-2xl font-bold\">\r\n              {templates.reduce((sum, t) => sum + t.usageCount, 0)}\r\n            </div>\r\n          </CardContent>\r\n        </Card>\r\n      </div>\r\n\r\n      {/* Filters */}\r\n      <Card>\r\n        <CardContent className=\"pt-6\">\r\n          <div className=\"flex fl