ssage || 'Câ”œâ”‚ lأںâ•—أ¹i xأںâ•‘أ؛y ra'),\r\n  });\r\n  \r\n  const [isAlertOpen, setIsAlertOpen] = React.useState(false)\r\n  const [idToDelete, setIdToDelete] = React.useState<SystemId | null>(null)\r\n  const [isFormOpen, setIsFormOpen] = React.useState(false)\r\n  const [editingDepartment, setEditingDepartment] = React.useState<Department | null>(null)\r\n  \r\n  const [globalFilter, setGlobalFilter] = React.useState('');\r\n\r\n  const handleDelete = React.useCallback((systemId: SystemId) => {\r\n    setIdToDelete(systemId)\r\n    setIsAlertOpen(true)\r\n  }, [])\r\n\r\n  const handleEdit = React.useCallback((department: Department) => {\r\n    setEditingDepartment(department)\r\n    setIsFormOpen(true)\r\n  }, [])\r\n\r\n  const columns: ColumnDef<Department>[] = React.useMemo(() => ([\r\n    {\r\n      id: \"id\",\r\n      accessorKey: \"id\",\r\n      header: \"Mâ”œأ؛\",\r\n      cell: ({ row }) => <span>{row.id}</span>,\r\n      meta: { displayName: \"Mâ”œأ؛ phâ”œâ–“ng ban\" },\r\n    },\r\n    {\r\n      id: \"name\",\r\n      accessorKey: \"name\",\r\n      header: \"Tâ”œآ¬n phâ”œâ–“ng ban\",\r\n      cell: ({ row }) => <span>{row.name}</span>,\r\n      meta: { displayName: \"Tâ”œآ¬n phâ”œâ–“ng ban\" },\r\n    },\r\n    {\r\n      id: \"description\",\r\n      accessorKey: \"description\",\r\n      header: \"Mâ”œâ”¤ tأںâ•‘أ؛\",\r\n      cell: ({ row }) => <span className=\"text-muted-foreground\">{(row as any).description || '-'}</span>,\r\n      meta: { displayName: \"Mâ”œâ”¤ tأںâ•‘أ؛\" },\r\n    },\r\n    {\r\n      id: \"actions\",\r\n      header: () => <div className=\"text-center\">Sأںâ•—آ،a</div>,\r\n      cell: ({ row }) => (\r\n        <div className=\"flex items-center justify-center\">\r\n          <DropdownMenu>\r\n            <DropdownMenuTrigger asChild>\r\n              <Button variant=\"ghost\" className=\"h-8 w-8 p-0\">\r\n                <span className=\"sr-only\">Mأںâ•—ئ’ menu</span>\r\n                <MoreHorizontal className=\"h-4