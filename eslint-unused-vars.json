kgxSlug',\r\n    label: 'Slug PKGX',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'E-commerce PKGX',\r\n    example: 'ao-so-mi-nam-trang-oxford',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      // Convert to URL-friendly slug\r\n      return String(value).trim()\r\n        .toLowerCase()\r\n        .normalize('NFD')\r\n        .replace(/[\\u0300-\\u036f]/g, '') // Remove diacritics\r\n        .replace(/â”€أ¦/g, 'd')\r\n        .replace(/[^a-z0-9]+/g, '-')\r\n        .replace(/^-+|-+$/g, '');\r\n    },\r\n  },\r\n  // Slug riâ”œآ¬ng cho Trendtech website\r\n  {\r\n    key: 'trendtechSlug',\r\n    label: 'Slug Trendtech',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'E-commerce Trendtech',\r\n    example: 'ao-so-mi-nam-trang-oxford',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      // Convert to URL-friendly slug\r\n      return String(value).trim()\r\n        .toLowerCase()\r\n        .normalize('NFD')\r\n        .replace(/[\\u0300-\\u036f]/g, '') // Remove diacritics\r\n        .replace(/â”€أ¦/g, 'd')\r\n        .replace(/[^a-z0-9]+/g, '-')\r\n        .replace(/^-+|-+$/g, '');\r\n    },\r\n  },\r\n  {\r\n    key: 'isPublished',\r\n    label: 'â”€أ‰â”€أ¢ng web',\r\n    required: false,\r\n    type: 'boolean',\r\n    exportGroup: 'E-commerce',\r\n    example: 'Câ”œâ”‚',\r\n    defaultValue: false,\r\n    importTransform: (value: unknown) => {\r\n      if (value === undefined || value === null || value === '') return false;\r\n      const str = String(value).toLowerCase().trim();\r\n      return str === 'câ”œâ”‚' || str === 'yes' || str === '1' || str === 'true' || str === 'x';\r\n    },\r\n    exportTransform: (value: unknown) => (value ? 'Câ”œâ”‚' : 'Khâ”œâ”¤ng'),\r\n  },\r\n  {\r\n    key: 'isFeatured',\r\n    label: 'Nأںâ•—أ²i bأںâ•‘آ،t',\r\n    required: false,\r\n    type: 'boolean',\r\n    exportGroup: 'E-commerce',\r\n    example: 'Câ”œâ”‚',\r\n    defaultValue: false,\r\n    importTransform: (value: unknown) => {\r\n      if (value === undefined || value === null || value === '') return false;\r\n      const str = String(value).toLowerCase().trim();\r\n      return str === 'câ”œâ”‚' || str === 'yes' || str === '1' || str === 'true' || str === 'x';\r\n    },\r\n    exportTransform: (value: unknown) => (value ? 'Câ”œâ”‚' : 'Khâ”œâ”¤ng'),\r\n  },\r\n  {\r\n    key: 'isNewArrival',\r\n    label: 'Mأںâ•—آ¢i vأںâ•—أ¼',\r\n    required: false,\r\n    type: 'boolean',\r\n    exportGroup: 'E-commerce',\r\n    example: 'Câ”œâ”‚',\r\n    defaultValue: false,\r\n    importTransform: (value: unknown) => {\r\n      if (value === undefined || value === null || value === '') return false;\r\n      const str = String(value).toLowerCase().trim();\r\n      return str === 'câ”œâ”‚' || str === 'yes' || str === '1' || str === 'true' || str === 'x';\r\n    },\r\n    exportTransform: (value: unknown) => (value ? 'Câ”œâ”‚' : 'Khâ”œâ”¤ng'),\r\n  },\r\n  {\r\n    key: 'isBestSeller',\r\n    label: 'Bâ”œأ­n chأںâ•‘أ­y',\r\n    required: false,\r\n    type: 'boolean',\r\n    exportGroup: 'E-commerce',\r\n    example: 'Câ”œâ”‚',\r\n    defaultValue: false,\r\n    importTransform: (value: unknown) => {\r\n      if (value === undefined || value === null || value === '') return false;\r\n      const str = String(value).toLowerCase().trim();\r\n      return str === 'câ”œâ”‚' || str === 'yes' || str === '1' || str === 'true' || str === 'x';\r\n    },\r\n    exportTransform: (value: unknown) => (value ? 'Câ”œâ”‚' : 'Khâ”œâ”¤ng'),\r\n  },\r\n  {\r\n    key: 'isOnSale',\r\n    label: 'â”€أ‰ang giأںâ•‘أ؛m giâ”œأ­',\r\n    required: false,\r\n    type: 'boolean',\r\n    exportGroup: 'E-commerce',\r\n    example: 'Câ”œâ”‚',\r\n    defaultValue: false,\r\n    importTransform: (value: unknown) => {\r\n      if (value === undefined || value === null || value === '') return false;\r\n      const str = String(value).toLowerCase().trim();\r\n      return str === 'câ”œâ”‚' || str === 'yes' || str === '1' || str === 'true' || str === 'x';\r\n    },\r\n    exportTransform: (value: unknown) => (value ? 'Câ”œâ”‚' : 'Khâ”œâ”¤ng'),\r\n  },\r\n  {\r\n    key: 'sortOrder',\r\n    label: 'Thأںâ•—âŒگ tأںâ•—â–’ hiأںâ•—أ¢n thأںâ•—أ¯',\r\n    required: false,\r\n    type: 'number',\r\n    exportGroup: 'E-commerce',\r\n    example: '1',\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const num = Number(String(value).replace(/[,.\\s]/g, ''));\r\n      return isNaN(num) ? undefined : num;\r\n    },\r\n  },\r\n  {\r\n    key: 'publishedAt',\r\n    label: 'Ngâ”œأ،y â”€أ¦â”€أ¢ng web',\r\n    required: false,\r\n    type: 'date',\r\n    exportGroup: 'E-commerce',\r\n    example: '2024-01-15',\r\n  },\r\n\r\n  // ===== PHâ”œأ©N Tâ”œأ¬CH Bâ”œأ¼N Hâ”œأ‡NG =====\r\n  {\r\n    key: 'totalSold',\r\n    label: 'Tأںâ•—أ²ng â”€أ¦â”œأ؛ bâ”œأ­n',\r\n    required: false,\r\n    type: 'number',\r\n    exportGroup: 'Phâ”œأ³n tâ”œآ،ch',\r\n    hidden: true, // Chأںâ•—أ« export, khâ”œâ”¤ng import\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const num = Number(String(value).replace(/[,.\\s]/g, ''));\r\n      return isNaN(num) ? undefined : num;\r\n    },\r\n  },\r\n  {\r\n    key: 'totalRevenue',\r\n    label: 'Tأںâ•—أ²ng doanh thu',\r\n    required: false,\r\n    type: 'number',\r\n    exportGroup: 'Phâ”œأ³n tâ”œآ،ch',\r\n    hidden: true, // Chأںâ•—أ« export, khâ”œâ”¤ng import\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const num = Number(String(value).replace(/[,.\\s]/g, ''));\r\n      return isNaN(num) ? undefined : num;\r\n    },\r\n  },\r\n  {\r\n    key: 'lastSoldDate',\r\n    label: 'Ngâ”œأ،y bâ”œأ­n gأںâ•‘آ؛n nhأںâ•‘أ‘t',\r\n    required: false,\r\n    type: 'date',\r\n    exportGroup: 'Phâ”œأ³n tâ”œآ،ch',\r\n    hidden: true,\r\n  },\r\n  {\r\n    key: 'viewCount',\r\n    label: 'Lâ•‍â–‘أںâ•—أ؛t xem',\r\n    required: false,\r\n    type: 'number',\r\n    exportGroup: 'Phâ”œأ³n tâ”œآ،ch',\r\n    hidden: true,\r\n    importTransform: (value: unknown) => {\r\n      if (!value) return undefined;\r\n      const num = Number(String(value).replace(/[,.\\s]/g, ''));\r\n      return isNaN(num) ? undefined : num;\r\n    },\r\n  },\r\n\r\n  // ===== Vâ”œأ†NG â”€أ‰أںâ•—آ£I Sأںâ•‘أ³N PHأںâ•‘آ؟M =====\r\n  {\r\n    key: 'launchedDate',\r\n    label: 'Ngâ”œأ،y ra mأںâ•‘آ»t',\r\n    required: false,\r\n    type: 'date',\r\n    exportGroup: 'Vâ”œâ–“ng â”€أ¦أںâ•—آ¥i',\r\n    example: '2024-01-15',\r\n  },\r\n  {\r\n    key: 'lastPurchaseDate',\r\n    label: 'Ngâ”œأ،y nhأںâ•‘آ،p gأںâ•‘آ؛n nhأںâ•‘أ‘t',\r\n    required: false,\r\n    type: 'date',\r\n    exportGroup: 'Vâ”œâ–“ng â”€أ¦أںâ•—آ¥i',\r\n    hidden: true,\r\n  },\r\n  {\r\n    key: 'discontinuedDate',\r\n    label: 'Ngâ”œأ،y ngأںâ•—آ½ng kinh doanh',\r\n    required: false,\r\n    type: 'date',\r\n    exportGroup: 'Vâ”œâ–“ng â”€أ¦أںâ•—آ¥i',\r\n    example: '2025-12-31',\r\n  },\r\n\r\n  // ===== Hأںâ•—أ¥ THأںâ•—أ‰NG (hidden) =====\r\n  {\r\n    key: 'systemId',\r\n    label: 'System ID',\r\n    required: false,\r\n    type: 'string',\r\n    exportGroup: 'Hأںâ•—أ§ thأںâ•—أ¦ng',\r\n    hidden: true,\r\n  },\r\n  {\r\n    key: 'createdAt',\r\n    label: 'Ngâ”œأ،y tأںâ•‘أ­o',\r\n    required: false,\r\n    type: 'date',\r\n    exportGroup: 'Hأںâ•—أ§ thأںâ•—أ¦ng',\r\n    hidden: true,\r\n  },\r\n  {\r\n    key: 'updatedAt',\r\n    label: 'Ngâ”œأ،y cأںâ•‘آ،p nhأںâ•‘آ،t',\r\n    required: false,\r\n    type: 'date',\r\n    exportGroup: 'Hأںâ•—أ§ thأںâ•—أ¦ng',\r\n    hidden: true,\r\n  },\r\n];\r\n\r\n// ===== MAIN CONFIG =====\r\nexport const productImportExportConfig: ImportExportConfig<Product> = {\r\n  entityType: 'products',\r\n  entityDisplayName: 'Sأںâ•‘أ؛n phأںâ•‘âŒگm',\r\n  fields: productFields,\r\n  upsertKey: 'id', // Dâ”œâ•£ng mâ”œأ؛ sأںâ•‘أ؛n phأںâ•‘âŒگm â”€أ¦أںâ•—أ¢ â”€أ¦أںâ•—أ¦i chiأںâ•‘â”گu khi UPDATE\r\n  templateFileName: 'mau-import-san-pham.xlsx',\r\n  requireBranch: true, // Bأںâ•‘آ»t buأںâ•—أ–c chi nhâ”œأ­nh â”€أ¦أںâ•—أ¢ xأںâ•—آ، lâ”œâ•œ tأںâ•—أ´n kho ban â”€أ¦أںâ•‘آ؛u\r\n  \r\n  // Pre-transform raw row (normalize column names + detect pricing columns)\r\n  preTransformRawRow: (rawRow: Record<string, unknown>) => {\r\n    const normalized: Record<string, unknown> = {};\r\n    const prices: Record<string, number> = {};\r\n    \r\n    // Map tأںâ•—آ½ label tiأںâ•‘â”گng Viأںâ•—أ§t sang key\r\n    const labelToKey: Record<string, string> = {};\r\n    productFields.forEach(field => {\r\n      labelToKey[field.label.toLowerCase()] = field.key as string;\r\n      // Also map without (*) marker\r\n      const labelWithoutStar = field.label.replace(/\\s*\\(\\*\\)\\s*$/, '').toLowerCase();\r\n      labelToKey[labelWithoutStar] = field.key as string;\r\n    });\r\n    \r\n    Object.entries(rawRow).forEach(([key, value]) => {\r\n      // Normalize Excel header: strip (*) marker and lowercase\r\n      const normalizedExcelHeader = key.replace(/\\s*\\(\\*\\)\\s*$/, '').toLowerCase();\r\n      \r\n      // Check if this column is a pricing policy code (e.g., PL_10, BANLE, VIP)\r\n      const policySystemId = getPricingPolicySystemId(key);\r\n      if (policySystemId && value !== undefined && value !== null && value !== '') {\r\n        // This is a pricing column - parse price value\r\n        const priceValue = Number(String(value).replace(/[,.\\s]/g, ''));\r\n        if (!isNaN(priceValue) && priceValue > 0) {\r\n          prices[policySystemId] = priceValue;\r\n        }\r\n      } else {\r\n        // Normal field - map to key\r\n        const normalizedKey = labelToKey[normalizedExcelHeader] || labelToKey[key.toLowerCase()] || key;\r\n        normalized[normalizedKey] = value;\r\n      }\r\n    });\r\n    \r\n    // Add prices if any pricing columns were found\r\n    if (Object.keys(prices).length > 0) {\r\n      normalized.prices = prices;\r\n    }\r\n    \r\n    return normalized;\r\n  },\r\n  \r\n  // Post-transform row (set defaults, enrich data)\r\n  // NOTE: branchSystemId â”€أ¦â•‍â–‘أںâ•—أ؛c truyأںâ•—أ¼n tأںâ•—آ½ import dialog â”€أ¦أںâ•—أ¢ xأںâ•—آ، lâ”œâ•œ tأںâ•—أ´n kho ban â”€أ¦أںâ•‘آ؛u\r\n  postTransformRow: (row: Partial<Product & { initialStock?: number }>, _index?: number, branchSystemId?: string) => {\r\n    // Xأںâ•—آ، lâ”œâ•œ tأںâ•—أ´n kho ban â”€أ¦أںâ•‘آ؛u - chأںâ•—أ« â”œأ­p dأںâ•—أ‘ng khi câ”œâ”‚ initialStock vâ”œأ، branchSystemId\r\n    let inventoryByBranch = row.inventoryByBranch || {};\r\n    const initialStock = (row as { initialStock?: number }).initialStock;\r\n    \r\n    if (initialStock !== undefined && initialStock > 0 && branchSystemId) {\r\n      inventoryByBranch = {\r\n        ...inventoryByBranch,\r\n        [branchSystemId]: initialStock,\r\n      };\r\n    }\r\n    \r\n    // Remove initialStock from final data (khâ”œâ”¤ng lâ•‍â–‘u vâ”œأ،o Product)\r\n    const { initialStock: _removed, ...cleanRow } = row as Partial<Product> & { initialStock?: number };\r\n    \r\n    // TODO: Auto-set productTypeSystemId - requires async support\r\n    // For now, these fields should be handled in beforeImport hook if needed\r\n    // Auto-set productTypeSystemId nأںâ•‘â”گu châ•‍â–‘a câ”œâ”‚\r\n    // â•‍آ»u tiâ”œآ¬n: productTypeSystemId > type enum mapping > default\r\n    const productTypeSystemIdStr = cleanRow.productTypeSystemId as string | undefined;\r\n    // Note: The async helpers cannot be called here. This logic should be moved\r\n    // to beforeImport hook if productTypeSystemId transformation is needed.\r\n    // if (!productTypeSystemIdStr && cleanRow.type) {\r\n    //   productTypeSystemIdStr = await getProductTypeSystemIdByEnumType(cleanRow.type) || undefined;\r\n    // }\r\n    // if (!productTypeSystemIdStr) {\r\n    //   productTypeSystemIdStr = await getDefaultProductTypeSystemId() || undefined;\r\n    // }\r\n    \r\n    // Cast to SystemId if we have a value\r\n    const productTypeSystemId = productTypeSystemIdStr ? asSystemId(productTypeSystemIdStr) : undefined;\r\n    \r\n    return {\r\n      ...cleanRow,\r\n      type: cleanRow.type || 'physical',\r\n      productTypeSystemId, // Luâ”œâ”¤n set productTypeSystemId\r\n      status: cleanRow.status || 'active',\r\n      unit: cleanRow.unit || 'Câ”œأ­i',\r\n      costPrice: cleanRow.costPrice ?? 0,\r\n      sellingPrice: cleanRow.sellingPrice ?? 0,\r\n      isStockTracked: cleanRow.isStockTracked ?? true,\r\n      prices: cleanRow.prices || {},\r\n      inventoryByBranch,\r\n      committedByBranch: cleanRow.committedByBranch || {},\r\n      inTransitByBranch: cleanRow.inTransitByBranch || {},\r\n    };\r\n  },\r\n  \r\n  // Validate row level (check duplicate SKU/barcode + warnings)\r\n  validateRow: (row, _index, existingData, mode) => {\r\n    const errors: Array<{ field?: string; message: string; type?: 'error' | 'warning' }> = [];\r\n    const rowWithInitialStock = row as Partial<Product> & { initialStock?: number };\r\n    \r\n    // Check unique SKU - only in insert-only mode\r\n    if (row.sku && mode === 'insert-only') {\r\n      const duplicate = existingData.find(\r\n        p => p.sku === row.sku && p.id !== row.id\r\n      );\r\n      if (duplicate) {\r\n        errors.push({\r\n          field: 'sku',\r\n          message: `SKU â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c sأںâ•—آ، dأںâ•—أ‘ng bأںâ•—ئ’i ${duplicate.name} (${duplicate.id})`,\r\n        });\r\n      }\r\n    }\r\n    \r\n    // Check unique barcode - only in insert-only mode\r\n    if (row.barcode && mode === 'insert-only') {\r\n      const duplicate = existingData.find(\r\n        p => p.barcode === row.barcode && p.id !== row.id\r\n      );\r\n      if (duplicate) {\r\n        errors.push({\r\n          field: 'barcode',\r\n          message: `Mâ”œأ؛ vأںâ•‘أ­ch â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c sأںâ•—آ، dأںâ•—أ‘ng bأںâ•—ئ’i ${duplicate.name} (${duplicate.id})`,\r\n        });\r\n      }\r\n    }\r\n    \r\n    // Cأںâ•‘أ؛nh bâ”œأ­o: initialStock chأںâ•—أ« câ”œâ”‚ tâ”œأ­c dأںâ•—أ‘ng khi tأںâ•‘أ­o mأںâ•—آ¢i\r\n    if (rowWithInitialStock.initialStock !== undefined && rowWithInitialStock.initialStock > 0) {\r\n      if (mode === 'update-only') {\r\n        errors.push({\r\n          field: 'initialStock',\r\n          message: 'Tأںâ•—أ´n kho ban â”€أ¦أںâ•‘آ؛u sأںâ•‘â•œ bأںâ•—أ¯ Bأںâ•—أ„ QUA vâ”œآ¼ â”€أ¦ang أںâ•—ئ’ chأںâ•‘â”گ â”€أ¦أںâ•—أ– Cأںâ•‘آ،p nhأںâ•‘آ،t',\r\n          type: 'warning',\r\n        });\r\n      } else if (mode === 'upsert') {\r\n        // Check if product exists\r\n        const exists = existingData.find(p => p.id === row.id);\r\n        if (exists) {\r\n          errors.push({\r\n            field: 'initialStock',\r\n            message: `SP â”€أ¦â”œأ؛ tأںâ•—أ´n tأںâ•‘أ­i - tأںâ•—أ´n kho ban â”€أ¦أںâ•‘آ؛u sأںâ•‘â•œ Bأںâ•—أ„ QUA (giأںâ•—آ» nguyâ”œآ¬n tأںâ•—أ´n kho hiأںâ•—أ§n tأںâ•‘أ­i)`,\r\n            type: 'warning',\r\n          });\r\n        }\r\n      }\r\n    }\r\n    \r\n    // Cأںâ•‘أ؛nh bâ”œأ­o giâ”œأ­ bâ”œأ­n < giâ”œأ­ vأںâ•—أ¦n\r\n    if (row.costPrice && row.sellingPrice && row.costPrice > row.sellingPrice) {\r\n      errors.push({\r\n        field: 'sellingPrice',\r\n        message: `Giâ”œأ­ bâ”œأ­n (${row.sellingPrice?.toLocaleString()}) thأںâ•‘أ‘p hâ•‍أ­n giâ”œأ­ vأںâ•—أ¦n (${row.costPrice?.toLocaleString()})`,\r\n        type: 'warning',\r\n      });\r\n    }\r\n    \r\n    return errors;\r\n  },\r\n};\r\n\r\n// Re-export cho backward compatibility\r\nexport default productImportExportConfig;\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\lib\\import-export\\configs\\purchase-order.config.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\lib\\import-export\\configs\\purchase-return.config.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixa