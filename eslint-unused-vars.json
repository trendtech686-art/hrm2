ount)\r\n                                                                        : component.formula || 'Theo câ”œâ”¤ng thأںâ•—âŒگc'}\r\n                                                                </p>\r\n                                                            </div>\r\n                                                            <Badge variant=\"secondary\" className=\"text-xs\">\r\n                                                                â”€أ‰â”œâ”‚ng gâ”œâ”‚p\r\n                                                            </Badge>\r\n                                                        </div>\r\n                                                    ))}\r\n                                                </div>\r\n                                            )}\r\n                                        </CardContent>\r\n                                    </Card>\r\n\r\n                                    <Card>\r\n                                        <CardHeader className=\"space-y-1\">\r\n                                            <CardTitle className=\"text-h6\">Thâ”œâ”¤ng tin trأںâ•‘أ؛ lâ•‍â–‘â•‍أ­ng</CardTitle>\r\n                                            <div className=\"flex items-center gap-2 text-sm text-muted-foreground\">\r\n                                                <Lock className=\"h-4 w-4\" />\r\n                                                <span>Hâ”œآ¼nh thأںâ•—âŒگc: {payrollProfile?.paymentMethod === 'cash' ? 'Tiأںâ•—أ¼n mأںâ•‘â•–t' : 'Chuyأںâ•—أ¢n khoأںâ•‘أ؛n'}</span>\r\n                                            </div>\r\n                                        </CardHeader>\r\n                                        <CardContent className=\"space-y-2 text-sm\">\r\n                                            {payrollProfile?.paymentMethod === 'cash' ? (\r\n                                                <p className=\"text-muted-foreground\">Trأںâ•‘أ؛ lâ•‍â–‘â•‍أ­ng trأںâ•—â–’c tiأںâ•‘â”گp, khâ”œâ”¤ng cأںâ•‘آ؛n tâ”œأ،i khoأںâ•‘أ؛n ngâ”œأ³n hâ”œأ،ng.</p>\r\n                                            ) : (\r\n                                                <>\r\n                                                    <InfoItem label=\"Sأںâ•—أ¦ tâ”œأ،i khoأںâ•‘أ؛n\" value={payrollProfile?.payrollBankAccount?.accountNumber || employee.bankAccountNumber || 'خ“أ‡أ¶'} />\r\n                                                    <InfoItem label=\"Ngâ”œأ³n hâ”œأ،ng\" value={payrollProfile?.payrollBankAccount?.bankName || employee.bankName || 'خ“أ‡أ¶'} />\r\n                                                    <InfoItem label=\"Chi nhâ”œأ­nh\" value={payrollProfile?.payrollBankAccount?.bankBranch || employee.bankBranch || 'خ“أ‡أ¶'} />\r\n                                                </>\r\n                                            )}\r\n                                            {payrollShift ? (\r\n                                                <InfoItem\r\n                                                    label=\"Ca mأںâ•‘â•–c â”€أ¦أںâ•—أ¯nh\"\r\n                                                    value={`${payrollShift.name} (${payrollShift.startTime} - ${payrollShift.endTime})`}\r\n                                                />\r\n                                            ) : (\r\n                                                <InfoItem label=\"Ca mأںâ•‘â•–c â”€أ¦أںâ•—أ¯nh\" value=\"Theo câ”œأ،i â”€أ¦أںâ•‘â•–t chung\" />\r\n                                            )}\r\n                                        </CardContent>\r\n                                    </Card>\r\n                                </div> */}\r\n                        </TabsContent>\r\n\r\n        {/* Payslip Detail Dialog - Using extracted component */}\r\n        <PayslipDetailDialog\r\n          open={isPayslipDialogOpen}\r\n          onOpenChange={setIsPayslipDialogOpen}\r\n          selectedPayslip={selectedPayslip}\r\n          onViewPayroll={handleViewPayroll}\r\n        />\r\n\r\n        {/* Attendance Detail Dialog - Using extracted component */}\r\n        <AttendanceDetailDialog\r\n          open={isAttendanceDialogOpen}\r\n          onOpenChange={setIsAttendanceDialogOpen}\r\n          selectedAttendance={selectedAttendance}\r\n          employee={{ fullName: employee.fullName, id: employee.id }}\r\n          onPrintSingle={handlePrintSingleAttendance}\r\n        />\r\n\r\n        </Tabs>\r\n\r\n        {/* Comments */}\r\n        <Comments\r\n          entityType=\"employee\"\r\n          entityId={employee.systemId}\r\n          comments={comments}\r\n          onAddComment={handleAddComment}\r\n          onUpdateComment={handleUpdateComment}\r\n          onDeleteComment={handleDeleteComment}\r\n          currentUser={commentCurrentUser}\r\n          title=\"Bâ”œآ¼nh luأںâ•‘آ،n\"\r\n          placeholder=\"Thâ”œآ¬m bâ”œآ¼nh luأںâ•‘آ،n vأںâ•—أ¼ nhâ”œأ³n viâ”œآ¬n...\"\r\n        />\r\n\r\n        {/* Activity History */}\r\n        <ActivityHistory\r\n          history={employee.activityHistory || []}\r\n          title=\"Lأںâ•—أ¯ch sأںâ•—آ، hoأںâ•‘أ­t â”€أ¦أںâ•—أ–ng\"\r\n          emptyMessage=\"Châ•‍â–‘a câ”œâ”‚ lأںâ•—أ¯ch sأںâ•—آ، hoأںâ•‘أ­t â”€أ¦أںâ•—أ–ng\"\r\n          groupByDate\r\n          maxHeight=\"400px\"\r\n        />\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\employees\\components\\employee-account-tab.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":142,"column":10,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":142,"endColumn":13,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[5069,5072],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[5069,5072],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"âˆ©â•—â”گimport * as React from 'react';\r\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';\r\nimport { Button } from '@/components/ui/button';\r\nimport { Input } from '@/components/ui/input';\r\nimport { Label } from '@/components/ui/label';\r\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';\r\nimport { Badge } from '@/components/ui/badge';\r\nimport { Eye, EyeOff, ShieldAlert } from 'lucide-react';\r\nimport type { Employee } from '@/lib/types/prisma-extended';\r\nimport type { EmployeeRole } from '../roles';\r\nimport { useEmployeeMutations } from '../hooks/use-employees';\r\nimport { useAuth } from '@/contexts/auth-context';\r\nimport { toast } from 'sonner';\r\nimport { hashPassword, validatePasswordStrength } from '@/lib/security-utils';\r\n\r\ninterface EmployeeAccountTabProps {\r\n  employee: Employee;\r\n}\r\n\r\nconst getRoleLabel = (role: EmployeeRole): string => {\r\n  switch (role) {\r\n    case 'Admin': return 'Quأںâ•‘أ؛n trأںâ•—أ¯ viâ”œآ¬n';\r\n    case 'Manager': return 'Quأںâ•‘أ؛n lâ”œâ•œ';\r\n    case 'Sales': return 'Kinh doanh';\r\n    case 'Warehouse': return 'Kho';\r\n    default: return role;\r\n  }\r\n};\r\n\r\nconst getRoleDescription = (role: EmployeeRole): string => {\r\n  switch (role) {\r\n    case 'Admin': return 'Toâ”œأ،n quyأںâ•—أ¼n hأںâ•—أ§ thأںâ•—أ¦ng';\r\n    case 'Manager': return 'Quأںâ•‘أ؛n lâ”œâ•œ phâ”œâ–“ng ban';\r\n    case 'Sales': return 'Nhâ”œأ³n viâ”œآ¬n kinh doanh';\r\n    case 'Warehouse': return 'Nhâ”œأ³n viâ”œآ¬n kho';\r\n    default: return '';\r\n  }\r\n};\r\n\r\nconst getRoleBadgeVariant = (role: EmployeeRole) => {\r\n  switch (role) {\r\n    case 'Admin': return 'destructive' as const;\r\n    case 'Manager': return 'default' as const;\r\n    case 'Sales': return 'secondary' as const;\r\n    case 'Warehouse': return 'outline' as const;\r\n    default: return 'secondary' as const;\r\n  }\r\n};\r\n\r\n// Hâ”œأ،m tأںâ•‘أ­o mأںâ•‘آ،t khأںâ•‘âŒگu ngأںâ•‘آ½u nhiâ”œآ¬n\r\nconst generatePassword = (length: number = 12): string => {\r\n  const uppercase = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';\r\n  const lowercase = 'abcdefghijklmnopqrstuvwxyz';\r\n  const numbers = '0123456789';\r\n  const symbols = '!@#$%^&*';\r\n  const allChars = uppercase + lowercase + numbers + symbols;\r\n  \r\n  let password = '';\r\n  // â”€أ‰أںâ•‘أ؛m bأںâ•‘أ؛o câ”œâ”‚ â”œآ،t nhأںâ•‘أ‘t 1 kâ”œâ•œ tأںâ•—â–’ mأںâ•—أ¹i loأںâ•‘أ­i\r\n  password += uppercase[Math.floor(Math.random() * uppercase.length)];\r\n  password += lowercase[Math.floor(Math.random() * lowercase.length)];\r\n  password += numbers[Math.floor(Math.random() * numbers.length)];\r\n  password += symbols[Math.floor(Math.random() * symbols.length)];\r\n  \r\n  // Thâ”œآ¬m câ”œأ­c kâ”œâ•œ tأںâ•—â–’ ngأںâ•‘آ½u nhiâ”œآ¬n câ”œâ–“n lأںâ•‘أ­i\r\n  for (let i = password.length; i < length; i++) {\r\n    password += allChars[Math.floor(Math.random() * allChars.length)];\r\n  }\r\n  \r\n  // Trأںâ•—أ–n ngأںâ•‘آ½u nhiâ”œآ¬n\r\n  return password.split('').sort(() => Math.random() - 0.5).join('');\r\n};\r\n\r\nexport function EmployeeAccountTab({ employee }: EmployeeAccountTabProps) {\r\n  const { update } = useEmployeeMutations({\r\n    onUpdateSuccess: () => toast.success('â”€أ‰â”œأ؛ cأںâ•‘آ،p nhأںâ•‘آ،t thâ”œâ”¤ng tin â”€أ¦â”€أ¢ng nhأںâ•‘آ،p'),\r\n    onError: (error) => toast.error('Câ”œâ”‚ lأںâ•—أ¹i: ' + error.message),\r\n  });\r\n  const { user: currentUser } = useAuth();\r\n  const [showPassword, setShowPassword] = React.useState(false);\r\n  const [password, setPassword] = React.useState('');\r\n  const [confirmPassword, setConfirmPassword] = React.useState('');\r\n  \r\n  // Get role from employee.role field\r\n  const userRole = (employee.role as EmployeeRole) || 'Sales';\r\n  const [selectedRole, setSelectedRole] = React.useState<EmployeeRole>(userRole);\r\n\r\n  // Check if current user can change roles (only Admin can)\r\n  const canChangeRole = currentUser?.role === 'admin';\r\n  // Check if trying to edit own account\r\n  const _isOwnAccount = currentUser?.employeeId === employee.systemId;\r\n\r\n  const handleGeneratePassword = () => {\r\n    const newPassword = generatePassword(12);\r\n    setPassword(newPassword);\r\n    setConfirmPassword(newPassword);\r\n    setShowPassword(true);\r\n    toast.success('â”€أ‰â”œأ؛ tأںâ•‘أ­o mأںâ•‘آ،t khأںâ•‘âŒگu ngأںâ•‘آ½u nhiâ”œآ¬n');\r\n  };\r\n\r\n  const handleCopyPassword = async () => {\r\n    if (!password) {\r\n      toast.error('Châ•‍â–‘a câ”œâ”‚ mأںâ•‘آ،t khأںâ•‘âŒگu â”€أ¦أںâ•—أ¢ copy');\r\n      return;\r\n    }\r\n    \r\n    try {\r\n      await navigator.clipboard.writeText(password);\r\n      toast.success('â”€أ‰â”œأ؛ copy mأںâ•‘آ،t khأںâ•‘âŒگu vâ”œأ،o clipboard');\r\n    } catch (_err) {\r\n      toast.error('Khâ”œâ”¤ng thأںâ•—أ¢ copy mأںâ•‘آ،t khأںâ•‘âŒگu');\r\n    }\r\n  };\r\n\r\n  const handleSave = async () => {\r\n    if (password || confirmPassword) {\r\n      // Use centralized password validation\r\n      const validation = validatePasswordStrength(password);\r\n      if (!validation.isValid) {\r\n        toast.error(validation.errors[0]);\r\n        return;\r\n      }\r\n      if (password !== confirmPassword) {\r\n        toast.error('Mأںâ•‘آ،t khأںâ•‘âŒگu xâ”œأ­c nhأںâ•‘آ،n khâ”œâ”¤ng khأںâ•—آ¢p');\r\n        return;\r\n      }\r\n    }\r\n\r\n    const updates: Partial<Employee> = {\r\n      role: selectedRole,\r\n    };\r\n\r\n    if (password) {\r\n      // Hash password before storing (client-side protection)\r\n      // Real hashing should be done server-side with bcrypt\r\n      updates.password = await hashPassword(password);\r\n    }\r\n\r\n    update.mutate({\r\n      systemId: employee.systemId,\r\n      ...updates,\r\n    } as any);\r\n    \r\n    setPassword('');\r\n    setConfirmPassword('');\r\n  };\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"text-h5\">\r\n            Thâ”œâ”¤ng tin â”€أ¦â”€أ¢ng nhأںâ•‘آ،p\r\n          </CardTitle>\r\n          <CardDescription>\r\n            Cأںâ•‘أ‘u hâ”œآ¼nh tâ”œأ،i khoأںâ•‘أ؛n vâ”œأ، quyأںâ•—أ¼n truy cأںâ•‘آ،p hأںâ•—أ§ thأںâ•—أ¦ng cho nhâ”œأ³n viâ”œآ¬n\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-6\">\r\n          <div className=\"space-y-2\">\r\n            <Label>Email â”€أ¦â”€أ¢ng nhأںâ•‘آ،p</Label>\r\n            <Input \r\n              value={employee.workEmail} \r\n              disabled \r\n              className=\"bg-muted\"\r\n            />\r\n            <p className=\"text-xs text-muted-foreground\">\r\n              Email câ”œâ”¤ng viأںâ•—أ§c â”€أ¦â•‍â–‘أںâ•—أ؛c sأںâ•—آ، dأںâ•—أ‘ng lâ”œأ،m tâ”œآ¬n â”€أ¦â”€أ¢ng nhأںâ•‘آ،p\r\n            </p>\r\n          </div>\r\n\r\n          <div className=\"space-y-2\">\r\n            <Label>Vai trâ”œâ–“ hiأںâ•—أ§n tأںâ•‘أ­i</Label>\r\n            <div>\r\n              <Badge variant={getRoleBadgeVariant(userRole)} className=\"text-sm\">\r\n                {getRoleLabel(userRole)}\r\n              </Badge>\r\n            </div>\r\n          </div>\r\n\r\n          <div className=\"space-y-2\">\r\n            <Label htmlFor=\"role\">Thay â”€أ¦أںâ•—أ²i vai trâ”œâ–“</Label>\r\n            {canChangeRole ? (\r\n              <>\r\n                <Select value={selectedRole} onValueChange={(value) => setSelectedRole(value as EmployeeRole)}>\r\n                  <SelectTrigger id=\"role\">\r\n                    <SelectValue />\r\n                  </SelectTrigger>\r\n                  <SelectContent>\r\n                    <SelectItem value=\"Sales\">\r\n                      <div className=\"flex flex-col items-start py-1\">\r\n                        <span className=\"font-medium\">{getRoleLabel('Sales')}</span>\r\n                        <span className=\"text-xs text-muted-foreground\">{getRoleDescription('Sales')}</span>\r\n                      </div>\r\n                    </SelectItem>\r\n                    <SelectItem value=\"Warehouse\">\r\n                      <div className=\"flex flex-col items-start py-1\">\r\n                        <span className=\"font-medium\">{getRoleLabel('Warehouse')}</span>\r\n                        <span className=\"text-xs text-muted-foreground\">{getRoleDescription('Warehouse')}</span>\r\n                      </div>\r\n                    </SelectItem>\r\n                    <SelectItem value=\"Manager\">\r\n                      <div className=\"flex flex-col items-start py-1\">\r\n                        <span className=\"font-medium\">{getRoleLabel('Manager')}</span>\r\n                        <span className=\"text-xs text-muted-foreground\">{getRoleDescription('Manager')}</span>\r\n                      </div>\r\n                    </SelectItem>\r\n                    <SelectItem value=\"Admin\">\r\n                      <div className=\"flex flex-col items-start py-1\">\r\n                        <span className=\"font-medium\">{getRoleLabel('Admin')}</span>\r\n                        <span className=\"text-xs text-muted-foreground\">{getRoleDescription('Admin')}</span>\r\n                      </div>\r\n                    </SelectItem>\r\n                  </SelectContent>\r\n                </Select>\r\n                <p className=\"text-xs text-muted-foreground\">\r\n                  Vai trâ”œâ–“ xâ”œأ­c â”€أ¦أںâ•—أ¯nh quyأںâ•—أ¼n truy cأںâ•‘آ،p câ”œأ­c chأںâ•—âŒگc nâ”€أ¢ng trong hأںâ•—أ§ thأںâ•—أ¦ng\r\n                </p>\r\n              </>\r\n            ) : (\r\n              <div className=\"rounded-lg border border-amber-200 p-3 bg-amber-50 dark:bg-amber-950/20\">\r\n                <div className=\"flex items-center gap-2 text-amber-800 dark:text-amber-200\">\r\n                  <ShieldAlert className=\"h-4 w-4\" />\r\n                  <p className=\"text-sm\">\r\n                    Chأںâ•—أ« Admin mأںâ•—آ¢i câ”œâ”‚ quyأںâ•—أ¼n thay â”€أ¦أںâ•—أ²i vai trâ”œâ–“ nhâ”œأ³n viâ”œآ¬n.\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            )}\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"text-h5\">\r\n            â”€أ‰أںâ•—أ²i mأںâ•‘آ،t khأںâ•‘âŒگu\r\n          </CardTitle>\r\n          <CardDescription>\r\n            {(employee as { hasPassword?: boolean }).hasPassword ? 'Cأںâ•‘آ،p nhأںâ•‘آ،t mأںâ•‘آ،t khأںâ•‘âŒگu â”€أ¦â”€أ¢ng nhأںâ•‘آ،p' : 'Thiأںâ•‘â”گt lأںâ•‘آ،p mأںâ•‘آ،t khأںâ•‘âŒگu â”€أ¦â”€أ¢ng nhأںâ•‘آ،p mأںâ•—آ¢i'}\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          {(employee as { hasPassword?: boolean }).hasPassword ? (\r\n            <div className=\"rounded-lg border p-3 bg-muted/50\">\r\n              <p className=\"text-sm text-muted-foreground\">\r\n                 Mأںâ•‘آ،t khأںâ•‘âŒگu â”€أ¦â”œأ؛ â”€أ¦â•‍â–‘أںâ•—أ؛c thiأںâ•‘â”گt lأںâ•‘آ،p. â”€أ‰أںâ•—أ¢ thay â”€أ¦أںâ•—أ²i, nhأںâ•‘آ،p mأںâ•‘آ،t khأںâ•‘âŒگu mأںâ•—آ¢i bâ”œآ¬n dâ•‍â–‘أںâ•—آ¢i.\r\n              </p>\r\n            </div>\r\n          ) : (\r\n            <div className=\"rounded-lg border border-orange-200 p-3 bg-orange-50 dark:bg-orange-950/20\">\r\n              <p className=\"text-sm text-orange-800 dark:text-orange-200\">\r\n                 Châ•‍â–‘a câ”œâ”‚ mأںâ•‘آ،t khأںâ•‘âŒگu. Nhâ”œأ³n viâ”œآ¬n châ•‍â–‘a thأںâ•—أ¢ â”€أ¦â”€أ¢ng nhأںâ•‘آ،p hأںâ•—أ§ thأںâ•—أ¦ng.\r\n              </p>\r\n            </div>\r\n          )}\r\n\r\n          <div className=\"space-y-2\">\r\n            <div className=\"flex items-center justify-between\">\r\n              <Label htmlFor=\"password\">Mأںâ•‘آ،t khأںâ•‘âŒگu mأںâ•—آ¢i</Label>\r\n              <div className=\"flex gap-2\">\r\n                <Button\r\n                  type=\"button\"\r\n                  variant=\"outline\"\r\n                  size=\"sm\"\r\n                  onClick={handleGeneratePassword}\r\n                >\r\n                  Tأںâ•‘أ­o tأںâ•—â–’ â”€أ¦أںâ•—أ–ng\r\n                </Button>\r\n                {password && (\r\n                  <Button\r\n                    type=\"button\"\r\n                    variant=\"outline\"\r\n                    size=\"sm\"\r\n                    onClick={handleCopyPassword}\r\n                  >\r\n                    Copy\r\n                  </Button>\r\n                )}\r\n              </div>\r\n            </div>\r\n            <div className=\"relative\">\r\n              <Input\r\n                id=\"password\"\r\n                type={showPassword ? 'text' : 'password'}\r\n                value={password}\r\n                onChange={(e) => setPassword(e.target.value)}\r\n                placeholder=\"Nhأںâ•‘آ،p mأںâ•‘آ،t khأںâ•‘âŒگu mأںâ•—آ¢i (tأںâ•—أ¦i thiأںâ•—أ¢u 6 kâ”œâ•œ tأںâ•—â–’)\"\r\n              />\r\n              <Button\r\n                type=\"button\"\r\n                variant=\"ghost\"\r\n                size=\"sm\"\r\n                className=\"absolute right-0 top-0 h-full px-3 hover:bg-transparent\"\r\n                onClick={() => setShowPassword(!showPassword)}\r\n              >\r\n                {showPassword ? <EyeOff className=\"h-4 w-4\" /> : <Eye className=\"h-4 w-4\" />}\r\n              </Button>\r\n            </div>\r\n          </div>\r\n\r\n          <div className=\"space-y-2\">\r\n            <Label htmlFor=\"confirmPassword\">Xâ”œأ­c nhأںâ•‘آ،n mأںâ•‘آ،t khأںâ•‘âŒگu</Label>\r\n            <Input\r\n              id=\"confirmPassword\"\r\n              type={showPassword ? 'text' : 'password'}\r\n              value={confirmPassword}\r\n              onChange={(e) => setConfirmPassword(e.target.value)}\r\n              placeholder=\"Nhأںâ•‘آ،p lأںâ•‘أ­i mأںâ•‘آ،t khأںâ•‘âŒگu mأںâ•—آ¢i\"\r\n            />\r\n          </div>\r\n\r\n          <div className=\"flex justify-end pt-2\">\r\n            <Button onClick={handleSave}>\r\n              Lâ•‍â–‘u thay â”€أ¦أںâ•—أ²i\r\n            </Button>\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n\r\n      <Card className=\"border-blue-200 bg-blue-50/50 dark:bg-blue-950/20\">\r\n        <CardContent className=\"pt-6\">\r\n          <div className=\"space-y-2\">\r\n            <p className=\"text-sm font-medium text-blue-900 dark:text-blue-100\">\r\n               Lâ•‍â–‘u â”œâ•œ quan trأںâ•—أ¬ng:\r\n            </p>\r\n            <ul className=\"text-sm text-blue-800 dark:text-blue-200 space-y-1 list-disc list-inside\">\r\n              <li>Email câ”œâ”¤ng viأںâ•—أ§c â”€أ¦â•‍â–‘أںâ•—أ؛c dâ”œâ•£ng lâ”œأ،m tâ”œآ¬n â”€أ¦â”€أ¢ng nhأںâ•‘آ،p</li>\r\n              <li>Mأںâ•‘آ،t khأںâ•‘âŒگu phأںâ•‘أ؛i câ”œâ”‚ tأںâ•—أ¦i thiأںâ•—أ¢u 6 kâ”œâ•œ tأںâ•—â–’</li>\r\n              <li>Vai trâ”œâ–“ quyأںâ•‘â”گt â”€أ¦أںâ•—أ¯nh quyأںâ•—أ¼n truy cأںâ•‘آ،p câ”œأ­c chأںâ•—âŒگc nâ”€أ¢ng</li>\r\n              <li>Chأںâ•—أ« Admin mأںâ•—آ¢i â”€أ¦â•‍â–‘أںâ•—أ؛c thay â”€أ¦أںâ•—أ²i vai trâ”œâ–“ nhâ”œأ³n viâ”œآ¬n khâ”œأ­c</li>\r\n            </ul>\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\employees\\components\\employee-documents-tab.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\employees\\components\\employee-documents.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\hrm2\\features\\employees\\components\\employee-form-page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErro