ory'\r\n    | 'sync_seo'\r\n    | 'sync_description'\r\n    | 'sync_flags'\r\n    | 'sync_basic_info'\r\n    | 'sync_images'\r\n    | 'create_product'\r\n    | 'update_product'\r\n    | 'link_product'\r\n    | 'unlink_product'\r\n    | 'unlink_mapping'\r\n    | 'sync_categories'\r\n    | 'sync_brands'\r\n    | 'get_products'\r\n    | 'upload_image'\r\n    | 'save_config'\r\n    | 'save_mapping';\r\n  status: 'success' | 'error' | 'partial' | 'info';\r\n  message: string;\r\n  details?: Record<string, unknown>;\r\n};\r\n\r\ntype UsePkgxSyncOptions = {\r\n  addPkgxLog: (entry: PkgxLogEntry) => void;\r\n};\r\n\r\n/**\r\n * Hook cung cأںâ•‘أ‘p câ”œأ­c handlers â”€أ¦أںâ•—أ¢ â”€أ¦أںâ•—أ´ng bأںâ•—أ– sأںâ•‘أ؛n phأںâ•‘âŒگm vأںâ•—آ¢i PKGX\r\n */\r\nexport function usePkgxSync({ addPkgxLog }: UsePkgxSyncOptions) {\r\n  const { data: pkgxSettings } = usePkgxSettings();\r\n\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  // HELPER: Get price by mapping\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  const getPriceByMapping = React.useCallback((product: Product, pkgxPriceField: string): number | undefined => {\r\n    const priceMapping = pkgxSettings?.priceMapping;\r\n    if (!priceMapping) return undefined;\r\n    \r\n    // priceMapping is PkgxPriceMapping { shopPrice, marketPrice, partnerPrice, acePrice, dealPrice }\r\n    // Each field contains SystemId of HRM pricing policy\r\n    let hrmPriceSystemId: string | null = null;\r\n    \r\n    switch (pkgxPriceField) {\r\n      case 'shopPrice': hrmPriceSystemId = priceMapping.shopPrice; break;\r\n      case 'marketPrice': hrmPriceSystemId = priceMapping.marketPrice; break;\r\n      case 'partnerPrice': hrmPriceSystemId = priceMapping.partnerPrice; break;\r\n      case 'acePrice': hrmPriceSystemId = priceMapping.acePrice; break;\r\n      case 'dealPrice': hrmPriceSystemId = priceMapping.dealPrice; break;\r\n    }\r\n    \r\n    if (!hrmPriceSystemId) return undefined;\r\n    return product.prices?.[hrmPriceSystemId];\r\n  }, [pkgxSettings]);\r\n\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  // HELPER: Check if has price mapping\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  const hasPriceMapping = React.useMemo(() => {\r\n    const priceMapping = (pkgxSettings as any)?.priceMapping;\r\n    return priceMapping && (\r\n      priceMapping.shopPrice || \r\n      priceMapping.marketPrice || \r\n      priceMapping.partnerPrice || \r\n      priceMapping.acePrice || \r\n      priceMapping.dealPrice\r\n    );\r\n  }, [pkgxSettings]);\r\n\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  // HELPER: Get mapped category ID\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  const getMappedCategoryId = React.useCallback((product: Product): number | undefined => {\r\n    if (!pkgxSettings?.categoryMappings || !product.categorySystemId) return undefined;\r\n    const mapping = pkgxSettings.categoryMappings.find(m => m.hrmCategorySystemId === product.categorySystemId);\r\n    return mapping?.pkgxCatId;\r\n  }, [pkgxSettings?.categoryMappings]);\r\n\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  // HELPER: Get mapped brand ID\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  const getMappedBrandId = React.useCallback((product: Product): number | undefined => {\r\n    if (!pkgxSettings?.brandMappings || !product.brandSystemId) return undefined;\r\n    const mapping = pkgxSettings.brandMappings.find(m => m.hrmBrandSystemId === product.brandSystemId);\r\n    return mapping?.pkgxBrandId;\r\n  }, [pkgxSettings?.brandMappings]);\r\n\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  // 1. SYNC GIâ”œأ¼ (bao gأںâ•—أ´m cأںâ•‘أ؛ giâ”œأ­ thâ”œأ،nh viâ”œآ¬n ace)\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  const handlePkgxUpdatePrice = React.useCallback(async (product: Product) => {\r\n    if (!product.pkgxId) {\r\n      toast.error('Sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a â”€أ¦â•‍â–‘أںâ•—أ؛c liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i PKGX');\r\n      return;\r\n    }\r\n\r\n    if (!hasPriceMapping) {\r\n      toast.error('Châ•‍â–‘a cأںâ•‘أ‘u hâ”œآ¼nh mapping giâ”œأ­. Vui lâ”œâ–“ng vâ”œأ،o Câ”œأ،i â”€أ¦أںâ•‘â•–t > PKGX > Mapping Giâ”œأ­ â”€أ¦أںâ•—أ¢ thiأںâ•‘â”گt lأںâ•‘آ،p.');\r\n      return;\r\n    }\r\n    \r\n    toast.loading(`â”€أ‰ang â”€أ¦أںâ•—أ´ng bأںâ•—أ– giâ”œأ­...`, { id: 'pkgx-sync-price' });\r\n    \r\n    try {\r\n      const payload: Record<string, number> = {};\r\n      \r\n      const shopPrice = getPriceByMapping(product, 'shopPrice');\r\n      if (shopPrice !== undefined) payload.shop_price = shopPrice;\r\n      \r\n      const marketPrice = getPriceByMapping(product, 'marketPrice');\r\n      if (marketPrice !== undefined) payload.market_price = marketPrice;\r\n      \r\n      const partnerPrice = getPriceByMapping(product, 'partnerPrice');\r\n      if (partnerPrice !== undefined) payload.partner_price = partnerPrice;\r\n      \r\n      const acePrice = getPriceByMapping(product, 'acePrice');\r\n      if (acePrice !== undefined) payload.ace_price = acePrice;\r\n      \r\n      const dealPrice = getPriceByMapping(product, 'dealPrice');\r\n      if (dealPrice !== undefined) payload.deal_price = dealPrice;\r\n\r\n      if (Object.keys(payload).length === 0) {\r\n        toast.error('Khâ”œâ”¤ng câ”œâ”‚ giâ”œأ­ nâ”œأ،o â”€أ¦â•‍â–‘أںâ•—أ؛c mapping. Vui lâ”œâ–“ng kiأںâ•—أ¢m tra cأںâ•‘أ‘u hâ”œآ¼nh.', { id: 'pkgx-sync-price' });\r\n        return;\r\n      }\r\n      \r\n      // 1. Sync giâ”œأ­ vâ”œأ،o bأںâ•‘أ؛ng goods\r\n      const response = await updateProduct(product.pkgxId, payload);\r\n      \r\n      if (!response.success) {\r\n        throw new Error(response.error);\r\n      }\r\n\r\n      // 2. Sync giâ”œأ­ ace vâ”œأ،o member_price table (ace = rank_id 8)\r\n      let memberPriceSynced = false;\r\n      if (acePrice !== undefined && acePrice > 0) {\r\n        const memberPriceResponse = await updateMemberPrice(product.pkgxId, [\r\n          { user_rank: 8, user_price: acePrice }\r\n        ]);\r\n        memberPriceSynced = memberPriceResponse.success;\r\n      }\r\n      \r\n      const successMsg = memberPriceSynced \r\n        ? `â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– giâ”œأ­ + giâ”œأ­ ace thâ”œأ،nh viâ”œآ¬n: ${product.name}`\r\n        : `â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– giâ”œأ­: ${product.name}`;\r\n      \r\n      toast.success(successMsg, { id: 'pkgx-sync-price' });\r\n      addPkgxLog({\r\n        action: 'sync_price',\r\n        status: 'success',\r\n        message: successMsg,\r\n        details: { \r\n          productId: product.systemId, \r\n          pkgxId: product.pkgxId, \r\n          prices: payload,\r\n          memberPriceSynced,\r\n          acePrice: acePrice \r\n        },\r\n      });\r\n    } catch (error) {\r\n      toast.error(`Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– giâ”œأ­: ${error instanceof Error ? error.message : 'Unknown error'}`, { id: 'pkgx-sync-price' });\r\n      addPkgxLog({\r\n        action: 'sync_price',\r\n        status: 'error',\r\n        message: `Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– giâ”œأ­: ${product.name}`,\r\n        details: { productId: product.systemId, error: error instanceof Error ? error.message : String(error) },\r\n      });\r\n    }\r\n  }, [hasPriceMapping, getPriceByMapping, addPkgxLog]);\r\n\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  // 2. SYNC Tأںâ•—أ†N KHO\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  const handlePkgxSyncInventory = React.useCallback(async (product: Product) => {\r\n    if (!product.pkgxId) {\r\n      toast.error('Sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a â”€أ¦â•‍â–‘أںâ•—أ؛c liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i PKGX');\r\n      return;\r\n    }\r\n    \r\n    toast.loading(`â”€أ‰ang â”€أ¦أںâ•—أ´ng bأںâ•—أ– tأںâ•—أ´n kho...`, { id: 'pkgx-sync-inventory' });\r\n    \r\n    try {\r\n      const totalInventory = product.inventoryByBranch\r\n        ? Object.values(product.inventoryByBranch).reduce((sum, qty) => sum + (qty || 0), 0)\r\n        : 0;\r\n      \r\n      const response = await updateProduct(product.pkgxId, {\r\n        goods_number: totalInventory,\r\n      });\r\n      \r\n      if (response.success) {\r\n        toast.success(`â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– tأںâ•—أ´n kho: ${totalInventory} sأںâ•‘أ؛n phأںâ•‘âŒگm`, { id: 'pkgx-sync-inventory' });\r\n        addPkgxLog({\r\n          action: 'sync_inventory',\r\n          status: 'success',\r\n          message: `â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– tأںâ•—أ´n kho: ${product.name} (${totalInventory})`,\r\n          details: { productId: product.systemId, pkgxId: product.pkgxId, inventory: totalInventory },\r\n        });\r\n      } else {\r\n        throw new Error(response.error);\r\n      }\r\n    } catch (error) {\r\n      toast.error(`Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– tأںâ•—أ´n kho: ${error instanceof Error ? error.message : 'Unknown error'}`, { id: 'pkgx-sync-inventory' });\r\n      addPkgxLog({\r\n        action: 'sync_inventory',\r\n        status: 'error',\r\n        message: `Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– tأںâ•—أ´n kho: ${product.name}`,\r\n        details: { productId: product.systemId, error: error instanceof Error ? error.message : String(error) },\r\n      });\r\n    }\r\n  }, [addPkgxLog]);\r\n\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  // 3. SYNC SEO\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  const handlePkgxUpdateSeo = React.useCallback(async (product: Product) => {\r\n    if (!product.pkgxId) {\r\n      toast.error('Sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a â”€أ¦â•‍â–‘أںâ•—أ؛c liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i PKGX');\r\n      return;\r\n    }\r\n    \r\n    toast.loading(`â”€أ‰ang â”€أ¦أںâ•—أ´ng bأںâ•—أ– SEO...`, { id: 'pkgx-sync-seo' });\r\n    \r\n    try {\r\n      const pkgxSeo = product.seoPkgx;\r\n      // Fallback chain: SEO PKGX خ“أ¥أ† SEO Chung خ“أ¥أ† tags خ“أ¥أ† name\r\n      const seoPayload = {\r\n        keywords: pkgxSeo?.seoKeywords || product.seoKeywords || product.tags?.join(', ') || product.name,\r\n        meta_title: pkgxSeo?.seoTitle || product.ktitle || product.name,\r\n        meta_desc: pkgxSeo?.metaDescription || product.seoDescription || '',\r\n      };\r\n      \r\n      // DEBUG: Log payload â”€أ¦أںâ•—أ¢ kiأںâ•—أ¢m tra\r\n      \r\n      const response = await updateProduct(product.pkgxId, seoPayload);\r\n      \r\n      if (response.success) {\r\n        toast.success(`â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– SEO cho sأںâ•‘أ؛n phأںâ•‘âŒگm: ${product.name}`, { id: 'pkgx-sync-seo' });\r\n        addPkgxLog({\r\n          action: 'sync_seo',\r\n          status: 'success',\r\n          message: `â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– SEO: ${product.name}`,\r\n          details: { productId: product.systemId, pkgxId: product.pkgxId },\r\n        });\r\n      } else {\r\n        throw new Error(response.error);\r\n      }\r\n    } catch (error) {\r\n      toast.error(`Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– SEO: ${error instanceof Error ? error.message : 'Unknown error'}`, { id: 'pkgx-sync-seo' });\r\n      addPkgxLog({\r\n        action: 'sync_seo',\r\n        status: 'error',\r\n        message: `Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– SEO: ${product.name}`,\r\n        details: { productId: product.systemId, error: error instanceof Error ? error.message : String(error) },\r\n      });\r\n    }\r\n  }, [addPkgxLog]);\r\n\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  // 4. SYNC Mâ”œأ¶ Tأںâ•‘أ³ (vأںâ•—آ¢i xأںâ•—آ، lâ”œâ•œ أںâ•‘أ؛nh trong HTML)\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  const handlePkgxSyncDescription = React.useCallback(async (product: Product) => {\r\n    if (!product.pkgxId) {\r\n      toast.error('Sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a â”€أ¦â•‍â–‘أںâ•—أ؛c liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i PKGX');\r\n      return;\r\n    }\r\n    \r\n    toast.loading(`â”€أ‰ang â”€أ¦أںâ•—أ´ng bأںâ•—أ– mâ”œâ”¤ tأںâ•‘أ؛...`, { id: 'pkgx-sync-desc' });\r\n    \r\n    try {\r\n      const pkgxSeo = product.seoPkgx;\r\n      \r\n      // Get raw descriptions\r\n      const rawLongDesc = pkgxSeo?.longDescription || product.description || '';\r\n      const rawShortDesc = pkgxSeo?.shortDescription || product.shortDescription || '';\r\n      \r\n      // Process images in long description (upload to PKGX and replace URLs)\r\n      let processedLongDesc = rawLongDesc;\r\n      let imageStats = { uploadedCount: 0, skippedCount: 0, errors: [] as string[] };\r\n      \r\n      if (rawLongDesc.includes('<img')) {\r\n        toast.loading(`â”€أ‰ang xأںâ•—آ، lâ”œâ•œ أںâ•‘أ؛nh trong mâ”œâ”¤ tأںâ•‘أ؛...`, { id: 'pkgx-sync-desc' });\r\n        \r\n        const filenamePrefix = product.sku || product.id || `product-${product.pkgxId}`;\r\n        const result = await processHtmlImagesForPkgx(rawLongDesc, filenamePrefix);\r\n        \r\n        processedLongDesc = result.processedHtml;\r\n        imageStats = result;\r\n        \r\n        if (result.uploadedCount > 0) {\r\n          toast.loading(`â”€أ‰â”œأ؛ upload ${result.uploadedCount} أںâ•‘أ؛nh, â”€أ¦ang cأںâ•‘آ،p nhأںâ•‘آ،t mâ”œâ”¤ tأںâ•‘أ؛...`, { id: 'pkgx-sync-desc' });\r\n        }\r\n      }\r\n      \r\n      // Sync to PKGX\r\n      const response = await updateProduct(product.pkgxId, {\r\n        goods_desc: processedLongDesc,\r\n        goods_brief: rawShortDesc,\r\n      });\r\n      \r\n      if (response.success) {\r\n        const message = imageStats.uploadedCount > 0\r\n          ? `â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– mâ”œâ”¤ tأںâ•‘أ؛ (${imageStats.uploadedCount} أںâ•‘أ؛nh â”€أ¦â”œأ؛ upload)`\r\n          : `â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– mâ”œâ”¤ tأںâ•‘أ؛`;\r\n          \r\n        toast.success(message, { id: 'pkgx-sync-desc' });\r\n        addPkgxLog({\r\n          action: 'sync_description',\r\n          status: imageStats.errors.length > 0 ? 'partial' : 'success',\r\n          message: `${message}: ${product.name}`,\r\n          details: { \r\n            productId: product.systemId, \r\n            pkgxId: product.pkgxId,\r\n            imagesUploaded: imageStats.uploadedCount,\r\n            imagesSkipped: imageStats.skippedCount,\r\n            imageErrors: imageStats.errors,\r\n          },\r\n        });\r\n      } else {\r\n        throw new Error(response.error);\r\n      }\r\n    } catch (error) {\r\n      toast.error(`Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– mâ”œâ”¤ tأںâ•‘أ؛: ${error instanceof Error ? error.message : 'Unknown error'}`, { id: 'pkgx-sync-desc' });\r\n      addPkgxLog({\r\n        action: 'sync_description',\r\n        status: 'error',\r\n        message: `Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– mâ”œâ”¤ tأںâ•‘أ؛: ${product.name}`,\r\n        details: { productId: product.systemId, error: error instanceof Error ? error.message : String(error) },\r\n      });\r\n    }\r\n  }, [addPkgxLog]);\r\n\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  // 5. SYNC FLAGS (best, hot, new, ishome, is_on_sale)\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  const handlePkgxSyncFlags = React.useCallback(async (product: Product) => {\r\n    if (!product.pkgxId) {\r\n      toast.error('Sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a â”€أ¦â•‍â–‘أںâ•—أ؛c liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i PKGX');\r\n      return;\r\n    }\r\n    \r\n    toast.loading(`â”€أ‰ang â”€أ¦أںâ•—أ´ng bأںâ•—أ– flags...`, { id: 'pkgx-sync-flags' });\r\n    \r\n    try {\r\n      const response = await updateProduct(product.pkgxId, {\r\n        best: product.isFeatured || false,\r\n        hot: product.isBestSeller || false,\r\n        new: product.isNewArrival || false,\r\n        ishome: product.isFeatured || false,\r\n        is_on_sale: product.isPublished ?? (product.status === 'active'),\r\n      });\r\n      \r\n      if (response.success) {\r\n        toast.success(`â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– flags`, { id: 'pkgx-sync-flags' });\r\n        addPkgxLog({\r\n          action: 'sync_flags',\r\n          status: 'success',\r\n          message: `â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– flags: ${product.name}`,\r\n          details: { productId: product.systemId, pkgxId: product.pkgxId },\r\n        });\r\n      } else {\r\n        throw new Error(response.error);\r\n      }\r\n    } catch (error) {\r\n      toast.error(`Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– flags: ${error instanceof Error ? error.message : 'Unknown error'}`, { id: 'pkgx-sync-flags' });\r\n      addPkgxLog({\r\n        action: 'sync_flags',\r\n        status: 'error',\r\n        message: `Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– flags: ${product.name}`,\r\n        details: { productId: product.systemId, error: error instanceof Error ? error.message : String(error) },\r\n      });\r\n    }\r\n  }, [addPkgxLog]);\r\n\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  // 6. SYNC THâ”œأ¶NG TIN Câ•‍أ، Bأںâ•‘أ³N (tâ”œآ¬n, SKU, category, brand, seller_note)\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  const handlePkgxSyncBasicInfo = React.useCallback(async (product: Product) => {\r\n    if (!product.pkgxId) {\r\n      toast.error('Sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a â”€أ¦â•‍â–‘أںâ•—أ؛c liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i PKGX');\r\n      return;\r\n    }\r\n    \r\n    toast.loading(`â”€أ‰ang â”€أ¦أںâ•—أ´ng bأںâ•—أ– thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n...`, { id: 'pkgx-sync-basic' });\r\n    \r\n    try {\r\n      const payload: Record<string, unknown> = {\r\n        goods_name: product.name,\r\n        goods_sn: product.id,\r\n        seller_note: product.sellerNote || '',\r\n      };\r\n\r\n      // Map category nأںâ•‘â”گu câ”œâ”‚\r\n      const catId = getMappedCategoryId(product);\r\n      if (catId) payload.cat_id = catId;\r\n\r\n      // Map brand nأںâ•‘â”گu câ”œâ”‚  \r\n      const brandId = getMappedBrandId(product);\r\n      if (brandId) payload.brand_id = brandId;\r\n\r\n      const response = await updateProduct(product.pkgxId, payload);\r\n      \r\n      if (response.success) {\r\n        toast.success(`â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n`, { id: 'pkgx-sync-basic' });\r\n        addPkgxLog({\r\n          action: 'sync_basic_info',\r\n          status: 'success',\r\n          message: `â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n: ${product.name}`,\r\n          details: { productId: product.systemId, pkgxId: product.pkgxId, payload },\r\n        });\r\n      } else {\r\n        throw new Error(response.error);\r\n      }\r\n    } catch (error) {\r\n      toast.error(`Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n: ${error instanceof Error ? error.message : 'Unknown error'}`, { id: 'pkgx-sync-basic' });\r\n      addPkgxLog({\r\n        action: 'sync_basic_info',\r\n        status: 'error',\r\n        message: `Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– thâ”œâ”¤ng tin câ•‍أ­ bأںâ•‘أ؛n: ${product.name}`,\r\n        details: { productId: product.systemId, error: error instanceof Error ? error.message : String(error) },\r\n      });\r\n    }\r\n  }, [getMappedCategoryId, getMappedBrandId, addPkgxLog]);\r\n\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  // 7. SYNC Hâ”œأ®NH أںâ•‘أ³NH (أںâ•‘أ؛nh â”€أ¦أںâ•‘أ­i diأںâ•—أ§n + album gallery)\r\n  // Logic: Fetch أںâ•‘أ؛nh tأںâ•—آ½ HRM server trâ•‍â–‘أںâ•—آ¢c, upload lâ”œآ¬n PKGX, rأںâ•—أ´i sync â”€أ¦â•‍â–‘أںâ•—آ¥ng dأںâ•‘آ½n\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰\r\n  const handlePkgxSyncImages = React.useCallback(async (product: Product) => {\r\n    if (!product.pkgxId) {\r\n      toast.error('Sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a â”€أ¦â•‍â–‘أںâ•—أ؛c liâ”œآ¬n kأںâ•‘â”گt vأںâ•—آ¢i PKGX');\r\n      return;\r\n    }\r\n\r\n    toast.loading('â”€أ‰ang lأںâ•‘أ‘y thâ”œâ”¤ng tin hâ”œآ¼nh أںâ•‘أ؛nh...', { id: 'pkgx-sync-images' });\r\n\r\n    // ===== STEP 1: Fetch أںâ•‘أ؛nh tأںâ•—آ½ HRM server =====\r\n    const thumbnailUrls: string[] = [];\r\n    const galleryUrls: string[] = [];\r\n\r\n    // Helper: Kiأںâ•—أ¢m tra URL câ”œâ”‚ thأںâ•—أ¢ truy cأںâ•‘آ،p tأںâ•—آ½ internet khâ”œâ”¤ng\r\n    const isPublicUrl = (url: string): boolean => {\r\n      if (!url) return false;\r\n      // Bأںâ•—أ… qua localhost, 127.0.0.1, hoأںâ•‘â•–c internal IP\r\n      if (url.includes('localhost') || url.includes('127.0.0.1') || url.includes('192.168.')) {\r\n        return false;\r\n      }\r\n      return true;\r\n    };\r\n\r\n    try {\r\n      // Import â”€أ¦أںâ•—أ–ng â”€أ¦أںâ•—أ¢ trâ”œأ­nh circular dependency\r\n      const { FileUploadAPI } = await import('@/lib/file-upload-api');\r\n      const files = await FileUploadAPI.getProductFiles(product.systemId);\r\n      \r\n      \r\n      // Phâ”œأ³n loأںâ•‘أ­i أںâ•‘أ؛nh theo documentName - CHأںâ•—أھ lأںâ•‘أ‘y URL public\r\n      for (const file of files) {\r\n        if (file.documentName === 'thumbnail' && file.url && isPublicUrl(file.url)) {\r\n          thumbnailUrls.push(file.url);\r\n        } else if (file.documentName === 'gallery' && file.url && isPublicUrl(file.url)) {\r\n          galleryUrls.push(file.url);\r\n        }\r\n      }\r\n    } catch (_fetchError) {\r\n      // Silently fail - fallback to product object\r\n    }\r\n\r\n    // ===== STEP 2: Fallback vأںâ•—أ¼ product object nأںâ•‘â”گu server khâ”œâ”¤ng câ”œâ”‚ أںâ•‘أ؛nh =====\r\n\r\n    // Nأںâ•‘â”گu server khâ”œâ”¤ng câ”œâ”‚, dâ”œâ•£ng tأںâ•—آ½ product object - CHأںâ•—أھ lأںâ•‘أ‘y URL public\r\n    if (thumbnailUrls.length === 0 && product.thumbnailImage && isPublicUrl(product.thumbnailImage)) {\r\n      thumbnailUrls.push(product.thumbnailImage);\r\n    }\r\n    if (galleryUrls.length === 0 && product.galleryImages?.length) {\r\n      galleryUrls.push(...product.galleryImages.filter(isPublicUrl));\r\n    }\r\n    // Legacy fallback\r\n    if (thumbnailUrls.length === 0 && galleryUrls.length === 0 && product.images?.length) {\r\n      const publicImages = product.images.filter(isPublicUrl);\r\n      if (publicImages.length > 0) {\r\n        thumbnailUrls.push(publicImages[0]);\r\n        if (publicImages.length > 1) {\r\n          galleryUrls.push(...publicImages.slice(1));\r\n        }\r\n      }\r\n    }\r\n\r\n    // Câ”¼âŒگng check image-store (أںâ•‘أ؛nh â”€أ¦â”œأ؛ upload vâ”œأ،o HRM nhâ•‍â–‘ng châ•‍â–‘a fetch tأںâ•—آ½ server)\r\n    const imageStoreState = useImageStore.getState();\r\n    const permanentThumbnails = imageStoreState.getPermanentImages(product.systemId, 'thumbnail');\r\n    const permanentGallery = imageStoreState.getPermanentImages(product.systemId, 'gallery');\r\n\r\n    // Merge vأںâ•—آ¢i image-store nأںâ•‘â”گu câ”œâ”‚ - CHأںâ•—أھ lأںâ•‘أ‘y URL public\r\n    if (permanentThumbnails.length > 0 && thumbnailUrls.length === 0) {\r\n      thumbnailUrls.push(...permanentThumbnails.map(f => f.url).filter(url => url && isPublicUrl(url)));\r\n    }\r\n    if (permanentGallery.length > 0 && galleryUrls.length === 0) {\r\n      galleryUrls.push(...permanentGallery.map(f => f.url).filter(url => url && isPublicUrl(url)));\r\n    }\r\n\r\n\r\n    // Final main image vâ”œأ، gallery\r\n    const mainImage = thumbnailUrls[0] || null;\r\n    const galleryImages = galleryUrls;\r\n\r\n\r\n    if (!mainImage && galleryImages.length === 0) {\r\n      toast.error('Sأںâ•‘أ؛n phأںâ•‘âŒگm châ•‍â–‘a câ”œâ”‚ hâ”œآ¼nh أںâ•‘أ؛nh', { id: 'pkgx-sync-images' });\r\n      return;\r\n    }\r\n    \r\n    const totalImages = (mainImage ? 1 : 0) + galleryImages.length;\r\n    toast.loading(`â”€أ‰ang â”€أ¦أںâ•—أ´ng bأںâ•—أ– ${totalImages} hâ”œآ¼nh أںâ•‘أ؛nh...`, { id: 'pkgx-sync-images' });\r\n    \r\n    try {\r\n      // Tأںâ•‘أ­o slug tأںâ•—آ½ tâ”œآ¬n sأںâ•‘أ؛n phأںâ•‘âŒگm cho filename\r\n      const baseSlug = (product.name || 'product')\r\n        .toLowerCase()\r\n        .normalize('NFD')\r\n        .replace(/[\\u0300-\\u036f]/g, '')\r\n        .replace(/â”€أ¦/g, 'd')\r\n        .replace(/[^a-z0-9]+/g, '-')\r\n        .replace(/^-|-$/g, '')\r\n        .substring(0, 50);\r\n\r\n      let uploadedMainImg: string | null = null;\r\n      const uploadedGalleryPaths: string[] = [];\r\n      let errorCount = 0;\r\n\r\n      // Helper function: Upload أںâ•‘أ؛nh tأںâ•—آ½ URL qua server PKGX (trâ”œأ­nh CORS)\r\n      const uploadFromUrl = async (imageUrl: string, slugSuffix: string): Promise<string | null> => {\r\n        try {\r\n          // Kiأںâ•—أ¢m tra nأںâ•‘â”گu lâ”œأ، â”€أ¦â•‍â–‘أںâ•—آ¥ng dأںâ•‘آ½n local trâ”œآ¬n PKGX (â”€أ¦â”œأ؛ upload trâ•‍â–‘أںâ•—آ¢c â”€أ¦â”œâ”‚)\r\n          if (imageUrl.startsWith('images/') || imageUrl.includes('/cdn/images/')) {\r\n            // â”€أ‰â”œأ؛ lâ”œأ، path trâ”œآ¬n PKGX, khâ”œâ”¤ng cأںâ•‘آ؛n upload lأںâ•‘أ­i\r\n            const cleanPath = imageUrl.replace(/.*\\/cdn\\//, '').replace(/^cdn\\//, '');\r\n            return cleanPath;\r\n          }\r\n\r\n          // Gأںâ•—أ¬i API server-to-server â”€أ¦أںâ•—أ¢ trâ”œأ­nh CORS\r\n          const uploadResult = await uploadImageFromUrl(imageUrl, {\r\n            filenameSlug: `${baseSlug}-${slugSuffix}`,\r\n          });\r\n\r\n          if (!uploadResult.success || !uploadResult.data) {\r\n            throw new Error(uploadResult.error || 'Upload thأںâ•‘أ‘t bأںâ•‘أ­i');\r\n          }\r\n\r\n          // Trأںâ•‘أ؛ vأںâ•—أ¼ â”€أ¦â•‍â–‘أںâ•—آ¥ng dأںâ•‘آ½n original_img\r\n          return uploadResult.data.data?.original_img || null;\r\n        } catch (err) {\r\n          console.error(`Lأںâ•—أ¹i upload أںâ•‘أ؛nh ${imageUrl}:`, err);\r\n          return null;\r\n        }\r\n      };\r\n\r\n      // Upload أںâ•‘أ؛nh â”€أ¦أںâ•‘أ­i diأںâ•—أ§n\r\n      if (mainImage) {\r\n        toast.loading(`â”€أ‰ang upload أںâ•‘أ؛nh â”€أ¦أںâ•‘أ­i diأںâ•—أ§n...`, { id: 'pkgx-sync-images' });\r\n        uploadedMainImg = await uploadFromUrl(mainImage, 'main');\r\n        if (!uploadedMainImg) {\r\n          errorCount++;\r\n        }\r\n      }\r\n\r\n      // Upload gallery images\r\n      if (galleryImages.length > 0) {\r\n        for (let i = 0; i < galleryImages.length; i++) {\r\n          toast.loading(`â”€أ‰ang upload أںâ•‘أ؛nh ${i + 1}/${galleryImages.length}...`, { id: 'pkgx-sync-images' });\r\n          const galleryPath = await uploadFromUrl(galleryImages[i], `gallery-${i + 1}`);\r\n          if (galleryPath) {\r\n            uploadedGalleryPaths.push(galleryPath);\r\n          } else {\r\n            errorCount++;\r\n          }\r\n        }\r\n      }\r\n\r\n      // Kiأںâ•—أ¢m tra câ”œâ”‚ gâ”œآ¼ â”€أ¦أںâ•—أ¢ sync khâ”œâ”¤ng\r\n      if (!uploadedMainImg && uploadedGalleryPaths.length === 0) {\r\n        throw new Error('Khâ”œâ”¤ng thأںâ•—أ¢ upload bأںâ•‘أ‘t kأںâ•—â”‚ أںâ•‘أ؛nh nâ”œأ،o');\r\n      }\r\n\r\n      // Build payload â”€أ¦أںâ•—أ¢ sync vâ”œأ،o sأںâ•‘أ؛n phأںâ•‘âŒگm\r\n      const payload: Record<string, unknown> = {};\r\n      \r\n      if (uploadedMainImg) {\r\n        payload.original_img = uploadedMainImg;\r\n      }\r\n      \r\n      if (uploadedGalleryPaths.length > 0) {\r\n        payload.gallery_images = uploadedGalleryPaths;\r\n      }\r\n\r\n      // Sync â”€أ¦â•‍â–‘أںâ•—آ¥ng dأںâ•‘آ½n vâ”œأ،o sأںâ•‘أ؛n phأںâ•‘âŒگm\r\n      toast.loading(`â”€أ‰ang cأںâ•‘آ،p nhأںâ•‘آ،t sأںâ•‘أ؛n phأںâ•‘âŒگm...`, { id: 'pkgx-sync-images' });\r\n      const response = await updateProduct(product.pkgxId, payload);\r\n      \r\n      if (response.success) {\r\n        const syncedCount = (uploadedMainImg ? 1 : 0) + uploadedGalleryPaths.length;\r\n        const message = errorCount > 0 \r\n          ? `â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– ${syncedCount} hâ”œآ¼nh أںâ•‘أ؛nh (${errorCount} lأںâ•—أ¹i)`\r\n          : `â”€أ‰â”œأ؛ â”€أ¦أںâ•—أ´ng bأںâ•—أ– ${syncedCount} hâ”œآ¼nh أںâ•‘أ؛nh`;\r\n        \r\n        toast.success(message, { id: 'pkgx-sync-images' });\r\n        addPkgxLog({\r\n          action: 'sync_images',\r\n          status: errorCount > 0 ? 'partial' : 'success',\r\n          message: `${message}: ${product.name}`,\r\n          details: { \r\n            productId: product.systemId, \r\n            pkgxId: product.pkgxId, \r\n            uploadedMainImg,\r\n            galleryCount: uploadedGalleryPaths.length,\r\n            uploadedGalleryPaths,\r\n            errorCount,\r\n          },\r\n        });\r\n      } else {\r\n        throw new Error(response.error);\r\n      }\r\n    } catch (error) {\r\n      toast.error(`Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– hâ”œآ¼nh أںâ•‘أ؛nh: ${error instanceof Error ? error.message : 'Unknown error'}`, { id: 'pkgx-sync-images' });\r\n      addPkgxLog({\r\n        action: 'sync_images',\r\n        status: 'error',\r\n        message: `Lأںâ•—أ¹i â”€أ¦أںâ•—أ´ng bأںâ•—أ– hâ”œآ¼nh أںâ•‘أ؛nh: ${product.name}`,\r\n        details: { productId: product.systemId, error: error instanceof Error ? error.message : String(error) },\r\n      });\r\n    }\r\n  }, [addPkgxLog]);\r\n\r\n  // خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ²أ‰خ“أ