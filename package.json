{
  "name": "erp-nextjs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS='--max-old-space-size=16384' next dev",
    "dev:webpack": "cross-env NODE_OPTIONS='--max-old-space-size=16384' next dev --webpack",
    "dev:turbo": "cross-env NODE_OPTIONS='--max-old-space-size=16384' next dev",
    "build": "cross-env NODE_OPTIONS='--max-old-space-size=16384' next build",
    "build:analyze": "cross-env ANALYZE=true NODE_OPTIONS='--max-old-space-size=16384' next build",
    "build:webpack": "cross-env NODE_OPTIONS='--max-old-space-size=16384 TURBOPACK=0' next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-ports": "node check-ports.js",
    "start:backend": "node server/server.js",
    "start:full": "npm run check-ports && concurrently \"npm run start:backend\" \"npm run dev\"",
    "dev:safe": "npm run check-ports && npm run dev",
    "verify-ids": "tsx scripts/utils/verify-branded-ids.ts",
    "typecheck:strict": "tsc --project tsconfig.strict.json --noEmit --pretty false --incremental false",
    "prepare": "husky",
    "db:seed": "tsx prisma/seed.ts",
    "cleanup": "node -e \"require('fs').rmSync('.next', {recursive: true, force: true}); require('fs').rmSync('node_modules/.cache', {recursive: true, force: true}); console.log('Cache cleaned!')\"",
    "pwa:icons": "tsx scripts/generate-pwa-icons.ts",
    "pwa:vapid": "tsx scripts/generate-vapid-keys.ts"
  },
